  docType String [note: 'ประเภทเอกสาร: \'AFFIDAVIT\' (หนังสือรับรอง), \'VAT_REGISTRATION\' (ภพ.20), \'DIRECTOR_ID\'']
  createdAt DateTime [default: `now()`, not null]

  Note: '✅ [NEW] ตารางกลางสำหรับเอกสารทางกฎหมายของบริษัท'
}

Table int_cloud_configs {
  id Int [pk, increment, note: 'รหัสลำดับของการตั้งค่า (รันอัตโนมัติ)']
  companyId Int [not null, note: 'รหัสอ้างอิงบริษัทที่เป็นเจ้าของการตั้งค่านี้ (เชื่อมไปยังตาราง org_companies)']
  company org_companies [not null, note: 'ข้อมูลบริษัทที่เกี่ยวข้อง โดยระบุ onDelete: Cascade เพื่อให้การตั้งค่าถูกลบออกทันทีหากบริษัทถูกลบ เพื่อความปลอดภัยของข้อมูล']
  provider String [not null, note: 'ระบุผู้ให้บริการ Cloud เช่น GOOGLE_DRIVE หรือ AWS_S3 เพื่อให้ระบบเลือกใช้ Driver ได้ถูกต้อง']
  configName String [not null, note: 'ชื่อที่ผู้ใช้ตั้งขึ้นเพื่อจำแนกการเชื่อมต่อ เช่น "Google Drive ฝ่ายบัญชี" หรือ "S3 สำรองข้อมูลรูปภาพ"']
  configData String [not null, note: 'เนื้อหาการตั้งค่าในรูปแบบ JSON (เช่น Client ID, Secret Key) ซึ่งเก็บเป็นข้อความขนาดใหญ่ (Text) (แนะนำอย่างยิ่งให้ทำการเข้ารหัส (Encrypt) ก่อนเก็บลงฟิลด์นี้)']
  isActive Boolean [not null, default: true, note: 'สถานะการเปิดใช้งานการเชื่อมต่อนี้']
  createdAt DateTime [default: `now()`, not null, note: 'วันที่และเวลาที่สร้างรายการตั้งค่านี้ขึ้นมา']

  Note: 'ตารางนี้มีความสำคัญมากในส่วนของ Integration เพราะใช้เก็บข้อมูลลับหรือกุญแจ (Credentials) ที่ใช้เชื่อมต่อกับบริการภายนอก'
}

Table int_smtp_configs {
  id Int [pk, increment, note: 'รหัสอ้างอิง']
  companyId Int [note: 'รหัสบริษัท (ถ้า Null และ shopId Null = เป็นของส่วนกลาง KKV)']
  company org_companies
  shopId Int [unique, note: '🌟 เพิ่มฟิลด์นี้: รหัสร้านค้า (ถ้ามีค่า แสดงว่าตั้งค่าให้เฉพาะร้านค้านี้)']
  shop com_shop_profiles
  senderName String [not null, note: 'เช่น "Kookshop", "บริษัท A", "ร้านเสื้อผ้าแฟชั่น"']
  senderEmail String [not null, note: 'เช่น "noreply@kookshop.com"']
  host String [not null, note: 'ที่อยู่เซิร์ฟเวอร์ SMTP (เช่น "smtp.gmail.com")   ']
  port Int [not null, note: 'พอร์ตสำหรับส่งอีเมล (เช่น 465, 587, 25)   ']
  username String [not null, note: 'ชื่อผู้ใช้งาน (มักจะเป็นอีเมล)      ']
  password String [not null, note: 'รหัสผ่าน (แนะนำอย่างยิ่งให้เข้ารหัส Encrypt ก่อนบันทึกลงฐานข้อมูล)']
  isSecure Boolean [not null, default: true, note: 'ใช้งาน SSL/TLS หรือไม่ (ส่วนใหญ่เป็น true)']
  isActive Boolean [not null, default: true, note: 'สถานะการเปิดใช้งาน']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, shopId) [unique]
  }

  Note: 'เก็บข้อมูล smtp สำหรับส่งเมล์'
}

Table int_chat_messages {
  id Int [pk, increment, note: 'รหัสข้อความ (Primary Key)']
  sessionId Int [not null, note: '🌟 เชื่อมโยงกลับไปหาแฟ้มการสนทนา (Session) 🌟']
  session int_chat_sessions [not null]
  companyId Int [not null, note: 'เพื่อความเร็วในการ Query และทำ Data Isolation ของแต่ละบริษัท']
  company org_companies [not null]
  externalId String [note: 'ID ข้อความจาก Platform ภายนอก (เช่น Message ID จาก Webhook ของ LINE) เผื่อใช้ลบหรืออ้างอิง']
  senderType String [not null, note: 'ใครเป็นคนพิมพ์ข้อความนี้? ("CUSTOMER" = ลูกค้า, "AGENT" = แอดมินคน, "AI" = บอทตอบอัตโนมัติ)']
  messageType String [not null, note: 'ประเภทของข้อความ ("TEXT", "IMAGE", "FILE", "STICKER", "LOCATION")']
  content String [not null, note: 'เนื้อหาของข้อความ หรือ ลิงก์รูปภาพ']
  metadata Json [note: 'เก็บข้อมูลดิบ (Raw Data) หรือพิกัด Location / Sticker ID จาก Webhook']
  isRead Boolean [not null, default: false, note: 'สถานะว่าข้อความนี้ถูกอ่านโดยแอดมิน/ลูกค้าหรือยัง']
  createdAt DateTime [default: `now()`, not null]

  Note: 'ตารางเก็บ "ข้อความย่อย" แต่ละบรรทัด (Chat Messages)'
}

Table int_chat_sessions {
  id Int [pk, increment, note: 'รหัสแฟ้มการสนทนา (Primary Key)']
  companyId Int [not null, note: 'รหัสบริษัทที่เป็นเจ้าของแชทนี้']
  company org_companies [not null]
  shopId Int [note: '(Optional) ผูกกับหน้าร้านค้า กรณีที่บริษัทมีหลายหน้าร้าน']
  channel String [not null, note: 'ช่องทางที่ลูกค้าทักมา เช่น "LINE", "FACEBOOK", "WEBCHAT"']
  senderId String [not null, note: 'ID ผู้ส่ง (เช่น Line userId หรือ Facebook psid) ใช้เป็นกุญแจหลักในการรวมแชท']
  senderName String [note: 'ชื่อของลูกค้าที่ดึงมาจาก Social Media']
  aiSummary String [note: 'สรุปใจความสำคัญของการสนทนาในแฟ้มนี้ (ให้ AI สรุปแล้วมาเซฟเก็บไว้)']
  sentiment String [note: 'อารมณ์ของลูกค้าในเซสชันนี้ (เช่น POSITIVE, NEUTRAL, NEGATIVE, ANGRY)']
  intent String [note: 'จุดประสงค์หลักที่ลูกค้าทักมา (เช่น INQUIRY, COMPLAINT, BUY_PRODUCT)']
  status String [not null, default: 'OPEN', note: 'สถานะของแฟ้มนี้ (เช่น OPEN = กำลังคุย, WAITING = รอแอดมินตอบ, RESOLVED = แก้ปัญหาแล้ว, CLOSED = ปิดแฟ้ม)']
  assigneeId Int [note: 'แอดมินคนที่รับผิดชอบแฟ้มนี้ (ถ้ามี)']
  messages int_chat_messages [not null, note: 'ความสัมพันธ์แบบ 1-to-Many ไปยังตารางข้อความย่อย']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'แฟ้มรวบรวมการสนทนา (Chat Session) ทำหน้าที่เป็นตารางหลัก (Header)  เพื่อให้ AI เข้ามาสรุปแชท วิเคราะห์อารมณ์ และให้แอดมินจัดการสถานะเคสได้ง่ายขึ้น'
}

Table int_ai_bots {
  id Int [pk, increment, note: 'รหัสลำดับของบอท (รันอัตโนมัติ)']
  companyId Int [note: 'รหัสอ้างอิงบริษัทที่เป็นเจ้าของบอทตัวนี้']
  company org_companies [note: 'ข้อมูลบริษัทที่เกี่ยวข้อง โดยระบุ onDelete: Cascade เพื่อให้บอทถูกลบออกทันทีหากบริษัทปิดตัวลง']
  code String [note: 'รหัสอ้างอิงของบอท (ถ้ามี)']
  name String [not null, note: 'ชื่อเรียกบอทที่ต้องการให้แสดงผล เช่น "น้องขายดี" หรือ "Admin Support"']
  isSystem Boolean [not null, default: false, note: '🌟 เพิ่มฟิลด์นี้เพื่อบอกว่าเป็นบอทมาตรฐานของระบบ']
  description String [note: 'รายละเอียดเพิ่มเติมเกี่ยวกับหน้าที่ของบอทตัวนี้']
  provider String [not null, note: 'ผู้ให้บริการ AI ที่เลือกใช้ เช่น OPENAI, GEMINI, หรือ CLAUDE']
  modelName String [not null, note: 'ชื่อรุ่นของโมเดล AI เช่น gpt-4o หรือ gemini-1.5-pro']
  temperature Float [not null, default: 0.7000000000000001, note: 'ค่าความสร้างสรรค์ของ AI (0.0 - 1.0) โดยค่าที่สูงขึ้นจะทำให้ AI ตอบแบบมีความคิดสร้างสรรค์และไม่จำเจ']
  usageLogs int_ai_usage_logs [not null, note: 'รายการประวัติการใช้งานและจำนวน Token ที่บอทตัวนี้ใช้ไป']
  systemPrompt String [not null, note: 'คำสั่งพื้นฐาน (System Instruction) เพื่อกำหนดบุคลิกและขอบเขตการตอบ เช่น "คุณคือพนักงานขายที่สุภาพและเน้นปิดการขาย"']
  greetingMessage String [note: 'ข้อความทักทายแรกสุดที่ AI จะส่งให้ลูกค้าเมื่อมีการเริ่มแชท']
  canUseTools Boolean [not null, default: false, note: 'สถานะเปิดใช้งานเครื่องมือช่วย (Function Calling) เพื่อให้ AI สามารถตรวจสอบสต็อกสินค้าหรือเช็คสถานะออเดอร์ได้']
  isActive Boolean [not null, default: true, note: 'สถานะเปิด/ปิดการใช้งานบอทตัวนี้']
  lineChannels int_line_configs [not null, note: 'รายการช่องทางโซเชียลมีเดียที่บอทตัวนี้เชื่อมต่ออยู่ (1 บอท สามารถคุมได้หลาย Line bot)']
  fbPages int_facebook_pages [not null, note: 'รายการช่องทางโซเชียลมีเดียที่บอทตัวนี้เชื่อมต่ออยู่ (1 บอท สามารถคุมได้หลายเพจ)']
  InstagramConfig int_instagram_configs [not null]
  TiktokShop int_tiktok_shops [not null]
  LazadaShop int_lazada_shops [not null]
  ShopeeShop int_shopee_shops [not null]
  createdAt DateTime [default: `now()`, not null, note: 'วันที่สร้าง']
  updatedAt DateTime [not null, note: 'แก้ไขข้อมูลบอทล่าสุด']

  indexes {
    (companyId, code) [unique]
  }

  Note: 'ตารางนี้เปรียบเสมือน "สมอง" ของระบบ AI ที่คุณพัฒนาขึ้น โดยใช้ควบคุมบุคลิกภาพและความสามารถของบอทที่นำไปใช้ในช่องทางต่างๆ เช่น LINE หรือ Facebook'
}

Table int_knowledge_bases {
  id Int [pk, increment, note: 'รหัสลำดับของข้อมูลความรู้ (รันอัตโนมัติ)']
  topic String [not null, note: 'หัวข้อของความรู้ เช่น "วิธีการเคลมสินค้า" หรือ "ประวัติบริษัท"']
  content String [not null, note: 'เนื้อหาของความรู้แบบละเอียด ซึ่งจะถูกนำไปทำ Vector Search เพื่อให้ AI อ่าน']
  companyId Int [not null, note: 'รหัสอ้างอิงบริษัทที่เป็นเจ้าของข้อมูลชุดนี้']
  company org_companies [not null, note: 'ข้อมูลบริษัทที่เกี่ยวข้อง โดยระบุ onDelete: Cascade เพื่อให้ข้อมูลความรู้ถูกลบออกหากบริษัทถูกลบ']
  sourceType KnowledgeSourceType [not null, default: 'TEXT', note: 'ประเภทของแหล่งที่มาข้อมูล เช่น TEXT (พิมพ์เอง), FILE (อัปโหลดไฟล์), หรือ URL (ดึงจากหน้าเว็บ)']
  fileHash String [note: 'ตรวจสอบว่าเป็นไฟล์เดิมหรือไม']
  docFile doc_files
  fileId String [note: 'รหัสไฟล์ที่อ้างอิงจากระบบภายนอก เช่น Google Drive File ID']
  url String [note: 'ที่อยู่ลิงก์ของข้อมูล หรือที่อยู่ไฟล์ในระบบจัดเก็บข้อมูล (Cloud Storage)']
  fileName String [note: 'ชื่อไฟล์ต้นฉบับที่นำเข้าสู่ระบบ']
  fileSize BigInt [not null, default: 0, note: 'ขนาดของไฟล์ข้อมูล (หน่วยเป็น Bytes)']
  tags String[] [not null, note: 'คำค้นหาหรือหมวดหมู่ที่เกี่ยวข้องเพื่อช่วยในการจัดกลุ่มความรู้']
  isActive Boolean [not null, default: true, note: 'สถานะการเปิดใช้งานข้อมูลชุดนี้ (ถ้าปิด AI จะไม่สามารถนำข้อมูลนี้ไปตอบได้)']
  chunks int_knowledge_base_chunks [not null, note: 'เชื่อมไปยังตาราง  IntKnowledgeBaseChunk']
  createdAt DateTime [default: `now()`, not null, note: 'วันที่สร้าง']
  updatedAt DateTime [not null, note: 'แก้ไขข้อมูลล่าสุด']

  Note: 'ตารางนี้เปรียบเสมือน "ห้องสมุด" ที่เก็บข้อมูลดิบเพื่อให้บอท AI นำไปใช้ค้นหาคำตอบ (RAG - Retrieval-Augmented Generation) ให้กับลูกค้าได้อย่างแม่นยำ'
}

Table int_knowledge_base_chunks {
  id String [pk, note: 'รหัสประจำตัวของชิ้นส่วนข้อมูล (UUID)']
  knowledgeBaseId Int [not null, note: 'เชื่อมกลับไปหาไฟล์หลัก']
  knowledgeBase int_knowledge_bases [not null]
  content String [not null, note: 'ข้อความที่ถูกหั่นแล้ว (เช่น ข้อมูล Excel 1-5 บรรทัด หรือ PDF 1 ย่อหน้า)']
  createdAt DateTime [default: `now()`, not null, note: 'วันและเวลาที่สร้างชิ้นส่วนข้อมูลนี้ (Default: ปัจจุบัน)']

  Note: 'หน้าที่หลักคือเก็บข้อมูลที่ถูก "หั่น" เป็นชิ้นเล็กๆ (Chunking) พร้อมกับค่าพิกัดทางคณิตศาสตร์ (Vector Embedding) เพื่อให้ AI สามารถค้นหาเนื้อหาที่ใกล้เคียงกับคำถามของผู้ใช้ได้อย่างรวดเร็วและแม่นยำ'
}

Table int_line_configs {
  id Int [pk, increment, note: 'รหัสลำดับของการตั้งค่า (รันอัตโนมัติ)']
  companyId Int [not null, note: 'รหัสอ้างอิงบริษัทที่เป็นเจ้าของ LINE OA นี้']
  company org_companies [not null, note: 'ข้อมูลบริษัทที่เกี่ยวข้อง โดยมีระบบ onDelete: Cascade เพื่อลบการตั้งค่านี้หากบริษัทถูกลบออกจากระบบ']
  channelName String [not null, note: 'ชื่อเรียกช่องทาง LINE เช่น "สาขาสยาม" หรือ "ฝ่ายขาย" เพื่อให้แยกแยะได้ง่าย']
  channelId String [not null, note: 'รหัส Channel ID จาก LINE Developers Console']
  channelSecret String [not null, note: 'รหัส Channel Secret สำหรับยืนยันตัวตน']
  channelToken String [not null, note: 'รหัส Channel Access Token สำหรับใช้เรียก API ของ LINE (เก็บเป็น Text เพราะมีความยาวมาก)']
  liffIdMain String [note: 'รหัส LIFF ID หลัก สำหรับใช้พัฒนาหน้าจอเว็บภายในแอป LINE (Mini App)']
  webhookUrl String [note: 'ที่อยู่ URL สำหรับรับข้อมูลจาก LINE (Webhook) ที่ต้องนำไปกรอกใน LINE Dev Console']
  aiBotId Int [note: 'รหัสอ้างอิงของ AI Bot (สมอง) ที่ต้องการให้ดูแลตอบแชทในช่องทางนี้']
  aiBot int_ai_bots [note: 'ข้อมูลของ AI Bot ที่เชื่อมต่ออยู่']
  isAiEnabled Boolean [not null, default: true, note: 'สถานะเปิด/ปิดการตอบแชทด้วย AI (หากปิด พนักงานต้องมาตอบเอง)']
  createdAt DateTime [default: `now()`, not null, note: 'วันที่สร้าง']
  updatedAt DateTime [not null, note: 'แก้ไขข้อมูลล่าสุด']

  Note: 'ตารางนี้ใช้สำหรับเชื่อมต่อระบบของคุณกับ LINE Messaging API เพื่อให้ระบบสามารถรับ-ส่งข้อความกับลูกค้าได้ รวมถึงการเลือกใช้ AI มาช่วยตอบแชทอัตโนมัติด้วยครับ'
}

Table int_facebook_pages {
  id Int [pk, increment, note: 'รหัสลำดับของการตั้งค่า (รันอัตโนมัติ)']
  companyId Int [not null, note: 'รหัสอ้างอิงบริษัทที่เป็นเจ้าของ Facebook Page นี้']
  company org_companies [not null, note: 'ข้อมูลบริษัทที่เกี่ยวข้อง โดยมีระบบ onDelete: Cascade เพื่อลบการตั้งค่านี้หากบริษัทถูกลบออกจากระบบ']
  pageName String [not null, note: 'ชื่อของแฟนเพจ Facebook เพื่อให้ง่ายต่อการเลือกใช้งานในระบบ']
  pageId String [unique, not null, note: 'หมายเลขไอดีประจำตัวของเพจ (Page ID) จาก Facebook']
  accessToken String [not null, note: 'รหัสเข้าถึงเพจ (Page Access Token) สำหรับใช้เรียกใช้ API เพื่ออ่านหรือตอบแชท (เก็บเป็น Text เพราะมีความยาวมาก)']
  webhookUrl String [note: 'ที่อยู่ URL สำหรับรับข้อมูล Webhook จาก Facebook ที่ระบบสร้างให้เฉพาะแต่ละเพจ']
  externalConnectionId Int
  externalConnection int_external_connections
  tokenType String [default: 'PAGE_ACCESS_TOKEN']
  expiresAt DateTime [note: 'วันหมดอายุของ Token']
  fbUserId String [note: 'ID ของ Admin ที่เป็นคนกดเชื่อมต่อ']
  instagramConfig int_instagram_configs [note: 'เชื่อม 1:1 กับ IG ที่ผูกกับเพจนี้']
  aiBotId Int [note: 'รหัสอ้างอิงของ AI Bot (สมอง) ที่ต้องการให้ดูแลตอบแชทในเพจนี้']
  aiBot int_ai_bots [note: 'ข้อมูลของ AI Bot ที่เชื่อมต่ออยู่']
  isAiEnabled Boolean [not null, default: true, note: 'สถานะเปิด/ปิดการตอบแชทด้วย AI ในเพจนี้']
  createdAt DateTime [default: `now()`, not null, note: 'วันที่สร้าง']
  updatedAt DateTime [not null, note: 'แก้ไขข้อมูลล่าสุด']

  Note: 'ตารางนี้ใช้สำหรับเชื่อมต่อระบบของคุณกับ Facebook Graph API เพื่อจัดการข้อความจาก Messenger และคอมเมนต์ โดยสามารถเลือกใช้ AI Bot มาช่วยดูแลเพจได้เช่นเดียวกับช่องทาง LINE'
}

Table int_external_connections {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  provider String [not null, note: '"FACEBOOK", "TIKTOK"']
  externalUserId String [not null, note: 'ID ของ User จาก Platform นั้นๆ']
  accessToken String [not null]
  refreshToken String
  expiresAt DateTime
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  instagramConfigs int_instagram_configs [not null]
  tiktokShops int_tiktok_shops [not null]
  FacebookPage int_facebook_pages [not null]
  shopeeShops int_shopee_shops [not null]
  lazadaShops int_lazada_shops [not null]

  indexes {
    (companyId, provider, externalUserId) [unique]
  }

  Note: 'ตารางศูนย์กลางการล็อกอิน/OAuth Hub'
}

Table int_shopee_shops {
  id Int [pk, increment]
  companyId Int [not null]
  externalConnectionId Int [note: '🔗 เชื่อมกับ OAuth Connection หลัก (ใครเป็นคนกด Login)']
  externalConnection int_external_connections
  shopId String [unique, not null, note: '🏪 ข้อมูลร้านค้า']
  shopName String
  accessToken String [not null, note: '🔑 โทเค็น (ลบ Partner ID/Key ออก เพราะไปอยู่ใน .env)']
  refreshToken String
  accessTokenExpiresAt DateTime
  refreshTokenExpiresAt DateTime
  isAiEnabled Boolean [not null, default: false, note: '🤖 AI']
  aiBotId Int
  company org_companies [not null]
  aiBot int_ai_bots
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'เก็บข้อมูลและ Token ที่ใช้สำหรับดึงออเดอร์ จัดการสต็อก หรือตอบแชทของร้านค้าบน Shopee'
}

Table int_lazada_shops {
  id Int [pk, increment]
  companyId Int [not null]
  externalConnectionId Int [note: '🔗 เชื่อมกับ OAuth Connection หลัก']
  externalConnection int_external_connections
  sellerId String [unique, not null, note: '🏪 ข้อมูลร้านค้า']
  shopName String
  region String [not null, default: 'TH']
  accessToken String [not null, note: '🔑 โทเค็น (ลบ App Key/Secret ออก เพราะไปอยู่ใน .env)']
  refreshToken String
  accessTokenExpiresAt DateTime
  refreshTokenExpiresAt DateTime
  isAiEnabled Boolean [not null, default: false, note: '🤖 AI']
  aiBotId Int
  company org_companies [not null]
  aiBot int_ai_bots
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'เก็บข้อมูลและ Token ที่ใช้สำหรับดึงออเดอร์ จัดการสต็อก หรือตอบแชทของร้านค้าบน Lazada'
}

Table int_instagram_configs {
  id Int [pk, increment]
  companyId Int [not null]
  externalConnectionId Int [note: '🔗 เชื่อมกลับไปหา OAuth Connection หลัก (ใครเป็นคน Auth)']
  externalConnection int_external_connections
  fbPageId Int [unique, note: '🔗 เชื่อมกับ Facebook Page (IG Business ต้องมี FB Page เสมอ)']
  fbPage int_facebook_pages
  igAccountId String [unique, not null, note: 'IG Business Account ID']
  igUsername String
  igProfilePictureUrl String [note: 'สำหรับโชว์รูปในระบบ']
  accessToken String [not null, note: 'เก็บ Token ไว้ที่นี่เพื่อความเร็ว (หรือดึงจาก fbPage ก็ได้)']
  isAiEnabled Boolean [not null, default: false]
  aiBotId Int
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  company org_companies [not null]
  aiBot int_ai_bots

  Note: 'เก็บข้อมูลและ Token ที่ใช้สำหรับดึงออเดอร์ จัดการสต็อก หรือตอบแชทของร้านค้าบน IntInstagram'
}

Table int_tiktok_shops {
  id Int [pk, increment]
  companyId Int [not null]
  externalConnectionId Int [note: '🔗 เชื่อมกับ OAuth Connection หลัก']
  externalConnection int_external_connections
  sellerId String [not null, note: '🏪 ข้อมูลร้านค้า']
  sellerName String [note: 'ชื่อผู้ขาย']
  shopId String [unique, not null, note: 'Shop ID']
  shopCipher String [not null, note: '🚩 ต้องมี! สำหรับ API v2']
  shopName String
  region String [not null, default: 'TH', note: '🚩 เช่น TH, VN']
  accessToken String [not null, note: '🔑 การจัดการสิทธิ์ (Tokens)']
  refreshToken String
  accessTokenExpiresAt DateTime
  refreshTokenExpiresAt DateTime
  isAiEnabled Boolean [not null, default: false, note: '🤖 การตั้งค่า AI']
  aiBotId Int
  company org_companies [not null]
  aiBot int_ai_bots
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'เก็บข้อมูลและ Token ที่ใช้สำหรับดึงออเดอร์ จัดการสต็อก หรือตอบแชทของร้านค้าบน Tiktok'
}

Table sys_modules {
  id Int [pk, increment, note: 'รหัสลำดับของโมดูล']
  code String [unique, not null, note: 'รหัสอ้างอิงโมดูล (เช่น INV, ACC, HRM)']
  name String [not null, note: 'ชื่อโมดูลภาษาไทย']
  description String [note: 'รายละเอียดว่าโมดูลนี้ทำอะไรได้บ้าง']
  price Decimal [not null, default: 0, note: 'ราคาแยกขาย (กรณีซื้อเพิ่มแยกจากแพ็กเกจหลัก)']
  sortOrder Int [not null, default: 0, note: 'ลำดับการแสดงผลในเมนู']
  isActive Boolean [not null, default: true, note: 'สถานะการเปิดใช้งาน']
  packageModules sys_package_modules [not null, note: 'เชื่อมโยงเพื่อบอกว่าโมดูลนี้ไปปรากฏอยู่ในแพ็กเกจค่าบริการ (SysPackage) ไหนบ้าง']
  subscriptions org_subscriptions [not null, note: 'เก็บข้อมูลการสมัครใช้งานของแต่ละบริษัทว่าใครใช้โมดูลนี้อยู่บ้าง']
  menus sec_menus [not null, note: 'เชื่อมไปยังรายการเมนูต่างๆ ที่พนักงานจะเห็นเมื่อบริษัทเปิดใช้งานโมดูลนี้']
  permissions sec_permissions [not null, note: 'กำหนดสิทธิ์การเข้าถึงทรัพยากรต่างๆ ที่ผูกอยู่กับโมดูลนี้']

  Note: 'ตารางเก็บรายชื่อ Module ที่เรามีขาย (เช่น HR, E-COM, CRM, POS)'
}

Table org_subscriptions {
  id Int [pk, increment, note: 'รหัสลำดับของรายการสมัครใช้งาน']
  companyId Int [not null, note: 'รหัสอ้างอิงของบริษัทที่สมัครใช้งาน (เชื่อมไปยังตาราง org_companies)']
  company org_companies [not null, note: 'ข้อมูลบริษัทที่สมัคร โดยมีการตั้งค่า onDelete: Cascade เพื่อให้ข้อมูลการสมัครถูกลบออกโดยอัตโนมัติหากบริษัทนั้นถูกลบจากระบบ']
  paidAmount Decimal [note: '💰 ราคาที่จ่ายจริง (Snapshot ราคา ณ วันที่สมัคร/ต่ออายุ)']
  priceType String [default: 'NORMAL', note: '🏷️ ประเภทราคา เช่น \'NORMAL\' (ปกติ) หรือ \'RESELLER\' (ตัวแทน)']
  lastBillingId Int [note: '🔗 [เพิ่มใหม่] เชื่อมโยงไปยังประวัติการทำรายการ (Billing History) ล่าสุด']
  lastBilling org_billing_histories
  moduleId Int [not null, note: 'รหัสอ้างอิงของโมดูลที่สมัครใช้งาน (เชื่อมไปยังตาราง sys_modules)']
  module sys_modules [not null, note: 'ข้อมูลรายละเอียดของโมดูลที่สมัคร']
  startDate DateTime [default: `now()`, not null, note: 'วันที่เริ่มต้นการใช้งาน (ค่าเริ่มต้นคือวันที่ทำรายการ)']
  endDate DateTime [note: 'วันที่สิ้นสุดการใช้งาน หากฟิลด์นี้เป็นค่าว่าง (Null) จะหมายถึงใช้งานได้ตลอดชีพ หรือตามรอบการเรียกเก็บเงิน']
  status String [not null, default: 'ACTIVE', note: 'สถานะของการสมัครใช้งาน เช่น ACTIVE (กำลังใช้งาน), EXPIRED (หมดอายุ), หรือ SUSPENDED (ระงับการใช้งาน)']
  createdAt DateTime [default: `now()`, not null, note: 'วันที่สร้างรายการ']
  updatedAt DateTime [not null, note: 'วันที่แก้ไขข้อมูลล่าสุด']

  indexes {
    (companyId, moduleId) [unique]
  }

  Note: 'ตารางนี้ใช้บันทึกว่าบริษัทใดบ้างที่ได้รับสิทธิ์ใช้งานโมดูลตัวไหน และมีอายุการใช้งานถึงเมื่อไหร่'
}

Table sec_users {
  id Int [pk, increment, note: 'รหัสผู้ใช้งาน (Auto-increment)']
  username String [unique, not null, note: 'ชื่อผู้ใช้สำหรับเข้าสู่ระบบ (ห้ามซ้ำ)']
  email String [unique, note: 'อีเมลสำหรับเข้าใช้งานหรือกู้คืนรหัสผ่าน']
  passwordHash String [note: 'รหัสผ่านที่ผ่านการเข้ารหัสแล้ว (แนะนำให้ใช้ bcrypt หรือ argon2) ห้ามเก็บเป็น Plain Text เด็ดขาด']
  fullName String [note: 'ชื่อ-นามสกุลจริง สำหรับแสดงผลในหน้าจอต่างๆ']
  avatarUrl String [note: 'ลิงก์รูปภาพโปรไฟล์']
  isActive Boolean [not null, default: true, note: 'สถานะการใช้งานบัญชี (ถ้าเป็น False คือห้ามล็อกอิน)']
  passwordUpdatedAt DateTime [default: `now()`, not null, note: 'วันที่เปลี่ยนรหัสผ่านล่าสุด (ใช้สำหรับฟีเจอร์บังคับเปลี่ยนรหัสผ่านทุก 90 วัน)']
  loginAttempts Int [not null, default: 0, note: 'จำนวนครั้งที่พยายามล็อกอินผิด (สำหรับป้องกันการสุ่มรหัสผ่าน Brute-force)']
  isLocked Boolean [not null, default: false, note: 'สถานะล็อกบัญชีชั่วคราวเมื่อใส่รหัสผิดเกินกำหนด']
  docAccessRequests doc_access_requests [not null]
  docFolderAccesses doc_folder_access [not null]
  docFileAccesses doc_file_access [not null]
  reportedIncidents hr_disciplinary_incidents [not null]
  approvedPenalties hr_disciplinary_actions [not null]
  adhocInvites wf_actions [not null, note: 'ประวัติการเชิญคนนอกเข้ามาช่วยพิจารณางานใน Workflow']
  lockoutExpires DateTime [note: 'เวลาที่จะปลดล็อกบัญชีให้โดยอัตโนมัติ']
  lineUserId String [note: 'รหัส LINE User ID สำหรับใช้ล็อกอินผ่าน LINE หรือรับแจ้งเตือน']
  isNotified Boolean [not null, default: true, note: 'การตั้งค่าว่าผู้ใช้คนนี้ต้องการรับการแจ้งเตือนจากระบบหรือไม่']
  googleId String [unique, note: 'ฟิลด์รองรับการยืนยันตัวตน']
  facebookId String [unique, note: 'ฟิลด์รองรับการยืนยันตัวตน']
  thaiId String [unique, note: 'ฟิลด์รองรับการยืนยันตัวตน']
  paotangId String [unique, note: 'ฟิลด์รองรับการยืนยันตัวตน']
  ndidId String [unique, note: 'ฟิลด์รองรับการยืนยันตัวตน']
  phoneNumber String
  employee hr_employees [note: 'ข้อมูลพนักงาน (เชื่อมโยง 1-to-1 ถ้า User นี้เป็นพนักงาน)']
  billingHistories org_billing_histories [not null, note: 'ประวัติการกดทำรายการบิลลิ่ง (พนักงานที่กด)']
  roles sec_user_roles [not null, note: 'บทบาท/สิทธิ์การใช้งานระบบ']
  wfRequests wf_requests [not null, note: 'ประวัติการขออนุมัติงาน (Request)']
  wfActions wf_actions [not null, note: 'ประวัติการอนุมัติงาน (Action)']
  delegationsOwned sec_user_delegations [not null, note: 'รายการมอบหมายงานให้คนอื่นทำแทน (Delegation Owner)']
  delegationsReceived sec_user_delegations [not null, note: 'รายการได้รับมอบหมายงานทำแทน (Delegation Receiver)']
  logAudits log_audits [not null, note: 'ประวัติการใช้งานระบบ (Audit Log)']
  notifications sys_notifications [not null, note: 'การแจ้งเตือนที่ได้รับ']
  productsCreated com_products [not null, note: 'สินค้าที่สร้างโดย User นี้']
  paymentVerifications com_payments [not null, note: 'ประวัติการตรวจสอบการชำระเงิน']
  uploadedFiles doc_files [not null]
  docFileVersion doc_file_versions [not null]
  docSignatureRequest doc_signature_requests [not null]
  loginLogs sec_login_logs [not null]
  createdAt DateTime [default: `now()`, not null, note: 'วันที่สร้างบัญชี']
  updatedAt DateTime [not null, note: 'วันที่แก้ไขข้อมูลล่าสุด']

  Note: 'ตารางนี้ทำหน้าที่เก็บข้อมูลสำหรับการ Log in และการยืนยันตัวตนทั้งหมด แยกออกจากข้อมูลพนักงาน (HR) เพื่อความปลอดภัยและความยืดหยุ่น (เพราะ User บางคนอาจไม่ใช่พนักงาน เช่น Admin ภายนอก หรือ Auditor)'
}

Table sec_roles {
  id Int [pk, increment, note: 'รหัสลำดับของบทบาท (รันอัตโนมัติ)']
  companyId Int [note: 'รหัสอ้างอิงบริษัทที่บทบาทนี้สังกัดอยู่ หากเป็นค่าว่าง (Null) อาจหมายถึงบทบาทกลางของระบบ']
  company org_companies [note: 'ข้อมูลบริษัทที่เกี่ยวข้อง โดยระบุ onDelete: Cascade เพื่อให้บทบาทถูกลบออกหากบริษัทถูกลบ']
  name String [not null, note: 'ชื่อรหัสของบทบาท (System Name) เช่น admin, sale_manager']
  displayName String [note: 'ชื่อที่ใช้แสดงผลบนหน้าจอให้คนอ่าน เช่น "ผู้จัดการฝ่ายขาย"']
  description String [note: 'รายละเอียดเพิ่มเติมว่าบทบาทนี้มีหน้าที่ทำอะไรบ้าง']
  isSystem Boolean [not null, default: false, note: 'ระบุว่าเป็นบทบาทพื้นฐานที่ระบบสร้างให้หรือไม่ (ถ้าใช่ มักจะห้ามลบ)']
  isOrderNotified Boolean [not null, default: false, note: 'ตั้งค่าว่าผู้ที่ถือบทบาทนี้ต้องได้รับแจ้งเตือนเมื่อมีการสั่งซื้อใหม่หรือไม่']
  users sec_user_roles [not null, note: 'รายชื่อผู้ใช้งานที่ได้รับมอบหมายบทบาทนี้']
  permissions sec_role_permissions [not null, note: 'รายการสิทธิ์การเข้าถึงทรัพยากรต่างๆ ที่ผูกอยู่กับบทบาทนี้']
  menus sec_role_menus [not null, note: 'รายการเมนูหน้าเว็บที่บทบาทนี้ได้รับอนุญาตให้มองเห็น']
  wfNodes wf_nodes [not null, note: 'การเชื่อมโยงกับระบบ Workflow เพื่อกำหนดว่าใครต้องเป็นผู้อนุมัติในแต่ละขั้นตอน']
  docFolderAccesses doc_folder_access [not null]
  docFileAccesses doc_file_access [not null]

  indexes {
    (companyId, name) [unique]
  }

  Note: 'ตารางนี้ใช้สำหรับกำหนดกลุ่มของสิทธิ์ เช่น Admin, Manager, หรือ Staff เพื่อนำไปมอบให้กับผู้ใช้งานแต่ละคน'
}

Table sec_user_roles {
  userId Int [not null, note: 'รหัสผู้ใช้งานที่ต้องการมอบหมายบทบาทให้']
  roleId Int [not null, note: 'รหัสบทบาทที่จะมอบให้ (เช่น Admin, Sale, Stock)']
  companyId Int [not null, note: 'รหัสบริษัทที่บทบาทนี้มีผลบังคับใช้']
  user sec_users [not null, note: 'เชื่อมโยงไปยังตารางผู้ใช้งาน (SecUser) โดยตั้งค่า onDelete: Cascade เพื่อให้สิทธิ์นี้หายไปทันทีถ้า User ถูกลบ']
  role sec_roles [not null, note: 'ข้อมูลบทบาท (ลบสิทธิ์ทิ้งถ้า Role หาย)']
  company org_companies [not null, note: 'ข้อมูลบริษัท (ลบสิทธิ์ทิ้งถ้าบริษัทปิดตัว)']

  indexes {
    (userId, roleId, companyId) [pk]
  }

  Note: 'ตารางนี้ทำหน้าที่บอกว่า "นาย ก. (User) เป็น ผู้จัดการ (Role) ที่ บริษัท A (Company)" การออกแบบแบบนี้ทำให้ User 1 คน สามารถเป็น Admin ในบริษัทหนึ่ง แต่เป็นแค่ User ธรรมดาในอีกบริษัทหนึ่งได้ (มีความยืดหยุ่นสูงมาก)'
}

Table sec_permissions {
  id Int [pk, increment, note: 'รหัสลำดับสิทธิ์ (รันอัตโนมัติ)']
  resource String [not null, note: 'ชื่อทรัพยากรที่ต้องการควบคุม เช่น PRODUCT, ORDER, REPORT_SALES']
  action String [not null, note: 'การกระทำที่อนุญาตให้ทำได้ เช่น create, view, update, delete, ']
  description String [note: 'คำอธิบายสิทธิ์เพื่อให้แอดมินเข้าใจง่ายขึ้น เช่น "อนุญาตให้แก้ไขราคาสินค้าได้"']
  moduleId Int [note: 'รหัสโมดูลที่สิทธิ์นี้สังกัดอยู่ (Optional) ใช้สำหรับจัดหมวดหมู่สิทธิ์ตามแพ็กเกจที่ซื้อ']
  module sys_modules [note: 'ข้อมูลโมดูลที่เกี่ยวข้อง']
  roles sec_role_permissions [not null, note: 'รายการเชื่อมโยงว่ามีบทบาท (Role) ไหนบ้างที่ถือสิทธิ์นี้อยู่']

  indexes {
    (resource, action) [unique]
  }

  Note: 'ตารางนี้ทำหน้าที่กำหนด "กติกา" ว่าในระบบนี้ทำอะไรได้บ้าง เช่น "สร้างสินค้า", "ลบพนักงาน", หรือ "อนุมัติส่วนลด" โดยการเพิ่ม moduleId เข้ามาตามที่คุณทำนั้นถือว่า ยอดเยี่ยมมาก เพราะจะช่วยกรองสิทธิ์หน้าบ้านได้ง่ายขึ้น'
}

Table sec_role_permissions {
  roleId Int [not null, note: 'รหัสบทบาทที่ต้องการกำหนดสิทธิ์ให้']
  permissionId Int [not null, note: 'รหัสสิทธิ์ที่ต้องการมอบให้']
  role sec_roles [not null, note: 'เชื่อมโยงไปยังตารางบทบาท (SecRole) โดยตั้งค่า onDelete: Cascade เพื่อให้สิทธิ์นี้ถูกลบออกทันทีหากบทบาทนั้นถูกลบ']
  permission sec_permissions [not null, note: 'เชื่อมโยงไปยังตารางสิทธิ์ (SecPermission) โดยตั้งค่า onDelete: Cascade เช่นกัน']

  indexes {
    (roleId, permissionId) [pk]
  }

  Note: 'ตารางนี้เป็น "ตารางเชื่อม (Junction Table)" ที่จะตอบคำถามว่า "Role นี้... ทำอะไรได้บ้าง?"'
}

Table sec_menus {
  id Int [pk, increment, note: 'รหัสลำดับเมนู (รันอัตโนมัติ)']
  name String [not null, note: 'ชื่อเมนูที่จะแสดงผลบนหน้าจอ (เช่น "แดชบอร์ด", "จัดการสินค้า")']
  path String [note: 'เส้นทาง URL ที่เมนูนี้จะลิ้งก์ไป (เช่น /dashboard, /products) หากเป็นเมนูแม่ (Parent) ที่มีลูกย่อยๆ ค่านี้อาจจะเป็น Null ได้']
  icon String [note: 'ชื่อคลาสไอคอนหรือชื่อไฟล์รูปภาพสำหรับแสดงหน้าชื่อเมนู (เช่น fa-home, icon-settings)']
  parentId Int [note: 'รหัสเมนูแม่ (ถ้ามี) ใช้สำหรับทำเมนูแบบ Dropdown หรือ Accordion']
  parent sec_menus [note: 'ความสัมพันธ์แบบ Self-relation เพื่อสร้างโครงสร้าง Tree (แม่-ลูก) ได้ไม่จำกัดชั้น']
  children sec_menus [not null, note: 'ความสัมพันธ์แบบ Self-relation เพื่อสร้างโครงสร้าง Tree (แม่-ลูก) ได้ไม่จำกัดชั้น']
  securityConfigs sec_company_security_configs [not null]
  moduleId Int
  module sys_modules
  isSystem Boolean [not null, default: false, note: 'บ่งบอกว่าเป็นเมนูหลักของระบบหรือไม่ (ถ้า true = ห้ามลบ)']
  roles sec_role_menus [not null]
  displayConfigs sec_company_menu_configs [not null]
  sortOrder Int [not null, default: 0, note: 'ลำดับการเรียงเมนู (เลขน้อยขึ้นก่อน)']
  isVisible Boolean [not null, default: true, note: 'ตัวเปิด/ปิดเมนูระดับ Global (เช่น ถ้าเราทำฟีเจอร์ยังไม่เสร็จ ก็ปิด False ไว้ก่อน ลูกค้าจะได้ไม่เห็น)']

  Note: 'ตารางนี้มีความยืดหยุ่นสูงมาก เพราะรองรับทั้ง เมนูซ้อนชั้น (Sub-menu) และ การจำกัดการมองเห็นตามโมดูล (Feature Gating) ซึ่งเหมาะกับระบบ SaaS ที่ลูกค้าแต่ละรายอาจเห็นเมนูไม่เหมือนกัน'
}

Table sec_company_menu_configs {
  id Int [pk, increment, note: 'รหัสลำดับการตั้งค่า (รันอัตโนมัติ)']
  companyId Int [not null, note: 'รหัสบริษัทที่เป็นเจ้าของการตั้งค่านี้']
  company org_companies [not null, note: 'ข้อมูลบริษัท (ลบการตั้งค่าทิ้งถ้าบริษัทหายไป)']
  menuId Int [not null, note: 'รหัสเมนูที่ต้องการปรับแต่ง']
  menu sec_menus [not null, note: 'ข้อมูลเมนูเดิม (ลบการตั้งค่าทิ้งถ้าเมนูถูกลบจากระบบ)']
  showInSidebar Boolean [not null, default: true, note: 'แสดงใน Sidebar ด้านข้างหรือไม่']
  showInNavbar Boolean [not null, default: false, note: 'แสดงเป็นเมนูลัดด้านบนหรือไม่ (Navbar)']
  isShortcut Boolean [not null, default: false, note: 'แสดงเป็นปุ่มลัดใน Dashboard หรือไม่']
  customLabel String [note: 'ชื่อเมนูที่ตั้งเอง (Override ชื่อเดิม)']
  customIcon String [note: 'ไอคอนที่ตั้งเอง (Override ไอคอนเดิม)']
  sortOrder Int [note: 'ลำดับการแสดงผลเฉพาะบริษัทนี้ (Null = ใช้ค่าเดิม)']
  updatedAt DateTime [not null, note: 'วันที่แก้ไขล่าสุด']

  indexes {
    (companyId, menuId) [unique]
  }

  Note: 'ตารางนี้มีความสำคัญมากสำหรับระบบ SaaS ที่ต้องการความยืดหยุ่นสูง (Customizability) เพราะมันช่วยให้ลูกค้าแต่ละบริษัทสามารถ "จัดหน้าตาเมนู" ในแบบของตัวเองได้โดยไม่กระทบกับบริษัทอื่น'
}

Table sec_role_menus {
  roleId Int [not null, note: 'รหัสบทบาทที่ต้องการกำหนดการมองเห็น']
  menuId Int [not null, note: 'รหัสเมนูที่ต้องการให้บทบาทนี้มองเห็น']
  sortOrder Int [note: 'ลำดับการแสดงผลเมนู (เฉพาะบทบาทนี้) ถ้าเป็น Null: ให้ใช้ลำดับมาตรฐานจากตาราง SecMenu ถ้ามีค่า: ให้ใช้ค่านี้นำมาจัดเรียงแทน (เช่น Admin อาจเห็นเมนูตั้งค่าอยู่บนสุด แต่ User ทั่วไปเห็นอยู่ล่างสุด)']
  role sec_roles [not null, note: 'เชื่อมโยงไปยังตารางบทบาท (SecRole) โดยตั้งค่า onDelete: Cascade เพื่อให้สิทธิ์การมองเห็นถูกลบออกทันทีหากบทบาทถูกลบ']
  menu sec_menus [not null, note: 'เชื่อมโยงไปยังตารางเมนู (SecMenu) โดยตั้งค่า onDelete: Cascade เช่นกัน']

  indexes {
    (roleId, menuId) [pk]
  }

  Note: 'ตารางนี้มีความสำคัญมากในการทำ Menu Authorization หรือการซ่อนเมนูที่ไม่เกี่ยวข้องออกจากหน้าจอของพนักงานแต่ละระดับครับ'
}

Table sec_password_policies {
  id Int [pk, increment, note: 'รหัสลำดับนโยบาย (รันอัตโนมัติ)']
  companyId Int [unique, note: 'รหัสบริษัทที่ใช้นโยบายนี้ ✅ ถ้า NULL คือ Global Policy (ใช้กับทุกบริษัทที่ไม่ได้ตั้งค่าเอง) ถ้ามีค่า: หมายถึงบริษัทนั้นๆ มีการกำหนดความเข้มงวดของรหัสผ่านด้วยตัวเอง']
  company org_companies [note: '(และจะถูกลบอัตโนมัติหากบริษัทนั้นถูกลบทิ้ง)']
  minLength Int [not null, default: 8, note: 'ความยาวขั้นต่ำของรหัสผ่านที่อนุญาต (ค่ามาตรฐานคือ 8 ตัวอักษร)']
  requireUpper Boolean [not null, default: true, note: 'ต้องมีตัวพิมพ์ใหญ่']
  requireLower Boolean [not null, default: true, note: 'ต้องมีตัวพิมพ์เล็ก']
  requireNumber Boolean [not null, default: true, note: 'ต้องมีตัวเลข']
  requireSpecial Boolean [not null, default: true, note: 'ต้องมีอักขระพิเศษ']
  specialChars String [not null, default: '!@#$%^&*', note: 'อักขระพิเศษที่อนุญาตให้ใช้']
  passwordAgeDays Int [not null, default: 90, note: 'ต้องเปลี่ยนทุกๆ กี่วัน (0 = ไม่บังคับ)']
  historyCount Boolean [not null, default: true, note: 'การตั้งค่าเพื่อจดจำประวัติรหัสผ่านเก่า ป้องกันไม่ให้ผู้ใช้นำรหัสผ่านเดิมที่เคยใช้ไปแล้วกลับมาตั้งซ้ำ (💡 ข้อสังเกต: ปัจจุบันคุณตั้งเป็น Boolean เพื่อเปิด/ปิดฟีเจอร์นี้ แต่ถ้าในอนาคตอยากระบุว่า "ห้ามซ้ำกับรหัสผ่านเก่า 3 หรือ 5 ครั้งล่าสุด" อาจจะพิจารณาเปลี่ยน Type เป็น Int ก็ได้']
  maxLoginAttempts Int [not null, default: 5, note: 'จำนวนครั้งสูงสุดที่อนุญาตให้ใส่รหัสผ่านผิดก่อนที่บัญชีจะถูกล็อก (ป้องกันการสุ่มรหัส)']
  lockoutDuration Int [not null, default: 30, note: 'ระยะเวลาที่บัญชีจะถูกล็อก (หน่วยเป็นนาที) หลังจากที่ใส่รหัสผ่านผิดเกินโควตา']
  updatedAt DateTime [not null, note: 'วันที่แก้ไขการตั้งค่าล่าสุด']

  Note: 'ตารางนี้ใช้กำหนดมาตรฐานความปลอดภัยในการตั้งรหัสผ่าน การบังคับเปลี่ยนรหัสผ่านตามวงรอบ และการป้องกันการเดารหัสผ่าน (Brute-force Protection)'
}

Table sec_user_delegations {
  id Int [pk, increment, note: 'รหัสลำดับรายการมอบหมายงาน (รันอัตโนมัติ)']
  ownerUserId Int [not null, note: 'รหัสผู้ใช้งานที่เป็น "เจ้าของสิทธิ์" (ผู้มอบหมายงาน / ผู้ที่ไม่อยู่หรือลางาน)']
  delegateUserId Int [not null, note: 'รหัสผู้ใช้งานที่เป็น "ตัวแทน" (ผู้รับมอบอำนาจให้ตัดสินใจหรือทำงานแทน)']
  startDate DateTime [not null, note: 'วันและเวลาที่ เริ่มต้น ให้ตัวแทนมีสิทธิ์ทำงานแทน']
  endDate DateTime [not null, note: 'วันและเวลาที่ สิ้นสุด การมอบหมายสิทธิ์ (เมื่อถึงเวลานี้ สิทธิ์ของตัวแทนจะถูกยกเลิกอัตโนมัติ)']
  reason String [note: 'เหตุผลในการมอบหมายงาน เช่น "ลาพักร้อนประจำปี", "ไปราชการต่างประเทศ", หรือ "ลาป่วย"']
  owner sec_users [not null, note: 'เชื่อมโยงกลับไปหาข้อมูลของผู้มอบหมายในตาราง SecUser']
  delegate sec_users [not null, note: 'เชื่อมโยงกลับไปหาข้อมูลของตัวแทนในตาราง SecUser']

  Note: 'ใช้สำหรับบันทึกประวัติและระยะเวลาที่ผู้ใช้คนหนึ่ง (Owner) อนุญาตให้อีกคนหนึ่ง (Delegate) กระทำการต่างๆ ในระบบแทนตนเอง'
}

Table cfg_master_groups {
  id Int [pk, increment, note: 'รหัสลำดับกลุ่มข้อมูล (รันอัตโนมัติ)']
  groupCode String [unique, not null, note: 'รหัสอ้างอิงกลุ่มข้อมูล (เช่น NAME_PREFIX, BANK_LIST, ORDER_STATUS) ใช้สำหรับให้โปรแกรมเมอร์เรียกใช้ในโค้ด (ห้ามซ้ำ)']
  groupName String [note: 'ชื่อเรียกกลุ่มข้อมูลที่อ่านเข้าใจง่ายสำหรับให้ผู้ใช้ทั่วไปเห็น (เช่น "คำนำหน้าชื่อ", "รายชื่อธนาคาร")']
  description String [note: 'คำอธิบายเพิ่มเติมว่ากลุ่มข้อมูลนี้ใช้ทำอะไร หรือใช้ในหน้าจอไหน']
  isSystem Boolean [not null, default: false, note: 'ตัวป้องกันความผิดพลาด (System Lock) ถ้าเป็น True: หมายถึงกลุ่มข้อมูลนี้มีความสำคัญกับระบบมาก ห้ามผู้ใช้ลบหรือแก้ไขรหัส (เช่น สถานะเอกสารที่ผูกกับ Logic ของระบบ)']
  isActive Boolean [not null, default: true, note: 'สถานะเปิด/ปิดการใช้งานกลุ่มข้อมูลนี้ (ทำ Soft Delete หรือซ่อนไว้ชั่วคราวโดยไม่ต้องลบข้อมูลจริงทิ้ง)']
  items cfg_master_data [not null, note: 'ความสัมพันธ์แบบ 1-to-Many เชื่อมโยงไปยังตาราง CfgMasterData เพื่อเก็บ "รายการย่อย" ที่อยู่ภายใต้กลุ่มนี้ (เช่น นาย, นาง, นางสาว จะอยู่ในตารางนี้)']

  Note: 'ตารางนี้เป็นส่วนหัว (Header) ของระบบ Master Data Management ครับ ใช้สำหรับสร้าง "หมวดหมู่" ของข้อมูลตัวเลือกต่างๆ ที่จะนำไปใช้เป็น Dropdown ทั่วทั้งระบบ เช่น หมวดหมู่ "คำนำหน้าชื่อ", "ธนาคาร", หรือ "สถานะเอกสาร"'
}

Table cfg_master_data {
  id Int [pk, increment, note: 'รหัสลำดับรายการตัวเลือก (รันอัตโนมัติ)']
  masterGroupId Int [not null, note: 'รหัสกลุ่มข้อมูลที่ตัวเลือกนี้สังกัดอยู่ (เช่น รหัสของกลุ่ม "เพศ")']
  companyId Int [note: 'แยกให้แต่ละบริษัทสามารถมี matadata เป็นของตัวเองได้']
  company org_companies
  code String [not null, note: 'รหัสตัวเลือกสำหรับการอ้างอิงในระดับโค้ดหรือเก็บลงฐานข้อมูล (เช่น M, F, PENDING, SUCCESS)']
  name String [note: 'ชื่อตัวเลือกสำหรับแสดงผลหลัก (เช่น "ชาย", "หญิง", "รอชำระเงิน")']
  labels Json [not null, note: 'ข้อมูลชื่อตัวเลือกที่รองรับหลายภาษา เก็บในรูปแบบ JSON เช่น {"th": "ชาย", "en": "Male"} ทำให้หน้าบ้านสามารถสลับภาษาได้ทันทีโดยไม่ต้องสร้างตารางแยก']
  masterGroup cfg_master_groups [not null, note: 'เชื่อมโยงกลับไปยังตารางแม่ CfgMasterGroup (ตั้งค่า Cascade เพื่อให้ลบตัวเลือกเหล่านี้ทิ้งอัตโนมัติถ้ากลุ่มแม่ถูกลบ)']
  parentId Int [note: 'รหัสรายการแม่ (ถ้ามี) ใช้สำหรับสร้างตัวเลือกแบบซ้อนชั้นกัน เช่น ประเทศ -> จังหวัด -> อำเภอ']
  parent cfg_master_data [note: 'ความสัมพันธ์แบบ Self-relation ในตัวมันเอง ทำให้สร้างความลึกกี่ชั้นก็ได้']
  children cfg_master_data [not null, note: 'ความสัมพันธ์แบบ Self-relation ในตัวมันเอง ทำให้สร้างความลึกกี่ชั้นก็ได้']
  sortOrder Int [not null, default: 0, note: 'ลำดับการเรียงตัวเลือกใน Dropdown (ตัวเลขน้อยขึ้นก่อน)']
  isActive Boolean [not null, default: true, note: 'สถานะเปิด/ปิดการใช้งานตัวเลือกนี้ (ถ้าปิด หน้าบ้านจะไม่เห็นตัวเลือกนี้ให้กด)']
  colorCode String [note: 'รหัสสี (Hex Code เช่น #10B981) สำหรับนำไปทำ Badge หรือ Label สีในหน้า UI เช่น สถานะ "สำเร็จ" ให้โชว์สีเขียว, สถานะ "ยกเลิก" ให้โชว์สีแดง']
  products com_products [not null, note: 'เชื่อมกลุ่มสินค้าใน Products']
  productsWithUnit com_products [not null]
  productsWithBox com_products [not null]

  indexes {
    (masterGroupId, code, companyId) [unique]
  }

  Note: 'ตารางนี้เปรียบเสมือน "ไส้ใน" ของ CfgMasterGroup ใช้สำหรับเก็บ "ตัวเลือก (Options)" ทั้งหมดที่จะนำไปแสดงใน Dropdown ทั่วระบบ ความเจ๋งคือมันรองรับทั้งระบบหลายภาษา (Multi-language) และข้อมูลแบบซ้อนทับกันเป็นลำดับชั้น (Hierarchical Data)'
}

Table cfg_running_formats {
  id Int [pk, increment, note: 'รหัสลำดับรูปแบบ (รันอัตโนมัติ)']
  companyId Int [note: '🌟 1. เพิ่มฟิลด์ companyId (null = รูปแบบส่วนกลาง, มีเลข = รูปแบบเฉพาะบริษัท)']
  docCode String [not null, note: 'รหัสประเภทเอกสารอ้างอิง (ห้ามซ้ำ) สำหรับให้โปรแกรมเมอร์ใช้เรียกในโค้ด ']
  docName String [note: 'ชื่อเรียกประเภทเอกสารเพื่อให้ผู้ใช้เข้าใจ ']
  formatPattern String [not null, note: 'ครงสร้างหรือแพทเทิร์นของเลขเอกสาร (ตัวอย่างเช่น INV-{YYYY}{MM}-{RUN} ระบบก็จะสร้างเลขออกมาเป็น INV-202602-00001)']
  digitLength Int [not null, default: 5, note: 'จำนวนหลักของตัวเลขรันนิ่ง ']
  resetCriteria ResetCriteria [not null, default: 'MONTHLY', note: 'เงื่อนไขการรีเซ็ตเลขรันนิ่งให้กลับไปเริ่มที่ 1 ใหม่ ']
  isActive Boolean [not null, default: true, note: 'สถานะการใช้งานรูปแบบนี้ (เปิด/ปิด)']
  counters cfg_running_counters [not null, note: 'ความสัมพันธ์แบบ 1-to-Many เชื่อมไปยังตาราง CfgRunningCounter ซึ่งจะทำหน้าที่เก็บค่าตัวเลขล่าสุด (Last Value) ว่าตอนนี้รันไปถึงเลขอะไรแล้วในรอบเดือน/ปีนั้นๆ']

  indexes {
    (docCode, companyId) [unique]
  }

  Note: 'ใช้สำหรับตั้งค่าว่าเอกสารแต่ละประเภท (เช่น PO, Invoice) '
}

Table cfg_running_counters {
  id Int [pk, increment, note: 'รหัสลำดับหลักของตาราง (Primary Key) แบบรันอัตโนมัติ']
  formatId Int [not null, note: 'รหัสอ้างอิงไปยังตารางรูปแบบเลขรัน (CfgRunningFormat) เพื่อระบุว่าตัวนับนี้เป็นของรูปแบบใด']
  companyId Int [note: 'รหัสบริษัทที่ตัวนับนี้สังกัดอยู่ (ถ้าเป็นค่าว่างอาจหมายถึงใช้ร่วมกันทั้งระบบ)']
  periodKey String [not null, note: 'คีย์ที่ระบุรอบระยะเวลาของเลขรัน เช่น ปีเดือน (202602) หรือปี (2026) เพื่อให้เลขรันกลับไปเริ่มใหม่เมื่อขึ้นรอบใหม่']
  currentValue Int [not null, default: 0, note: 'ค่าตัวเลขล่าสุดที่ถูกใช้งานไป (ค่าเริ่มต้นคือ 0)']
  format cfg_running_formats [not null]

  indexes {
    (formatId, periodKey, companyId) [unique]
  }

  Note: 'ทำหน้าที่เป็นตัวเก็บค่าปัจจุบันของเลขรัน (Running Number) ในแต่ละรอบช่วงเวลาหรือแต่ละบริษัท เพื่อให้ระบบสามารถออกเลขเอกสารได้อย่างต่อเนื่องและไม่ซ้ำกันครับ'
}

Table cfg_system_configs {
  id Int [pk, increment, note: 'รหัสลำดับการตั้งค่า (รันอัตโนมัติ)']
  key String [unique, not null, note: 'ชื่อคีย์อ้างอิงของการตั้งค่า (ต้องไม่ซ้ำกัน) เพื่อให้โปรแกรมเมอร์ใช้ดึงค่าไปใช้ในโค้ด (เช่น MAINTENANCE_MODE, DEFAULT_LANGUAGE, SYSTEM_VERSION)']
  value String [not null, note: 'ค่าของการตั้งค่านั้นๆ (เก็บเป็นข้อความ String เสมอ แต่เวลานำไปใช้ในโค้ดอาจจะแปลงค่าเป็น Boolean, Integer, หรือ JSON ก็ได้ เช่น คีย์ MAINTENANCE_MODE มีค่าเป็น "true")']
  description String [note: 'คำอธิบายเพิ่มเติมว่าคีย์นี้ใช้ทำอะไร เพื่อให้ Admin คนอื่นที่เข้ามาดูแลระบบเข้าใจตรงกัน']

  Note: 'ใช้สำหรับเก็บตัวแปรการตั้งค่าของระบบที่ Super Admin หรือทีมนักพัฒนาต้องการปรับเปลี่ยนโดยไม่ต้องแก้โค้ดหรืออัปเดตระบบใหม่ '
}

Table com_templates {
  id Int [pk, increment]
  companyId Int [note: '1. เพิ่มฟิลด์ companyId และความสัมพันธ์']
  company org_companies
  shopId Int [note: '🏪 2. ระดับร้านค้า (Optional: ถ้าเป็น Null แสดงว่าเป็นเทมเพลตกลางของบริษัทนั้น)']
  shop com_shop_profiles
  code String [not null]
  channel String [not null]
  locale String [not null, default: 'th']
  subject String
  content String [not null]

  indexes {
    (companyId, code, channel, locale) [unique]
  }

  Note: 'ทำหน้าที่เป็นระบบจัดการ Template ข้อความ สำหรับการส่งการแจ้งเตือนหรือข้อความสื่อสารไปยังช่องทางต่างๆ (เช่น Email, SMS, หรือ LINE) เพื่อให้คุณสามารถแก้ไขข้อความได้โดยไม่ต้องแก้โค้ดโปรแกรม'
}

Table com_message_logs {
  id BigInt [pk, increment, note: 'รหัสลำดับหลักของ Log (Primary Key) ใช้ BigInt เพื่อรองรับปริมาณ Log จำนวนมากในระยะยาว']
  companyId Int [not null, note: 'รหัสอ้างอิงไปยังบริษัท (OrgCompany) ที่เป็นเจ้าของรายการส่งข้อความนี้']
  company org_companies [not null]
  channel String [not null, note: 'ช่องทางที่ใช้ส่ง เช่น EMAIL, SMS, LINE, FACEBOOK']
  recipient String [not null, note: 'ข้อมูลผู้รับ เช่น อีเมล เบอร์โทรศัพท์ หรือ LINE User ID']
  subject String [note: 'หัวข้อของข้อความ (ถ้ามี)']
  content String [note: 'เนื้อหาข้อความที่ส่งออกไปจริง (อาจเก็บเป็น HTML หรือ Text)']
  status String [not null, note: 'สถานะการส่งปัจจุบัน เช่น SENT, FAILED, PENDING, DELIVERED']
  apiResponse Json [note: 'ข้อมูลที่ตอบกลับมาจาก API ของผู้ให้บริการภายนอก (เช่น Response จาก LINE หรือ AWS SES)']
  errorMessage String [note: 'รายละเอียดข้อผิดพลาดในกรณีที่สถานะเป็น FAILED เพื่อใช้ในการวิเคราะห์ปัญหา']
  refType String [note: 'ระเภทของเอกสารหรือกิจกรรมที่เกี่ยวข้อง เช่น ORDER, INVOICE, OTP']
  refId String [note: 'รหัสอ้างอิงของเอกสารตาม refType เพื่อให้สามารถตรวจสอบย้อนกลับได้ง่าย']
  sentAt DateTime [default: `now()`, not null, note: 'วันและเวลาที่มีการบันทึกหรือส่งข้อความ (Default: ปัจจุบัน)']

  Note: 'ทำหน้าที่เป็นระบบเก็บ ประวัติการส่งข้อความ (Audit Log) ทั้งหมดของระบบ ไม่ว่าจะเป็นการส่งผ่าน Email, SMS, หรือ LINE เพื่อใช้ในการตรวจสอบสถานะการส่งย้อนหลังและวิเคราะห์ปัญหาเมื่อข้อความส่งไม่ถึงผู้รับ'
}

Table hr_employee_documents {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 เชื่อมกับบริษัท (Multi-tenancy)']
  company org_companies [not null]
  employeeId Int [not null, note: '👤 เชื่อมกับพนักงาน']
  employee hr_employees [not null]
  mediaId Int [unique, not null, note: '📁 เชื่อมกับไฟล์ใน DMS (SysMedia) ตั้งเป็น @unique เพื่อป้องกันการใช้ไฟล์ซ้ำในหลาย Record']
  media SysMedia [not null]
  docType String [not null, note: 'ประเภทเอกสาร (เช่น \'ID_CARD\', \'HOUSE_REGISTRATION\')']
  remark String
  createdAt DateTime [default: `now()`, not null]
}

Table hr_employees {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  employeeCode String [not null]
  employmentType String [default: 'FULL_TIME']
  title String
  firstName String [not null]
  lastName String [not null]
  nickName String
  birthDate DateTime
  phone String
  lineId String
  email String
  address String
  userId Int [unique]
  user sec_users
  profileImageUrl String
  joinDate DateTime [not null, note: 'วันเริ่มงาน (Start Date)']
  confirmDate DateTime [note: 'วันผ่านโปร (Probation Date)']
  resignDate DateTime [note: 'วันที่ลาออก (ถ้ามี)']
  serviceBaseDate DateTime [note: 'วันที่ใช้คำนวณอายุงานจริง (กรณี Re-hire)']
  status EmploymentStatus [not null, default: 'PROBATION', note: '2. สถานะการจ้างงาน']
  evaluationsAsManager hr_employee_evaluations [not null]
  previousEmployeeId Int [unique, note: '3. รองรับ Rehire (Self-relation)']
  previousEmployee hr_employees
  nextEmployee hr_employees
  hrDepartmentId Int [note: '4.1 แผนกที่สังกัดอยู่ (พนักงาน 1 คนสังกัด 1 แผนก)']
  department hr_departments
  managedDepartments hr_departments [not null, note: '4.2 แผนกที่คนนี้เป็น "หัวหน้า" (1 คนอาจคุมหลายแผนกได้)']
  deputyDepartments hr_departments [not null, note: '4.3 แผนกที่คนนี้เป็น "รองหัวหน้า"']
  managerId Int [note: '5. สายการบังคับบัญชา (Manager/Subordinates)']
  manager hr_employees
  subordinates hr_employees [not null]
  profileMediaId Int [unique, note: '✅ [NEW] เชื่อมกับ DMS สำหรับรูปโปรไฟล์']
  profileMedia SysMedia
  documents hr_employee_documents [not null, note: '✅ [NEW] เชื่อมกับเอกสารอื่นๆ ของพนักงาน (เช่น ทะเบียนบ้าน, วุฒิการศึกษา)']
  jobHistoriesAsManager hr_job_history [not null, note: '🌟 เพิ่มบรรทัดนี้ เพื่อเป็นฝั่งตรงข้ามของ HistoryManager']
  positionId Int [note: '6. ตำแหน่งและรูปแบบงาน']
  position hr_positions
  leaveRequests hr_leave_requests [not null, note: '1. ใบลาที่ตนเองเป็นคนเขียน (Owner)']
  approvedLeaves hr_leave_requests [not null, note: '2. ใบลาที่ตนเองเป็นผู้อนุมัติ (Approver) - ถ้ามีฟิลด์ approvedById ในใบลา']
  adjustedLeaves hr_leave_adjustments [not null, note: '3. รายการปรับปรุงยอดลาที่ตนเองเป็นคนกดทำรายการ (Admin/Manager)']
  seat hr_position_seats [note: '🌟 เพิ่มบรรทัดนี้ เพื่อบอกว่าพนักงานคนนี้ครอบครองเก้าอี้ (Seat) ตัวไหนอยู่']
  employeeEvaluation hr_employee_evaluations [not null]
  disciplinaryIncidents hr_disciplinary_incidents [not null]
  trainingEnrollments hr_training_enrollments [not null]
  decorations hr_employee_decorations [not null]
  meetingRequests adm_meeting_bookings [not null]
  meetingAttendances adm_meeting_attendees [not null]
  welfareRequests hr_welfare_requests [not null]
  salaryHistory hr_salary_adjustments [not null]
  payrollSlips hr_payroll_slips [not null]
  assignedAssets adm_assets [not null]
  assetRequests adm_asset_requests [not null]
  grievancesRequested hr_grievance_tickets [not null]
  grievancesAccused hr_grievance_tickets [not null]
  patternHistories hr_employee_patterns [not null]
  employeeInfo hr_employee_infos
  employmentPeriods hr_employment_periods [not null]
  jobHistory hr_job_history [not null]
  schedules hr_employee_schedules [not null]
  leaveBalances hr_leave_balances [not null]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, employeeCode) [unique]
  }

  Note: 'ข้อมูลพนักงาน'
}

Table hr_employee_infos {
  id Int [pk, increment]
  companyId Int [not null, note: '✅ เชื่อมกับบริษัทเพื่อความปลอดภัย (Multi-tenancy) [cite: 1, 98]']
  company org_companies [not null]
  employeeId Int [unique, not null, note: '✅ เชื่อมกับพนักงาน (1-to-1) [cite: 4]']
  employee hr_employees [not null]
  idCardNumber String [note: 'เลขบัตรประชาชน (PDPA Sensitive)']
  passportNo String [note: 'สำหรับพนักงานต่างชาติ']
  gender String
  birthDate DateTime
  bloodGroup String
  nationality String
  religion String
  mobilePhone String [note: 'ข้อมูลการติดต่อ']
  personalEmail String
  emergencyContactName String
  emergencyContactPhone String
  emergencyContactRelationship String [note: 'ความสัมพันธ์ผู้ติดต่อฉุกเฉิน']
  maritalStatus String [note: 'สถานภาพสมรส']
  militaryStatus String [note: 'สถานภาพทางทหาร']
  address String [note: 'ข้อมูลที่อยู่ (Address) ']
  subDistrict String
  district String
  province String
  zipCode String
  bankName String [note: 'ข้อมูลการเงิน']
  bankAccountNo String
  bankAccountName String
  metadata Json [note: '✅ ข้อมูลอื่นๆ ที่ยืดหยุ่น (ประวัติวัคซีน, ขนาดเสื้อ, ความสนใจ)']
  updatedAt DateTime [not null]

  Note: 'ข้อมูลส่วนตัวพนักงาน'
}

Table hr_employment_periods {
  id Int [pk, increment]
  employeeId Int [not null]
  employee hr_employees [not null]
  companyId Int [not null, note: '🏢 เพิ่มฟิลด์ companyId เพื่อรองรับ Multi-company']
  company org_companies [not null]
  startDate DateTime [not null, note: 'วันเริ่มงานของรอบนั้นๆ']
  endDate DateTime [note: 'วันสิ้นสุดงานของรอบนั้นๆ (NULL = ยังทำอยู่)']
  reason String [note: 'สาเหตุที่ออกในรอบนั้น']
  isDeductible Boolean [not null, default: true, note: 'true = ให้นับอายุงานช่วงนี้รวมด้วย']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'ตารางประวัติรอบการจ้างงาน (Employment Period / Rehire History)'
}

Table hr_departments {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null]
  name String [not null]
  description String
  parentId Int [note: '🌳 โครงสร้างต้นไม้ (แผนกหลัก/แผนกย่อย)']
  parent hr_departments
  children hr_departments [not null]
  sortOrder Int
  managerId Int
  deputyManagerId Int
  manager hr_employees
  deputyManager hr_employees
  jobHistory hr_job_history [not null]
  employees hr_employees [not null]
  allowedPositions hr_department_positions [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: 'แผนกในระบบ'
}

Table hr_positions {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null]
  name String [not null]
  level Int [not null, default: 1]
  description String
  jobHistory hr_job_history [not null]
  wfNodes wf_nodes [not null]
  employees hr_employees [not null]
  allowedInDepartments hr_department_positions [not null]
  departmentPositionVersion hr_department_position_versions [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: 'ตำแหน่งในระบบ'
}

Table hr_job_history {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  employeeId Int [not null]
  employee hr_employees [not null]
  departmentId Int [not null]
  department hr_departments [not null]
  positionId Int [not null]
  position hr_positions [not null]
  managerId Int
  manager hr_employees
  status JobHistoryStatus [not null, default: 'EFFECTIVE', note: '🌟 เพิ่มฟิลด์สถานะ (Default เป็น EFFECTIVE เพื่อไม่ให้กระทบของเดิม)']
  orgVersionId Int [note: '🌟 (Optional) เพิ่ม versionId เพื่ออ้างอิงว่าการวางแผนนี้อิงจากผังเวอร์ชันไหน']
  action String
  startDate DateTime [not null]
  endDate DateTime
  isPrimary Boolean [not null, default: false]
  remarks String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'การเก็บประวัติตามช่วงเวลา (Time-Travel History): ด้วยฟิลด์ startDate และ endDate ทำให้ HR สามารถย้อนดูได้ว่า เมื่อ 2 ปีที่แล้ว พนักงานคนนี้อยู่แผนกอะไร และใครเป็นหัวหน้า (managerId)'
}

Table hr_department_positions {
  id Int [pk, increment]
  companyId Int [not null]
  departmentId Int [not null]
  department hr_departments [not null]
  positionId Int [not null]
  position hr_positions [not null]
  maxHeadcount Int
  createdAt DateTime [default: `now()`, not null]

  indexes {
    (companyId, departmentId, positionId) [unique]
  }

  Note: 'ตารางกำหนดโครงสร้างตำแหน่งในแต่ละแผนก (Organization Chart Definition)'
}

Table wf_definitions {
  id Int [pk, increment, note: 'รหัสลำดับหลักของนิยาม Workflow (Primary Key) แบบรันอัตโนมัติ']
  companyId Int [not null, note: 'รหัสอ้างอิงไปยังบริษัท (OrgCompany) เพื่อระบุว่า Workflow นี้เป็นของบริษัทใด']
  company org_companies [not null]
  code String [not null, note: 'รหัสอ้างอิงของ Workflow เช่น PO_APPROVE, LEAVE_REQ เพื่อใช้ในการเรียกใช้งานผ่านโค้ด']
  name String [not null, note: 'ชื่อของกระบวนการ Workflow เช่น "อนุมัติใบสั่งซื้อ", "อนุมัติการลา"']
  defaultFolders doc_folders [not null]
  deleteFolders doc_folders [not null]
  description String [note: 'รายละเอียดหรือคำอธิบายเพิ่มเติมเกี่ยวกับกระบวนการนี้']
  isActive Boolean [not null, default: true, note: 'สถานะการใช้งาน (Default: true) หากเป็น false จะไม่สามารถสร้างรายการคำขอใหม่จาก Workflow นี้ได้']
  nodes wf_nodes [not null, note: '🔗 ความสัมพันธ์กับตารางอื่นๆ']
  requests wf_requests [not null]
  moduleMappings wf_module_mappings [not null]
  createdAt DateTime [default: `now()`, not null, note: '✨ เพิ่ม Timestamp เพื่อเก็บประวัติการสร้างและแก้ไข']
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: 'ตารางกำหนดนิยามและโครงสร้างหลักของกระบวนการทำงาน (Workflow) แยกตามบริษัท'
}

Table wf_nodes {
  id Int [pk, increment, note: 'รหัสลำดับหลักของโหนด (Primary Key) แบบรันอัตโนมัติ']
  workflowId Int [not null, note: 'รหัสอ้างอิงไปยังนิยาม Workflow หลัก (WfDefinition)']
  workflow wf_definitions [not null]
  nodeType WfNodeType [not null, default: 'APPROVAL', note: '✅ 2. เพิ่มประเภทโหนด']
  conditionLogic Json [note: '3. เพิ่มฟิลด์สำหรับเก็บเงื่อนไขทางแยก (เก็บเป็น JSON) ตัวอย่างค่า: { "field": "totalAmount", "operator": ">", "value": 10000, "trueNodeId": 5, "falseNodeId": 6 }']
  requireSignature Boolean [not null, default: false, note: '🌟 บังคับให้ผู้พิจารณาต้องแนบลายเซ็นดิจิทัล (Digital Signature) ก่อนกดอนุมัติ']
  nodeName String [not null, note: 'ชื่อเรียกของขั้นตอนนั้นๆ เช่น "หัวหน้าแผนกตรวจสอบ", "บัญชีอนุมัติ"']
  stepOrder Int [not null, note: 'ลำดับที่ของขั้นตอนใน Workflow เพื่อใช้จัดเรียงตามลำดับก่อน-หลัง']
  approverRoleId Int [note: 'รหัสบทบาท (SecRole) ของผู้มีสิทธิ์อนุมัติในขั้นตอนนี้ (ถ้ากำหนดตามบทบาท)']
  role sec_roles
  approverPositionId Int [note: 'รหัสตำแหน่งงาน (HrPosition) ของผู้มีสิทธิ์อนุมัติ (ถ้ากำหนดตามตำแหน่ง)']
  position hr_positions
  dynamicApprover String [note: 'สูตรหรือเงื่อนไขในการหาผู้อนุมัติแบบไดนามิก เช่น ดึงตามสายการบังคับบัญชา']
  notifyLine Boolean [not null, default: false, note: 'เปิดให้ยิงแจ้งเตือนเข้า LINE OA ทันทีที่งานมาถึงด่านนี้']
  notifyEmail Boolean [not null, default: false, note: 'เปิดให้ส่งอีเมลแจ้งเตือนไปยังผู้อนุมัติ']
  timeoutHours Int [note: 'จำนวนชั่วโมงที่รอก่อนจะ Auto Action (NULL = รอได้ตลอดไป)']
  timeoutAction String [note: 'สิ่งที่จะทำเมื่อหมดเวลา: "AUTO_APPROVE", "AUTO_REJECT", "SKIP"']
  voteRule VoteRule [not null, default: 'ANY_APPROVE', note: 'กฎการตัดสินใจ เช่น ANY_APPROVE, ALL_MUST_APPROVE หรือ CUSTOM_PERCENTAGE']
  voteThreshold Int [note: 'เปอร์เซ็นต์ที่ต้องการให้ผ่าน (เช่น 50, 75, 100) ใช้คู่กับ CUSTOM_PERCENTAGE']
  webhookUrl String [note: 'ใช้สำหรับยิง API ไปบอกระบบภายนอก หรือ Module อื่นเมื่อขั้นตอนนี้สำเร็จ']
  webhookPayload Json [note: 'โครงสร้างข้อมูล (Payload) ที่ต้องการส่งไป']
  nextApproveId Int [note: 'รหัสโหนดถัดไปในกรณีที่รายการนี้ได้รับ "การอนุมัติ"']
  nextRejectId Int [note: 'รหัสโหนดถัดไป (หรือย้อนกลับ) ในกรณีที่รายการนี้ถูก "ปฏิเสธ"']
  nextOnApprove wf_nodes
  nextOnReject wf_nodes
  prevApprove wf_nodes [not null]
  prevReject wf_nodes [not null]
  requests wf_requests [not null]

  Note: 'ตารางเก็บรายละเอียดขั้นตอนต่างๆ ในแต่ละกระบวนการ Workflow รวมถึงผู้มีอำนาจอนุมัติและเงื่อนไขการส่งต่อ'
}

Table wf_requests {
  id Int [pk, increment, note: 'รหัสลำดับหลักของรายการคำขอ (Primary Key) แบบรันอัตโนมัติ']
  companyId Int [not null, note: 'รหัสอ้างอิงไปยังบริษัท (OrgCompany) ที่เป็นเจ้าของรายการคำขอนี้']
  company org_companies [not null]
  workflowId Int [not null, note: 'รหัสอ้างอิงไปยังนิยาม Workflow (WfDefinition) ที่ใช้เป็นต้นแบบ']
  workflow wf_definitions [not null]
  currentNodeId Int [note: 'รหัสโหนดปัจจุบัน (WfNode) ที่รายการนี้กำลังค้างรอการพิจารณาอยู่']
  currentNode wf_nodes
  purchaseOrder pro_purchase_orders [note: '🚩 [เพิ่มใหม่] เชื่อมโยงกลับไปยังตารางสั่งซื้อสินค้า']
  businessId String [not null, note: 'รหัสอ้างอิงของข้อมูลทางธุรกิจต้นทาง (เช่น ID ของ Order หรือ ID ของใบลา)']
  businessType String [not null, note: 'ประเภทของข้อมูลธุรกิจต้นทาง เพื่อใช้จำแนกว่า businessId นั้นมาจากตารางใด']
  docAccessRequest doc_access_requests [note: '🌟 เพิ่ม Relation สำหรับคำขอสิทธิ์เข้าถึงข้อมูล']
  leaveRequest hr_leave_requests
  docFile doc_files
  signatureRequests doc_signature_requests [not null]
  topic String [note: 'หัวข้อเรื่อง หรือชื่อรายการคำขอ เพื่อให้ผู้ใช้งานเข้าใจเนื้อหาคร่าวๆ ได้ทันที']
  requesterId Int [not null, note: 'รหัสผู้ใช้งาน (SecUser) ที่เป็นผู้สร้างหรือส่งคำขอนี้เข้าสู่ระบบ']
  requester sec_users [not null]
  returnRequest com_return_requests
  status WorkflowStatus [not null, default: 'IN_PROGRESS', note: 'สถานะปัจจุบันของคำขอ เช่น IN_PROGRESS (กำลังดำเนินการ), APPROVED, REJECTED']
  data Json [note: 'ข้อมูลเพิ่มเติมในรูปแบบ JSON ที่เกี่ยวข้องกับคำขอนั้นๆ']
  orgStructureVersion hr_org_structure_versions [note: '🔗 เพิ่มส่วนนี้เพื่อเชื่อมโยงกลับไปยังตารางใหม่']
  manpowerRequest HrManpowerRequest
  crmRedemption crm_redemptions [note: '🚩 [เพิ่มใหม่] เชื่อมโยงกลับไปยังตารางใบแลกของรางวัล']
  currentStepEnteredAt DateTime [note: 'เวลาที่เอกสารวิ่งเข้ามาถึงโหนดปัจจุบัน']
  currentStepTimeoutAt DateTime [note: 'เวลาที่จะครบกำหนด Timeout (คำนวณจากตอนเข้าโหนด + timeoutHours) เพื่อให้ Cron Job หรือ Worker มาเช็คและ Auto-Action ได้ง่ายๆ']
  currentApproverIds Int[] [not null, note: 'จะทำให้การดึงข้อมูลหน้า Dashboard แอดมินรวดเร็วมาก (WHERE myId IN currentApproverIds)']
  disciplinaryIncident hr_disciplinary_incidents
  trainingSession hr_training_sessions
  meetingBooking adm_meeting_bookings
  welfareRequest hr_welfare_requests
  salaryAdjustment hr_salary_adjustments
  payrollCycle hr_payroll_cycles
  assetRequest adm_asset_requests
  grievanceTicket hr_grievance_tickets
  actions wf_actions [not null]
  orderItem com_order_items [note: 'เป็น Optional เพราะไม่ใช่ทุก Workflow จะมาจาก OrderItem']
  createdAt DateTime [default: `now()`, not null, note: 'วันและเวลาที่สร้างคำขอ']
  updatedAt DateTime [not null, note: 'วันและเวลาที่มีการปรับปรุงข้อมูลล่าสุด (เช่น เมื่อมีการเปลี่ยนสถานะหรือเปลี่ยนโหนด)']

  Note: 'ตารางเก็บบันทึกรายการคำขออนุมัติและสถานะการดำเนินการในกระบวนการ Workflow'
}

Table wf_actions {
  id Int [pk, increment, note: 'รหัสลำดับหลักของรายการบันทึก (Primary Key) แบบรันอัตโนมัติ']
  requestId Int [not null, note: 'รหัสอ้างอิงไปยังรายการคำขอหลัก (WfRequest) ที่มีการดำเนินการ']
  request wf_requests [not null]
  actorId Int [not null, note: 'รหัสผู้ใช้งาน (SecUser) ที่เป็นผู้กดดำเนินการในขั้นตอนนี้จริง']
  actor sec_users [not null]
  ipAddress String [note: '🌟 เก็บ IP และอุปกรณ์ที่กดอนุมัติ (Audit Trail สำหรับ Enterprise)']
  userAgent String
  isSystemAction Boolean [not null, default: false, note: '🌟 [เพิ่มใหม่] เพื่อระบุว่า Action นี้ทำโดยระบบอัตโนมัติ (เช่น Timeout Auto-Approve) หรือไม่']
  onBehalfOfId Int [note: 'รหัสผู้ใช้งานที่ถูกมอบอำนาจให้ทำแทน (ในกรณีที่มีการตั้งค่า Delegate/Acting แทนกัน)']
  stepName String [not null, note: 'ชื่อขั้นตอนในขณะที่กดดำเนินการ (คัดลอกมาจาก nodeName ของ WfNode ณ ขณะนั้น)']
  action String [not null, note: 'ประเภทการตัดสินใจ เช่น APPROVE, REJECT, SEND_BACK, หรือ CANCEL']
  isAdhoc Boolean [not null, default: false, note: 'ระบุว่าเป็นงานที่ถูกเชิญเข้ามาชั่วคราว (ไม่ได้อยู่ใน Flow ปกติ)']
  invitedById Int [note: 'รหัสคนที่กดเชิญเข้ามา (เพื่อให้รู้ว่าใครเป็นคนลากคนนอกเข้ามา)']
  invitedBy sec_users
  comment String [note: 'หมายเหตุหรือเหตุผลประกอบการตัดสินใจจากผู้ดำเนินการ']
  createdAt DateTime [default: `now()`, not null, note: 'วันและเวลาที่เกิดกิจกรรมการตัดสินใจนี้ขึ้น (Default: ปัจจุบัน)']

  Note: 'ตารางเก็บประวัติการดำเนินการ (Audit Trail) ในแต่ละขั้นตอนของรายการคำขออนุมัติ'
}

Table log_audits {
  id BigInt [pk, increment, note: 'รหัสลำ���ับหลักของ Log (Primary Key) ใช้ BigInt เพื่อรองรับปริมาณบันทึกมหาศาล']
  companyId Int [not null, note: 'รหัสอ้างอิงไปยังบริษัท (OrgCompany) เพื่อแยกประวัติการตรวจสอบตามองค์กร']
  company org_companies [not null]
  action String [not null, note: 'ประเภทของกิจกรรมที่เกิดขึ้น เช่น CREATE, UPDATE, DELETE']
  tableName String [not null, note: 'ชื่อตารางในฐานข้อมูลที่มีการเปลี่ยนแปลงข้อมูล']
  recordId String [not null, note: 'รหัส Primary Key ของข้อมูลในตารางนั้นๆ ที่ถูกกระทำ']
  userId Int [note: 'รหัสผู้ใช้งาน (SecUser) ที่เป็นคนกระทำการ (เป็น Null ได้หากเกิดจากระบบอัตโนมัติ)']
  user sec_users
  oldValues Json [note: 'ข้อมูลเดิมก่อนการเปลี่ยนแปลง (มักใช้ในกรณี Update หรือ Delete)']
  newValues Json [note: 'ข้อมูลใหม่หลังการเปลี่ยนแปลง (มักใช้ในกรณี Create หรือ Update)']
  ipAddress String [note: 'หมายเลข IP Address ของเครื่องที่ส่งคำขอเข้ามา']
  userAgent String [note: 'ข้อมูลเบราว์เซอร์หรืออุปกรณ์ที่ใช้ในการทำรายการ']
  createdAt DateTime [default: `now()`, not null, note: 'วันและเวลาที่เกิดเหตุการณ์บันทึกนี้ (Default: ปัจจุบัน)']

  Note: 'ตารางเก็บบันทึกประวัติการเปลี่ยนแปลงข้อมูลทุกเหตุการณ์ (Insert, Update, Delete) แยกตามบริษัทและผู้ใช้งาน'
}

Table crm_members {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 เปลี่ยนเป็น Int (ห้ามเป็น Null) เพื่อล็อกว่า SME เจ้าไหนเป็นเจ้าของข้อมูล']
  company org_companies [not null]
  memberCode String [not null, note: '🆔 Identity (ล็อก 1 บริษัท มี 1 เบอร์/LineID เท่านั้น)']
  lineUserId String
  lineName String
  linePicture String
  idCardNumber String
  phone String
  email String
  firstName String
  lastName String
  profileMediaId Int
  profileMedia SysMedia
  thaiId String
  isMarketingConsent Boolean [not null, default: true, note: 'consentimiento (PDPA)']
  addresses crm_addresses [not null, note: '🔗 Relations']
  shopMemberships crm_member_shops [not null, note: '🌟 เชื่อมไปยังตารางสมาชิกรายร้าน']
  pointLogs crm_point_logs [not null, note: 'ประวัติส่วนกลาง (ถ้าบอสต้องการเก็บแยกรายบริษัท)']
  notifications sys_notifications [not null]
  redemptions crm_redemptions [not null]
  orders com_orders [not null]
  returnRequests com_return_requests [not null]
  wishlists com_wishlists [not null]
  productReview com_product_reviews [not null]
  carts com_carts [not null]
  referralsMade crm_referrals [not null]
  referredBy crm_referrals
  commissionLogs crm_commission_logs [not null]
  commissionBalance Decimal [not null, default: 0]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, phone) [unique]
    (companyId, lineUserId) [unique]
  }

  Note: 'ตารางหลักที่ใช้เก็บข้อมูล "ลูกค้าหรือสมาชิก" ในระบบ CRM ของคุณ โดยมีการออกแบบให้รองรับการเชื่อมต่อกับ LINE OA และการปฏิบัติตามกฎหมายคุ้มครองข้อมูลส่วนบุคคล (PDPA) ไว้อย่างชัดเจนครับ'
}

Table crm_member_shops {
  id Int [pk, increment]
  companyId Int [not null, note: '🔒 Double-Locking']
  memberId Int [not null]
  shopId Int [not null]
  company org_companies [not null, note: '🏢 ความสัมพันธ์']
  member crm_members [not null]
  shop com_shop_profiles [not null]
  pointBalance Int [not null, default: 0, note: '🎁 ข้อมูลที่บอสอยากให้แยกตามร้าน']
  memberLevelCode String [not null, default: 'NORMAL']
  isActive Boolean [not null, default: true]
  joinedAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (memberId, shopId) [unique]
  }

  Note: 'ตารางเก็บสมาชิกของแต่ละร้าน'
}

Table crm_addresses {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 เพิ่มเพื่อให้รองรับ Multi-company แบบ 100%']
  company org_companies [not null]
  memberId Int [not null]
  member crm_members [not null]
  type String [not null]
  address String [not null]
  province String
  zipcode String
  isDefault Boolean [not null, default: false]
  createdAt DateTime [default: `now()`, not null]

  Note: 'ตาราง CrmAddress คือตารางที่ใช้สำหรับเก็บข้อมูล "ที่อยู่จัดส่งสินค้าหรือที่อยู่สำหรับออกใบเสร็จ" ของสมาชิก โดยออกแบบมาให้ลูกค้านึงคนสามารถมีได้หลายที่อยู่'
}

Table com_warehouses {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  shopId Int [note: '(Optional) ถ้าระบุ shopId หมายถึงเป็น "คลังย่อยประจำหน้าร้านนั้นๆ" ถ้า Null หมายถึงเป็นคลังกลาง']
  shop com_shop_profiles
  code String [not null, note: 'รหัสคลัง เช่น WH-CENTER, WH-BKK']
  name String [not null, note: 'ชื่อคลัง เช่น "คลังสินค้ากลางปทุมธานี"']
  type WarehouseType [not null, default: 'CENTRAL']
  address String
  isDefault Boolean [not null, default: false]
  isActive Boolean [not null, default: true]
  documents com_warehouse_documents [not null, note: '📁 เอกสารคลังสินค้า']
  stocks com_warehouse_stocks [not null, note: 'ความสัมพันธ์']
  stockLogs com_stock_logs [not null]
  transferLogs com_stock_logs [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: 'ตารางจัดการคลังสินค้า (รองรับคลังกลางและคลังสาขา)'
}

Table com_warehouse_stocks {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  warehouseId Int [not null]
  warehouse com_warehouses [not null]
  productId Int [not null]
  product com_products [not null]
  qty Int [not null, default: 0, note: 'ยอดคงเหลือของสินค้านี้ "ในคลังนี้"']
  updatedAt DateTime [not null]

  indexes {
    (warehouseId, productId) [unique]
  }

  Note: 'ตารางเก็บยอดสินค้าคงเหลือ "แยกตามคลัง"'
}

Table com_products {
  id Int [pk, increment, note: 'รหัสลำดับภายในระบบ ใช้เป็น Primary Key']
  companyId Int [not null, note: 'รหัสบริษัทที่เจ้าของสินค้านี้ เพื่อแยกข้อมูลตามลูกค้าแต่ละเจ้า']
  company org_companies [not null]
  sku String [not null, note: 'รหัสสินค้า (Stock Keeping Unit) ที่ผู้ใช้กำหนด ต้องไม่ซ้ำกันภายในบริษัทเดียวกัน']
  name String [not null, note: 'ชื่อสินค้า']
  description String [note: 'รายละเอียดเชิงลึก']
  status ProductStatus [not null, default: 'DRAFT', note: 'สถานะการดำเนินงานของสินค้า (เช่น DRAFT, PUBLISHED, ARCHIVED)']
  createdById Int [note: 'รหัสผู้ใช้งานที่เป็นคนสร้างสินค้าตัวนี้']
  createdBy sec_users
  productType ProductType [not null, default: 'PHYSICAL']
  isCancellable Boolean [not null, default: true, note: 'กำหนดว่าสินค้านี้อนุญาตให้ลูกค้ายกเลิกคำสั่งซื้อได้หรือไม่']
  price Decimal [not null, note: 'ราคาขายตั้งต้นหรือราคาขายปลีก']
  minTierPrice Decimal [note: 'ราคาสินค้าที่ต่ำที่สุดที่เป็นไปได้เมื่อซื้อตามจำนวนที่กำหนด']
  warehouseStocks com_warehouse_stocks [not null]
  marketplaceMappings int_product_mappings [not null]
  unitId Int
  unit cfg_master_data
  brand String [note: 'ตราสินค้า']
  slug String [unique, note: 'ที่อยู่ URL สำหรับหน้ารายละเอียดสินค้า (SEO Friendly)']
  defaultSupplierId Int [note: '✅ เพิ่ม: Supplier ขาประจำ (Default)']
  defaultSupplier pro_suppliers
  salesType ProductSalesType [not null, default: 'BOTH', note: '✅ เพิ่ม: ประเภทการขาย']
  weight Decimal [note: 'น้ำหนักสินค้า (กิโลกรัม) สำหรับคำนวณค่าส่ง']
  width Decimal [note: 'กว้าง (cm)']
  length Decimal [note: 'ยาว (cm)']
  height Decimal [note: 'สูง (cm)']
  boxSizeId Int [note: '✅ เพิ่มบรรทัดนี้: เชื่อมโยงกับขนาดกล่องมาตรฐาน']
  boxSize cfg_master_data
  ratingAvg Decimal [not null, default: 0, note: 'ค่าเฉลี่ยคะแนน']
  reviewCount Int [not null, default: 0, note: 'จำนวนรีวิวสะสม']
  reviews com_product_reviews [not null, note: 'การรีวิว ']
  usageTags String[] [not null, note: 'ป้ายกำกับวิธีการใช้งาน(เก็บแบบ Array) เพื่อให้ AI ช่วยจัดกลุ่ม เช่น ["ต้ม", "ทอด", "เข้าไมโครเวฟได้"]']
  materialTags String[] [not null, note: 'วัสดุ (เก็บแบบ Array) เพื่อให้ AI ช่วยจัดกลุ่ม']
  rptPerformance rpt_product_performance [not null]
  carts com_carts [not null]
  featuredImageUrl String [note: '✅ 4. เพิ่มรูปปก (Cache) เพื่อความไวในการโหลดหน้า List']
  exchangeTargetItems com_return_items [not null, note: '✅ เพิ่มบรรทัดนี้ครับ: บอกว่าสินค้านี้ เคยถูกเลือกเป็น "เป้าหมายการเปลี่ยนสินค้า" (Exchange Target) ในใบเคลมไหนบ้าง']
  wishlists com_wishlists [not null]
  stockQty Int [not null, default: 0, note: 'จำนวนสินค้าคงเหลือปัจจุบัน']
  costPrice Decimal [not null, default: 0]
  isPreOrder Boolean [not null, default: false, note: 'ระบุว่าเป็นสินค้าสั่งซื้อล่วงหน้าหรือไม่']
  daysToShip Int [not null, default: 2, note: 'ระยะเวลาที่ใช้ในการเตรียมจัดส่ง (หน่วยเป็นวัน)']
  tierPrices com_product_price_sets [not null, note: '✅ เพิ่ม: ความสัมพันธ์ไปหาตารางช่วงราคา']
  stockLogs com_stock_logs [not null]
  purchaseItems pro_purchase_items [not null]
  images com_product_images [not null, note: '✅ เพิ่มใหม่: ความสัมพันธ์กับรูปภาพ']
  parentId Int [note: 'เก็บ ID ของตัวแม่ (ถ้าเป็น NULL = เป็นแม่เอง หรือสินค้าเดี่ยว)']
  parent com_products
  variants com_products [not null, note: 'ลิสต์ลูกๆ ของตัวนี้']
  variantAttributes Json [note: 'ข้อมูลคุณสมบัติแยกย่อย เก็บเป็น JSON เช่น { "Color": "Red", "Size": "L" }']
  variantImages com_product_images [not null, note: '(ถ้าอยากทำ Relation กับรูปภาพแบบ Official ให้เพิ่มบรรทัดนี้ด้วย)']
  visibilityCode String [not null, default: 'PUBLIC', note: 'ระดับการมองเห็นสินค้า (ผูกกับรหัส Master Data: PRODUCT_VISIBILITY)']
  categoryId Int [note: '✅ 1. ความสัมพันธ์ไปยังตารางหมวดหมู่หลัก (Optional - ไม่บังคับเลือก)']
  category cfg_master_data
  tags String[] [not null, note: '✅ 2. ป้ายกำกับทั่วไป (เก็บแบบ Array) ให้ผู้ใช้พิมพ์จัดกลุ่มเองได้อิสระ เช่น ["ขายดี", "โปรปีใหม่"]']
  isActive Boolean [not null, default: true, note: 'สวิตช์เปิด/ปิดการใช้งานทั่วไป']
  orderItems com_order_items [not null]
  shopProducts com_shop_products [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, sku) [unique]
  }

  Note: 'เก็บข้อมูลพื้นฐานของสินค้าทั้งหมดในระบบ รองรับระบบหลายบริษัท (Multi-tenancy)'
}

Table com_carts {
  id Int [pk, increment]
  memberId Int [not null, note: 'ใครเป็นเจ้าของตะกร้า (ผูกกับสมาชิก)']
  member crm_members [not null]
  companyId Int [not null, note: 'สินค้าจากร้านไหน']
  company org_companies [not null]
  shopId Int
  shop com_shop_profiles
  productId Int [not null, note: 'สินค้าตัวไหน']
  product com_products [not null]
  quantity Int [not null, default: 1]
  priceAtAdd Decimal [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'ตะกร้าสั่งสินค้า'
}

Table com_order_discounts {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 เพิ่มเพื่อความเป็น Multi-company']
  company org_companies [not null]
  orderId Int [not null]
  order com_orders [not null]
  discountId Int [not null]
  discount com_discounts [not null]
  discountAmount Decimal [not null]
  createdAt DateTime [default: `now()`, not null]

  Note: 'สร้างตารางเก็บประวัติการใช้โค้ดหลายอันต่อ 1 ออเดอร์'
}

Table com_product_images {
  id Int [pk, increment, note: 'รหัสรูปภาพสินค้า (รันอัตโนมัติ)']
  companyId Int [not null]
  company org_companies [not null]
  productId Int [not null, note: 'เชื่อมโยงว่ารูปนี้เป็นของสินค้าชิ้นไหน หากลบสินค้า รูปภาพที่เกี่ยวข้องจะถูกลบออกไปด้วย']
  product com_products [not null]
  mediaType MediaType [not null, default: 'IMAGE', note: 'เพื่อระบุว่าเป็นรูปหรือวิดีโอ']
  source ImageSource [not null, default: 'GOOGLE_CLOUD', note: 'แหล่งที่เก็บไฟล์ เช่น GOOGLE_CLOUD (ค่าเริ่มต้น), GOOGLE_DRIVE, หรือ LOCAL']
  generationType ImageGenerationType [not null, default: 'ORIGINAL', note: 'ระบุว่ารูปนี้เป็นเวอร์ชันไหน เช่น รูปต้นฉบับ (ORIGINAL) หรือรูปที่ผ่านการแต่งเพิ่ม']
  parentId Int [note: 'เป็นระบบ Self-relation (ความสัมพันธ์ในตารางตัวเอง) เพื่อเก็บประวัติว่ารูปนี้ถูกแก้ไขมาจากรูปไหน ช่วยให้สามารถทำระบบ Undo หรือดูประวัติการเปลี่ยนแปลงรูปภาพได้']
  parent com_product_images
  children com_product_images [not null]
  url String [not null, note: 'ที่อยู่เต็มของไฟล์สำหรับเรียกใช้งาน']
  variantId Int [note: '(Option) เชื่อมรูปภาพเข้ากับ รุ่นย่อยของสินค้า (Variant) เช่น รูปนี้สำหรับเสื้อสีแดงเท่านั้น']
  variant com_products
  displayName String [note: 'ชื่อสำหรับแสดงผล (ตั้งเองได้)']
  fileId String [note: 'ไอดีเฉพาะของไฟล์จากระบบจัดเก็บ (เช่น ID จาก Google Drive)']
  colorCode String [note: 'เก็บค่าสีประจำรูปภาพ สำหรับใช้แสดงผลปุ่มเลือกสี (Color Swatches)']
  sortOrder Int [not null, default: 0, note: 'เพื่อให้คุณจัดเรียงได้ว่าอยากให้วิดีโอขึ้นก่อนหรือหลังรูป']
  fileName String [note: 'ชื่อไฟล์เดิมเพื่อใช้อ้างอิง']
  isMain Boolean [not null, default: false, note: 'กำหนดว่าเป็นรูปภาพหลักที่จะโชว์ในหน้าแรกของสินค้าหรือไม่ (Default เป็น false)']
  fileSize BigInt [note: 'ขนาดของไฟล์ข้อมูล']
  aiStatus AiProcessStatus [note: 'สถานะการประมวลผลของ AI (เช่น PENDING, PROCESSING, SUCCESS)']
  aiError String [note: 'บันทึกข้อความ Error หาก AI ประมวลผลรูปภาพนี้ไม่สำเร็จ']
  aiLastRunAt DateTime [note: 'บันทึกเวลาล่าสุดที่ AI ทำงานกับรูปนี้ เพื่อตรวจสอบว่าข้อมูลยังเป็นปัจจุบันหรือไม่']
  checksum String [note: 'เก็บค่า MD5 Hash ของไฟล์รูปภาพ เพื่อใช้ตรวจสอบรูปซ้ำ (ลดการเรียก AI ซ้ำซ้อนและประหยัด Quota)']
  tags com_tags [not null]

  Note: 'Table ComProductImage คือตารางสำหรับเก็บข้อมูล รูปภาพและวิดีโอของสินค้า ในระบบของคุณ โดยมีการออกแบบให้รองรับทั้งการจัดการไฟล์ทั่วไป การทำประวัติรูปภาพ (Version Control) และการประมวลผลด้วย AI ครับ'
}

Table int_ai_batch_jobs {
  id Int [pk, increment, note: 'รหัสลำดับคิวงาน (รันอัตโนมัติ)']
  companyId Int [not null, note: 'รหัสบริษัทที่เป็นเจ้าของคิวงานนี้ (เพื่อแยกบิ���ค่าใช้จ่าย AI และความปลอดภัยของข้อมูล)']
  company org_companies [not null, note: 'ข้อมูลบริษัทที่เกี่ยวข้อง (ลบอัตโนมัติหากบริษัทถูกลบ)']
  jobType String [not null, default: 'IMAGE_TAGGING', note: 'ประเภทของงานที่สั่งให้ AI ทำ เช่น IMAGE_TAGGING (แท็กรูปภาพอัตโนมัติ), TEXT_SUMMARY (สรุปข้อความ), DATA_EXTRACTION (ดึงข้อมูลจากไฟล์เอกสาร)']
  status WorkflowStatus [not null, default: 'IN_PROGRESS', note: 'สถานะปัจจุบันของงาน (อ้างอิงจาก Enum WorkflowStatus) เช่น IN_PROGRESS (กำลังทำงาน), COMPLETED (เสร็จสมบูรณ์), FAILED (ล้มเหลว)']
  totalItems Int [not null, default: 0, note: 'จำนวนชิ้นงานทั้งหมดที่ต้องประมวลผลในรอบนี้ (เช่น อัปโหลดรูปมา 500 รูป)']
  processedItems Int [not null, default: 0, note: 'จำนวนชิ้นงานที่ AI ประมวลผลเสร็จแล้ว (ใช้คำนวณ Progress Bar หน้าบ้าน เช่น 250/500 = 50%)']
  failedItems Int [not null, default: 0, note: 'จำนวนชิ้นงานที่ประมวลผลไม่สำเร็จ (เช่น รูปเสีย, ไฟล์ใหญ่เกิน, หรือ AI Error)']
  payload Json [note: '✅ ข้อมูลรายละเอียดของงาน (เช่น [fileId1, fileId2] หรือ params ต่างๆ)']
  errorSummary String [note: 'สรุปสาเหตุของปัญหาภาพรวม กรณีที่มีรายการที่พัง เพื่อให้ Admin เข้ามาดู log ได้']
  startedAt DateTime [default: `now()`, not null, note: 'วันและเวลาที่เริ่มรันคิวงานนี้']
  completedAt DateTime [note: 'วันและเวลาที่งานนี้ประมวลผลเสร็จสิ้น (รวมถึงกรณีที่ล้มเหลวด้วย)']

  Note: 'ตารางนี้ใช้สำหรับบันทึกสถานะและความคืบหน้าของงานที่ต้องให้ AI ประมวลผลทีละมากๆ เพื่อให้ผู้ใช้งานสามารถกดสั่งงานทิ้งไว้ แล้วค่อยกลับมาดูผลลัพธ์ทีหลังได้ (Asynchronous Processing)'
}

Table sys_ai_model_configs {
  id Int [pk, increment, note: 'รหัสลำดับการตั้งค่า (รันอัตโนมัติ)']
  companyId Int [note: 'ส่วนเชื่อมโยงบริษัท (ตัวแทน)- ถ้าเป็น NULL: หมายถึง "ราคากลางของ KKV" ที่ใช้กับลูกค้าทั่วไปทุกคน - ถ้าระบุ ID: หมายถึง "ราคาที่ตัวแทนตั้งเอง" เพื่อใช้กับลูกค้าภายใต้เครือข่ายของเขา']
  company org_companies [note: 'ข้อมูลบริษัทที่เกี่ยวข้อง (ลบอัตโนมัติหากบริษัทถูกลบ)']
  provider String [not null, note: 'ชื่อค่ายผู้ให้บริการ AI เช่น GOOGLE, OPENAI, ANTHROPIC']
  modelCode String [not null, note: 'รหัสรุ่นโมเดลที่ใช้ยิง API จริง เช่น gemini-1.5-flash, gpt-4o']
  modelName String [not null, note: 'ชื่อโมเดลสำหรับแสดงผลให้ลูกค้าเห็นในหน้าจอ เช่น "Gemini 1.5 Flash (ทำงานไว ราคาประหยัด)"']
  creditPer1kTokens Float [not null, default: 1, note: 'อัตราการหักเครดิตพื้นฐาน (Base Cost) ต่อการใช้ 1,000 โทเคน (Tokens) เช่น ตั้งไว้ 1.0 แปลว่าทุกๆ 1,000 โทเคน จะหักเงิน 1 เครดิต']
  markupMultiplier Float [not null, default: 1, note: 'ตัวคูณเพื่อทำกำไร (Profit Margin) เช่น เรทตั้งต้น 1.0 แต่ตัวแทนจำหน่ายตั้ง Multiplier เป็น 1.5 ลูกค้าของตัวแทนคนนี้จะถูกหักเครดิตแพงขึ้น 50% (ส่วนต่างคือกำไรของตัวแทน)']
  maxContextTokens Int [default: 128000, note: 'ความจุสมองของ AI ใน 1 รอบการสนทนา (Context Window) เช่น 128000 โทเคน (ช่วยให้หน้าบ้านสามารถแจ้งเตือนลูกค้าได้ว่าส่งไฟล์ใหญ่เกินไปไหม)']
  isVisionSupported Boolean [not null, default: false, note: 'ระบุว่าโมเดลนี้ "ตาบอด" หรือไม่ (ถ้าเป็น True คือส่งรูปภาพให้ AI ดูวิเคราะห์ได้)']
  isActive Boolean [not null, default: true, note: 'สถานะเปิด/ปิดการให้บริการโมเดลนี้']
  createdAt DateTime [default: `now()`, not null, note: 'เวลาที่สร้าง']
  updatedAt DateTime [not null, note: 'เวลาที่แก้ไข']

  indexes {
    (companyId, modelCode) [unique]
  }

  Note: 'ตารางนี้ใช้สำหรับจัดการรายชื่อโมเดล AI ที่ระบบรองรับ (เช่น GPT-4o, Gemini 1.5 Pro) รวมถึงการกำหนด "เรทราคา" ในการตัดเครดิตผู้ใช้งาน โดยรองรับทั้งราคากลางของระบบ และราคาที่ตัวแทนจำหน่ายตั้งเองเพื่อบวกกำไร'
}

Table com_tags {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 เพิ่มเพื่อให้ Tag เป็นของใครของมัน']
  company org_companies [not null]
  name String [not null, note: '🚩 เอา @unique ออกจากตรงนี้']
  images com_product_images [not null]

  indexes {
    (companyId, name) [unique]
  }

  Note: 'ตาราง ComTag เป็นตารางที่ใช้สำหรับเก็บข้อมูล "ป้ายกำกับ" (Tags) เพื่อใช้ในการจำแนกคุณลักษณะของรูปภาพสินค้า โดยทำงานร่วมกับตาราง ComProductImage แบบ Many-to-Many'
}

Table com_product_price_sets {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 เพิ่มเพื่อความเป็น Multi-company']
  company org_companies [not null]
  productId Int [not null]
  product com_products [not null]
  effectiveFrom DateTime [not null]
  effectiveTo DateTime
  note String
  isActive Boolean [not null, default: true]
  tiers com_product_tier_prices [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'ตารางสำหรับจัดการ "ชุดโครงสร้างราคา" ของสินค้า ซึ่งถูกออกแบบมาให้รองรับการวางแผนราคาล่วงหน้า (Price Scheduling) และการทำโปรโมชั่นตามช่วงเวลาครับ'
}

Table com_product_tier_prices {
  id Int [pk, increment]
  companyId Int [not null, note: 'แต่แนะนำให้ใส่ครับ เพื่อให้ทุก Query ในระบบใช้ Standard เดียวกันหมด']
  priceSetId Int [not null]
  priceSet com_product_price_sets [not null]
  minQty Int [not null]
  maxQty Int
  unitPrice Decimal [not null]

  Note: 'ตาราง ComProductTierPrice คือตารางที่เก็บ "ตัวเลขราคาจริง" โดยแบ่งตามระดับจำนวนสั่งซื้อ (Tiers) ซึ่งจะทำงานสัมพันธ์โดยตรงกับตาราง ComProductPriceSet'
}

Table com_discounts {
  id Int [pk, increment, note: 'รหัสหลักของส่วนลด']
  companyId Int [not null, note: 'เชื่อมโยงกับบริษัทเจ้าของส่วนลด']
  company org_companies [not null]
  shopId Int [note: '🏪 1. เพิ่มฟิลด์ Shop ID (ถ้า Null = ใช้ได้ทุกร้านในเครือ)']
  shop com_shop_profiles
  code String [not null, note: 'รหัสคูปอง (เช่น NEWYEAR2026) โดยมีการตั้งค่า @unique ร่วมกับ companyId เพื่อไม่ให้รหัสซ้ำกันภายในบริษัทเดียวกัน']
  description String [note: 'คำอธิบายสั้นๆ ของโปรโมชั่น']
  discountType String [not null, default: 'FIXED', note: 'ประเภทของส่วนลด เช่น FIXED (ลดเป็นจำนวนเงิน) หรือ PERCENTAGE (ลดเป็นเปอร์เซ็นต์)']
  discountValue Float [not null, default: 0, note: 'มูลค่าของส่วนลด']
  minPurchaseAmount Float [not null, default: 0, note: 'ยอดซื้อขั้นต่ำที่จะสามารถใช้ส่วนลดนี้ได้']
  maxDiscountAmount Float [note: 'จำนวนเงินส่วนลดสูงสุด (ใช้บ่อยในกรณีลดเป็น % เพื่อจำกัดเพดานส่วนลด)']
  isFreeShipping Boolean [not null, default: false, note: 'กำหนดว่าเป็นส่วนลดประเภท "ส่งฟรี" หรือไม่']
  appliesTo String [not null, default: 'ALL', note: 'ขอบเขตการใช้งาน เช่น ALL (ทั้งร้าน), CATEGORY (เฉพาะหมวดหมู่), หรือ PRODUCT (เฉพาะสินค้าบางรายการ)']
  targetIds Json [note: 'เก็บลิสต์ ID ของหมวดหมู่หรือสินค้าที่ระบุไว้ใน appliesTo ในรูปแบบ JSON']
  maxUsageTotal Int [note: 'จำนวนสิทธิ์ทั้งหมดที่ใช้ได้ (เช่น 100 สิทธิ์แรก)']
  usedCount Int [not null, default: 0, note: 'จำนวนที่มีการใช้ไปแล้วจริง']
  maxUsagePerUser Int [not null, default: 1, note: 'จำกัดจำนวนครั้งที่ลูกค้า 1 คนจะใช้รหัสนี้ได้']
  documents ecom_promotion_documents [not null, note: 'เชื่อม dms']
  startDate DateTime [note: 'ช่วงวันที่โค้ดนี้']
  endDate DateTime [note: 'หมดอายุ']
  isActive Boolean [not null, default: true, note: 'การเปิด-ปิดการใช้งานด้วยตัวเอง']
  orders com_orders [not null]
  orderDiscount com_order_discounts [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, shopId, code) [unique]
  }

  Note: 'ตารางหลักที่ใช้สำหรับจัดการ "คูปองส่วนลด" หรือ "โปรโมชั่น" ของบริษัท โดยถูกออกแบบมาให้มีความยืดหยุ่นสูง รองรับทั้งส่วนลดแบบจำนวนเงิน เปอร์เซ็นต์ และการส่งฟรี'
}

Table com_shipping_methods {
  id Int [pk, increment, note: 'รหัสลำดับภายในของวิธีการจัดส่ง (Primary Key)']
  companyId Int [not null, note: 'รหัสอ้างอิงบริษัทเจ้าของวิธีการจัดส่ง เพื่อรองรับระบบ Multi-tenancy']
  company org_companies [not null]
  name String [not null, note: 'ชื่อเรียกวิธีการจัดส่งที่จะแสดงให้ลูกค้าเห็น เช่น "Standard Delivery", "EMS", "ส่งด่วนภายในวัน"']
  description String [note: 'รายละเอียดเพิ่มเติมหรือเงื่อนไขเบื้องต้นของช่องทางนั้นๆ เช่น "ระยะเวลาจัดส่ง 1-3 วันทำการ"']
  calcType ShippingCalcType [not null, default: 'PRICE_BASED', note: '✅ เพิ่ม: ให้เลือกได้ว่าจะคำนวณแบบไหน PRICE_BASED ,WEIGHT_BASED,FLAT_RATE']
  isActive Boolean [not null, default: true, note: 'สถานะการเปิด-ปิดใช้งานช่องทางการจัดส่งนี้']
  rules com_shipping_rules [not null, note: 'วิธีการจัดส่ง มีได้หลายช่วงราคา (Rules)']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'เก็บรูปแบบหรือช่องทางการจัดส่งสินค้าที่แต่ละบริษัทเปิดให้บริการ (เช่น Flash Express, Kerry, หรือการเข้ารับสินค้าเอง) โดยรองรับการกำหนดเงื่อนไขการคำนวณค่าบริการที่หลากหลาย'
}

Table com_shipping_rules {
  id Int [pk, increment]
  companyId Int [not null, note: '🌟 เพิ่มส่วนนี้เพื่อให้รองรับ Multi-company']
  company org_companies [not null]
  methodId Int [not null]
  shippingMethod com_shipping_methods [not null]
  minAmount Decimal [not null, default: 0]
  maxAmount Decimal
  minWeight Decimal [not null, default: 0]
  maxWeight Decimal
  boxSize String [default: 'NONE']
  cost Decimal [not null, default: 0]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'เก็บรายละเอียดกฎเกณฑ์หรือ "ขั้นบันไดราคา" ของการจัดส่งแต่ละประเภท โดยตารางนี้จะทำงานร่วมกับ calcType ในตารางหลักเพื่อตัดสินใจว่าจะคิดค่าส่งเท่าไหร่ตามยอดซื้อหรือน้ำหนักสินค้า'
}

Table com_announcements {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  targetShops com_shop_profiles [not null]
  title String [not null]
  content String
  linkUrl String
  type String [not null, default: 'BANNER']
  position String [not null, default: 'HOME_HERO']
  displayOrder Int [not null, default: 0]
  startDate DateTime
  endDate DateTime
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  notifications sys_notifications [not null]
  media com_announcement_media [not null, note: 'รองรับทั้งรูป Banner และไฟล์ PDF แนบประกาศ']

  Note: 'ประกาศต่างๆ'
}

Table com_orders {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  memberId Int [not null]
  member crm_members [not null]
  orderNo String [not null]
  status String [not null, default: 'PENDING']
  shopId Int [not null, note: '✅ เพิ่ม: ระบุว่าออเดอร์นี้เกิดที่หน้าร้านไหน']
  shop com_shop_profiles [not null]
  shippingDocs ecom_shipping_documents [not null]
  paymentStatus String [not null, default: 'UNPAID', note: 'Payment Setup']
  paymentType String [not null, default: 'FULL']
  totalAmount Decimal [not null, default: 0]
  paidAmount Decimal [not null, default: 0]
  paymentMethod String [note: '[ปรับปรุง] รองรับช่องทางการชำระเงินแบบ API เช่น \'MANUAL_TRANSFER\', \'PROMPTPAY_QR\', \'CREDIT_CARD\'']
  paymentProvider String [note: 'เช่น \'OMISE\', \'GBPRIME\'']
  paymentRefId String [note: 'รหัส Charge ID ที่ Payment Gateway ออกให้ (เช่น ch_123456789)']
  isPaid Boolean [not null, default: false]
  paidAt DateTime
  discountId Int [note: 'Discount & Shipping']
  discount com_discounts
  discountAmount Decimal [not null, default: 0]
  returnRequests com_return_requests [not null]
  productReview com_product_reviews [not null]
  orderDiscount com_order_discounts [not null]
  invoice com_invoices [note: '🚩 [เพิ่มใหม่] เพื่อเชื่อมโยงย้อนกลับมาหาตารางใบกำกับภาษี']
  shippingRuleId Int
  shippingCost Decimal [not null, default: 0]
  shippingAddress String
  trackingNumber String
  courierTicketId String [note: 'รหัสอ้างอิงออเดอร์ในระบบขนส่ง (เอาไว้ใช้ยิง API ไปอัปเดต/ยกเลิกพัสดุ)']
  shippingLabelUrl String [note: 'ลิงก์ไฟล์ PDF ใบปะหน้า (Waybill) ที่ขนส่งส่งกลับมาให้พิมพ์']
  courierStatus String [note: 'สถานะเรียลไทม์จากขนส่ง (เช่น PICKED_UP, IN_TRANSIT, DELIVERED)']
  items com_order_items [not null]
  payments com_payments [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, orderNo) [unique]
  }

  Note: 'ตารางการสั่งสินค้าในระบบ'
}

Table com_order_items {
  id Int [pk, increment]
  orderId Int [not null]
  order com_orders [not null]
  companyId Int [not null]
  company org_companies [not null]
  productId Int [not null]
  product com_products [not null]
  productName String [not null]
  productSku String
  qty Int [not null]
  price Decimal [not null]
  total Decimal [not null]
  purchaseItemId Int [note: '✅ เพิ่ม: รายการนี้ถูกสั่งซื้อไปหรือยัง? (Link ไปหา PO)']
  purchaseItem pro_purchase_items
  returnedItems com_return_items [not null]
  cancelReason String
  cancelledById Int
  wfRequestId Int [unique, note: 'เชื่อมกับ Workflow เพื่อดูประวัติการอนุมัติยกเลิก']
  wfRequest wf_requests
  itemStatus String [not null, default: 'WAITING_PO', note: '✅ เพิ่ม: สถานะของสินค้ารายตัว (Tracking) WAITING_PO (รอรวมยอด), PO_CREATED (สั่งแล้ว), ARRIVED_TH (ถึงไทย), RECEIVED (ร้านได้รับแล้ว)']
  comment String

  Note: 'ตารางเก็บสินค้าที่สั่งใน แต่ละ order'
}

Table com_payment_methods {
  id Int [pk, increment, note: 'รหัสลำดับภายในของวิธีการชำระเงิน (Primary Key)']
  companyId Int [not null, note: 'รหัสอ้างอิงบริษัท เพื่อรองรับระบบ Multi-tenancy ให้แต่ละบริษัทมีช่องทางชำระเงินของตัวเอง']
  company org_companies [not null]
  code String [not null, note: 'รหัสอ้างอิงของวิธีการชำระเงิน เช่น BANK_TRANSFER, CREDIT_CARD, PROMPTPAY (ต้องไม่ซ้ำกันในหนึ่งบริษัท)']
  name String [not null, note: 'ชื่อเรียกช่องทางชำระเงินที่จะแสดงให้ลูกค้าเห็น เช่น "โอนเงินผ่านบัญชีธนาคาร", "ชำระผ่าน QR Code"']
  type String [not null, default: 'BANK_TRANSFER', note: 'ประเภทของระบบชำระเงิน (Default: BANK_TRANSFER) เพื่อให้ระบบเลือกกระบวนการจัดการได้ถูกต้อง']
  config Json [note: 'ข้อมูลการตั้งค่าเชิงเทคนิคในรูปแบบ JSON (เช่น API Key, Merchant ID สำหรับระบบตัดบัตรเครดิต)']
  instruction String [note: 'ข้อความแนะนำขั้นตอนการชำระเงินสำหรับลูกค้า เช่น "กรุณาโอนเงินภายใน 24 ชม. และแนบสลิป"']
  qrImage String [note: 'ลิงก์รูปภาพ QR Code สำหรับการรับชำระเงิน (เช่น รูป QR PromptPay ของร้าน)']
  isActive Boolean [not null, default: true, note: 'สถานะการเปิด/ปิดใช้งานช่องทางชำระเงินนี้']
  payments com_payments [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: 'เก็บรูปแบบหรือช่องทางการชำระเงินที่แต่ละบริษัทอนุญาตให้ลูกค้าใช้ (เช่น โอนเงินผ่านธนาคาร, ชำระผ่านบัตรเครดิต, หรือ Rabbit LINE Pay) โดยรองรับการตั้งค่าที่ยืดหยุ่นตามประเภทของระบบชำระเงิน'
}

Table com_payments {
  id Int [pk, increment, note: 'รหัสลำดับของรายการชำระเงิน (Primary Key)']
  companyId Int [not null, note: 'รหัสบริษัทที่ได้รับชำระเงินก้อนนี้']
  company org_companies [not null]
  orderId Int [not null, note: 'รหัสออเดอร์ที่ถูกชำระเงิน โดยระบุ onDelete: Cascade เพื่อให้ประวัติการจ่ายเงินถูกลบหากออเดอร์นั้นถูกลบทิ้ง']
  order com_orders [not null]
  methodId Int [not null, note: 'รหัสอ้างอิงไปยังช่องทางการชำระเงินที่ลูกค้าเลือกใช้ (เชื่อมกับตาราง ComPaymentMethod)']
  method com_payment_methods [not null]
  amount Decimal [not null, note: 'ยอดเงินที่ลูกค้าระบุว่าชำระเข้ามาจริง']
  transferredAt DateTime [default: `now()`, not null, note: 'วันและเวลาที่ลูกค้าแจ้งว่าได้ทำการโอนเงิน']
  slipUrl String [note: 'ที่อยู่ไฟล์รูปภาพหลักฐานการโอน���งิน (Slip) ที่ลูกค้าอัปโหลด']
  refNo String [note: 'หมายเลขอ้างอิงการทำรายการจากธนาคารหรือระบบชำระเงินภายนอก']
  status String [not null, default: 'PENDING', note: 'สถานะของรายการชำระเงินนี้ เช่น PENDING (รอนุมัติ), SUCCESS (ยืนยันแล้ว), หรือ REJECTED']
  verifiedBy Int [note: 'รหัสผู้ใช้งาน (แอดมิน) ที่เป็นคนตรวจสอบรายการนี้']
  verifier sec_users
  verifiedAt DateTime [note: 'วันและเวลาที่มีการกดอนุมัติรายการ']
  rejectReason String [note: 'เหตุผลที่ปฏิเสธการชำระเงิน (กรณีสถานะเป็น REJECTED) เช่น "ยอดเงินไม่ตรง" หรือ "สลิปซ้ำ"']
  slips ecom_payment_slips [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'เก็บข้อมูลการชำระเงินของลูกค้าที่เกิดขึ้นจริงในแต่ละออเดอร์ ใช้สำหรับบันทึกหลักฐานการโอนเงิน (Slip) และเป็นฐานข้อมูลให้แอดมินเข้ามาตรวจสอบเพื่ออนุมัติหรือปฏิเสธยอดเงินนั้นๆ'
}

Table int_message_queue {
  id Int [pk, increment]
  companyId Int [not null, note: 'ผูกกับบริษัทเจ้าของข้อความ']
  shopId Int [note: '(เพิ่ม) กรณีส่งในนามร้านค้าใดร้านค้าหนึ่ง']
  channel String [not null, note: '(เพิ่ม) ช่องทาง เช่น LINE, SMS, EMAIL, FACEBOOK']
  recipient String [not null, note: 'Line User ID, เบอร์โทร หรือ Email']
  subject String [note: 'หัวข้อ (สำหรับ Email) ']
  content String [not null, note: 'เนื้อหาข้อความ']
  scheduledTime DateTime [not null, note: 'เวลาที่กำหนดให้ส่ง']
  status String [not null, default: 'PENDING', note: 'PENDING, PROCESSING, SENT, FAILED, CANCELLED']
  retryCount Int [not null, default: 0, note: 'จำนวนครั้งที่พยายามส่งใหม่หากพัง']
  maxRetries Int [not null, default: 3, note: '(เพิ่ม) กำหนดเพดานการส่งซ้ำ']
  refType String [note: 'อ้างอิงว่าส่งจากส่วนไหน เช่น PROMOTION, ORDER_NOTIFY']
  refId String [note: 'ID อ้างอิงของงานนั้นๆ']
  errorMessage String [note: 'เก็บสาเหตุถ้าส่งไม่สำเร็จ']
  sentAt DateTime [note: 'เวลาที่ส่งออกไปจริง']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  company org_companies [not null]

  Note: '📦 IntMessageQueue: ระบบศูนย์กระจายข้อความ (External Message Dispatcher) พักข้อมูลข้อความ (LINE, SMS, Email) ไว้ก่อนส่งจริง เพื่อไม่ให้ระบบหลักทำงานช้าลง (Asynchronous) ,รองรับการตั้งเวลาส่งล่วงหน้า (Scheduled Task) ผ่านฟิลด์ scheduledTime'
}

Table pro_suppliers {
  id Int [pk, increment, note: 'รหัสลำดับหลักของคู่ค้า (Primary Key) แบบรันอัตโนมัติ']
  companyId Int [not null, note: 'รหัสอ้างอิงไปยังบริษัท (OrgCompany) เพื่อแยกรายชื่อคู่ค้าตามแต่ละองค์กร']
  company org_companies [not null]
  code String [not null, note: 'รหัสอ้างอิงคู่ค้าที่กำหนดขึ้นเอง เช่น SUP-001, HK-SUP-01']
  name String [not null, note: 'ชื่อร้านค้า หรือชื่อบริษัทคู่ค้า']
  taxId String [note: 'เลขผู้เสียภาษี']
  contactName String [note: 'ชื่อบุคคลที่ติดต่อได้ของบริษัทคู่ค้า']
  phone String [note: 'เบอร์โทรศัพท์สำหรับติดต่อ']
  email String [note: 'อีเมลสำหรับติดต่อหรือส่งใบสั่งซื้อ (PO)']
  address String [note: 'ที่อยู่ตามทะเบียนภาษีหรือสถานที่จัดส่งของคู่ค้า']
  creditTerm Int [not null, default: 0, note: 'เครดิตเทอม (จำนวนวัน)']
  products com_products [not null, note: '✅ 1. เพิ่ม Relation นี้ครับ (สินค้าที่ Supplier เจ้านี้เป็นคนขายหลัก)']
  currency String [not null, default: 'THB', note: '✅ (Optional) แนะนำเพิ่ม: สกุลเงินหลัก (เช่น CNY, USD, THB) จะช่วยตอนเปิด PO']
  type String [not null, default: 'LOCAL', note: '✅ (Optional) แนะนำเพิ่ม: ประเภท Supplier (ในประเทศ / นำเข้า)']
  purchaseOrders pro_purchase_orders [not null]
  isActive Boolean [not null, default: true, note: 'สถานะการเปิดใช้งาน (หากเป็น false จะไม่สามารถเลือกไปออก PO ใหม่ได้)']
  createdAt DateTime [default: `now()`, not null, note: 'วันและเวลาที่สร้างข้อมูลคู่ค้า']
  updatedAt DateTime [not null, note: 'วันและเวลาที่แก้ไขข้อมูลล่าสุด']

  indexes {
    (companyId, code) [unique]
  }

  Note: 'ตารางเก็บข้อมูลรายละเอียดคู่ค้า ผู้ขาย และผู้ผลิตสินค้าที่บริษัททำการติดต่อสั่งซื้อ'
}

Table pro_purchase_orders {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  supplierId Int [not null]
  supplier pro_suppliers [not null]
  docNo String [not null]
  docDate DateTime [default: `now()`, not null]
  dueDate DateTime
  status String [not null, default: 'DRAFT']
  note String
  totalAmount Decimal [not null, default: 0]
  vatAmount Decimal [not null, default: 0]
  netAmount Decimal [not null, default: 0]
  documents ecom_purchase_documents [not null]
  items pro_purchase_items [not null]
  wfRequestId Int [unique]
  wfRequest wf_requests
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, docNo) [unique]
  }

  Note: 'เก็บข้อมูลหลัก (Header) ของใบสั่งซื้อสินค้าที่บริษัทออกให้แก่ซัพพลายเออร์ (Supplier) ทำหน้าที่ควบคุมยอดเงิน สถานะการสั่งซื้อ และกำหนดการส่งมอบสินค้า เพื่อใช้ในกระบวนการเติมสต็อกสินค้าให้เพียงพอต่อการขาย'
}

Table pro_purchase_items {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 เพิ่ม companyId ในระดับ Item ']
  company org_companies [not null]
  purchaseOrderId Int [not null]
  purchaseOrder pro_purchase_orders [not null]
  productId Int [not null]
  product com_products [not null]
  productName String [not null]
  qty Int [not null]
  qtyReceived Int [not null, default: 0]
  unitCost Decimal [not null]
  totalCost Decimal [not null]
  customerOrderItems com_order_items [not null]

  Note: 'เก็บรายละเอียดรายการสินค้าแต่ละชนิดที่ระบุอยู่ในใบสั่งซื้อ (Purchase Order) ทำหน้าที่เชื่อมโยงระหว่าง "ความต้องการซื้อ" กับ "ตัวสินค้าจริง" ในระบบ พร้อมทั้งติดตามสถานะการรับของว่าได้รับครบตามจำนวนที่สั่งหรือไม่'
}

Table com_shop_profiles {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  googleAnalyticsId String
  facebookPixelId String
  tiktokPixelId String
  headingFont String [default: 'Kanit']
  bodyFont String [default: 'Prompt']
  shopCode String [unique, not null]
  shopName String [not null]
  customDomain String [unique, note: '🌐 [NEW] โดเมนเฉพาะสำหรับหน้าร้านค้าออนไลน์ขายปลีก (Shop Level Storefront)']
  logoMediaId Int [unique, note: '✅ [NEW] เปลี่ยนมาใช้ Relation เชื่อมกับ SysMedia (DMS) สำหรับรูปโลโก้ร้าน']
  logoMedia SysMedia
  documents com_shop_documents [not null, note: '✅ [NEW] เชื่อมโยงกับตารางเอกสารยืนยันตัวตนร้านค้า (KYC, ทะเบียนพาณิชย์, หน้าบุ๊คแบงก์)']
  logisticsProviders cfg_logistics_providers [not null, note: '🚩 [เพิ่มใหม่] ความสัมพันธ์สำหรับการตั้งค่าแยกรายสาขา']
  paymentGateways cfg_payment_gateways [not null]
  invoices com_invoices [not null, note: '🚩 [เพิ่มใหม่] เพื่อรองรับประวัติใบกำกับภาษีแยกตามรายสาขา']
  webBaseUrl String
  lineOaUrl String
  primaryColor String [default: '#4F46E5']
  secondaryColor String
  comWarehouse com_warehouses [not null]
  crmMemberShops crm_member_shops [not null]
  carts com_carts [not null]
  warehouseAddress String
  pickupAddress String
  returnAddress String
  returnRequests com_return_requests [not null]
  rptDailySales rpt_daily_sales [not null]
  comDiscount com_discounts [not null]
  otps sec_otps [not null]
  announcements com_announcements [not null]
  currency String [not null, default: 'THB']
  timezone String [not null, default: 'Asia/Bangkok']
  taxRate Decimal [not null, default: 7]
  isVatIncluded Boolean [not null, default: true]
  address String
  subDistrict String
  district String
  province String
  zipCode String
  latitude Decimal
  longitude Decimal
  phone String
  isMainShop Boolean [not null, default: false]
  isActive Boolean [not null, default: true]
  bankAccounts com_bank_accounts [not null]
  shopProducts com_shop_products [not null]
  orders com_orders [not null]
  rewards crm_rewards [not null]
  redemptions crm_redemptions [not null]
  SmtpConfig int_smtp_configs [not null]
  Template com_templates [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, shopCode) [unique]
  }

  Note: 'จุดประสงค์หลักของตารางนี้คือการรองรับโครงสร้างแบบ Multi-Storefront ซึ่งหมายความว่า 1 บริษัท (Company) สามารถแตกสาขาหรือแตกหน้าร้านออกไปได้หลายช่องทาง เช่น มี "ร้านขายปลีก", "ร้านขายส่ง", หรือ "หน้าร้านสาขาเชียงใหม่" โดยแต่ละร้านสามารถมีการตั้งค่าหน้าตา โลโก้ นโยบายภาษี และโกดังแยกกันได้อย่างอิสระ'
}

Table com_bank_accounts {
  id Int [pk, increment]
  shopId Int [not null]
  shop com_shop_profiles [not null]
  companyId Int [not null]
  company org_companies [not null]
  bankCode String [not null, note: 'รหัสธนาคาร']
  bankName String [not null, note: 'ชื่อธนาคาร']
  accountNo String [not null, note: 'หมายเลขบัญชีธนาคาร']
  accountName String [not null, note: 'ชื่อบัญชี ธนาคาร']
  branch String [note: 'สาขาธนาคาร']
  isDefault Boolean [not null, default: false]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: '✅ Table ใหม่: บัญชีธนาคารของร้านค้า (สำหรับโชว์ในใบเสร็จ / Footer เว็บ / หรือ Payment Method)'
}

Table com_shop_products {
  shopId Int [not null]
  productId Int [not null]
  companyId Int [not null]
  shop com_shop_profiles [not null]
  product com_products [not null]
  company org_companies [not null]
  skuOverride String [note: '✅ เพิ่มตัวนี้: เผื่อหน้าร้านอยากใช้รหัสสินค้าคนละรหัสกับคลังกลาง']
  isActive Boolean [not null, default: true, note: 'เปิด/ปิด การขายในร้านนี้']
  priceOverride Decimal [note: '(Optional) ตั้งราคาต่างกันแต่ละร้านได้']
  featuredImageUrl String [note: '✅ เพิ่ม: รูปปกเฉพาะร้านนี้']
  nameOverride String [note: '✅ (Optional) เพิ่ม: ชื่อสินค้าเฉพาะร้านนี้ (เผื่ออยากตั้งชื่อให้ดูไม่เหมือนกันเลย)']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shopId, productId) [pk]
  }

  Note: 'ทำหน้าที่เชื่อมสินค้าหลัก (Master Product) เข้ากับหน้าร้านแต่ละสาขา ทำให้แต่ละร้านสามารถตั้งราคา (Price Override), เปลี่ยนชื่อ, เปลี่ยนรูป และเปิด/ปิดการขายแยกกันได้อย่างอิสระ'
}

Table com_return_requests {
  id Int [pk, increment]
  companyId Int [not null, note: '✅ 1. Multi-Company Support']
  company org_companies [not null]
  shopId Int [not null, note: '✅ 2. รองรับ Multi-Shop (คืนเข้าร้านไหน)']
  shop com_shop_profiles [not null]
  orderId Int [not null, note: 'ข้อมูลอ้างอิง']
  order com_orders [not null]
  memberId Int [not null]
  member crm_members [not null]
  docNo String [not null, note: 'เลขที่ใบเคลม (RMA-2024-0001)']
  documents ecom_return_documents [not null]
  type RmaType [not null]
  status RmaStatus [not null, default: 'PENDING']
  reason String [not null, note: 'เหตุผล (เช่น "สินค้าชำรุด", "ใส่ไม่ได้")']
  description String
  proofImages String[] [not null, note: 'หลักฐาน (รูปภาพ/วิดีโอ)']
  customerTrackingNo String [note: 'การส่งของคืน (Logistics) เลขพัสดุที่ลูกค้าส่งกลับมา ']
  customerCourier String [note: 'ขนส่งที่ลูกค้าใช้']
  shopTrackingNo String [note: 'เลขพัสดุที่เราส่งตัวใหม่/ตัวซ่อม กลับไปให้ลูกค้า']
  refundAmount Decimal [note: 'การเงิน (กรณี Refund)']
  refundSlipUrl String
  items com_return_items [not null, note: 'รายการสินค้าที่ส่งมาเคลม']
  wfRequestId Int [unique, note: '1 RMA ผูกกับ 1 Workflow Request']
  wfRequest wf_requests
  adminNote String [note: 'Admin Note (บันทึกภายใน)']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, docNo) [unique]
  }

  Note: 'ก็บข้อมูลภาพรวมของการขอคืนสินค้า เช่น ใครเป็นคนขอคืน (memberId), คืนจากออเดอร์ไหน (orderId), คืนสาขาไหน (shopId)'
}

Table com_return_items {
  id Int [pk, increment]
  companyId Int [not null]
  returnRequestId Int [not null]
  returnRequest com_return_requests [not null]
  orderItemId Int [not null, note: 'อ้างอิงว่าคืนรายการไหนใน Order เดิม']
  orderItem com_order_items [not null]
  qty Int [not null, note: 'จำนวนที่เคลม']
  targetProductId Int [note: 'กรณี Exchange: ต้องการเปลี่ยนเป็นสินค้าตัวไหน (เช่น เปลี่ยนจาก Size S -> M)']
  targetProduct com_products
  condition String [note: 'สภาพสินค้าที่ได้รับ (เช่น "กล่องบุบ", "มีรอยขีดข่วน")']

  Note: 'ระบุเจาะจงลงไปเลยว่า "สินค้าชิ้นไหน" ในออเดอร์นั้นที่ถูกส่งเคลม (orderItemId) และเคลมจำนวนกี่ชิ้น (qty)'
}

Table com_stock_logs {
  id BigInt [pk, increment]
  companyId Int [not null, note: '1. ผูกกับบริษัท (Multi-Tenant)']
  company org_companies [not null]
  productId Int [not null, note: '2. ผูกกับสินค้า']
  product com_products [not null]
  warehouseId Int [not null, note: '🌟 1. คลังสินค้าที่เกิดเหตุการณ์นี้ขึ้น']
  warehouse com_warehouses [not null]
  refWarehouseId Int [note: '🌟 2. คลังต้นทาง/ปลายทาง (ใช้เฉพาะตอนโอนย้าย Transfer)']
  refWarehouse com_warehouses
  changeQty Int [not null, note: 'เปลี่ยนแปลงเท่าไหร่ (เช่น +10, -5)']
  balanceAfter Int [not null, note: 'ยอดคงเหลือหลังจากเปลี่ยน (Snapshot ไว้ดูย้อนหลัง)']
  type StockChangeType [not null, note: 'สาเหตุ (ขาย/ซื้อ/คืน)']
  refOrderId Int [note: 'มาจาก Order ID ไหน']
  refPurchaseItemId Int [note: 'มาจาก PO Item ID ไหน']
  refReturnId Int [note: 'มาจากใบรับคืน (RMA) ไหน']
  note String [note: 'หมายเหตุเพิ่มเติม']
  createdBy Int [note: 'User ID คนทำรายการ (เก็บแค่ ID พอ)']
  createdAt DateTime [default: `now()`, not null]

  Note: 'บันทึกทุกๆ การขยับของสต็อก ไม่ว่าจะเป็นของเข้า ของออก หรือของพัง ระบบจะบันทึกว่า ขยับกี่ชิ้น (changeQty), ยอดคงเหลือตอนนั้นคือเท่าไหร่ (balanceAfter), และขยับด้วยสาเหตุอะไร (type เช่น SALE, PURCHASE, TRANSFER)'
}

Table int_ai_quotas {
  id Int [pk, increment]
  companyId Int [unique, not null, note: 'เชื่อมกับบริษัท (1 บริษัท มี 1 โควตา)']
  company org_companies [not null]
  tier String [not null, default: 'FREE', note: 'แพ็กเกจการใช้งาน (เช่น FREE, PRO, ENTERPRISE)']
  maxSingleFileSize Int [not null, default: 10485760, note: '✅ [NEW] ขนาดไฟล์สูงสุดต่อการอัปโหลด 1 ครั้ง (Default 10MB)']
  monthlyLimit BigInt [not null, default: 100000]
  usedThisMonth BigInt [not null, default: 0]
  maxStorageBytes BigInt [not null, default: 524288000, note: '--- 📁 Storage Quota (Bytes) ค่า Default 500MB (500 * 1024 * 1024)']
  usedStorageBytes BigInt [not null, default: 0, note: 'ผลรวมขนาดไฟล์ที่อัปโหลดทั้งหมด']
  slipVerifyLimit Int [not null, default: 0, note: 'จำนวนโควตาการตรวจสลิปที่ได้ต่อเดือน (0 = ไม่ได้ซื้อแพ็กเกจนี้)']
  slipVerifyUsed Int [not null, default: 0, note: 'จำนวนโควตาที่ใช้ไปแล้วในเดือนนี้']
  startDate DateTime [default: `now()`, not null, note: '--- ⏳ Validity (ช่วงที่มีผล) ---']
  endDate DateTime [note: 'ถ้าเป็น NULL = ไม่มีวันหมดอายุ']
  extraCredit BigInt [not null, default: 0, note: 'เครดิตคงเหลือที่ซื้อเพิ่ม (Top-up) กรณีใช้โควตาเดือนนั้นหมดแล้ว']
  lastResetDate DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'สร้างขึ้นมาเพื่อ ควบคุมไม่ให้บริษัทใดบริษัทหนึ่งใช้งาน AI หนักเกินไปจนคุณขาดทุน และใช้เพื่อแบ่งระดับการให้บริการตามแพ็กเกจ (Tier) ครับ'
}

Table int_ai_usage_logs {
  id BigInt [pk, increment, note: 'รหัสรายการ (ใช้ BigInt ถูกต้องมากครับ เพราะ Log แบบนี้ข้อมูลจะโตไวมาก อาจจะทะลุล้านบรรทัดในไม่กี่เดือน)']
  companyId Int [not null, note: 'ระบุว่าบิลค่า AI รอบนี้เป็นของบริษัทไหน (ใครต้องถูกหักโควตา)']
  company org_companies [not null]
  aiBotId Int [note: 'ระบุเจาะจงลงไปอีกว่า บอทตัวไหนของบริษัทนั้นที่เป็นคนเรียกใช้ (เผื่อบริษัทนึงมีบอท 3 ตัว จะได้รู้ว่าตัวไหนทำงานหนักสุด)']
  aiBot int_ai_bots
  modelName String [not null, note: 'ชื่อสมองกลที่ใช้ทำงาน เช่น gpt-4o หรือ gemini-1.5-pro (สำคัญมากเพราะโมเดลแต่ละตัวราคาไม่เท่ากัน) // เช่น gpt-4o, gemini-1.5-pro']
  promptTokens Int [not null, note: 'จำนวน Token "ขาไป" (คำถามที่ลูกค้าพิมพ์ + ข้อความ System Prompt + ข้อมูลที่ดึงจาก Knowledge Base)']
  completionTokens Int [not null, note: 'จำนวน Token "ขากลับ" (คำตอบที่ AI พิมพ์ตอบกลับมา)']
  totalTokens Int [not null, note: 'ผลรวมของขาไปและขากลับ (นี่คือตัวเลขที่เราใช้เอาไปหักลบออกจากโควตารายเดือนของลูกค้าครับ)']
  source String [note: 'ระบุว่า AI ถูกเรียกใช้งานจากฟีเจอร์ไหน เช่น มาจากแชทบอท ("CHAT_BOT"), ดึงข้อมูลจากเอกสาร ("KNOWLEDGE_BASE_RAG"), หรือปุ่มกดสร้าง Tag สินค้าอัตโนมัติ ("PRODUCT_TAGGING")']
  createdAt DateTime [default: `now()`, not null]

  Note: 'มิเตอร์น้ำ/มิเตอร์ไฟประจำระบบ AI (AI Meter & Billing Log)" ครับทุกครั้งที่บอทน้องขายดีคิดคำตอบ, ทุกครั้งที่ AI ช่วยสกัดข้อมูลจาก PDF หรือทุกครั้งที่ระบบช่วยคิด Tag สินค้า... ข้อมูลทั้งหมดจะถูกบันทึกลงตารางนี้'
}

Table sec_company_security_configs {
  id Int [pk, increment, note: 'รหัสลำดับหลักของนโยบาย (Primary Key) แบบรันอัตโนมัติ']
  companyId Int [not null]
  company org_companies [not null]
  menuId Int [not null, note: 'รหัสอ้างอิงไปยังเมนู (SecMenu) ที่ต้องการควบคุมความปลอดภัยเป็นพิเศษ']
  menu sec_menus [not null]
  requireReAuth Boolean [not null, default: true, note: 'หากเป็น true ผู้ใช้ต้องใส่รหัสผ่านซ้ำอีกครั้ง (Re-authenticate) ก่อนเข้าถึงเมนูนี้']
  requireMfa Boolean [not null, default: false, note: '✅ (เพิ่มเติม) บังคับใช้ OTP หรือ Biometric แทนรหัสผ่านปกติ']
  gracePeriod Int [not null, default: 15, note: '✅ ระยะเวลาที่อนุญาตให้ไม่ต้องใส่รหัสซ้ำ (Sudo Mode duration) หน่วยเป็นนาที']
  updatedAt DateTime [not null, note: 'วันและเวลาที่ปรับปรุงนโยบายล่าสุด']

  indexes {
    (companyId, menuId) [unique]
  }

  Note: 'ตารางกำหนดนโยบายความปลอดภัยพิเศษ (เช่น การบังคับใส่รหัสซ้ำ) สำหรับการเข้าถึงเมนูต่างๆ แยกตามบริษัท'
}

Table crm_point_logs {
  id BigInt [pk, increment]
  companyId Int [not null]
  memberId Int [not null]
  member crm_members [not null]
  amount Int [not null]
  balanceAfter Int [not null]
  action String [not null, note: 'สาเหตุ']
  refOrderId Int [note: 'อ้างอิง']
  refRedemptionId Int
  note String
  expiredAt DateTime
  createdAt DateTime [default: `now()`, not null]

  Note: 'ประวัติการได้แต้ม/ใช้แต้ม'
}

Table crm_rewards {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  name String [not null]
  description String
  mediaId Int [note: '🚩 [แก้ไข] เปลี่ยนจาก imageUrl String? มาผูกกับศูนย์กลาง DMS']
  media SysMedia
  pointCost Int [not null, note: 'ใช้กี่แต้มแลก']
  type String [not null, default: 'DISCOUNT_COUPON', note: 'COUPON, PHYSICAL_GOOD, EXTERNAL_CODE']
  discountTemplateId Int [note: 'ถ้าเป็นคูปอง ให้ผูกกับ ComDiscount ที่เราทำไว้']
  shopId Int [note: 'รองรับการระบุสาขาที่ให้แลก ถ้าเป็น null แลกได้ในเครือทั้งหมด']
  shop com_shop_profiles
  productId Int [note: 'ถ้าเป็น Physical Good (เช่น แก้วน้ำ) ให้ผูกกับ Product เพื่อตัดสต็อก']
  stockQty Int [note: 'จำกัดจำนวนสิทธิ์ไหม (Null = ไม่จำกัด)']
  isActive Boolean [not null, default: true]
  redemptions crm_redemptions [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'ของรางวัล (Catalog)'
}

Table crm_redemptions {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  shopId Int
  shop com_shop_profiles
  memberId Int [not null]
  member crm_members [not null]
  rewardId Int [not null]
  reward crm_rewards [not null]
  pointUsed Int [not null]
  status String [not null, default: 'PENDING']
  redeemCode String
  wfRequestId Int [unique, note: '🚩 [เพิ่มใหม่] เชื่อมโยงกับสายอนุมัติ Workflow (1 ใบแลกของ ต่อ 1 คำร้อง)']
  wfRequest wf_requests
  documents crm_redemption_documents [not null, note: '🚩 [เพิ่มใหม่] เชื่อมโยงประวัติเอกสาร/หลักฐานรูปภาพที่อัปโหลดเข้า DMS']
  createdAt DateTime [default: `now()`, not null]

  Note: 'ประวัติการแลกรางวัล'
}

Table crm_redemption_documents {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 Multi-tenancy']
  company org_companies [not null]
  redemptionId Int [not null, note: '🎁 เชื่อมใบแลกของรางวัล']
  redemption crm_redemptions [not null]
  mediaId Int [unique, not null, note: '📁 ผูกกับไฟล์บนศูนย์กลาง DMS']
  media SysMedia [not null]
  docType String [note: 'ประเภทเอกสาร เช่น \'DELIVERY_SLIP\' (ใบจัดส่ง), \'CLAIM_PROOF\' (ภาพหลักฐานการรับของ)']
  createdAt DateTime [default: `now()`, not null]

  Note: '📂 [NEW] ตารางผูกหลักฐานการแลกของรางวัลเข้าศูนย์จัดเก็บไฟล์กลาง DMS (SysMedia)'
}

Table crm_company_configs {
  id Int [pk, increment]
  companyId Int [unique, not null]
  company org_companies [not null]
  isPointEnabled Boolean [not null, default: true, note: '💰 กติกาการได้แต้ม']
  earnRatio Int [not null, default: 100]
  pointExpiryMonths Int [note: '⏳ กติกาการหมดอายุ']
  pointName String [not null, default: 'Point', note: '🏷️ ชื่อเรียกแต้ม (Branding)  เช่น "Coin", "Star", "แต้ม"']
  updatedAt DateTime [not null]

  Note: 'การตั้งค่าระบบสมาชิกและแต้ม'
}

Table com_wishlists {
  id BigInt [pk, increment, note: 'ใช้ BigInt เผื่ออนาคตคนกดเยอะ']
  companyId Int [not null, note: '✅ 1. เพิ่ม Company ID']
  company org_companies [not null]
  memberId Int [not null]
  member crm_members [not null]
  productId Int [not null]
  product com_products [not null]
  createdAt DateTime [default: `now()`, not null]

  indexes {
    (memberId, productId) [unique]
  }

  Note: 'ตารางเก็บเกี่ยวกับ ความสนใจสินค้าของสมาชิก'
}

Table com_product_reviews {
  id BigInt [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  productId Int [not null]
  product com_products [not null]
  memberId Int [not null]
  member crm_members [not null]
  orderId Int [note: 'อ้างอิง Order เพื่อยืนยันว่า "ซื้อจริง" (Verified Buyer)']
  order com_orders
  rating Int [not null, default: 5, note: '1-5 ดาว']
  comment String
  reviewMedias com_product_review_media [not null]
  replyMessage String [note: 'ร้านตอบกลับ']
  repliedAt DateTime
  isHidden Boolean [not null, default: false]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'ตารางเกี่ยวกับการ review สินค้า'
}

Table com_product_review_media {
  id BigInt [pk, increment]
  companyId Int [not null, note: '🏢 Multi-tenancy']
  company org_companies [not null]
  reviewId BigInt [not null, note: '⭐️ เชื่อมกับรีวิว (ระบุเป็น BigInt ตามตารางหลัก)']
  review com_product_reviews [not null]
  mediaId Int [unique, not null, note: '📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)']
  media SysMedia [not null]
  sortOrder Int [not null, default: 0, note: 'ลำดับการแสดงผลของรูป (ถ้ารีวิวมีหลายรูป)']
  createdAt DateTime [default: `now()`, not null]

  Note: '📸 ตารางกลางสำหรับเชื่อมรูปภาพรีวิวเข้ากับศูนย์เก็บไฟล์ (SysMedia)'
}

Table sys_notifications {
  id BigInt [pk, increment, note: 'รหัสลำดับหลักของการแจ้งเตือน (Primary Key) ใช้ BigInt เพื่อรองรับปริมาณข้อมูลสะสม']
  companyId Int [not null, note: 'รหัสอ้างอิงไปยังบริษัท (OrgCompany) เพื่อระบุความเป็นเจ้าของข้อมูลแจ้งเตือน']
  company org_companies [not null]
  recipientMemberId Int [note: 'รหัสอ้างอิงไปยังลูกค้า (CrmMember) ในกรณีที่ส่งหาลูกค้าฝั่งหน้าบ้าน']
  member crm_members [note: '(Optional) ผูก Relation เผื่อไว้']
  recipientUserId Int
  user sec_users [note: '(Optional) ผูก Relation เผื่อไว้']
  announcementId Int [note: 'รหัสอ้างอิงไปยังประกาศหลัก (ComAnnouncement) หากการแจ้งเตือนนี้มาจากประกาศ']
  announcement com_announcements
  type NotificationType [not null, note: 'ประเภทของการแจ้งเตือน เช่น INFO, ORDER_STATUS, PROMOTION, SYSTEM']
  title String [not null, note: 'หัวข้อของการแจ้งเตือน']
  message String [not null, note: 'เนื้อหาหรือรายละเอียดของการแจ้งเตือน']
  iconUrl String [note: 'ลิงก์รูปภาพไอคอนที่แสดงประกอบการแจ้งเตือน']
  actionUrl String [note: 'ลิงก์ปลายทาง (Deep Link) ที่ต้องการให้ผู้ใช้ไปเมื่อกดที่รายการแจ้งเตือน']
  isRead Boolean [not null, default: false, note: 'สถานะการอ่าน (Default: false)']
  readAt DateTime [note: 'วันและเวลาที่ผู้ใช้กดอ่านข้อมูล']
  createdAt DateTime [default: `now()`, not null, note: 'วันและเวลาที่สร้างรายการแจ้งเตือน (Default: ปัจจุบัน)']

  Note: 'ทำหน้าที่เป็น ระบบแจ้งเตือนภายใน (In-app Notification) เพื่อส่งข้อมูลข่าวสาร สถานะกิจกรรม หรือประกาศสำคัญไปยังผู้ใช้งานโดยตรง ไม่ว่าจะเป็นลูกค้า (Members) หรือพนักงานหลังบ้าน (Admin Users) ภายในระบบของคุณ'
}

Table rpt_daily_sales {
  id Int [pk, increment]
  companyId Int [not null]
  shopId Int [note: 'แยกตามหน้าร้าน (ถ้า null = รวมทั้งบริษัท)']
  date DateTime [not null, note: 'วันที่ของยอดขาย (เช่น 2023-10-25)']
  totalSales Decimal [not null, default: 0, note: 'ยอดขายรวม (Gross)']
  totalDiscount Decimal [not null, default: 0, note: 'ส่วนลดรวม']
  netSales Decimal [not null, default: 0, note: 'ยอดขายสุทธิ (Net)']
  totalOrders Int [not null, default: 0]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  company org_companies [not null]
  shop com_shop_profiles

  indexes {
    (companyId, shopId, date) [unique]
  }

  Note: 'ตารางนี้เปรียบเสมือนสมุดบัญชีปิดยอดรายวันของแต่ละสาขาครับ'
}

Table rpt_product_performance {
  id Int [pk, increment]
  companyId Int [not null]
  productId Int [not null]
  shopId Int
  month DateTime [not null]
  totalSoldQty Int [not null, default: 0]
  totalRevenue Decimal [not null, default: 0]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  company org_companies [not null]
  product com_products [not null]

  indexes {
    (companyId, productId, shopId, month) [unique]
  }

  Note: 'ตารางนี้เปรียบเสมือนใบจัดอันดับความฮอตของสินค้าแบบรายเดือนครับ'
}

Table sys_auth_providers {
  id String [pk, note: 'ใช้เป็น Code ไปเลย เช่น "LINE", "GOOGLE"']
  name String [not null, note: 'เช่น "Line Login", "ThaID"']
  iconUrl String [note: 'รูปปุ่ม Login']
  isEnabled Boolean [not null, default: true, note: 'เปิดใช้งานหรือไม่']
  isMaintenance Boolean [not null, default: false, note: 'ปิดปรับปรุงชั่วคราวหรือไม่']
  sortOrder Int [not null, default: 0, note: 'เรียงลำดับปุ่ม']
  companyConfigs sec_company_auth_configs [not null]
  updatedAt DateTime [not null]

  Note: 'ตาราง Master ควบคุมการเปิด/ปิด ระดับ Global (Admin สูงสุดเป็นคนคุม)'
}

Table sec_company_auth_configs {
  id Int [pk, increment, note: 'รหัสลำดับของการตั้งค่า (Primary Key)']
  companyId Int [not null, note: 'รหัสอ้างอิงบริษัท เพื่อระบุว่าการตั้งค่านี้เป็นของบริษัทใด โดยใช้ onDelete: Cascade เพื่อให้ข้อมูลการตั้งค่าถูกลบหากบริษัทถูกลบออกจากระบบ']
  company org_companies [not null]
  providerId String [not null, note: 'รหัสอ้างอิงประเภทของผู้ให้บริการล็อกอิน (เชื่อมโยงกับตาราง SysAuthProvider) เช่น "GOOGLE", "LINE", หรือ "APPLE"']
  provider sys_auth_providers [not null, note: 'เชื่อมโยงไปยังระบบหลักเพื่อดูรายละเอียดทางเทคนิคของแต่ละช่องทางล็อกอิน SysAuthProvider']
  isEnabled Boolean [not null, default: true, note: 'สถานะการเปิด/ปิดใช้งานผู้ให้บริการรายนี้สำหรับบริษัทนั้นๆ หากตั้งเป็น false พนักงานในบริษัทนี้จะไม่เห็นตัวเลือกล็อกอินด้วยช่องทางดังกล่าว']
  clientId String [note: 'รหัสประจำตัวแอปพลิเคชัน (App ID) กรณีที่บริษัทต้องการใช้บัญชีนักพัฒนาของตนเอง หากเป็นค่าว่าง (Null) ระบบจะดึงค่ามาตรฐาน (Default System Key) มาใช้แทน']
  clientSecret String [note: 'รหัสลับแอปพลิเคชัน (App Secret) ที่ใช้คู่กับ Client ID เพื่อยืนยันความปลอดภัย     ']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, providerId) [unique]
  }

  Note: 'เก็บการตั้งค่าการยืนยันตัวตน (Authentication) แยกตามแต่ละบริษัท ทำหน้าที่ควบคุมว่าบริษัทนั้นๆ อนุญาตให้พนักงานล็อกอินผ่านช่องทางใดบ้าง (เช่น Google, LINE) และรองรับการใช้แอปพลิเคชันส่วนตัวของบริษัทเอง (Custom OAuth App)'
}

Table cms_pages {
  id Int [pk, increment, note: 'รหัสลำดับของหน้าเพจ (Primary Key)']
  companyId Int [not null, note: '✅ ผูกกับบริษัท (สำคัญมาก เพื่อให้ลูกค้า A ไม่เห็นหน้าของลูกค้า B)']
  company org_companies [not null]
  slug String [not null, note: 'URL ของหน้านั้นๆ เช่น "about-us", "promotion"']
  title String [note: 'ชื่อหน้า (ไว้แสดงในรายการหลังบ้าน)']
  content Json [note: '🔥 หัวใจสำคัญ: เก็บ JSON Layout ที่ได้จาก Lovable/Puck']
  seoTitle String [note: 'ข้อมูลสำหรั���การทำ Search Engine Optimization เพื่อให้หน้าเว็บติดอันดับการค้นหาบน Google ได้ดีขึ้น และแสดงรูปภาพพรีวิวที่สวยงามเวลาแชร์ลงโซเชียล']
  seoDescription String [note: 'ข้อมูลสำหรับการทำ Search Engine Optimization เพื่อให้หน้าเว็บติดอันดับการค้นหาบน Google ได้ดีขึ้น และแสดงรูปภาพพรีวิวที่สวยงามเวลาแชร์ลงโซเชียล']
  seoImage String [note: 'ข้อมูลสำหรับการทำ Search Engine Optimization เพื่อให้หน้าเว็บติดอันดับการค้นหาบน Google ได้ดีขึ้น และแสดงรูปภาพพรีวิวที่สวยงามเวลาแชร์ลงโซเชียล']
  isPublished Boolean [not null, default: false, note: 'สถานะการเผยแพร่หน้าเว็บ (True = ออนไลน์ให้คนทั่วไปเห็น, False = ฉบับร่างที่เห็นเฉพาะหลังบ้าน)']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, slug) [unique]
  }

  Note: 'เก็บข้อมูลโครงสร้างหน้าเว็บไซต์หรือหน้า Landing Page ที่แต่ละบริษัทสร้างขึ้นเอง โดยใช้เทคโนโลยีแบบ No-code/Low-code (เช่น Lovable หรือ Puck) ในการออกแบบเลย์เอาต์ เพื่อให้แต่ละร้านค้ามีหน้าเว็บที่เป็นเอกลักษณ์ของตนเองได้โดยไม่ต้องเขียนโค้ดเพิ่ม'
}

Table cms_menus {
  id Int [pk, increment]
  companyId Int [not null, note: 'ผูกกับบริษัท เพื่อให้แต่ละร้านมีเมนูไม่เหมือนกัน']
  company org_companies [not null]
  label String [not null, note: 'ชื่อเมนูที่แสดงบนหน้าเว็บ (เช่น "หน้าแรก", "สินค้าของเรา", "ติดต่อเรา")']
  url String [not null, note: 'URL เป้าหมาย (อาจจะเป็น Path ในเว็บเรา เช่น "/about-us" หรือเว็บนอก เช่น "https://facebook.com/...")']
  isExternal Boolean [not null, default: false, note: 'ระบุว่าให้เปิดในแท็บใหม่หรือไม่ (กรณีเป็นลิงก์เว็บนอก)']
  sortOrder Int [not null, default: 0, note: 'ลำดับการแสดงผล (เรียงจากซ้ายไปขวา หรือบนลงล่าง) ใช้สำหรับทำ Drag & Drop']
  description String [note: 'คำอธิบายย่อยใต้ชื่อเมนู (เช่น "รวมเสื้อผ้าคอลเลกชันใหม่ล่าสุด")']
  imageUrl String [note: 'รูปภาพประกอบเมนู']
  isMegaMenu Boolean [not null, default: false, note: 'สวิตช์บอกหน้าบ้านว่าเมนูนี้ให้กางออกแบบ Mega Menu นะ']
  parentId Int [note: '🌟 ระบบรองรับเมนูย่อย (Sub-menu / Dropdown) 🌟 ถ้า parentId เป็น null แสดงว่าเป็นเมนูหลัก ถ้ามี parentId แสดงว่าเป็นเมนูย่อยที่อยู่ภายใต้เมนูหลักนั้นๆ']
  parent cms_menus
  children cms_menus [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'ระบบจัดการเมนูหน้าเว็บไซต์ (Storefront Navigation)'
}

Table hr_shifts {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null]
  name String [not null]
  color String
  type ShiftType [not null, default: 'WORK_DAY']
  workStartTime String
  workStartRel DayRelative [not null, default: 'CURRENT']
  workEndTime String
  workEndRel DayRelative [not null, default: 'CURRENT']
  totalDayHours Decimal [not null, default: 8]
  firstHalfHours Decimal [not null, default: 4]
  secondHalfHours Decimal [not null, default: 4]
  isOtBeforeShift Boolean [not null, default: false]
  minOtBeforeMinutes Int [not null, default: 0]
  isOtAfterShift Boolean [not null, default: false]
  minOtAfterMinutes Int [not null, default: 0]
  schedules hr_employee_schedules [not null]
  details hr_shift_details [not null]
  asPreviousShiftDetails hr_shift_details [not null]
  patternItems hr_work_pattern_items [not null]
  breaks hr_shift_breaks [not null]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  HrRosterDetail HrRosterDetail [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: '2. SHIFT MASTER'
}

Table hr_shift_details {
  id Int [pk, increment]
  companyId Int [not null]
  shiftId Int [not null]
  shift hr_shifts [not null]
  previousShiftId Int
  previousShift hr_shifts
  boundaryStartTime String [not null, default: '00:00']
  boundaryStartRel DayRelative [not null, default: 'CURRENT']
  boundaryEndTime String [not null, default: '00:00']
  boundaryEndRel DayRelative [not null, default: 'NEXT']
  priority Int [not null, default: 1]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (shiftId, previousShiftId) [unique]
  }

  Note: '3. SHIFT DETAIL (ขอบเขตวัน - Boundary Only)'
}

Table hr_time_break_groups {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null]
  name String [not null]
  type BreakType [not null, default: 'FIXED_TIME', note: '🚩 ย้าย type ขึ้นมาไว้ที่ Master']
  isActive Boolean [not null, default: true]
  details hr_time_break_details [not null]
  shifts hr_shift_breaks [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: 'BREAK MASTER (หัว - ชุดเวลาพัก)'
}

Table hr_time_break_details {
  id Int [pk, increment]
  companyId Int [not null]
  groupId Int [not null]
  group hr_time_break_groups [not null]
  name String [not null]
  startTime String
  endTime String
  triggerAfterHours Decimal
  duration Int [not null]

  Note: 'BREAK DETAIL (หาง - ช่วงเวลาพักย่อย)'
}

Table hr_shift_breaks {
  id Int [pk, increment]
  companyId Int [not null]
  shiftId Int [not null]
  shift hr_shifts [not null]
  groupId Int [not null]
  group hr_time_break_groups [not null]

  indexes {
    (companyId, shiftId, groupId) [unique]
  }

  Note: 'SHIFT BREAK (Junction Table)'
}

Table hr_calendars {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  name String [not null, note: 'ชื่อเรียก เช่น "ปีงบประมาณ 2569", "ปีปฏิทิน 2026"']
  year Int [not null, note: 'ปีที่อ้างอิง (เช่น 2026)']
  kpiCycles hr_kpi_cycles [not null, note: '🌟 เพิ่ม Relation ไปหา KPI Cycle']
  type CalendarType [not null, default: 'CALENDAR', note: 'ประเภท: FISCAL (งบประมาณ), CALENDAR (ปฏิทินปกติ)']
  compensationRule String [not null, default: 'NEXT_WORKING_DAY', note: 'กฎการชดเชยวันหยุด: NEXT_WORKING_DAY (เลื่อนไปวันทำการถัดไป), NONE (ไม่ชดเชย)']
  startDate DateTime [not null, note: 'วันที่เริ่มรอบ (เช่น 2025-10-01 สำหรับปีงบประมาณ 2026)']
  endDate DateTime [not null, note: 'วันที่สิ้นสุดรอบ (เช่น 2026-09-30)']
  holidayGroups hr_holiday_groups [not null]
  workPatterns hr_work_patterns [not null]
  orgStructureVersion hr_org_structure_versions [not null]
  leaveBalance hr_leave_balances [not null]
  LeaveRequest hr_leave_requests [not null]
  isActive Boolean [not null, default: true, note: 'สถานะการใช้งาน (ในหนึ่งบริษัทควรมี Active แค่ 1 อันต่อประเภทปี)']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'รอบปฏิทิน (รองรับทั้งปีปฏิทิน และ ปีงบประมาณ)'
}

Table hr_holiday_groups {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  calendarId Int [not null, note: '📌 ผูกกับ Calendar (บอกว่าชุดวันหยุดนี้เป็นของปีไหน/รอบไหน)']
  calendar hr_calendars [not null]
  code String [not null, note: 'รหัสชุดวันหยุด เช่น "OFFICE_2026", "FACTORY_2026"']
  nameTh String [not null, note: 'คำอธิบาย (ภาษาไทย) เช่น "วันหยุดประจำปี พนักงานออฟฟิศ"']
  nameEn String [note: 'คำอธิบาย (ภาษาอังกฤษ)']
  status HolidayGroupStatus [not null, default: 'DRAFT', note: 'สถานะของกลุ่มวันหยุด']
  publishedAt DateTime [note: 'วันที่กด Published (เอาไว้ดูว่าประกาศเมื่อไหร่)']
  isCompensateWhenOffDay Boolean [not null, default: true, note: '📌 กฎการชดเชย: ถ้าวันหยุดตรงกับวันหยุดประจำสัปดาห์ (Off-day) ให้ชดเชยหรือไม่?']
  holidays hr_holidays [not null, note: 'ความสัมพันธ์ไปหา Detail (วันหยุดย่อย) และกะงาน']
  workPatterns hr_work_patterns [not null]
  HrRoster HrRoster [not null]

  indexes {
    (companyId, calendarId, code) [unique]
  }

  Note: '1. HOLIDAY GROUP (Master - หัว)'
}

Table hr_holidays {
  id Int [pk, increment]
  companyId Int [not null, note: '🌟 เพิ่ม companyId และ Relation กลับไปที่บริษัท']
  company org_companies [not null]
  groupId Int [not null, note: '📌 ชี้กลับไปที่หัว (Holiday Group)']
  group hr_holiday_groups [not null]
  date DateTime [not null, note: 'วันที่หยุดจริง']
  nameTh String [not null, note: 'ชื่อวันหยุด (ภาษาไทย) เช่น "วันสงกรานต์"']
  nameEn String [note: 'ชื่อวันหยุด (ภาษาอังกฤษ) เช่น "Songkran Festival"']
  category HolidayCategory [not null, default: 'PUBLIC']
  isActive Boolean [not null, default: true, note: 'เปิด/ปิด การใช้งานวันหยุดนี้ (มีผล/ยกเลิก)']
  HrRosterDetail HrRosterDetail [not null]

  indexes {
    (companyId, groupId, date) [unique]
  }

  Note: '2. HOLIDAY DETAIL (Detail - หาง)'
}

Table hr_work_patterns {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null]
  name String [not null]
  cycleDays Int [not null, default: 7]
  isActive Boolean [not null, default: true]
  calendarId Int [note: '2. ชี้กลับไปหาปฏิทิน (HrCalendar)']
  calendar hr_calendars
  holidayGroupId Int [note: '3. ชี้กลับไปหาชุดวันหยุด (HrHolidayGroup)']
  holidayGroup hr_holiday_groups
  employeeHistories hr_employee_patterns [not null, note: '🌟 [เพิ่มบรรทัดนี้เข้าไปครับ] เพื่อรับ Relation จากประวัติกะ']
  items hr_work_pattern_items [not null]
  schedules hr_employee_schedules [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  HrRoster HrRoster [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: 'WORK PATTERN MASTER (หัว - แม่พิมพ์รูปแบบการทำงาน)'
}

Table hr_work_pattern_items {
  id Int [pk, increment]
  companyId Int [not null, note: '🌟 จุดที่ 1: เพิ่ม Relation ชี้กลับไปที่ OrgCompany ให้ชัดเจน']
  company org_companies [not null]
  patternId Int [not null]
  pattern hr_work_patterns [not null]
  dayIndex Int [not null, note: 'ลำดับวันที่ในรอบ เช่น 1=จันทร์, 2=อังคาร ... 7=อาทิตย์ หรือถ้าทำ 4 หยุด 2 ก็จะมี index 1 ถึง 6']
  shiftId Int [note: '🚩 กะการทำงาน (ถ้าเป็น Null แปลว่าวันนั้นคือ "วันหยุดประจำสัปดาห์ (Off Day)")']
  shift hr_shifts

  indexes {
    (companyId, patternId, dayIndex) [unique]
  }

  Note: 'WORK PATTERN ITEM (หาง - กำหนดกะในแต่ละวันของรอบ)'
}

Table hr_employee_schedules {
  id Int [pk, increment]
  companyId Int [not null, note: '🚩 1. เพิ่มเพื่อความปลอดภัยและ Performance']
  company org_companies [not null]
  employeeId Int [not null]
  employee hr_employees [not null]
  date DateTime [not null]
  shiftId Int [not null]
  shift hr_shifts [not null]
  workPatternId Int
  workPattern hr_work_patterns
  isPublicHoliday Boolean [not null, default: false, note: 'Flag สำหรับ Overrides']
  isDayOff Boolean [not null, default: false, note: 'ก๊อปปี้จาก shift.type มาไว้ เพื่อให้แก้ไขรายวันได้โดยไม่กระทบกะหลัก']
  note String
  createdAt DateTime [default: `now()`, not null, note: '🚩 2. เพิ่มเพื่อการตรวจสอบ']
  updatedAt DateTime [not null]

  indexes {
    (employeeId, date) [unique]
  }

  Note: '⭐️ EMPLOYEE SCHEDULE (ตารางทำงานรายวันของพนักงาน)'
}

Table cfg_rounding_rules {
  id Int [pk, increment, note: 'รหัสลำดับหลักของกฎการปัดเศษ (Primary Key) แบบรันอัตโนมัติ']
  companyId Int [note: 'รหัสอ้างอิงไปยังบริษัท (OrgCompany) เพื่อแยกกฎเกณฑ์ตามแต่ละองค์กร']
  company org_companies
  code String [not null, note: 'รหัสอ้างอิงของกฎ เช่น R_001, RETAIL_ROUND เพื่อใช้เรียกใช้งานในโปรแกรม']
  name String [not null, note: 'ชื่อที่ใช้อธิบายกฎ เช่น "ปัดเศษสตางค์ (0.25, 0.50, 0.75)", "ปัดทิ้งทศนิยมหลักที่ 3"']
  type RoundingType [not null, default: 'DIGIT', note: 'ประเภทของการปัดเศษ (เช่น DIGIT สำหรับปัดตามตำแหน่ง หรือประเภทอื่น ๆ)']
  digitIndex Int [default: 2, note: 'ตำแหน่งทศนิยมที่ต้องการให้นำมาพิจารณาเพื่อปัดเศษ (Default: 2) ✅ Option เสริม: ระบุตำแหน่งทศนิยม (ใช้เฉพาะเมื่อ type = DIGIT) เช่น 3 หมายถึงตัด 2 หลักแรกทิ้ง แล้วเอาหลักที่ 3 เป็นต้นไปมาเทียบ Range']
  ranges cfg_rounding_ranges [not null, note: 'Link ไปหา Detail']
  isActive Boolean [not null, default: true, note: 'สถานะการเปิดใช้งานกฎ (Default: true)']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: 'ระบบกำหนดกฎเกณฑ์การปัดเศษ (Rounding Configuration Master) ซึ่งช่วยให้ระบบสามารถคำนวณราคา ภาษี หรือยอดเงินต่าง ๆ ได้ตามมาตรฐานที่แต่ละบริษัทต้องการ (เช่น กฎการปัดเศษสตางค์ตามมาตรฐานบัญชี หรือการปัดเศษทศนิยมสำหรับราคาสินค้า)'
}

Table cfg_rounding_ranges {
  id Int [pk, increment, note: 'รหัสลำดับหลักของรายการ (Primary Key) แบบรันอัตโนมัติ']
  ruleId Int [not null, note: 'รหัสอ้างอิงไปยังกฎหลัก (CfgRoundingRule)']
  rule cfg_rounding_rules [not null]
  minVal Decimal [not null, note: 'ค่าต่ำสุดของช่วงข้อมูลที่ต้องการตรวจสอบ (รวมค่านี้)']
  maxVal Decimal [not null, note: 'ค่าสูงสุดของช่วงข้อมูลที่ต้องการตรวจสอบ (รวมค่านี้)']
  result Decimal [not null, note: 'ค่าที่จะให้นำไปใช้หลังจากผ่านเงื่อนไขในช่วงนี้']
  sortOrder Int [not null, default: 0, note: 'ลำดับการตรวจสอบข้อมูล (ใช้ในกรณีที่มีช่วงข้อมูลซ้อนทับกัน เพื่อระบุว่าจะให้เช็คเงื่อนไขใดก่อน)']

  Note: 'ทำหน้าที่เก็บ รายละเอียดเงื่อนไขในช่วงตัวเลข (Range Logic) เพื่อกำหนดว่าถ้าตัวเลขตกอยู่ในช่วงที่ระบุ จะให้ปัดเศษเป็นค่าใด โดยทำงานเป็นตารางลูก (Child Table) ที่เชื่อมโยงกับ CfgRoundingRule เพื่อให้การปัดเศษมีความยืดหยุ่นสูงมาก เช่น การปัดเศษสตางค์แบบขั้นบันได'
}

Table hr_leave_types {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null]
  name String [not null]
  color String [default: '#4F46E5', note: '🎨 สีสำหรับแสดงผลหน้าบ้าน']
  accrualType AccrualType [not null, default: 'LUMP_SUM', note: '--- กติกาการแจกสิทธิ์ ---']
  carryOverPolicyId Int [note: '--- นโยบายทบวันลา (แยก Master-Detail) ---']
  carryOverPolicy hr_carry_over_policies
  substitutions hr_leave_substitutions [not null, note: 'Back-relation สำหรับการยืมวันลา']
  substitutedBy hr_leave_substitutions [not null]
  adjustments hr_leave_adjustments [not null, note: 'Back-relation สำหรับการปรับปรุงยอด']
  entitlementTiers hr_leave_entitlement_tiers [not null]
  balances hr_leave_balances [not null]
  requests hr_leave_requests [not null]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: 'ประเภทของการลา'
}

Table hr_leave_entitlement_tiers {
  id Int [pk, increment]
  leaveTypeId Int [not null]
  leaveType hr_leave_types [not null]
  departmentCode String [not null, default: '*', note: 'เงื่อนไข แผนก/ตำแหน่ง (ใช้ "*" แทน ทั้งหมด)']
  positionCode String [not null, default: '*']
  minServiceMonths Int [not null, default: 0]
  maxServiceMonths Int
  quotaAmount Decimal [not null]

  Note: 'ตัว detail สำหรับกฎการแจกสิทธิ์ของ Leave แต่ละประเภท'
}

Table hr_carry_over_policies {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  name String [not null]
  description String
  maxCarryDays Decimal [not null, default: 0]
  carryOverExpiryMonth Int
  details hr_carry_over_details [not null]
  leaveTypes hr_leave_types [not null]

  Note: 'ตัวหัว กฎการ carry Over ของ Leave แต่ละประเภท'
}

Table hr_carry_over_details {
  id Int [pk, increment]
  companyId Int [not null, note: '🌟 1. ฝัง companyId เพื่อให้เป็น Multi-company สมบูรณ์แบบ']
  company org_companies [not null]
  policyId Int [not null]
  policy hr_carry_over_policies [not null]
  departmentCode String [not null, default: '*']
  positionCode String [not null, default: '*']
  minServiceMonths Int [not null, default: 0]
  carryAmount Decimal
  carryPercent Decimal

  Note: 'ตัว detail สำหรับ carryOver policy'
}

Table hr_leave_substitutions {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 เพิ่ม Company ID เพื่อความปลอดภัย']
  company org_companies [not null]
  departmentCode String [not null, default: '*', note: '🚩 เงื่อนไข: การยืมนี้ใช้กับใคร (Master-Detail Condition) "*" = ทั้งหมด, หรือระบุเฉพาะตำแหน่ง/แผนกที่อนุญาตให้ยืมข้ามประเภทได้']
  positionCode String [not null, default: '*']
  leaveTypeId Int [not null, note: 'ต้นทาง: วันลาที่ถูกใช้จนหมด (เช่น ลาป่วย)']
  leaveType hr_leave_types [not null]
  targetLeaveTypeId Int [not null, note: 'ปลายทาง: วันลาที่จะไปขอยืมมาใช้ (เช่น พักร้อน)']
  targetLeaveType hr_leave_types [not null]
  priority Int [not null, default: 1]
  deductRatio Decimal [not null, default: 1]
  isActive Boolean [not null, default: true]

  indexes {
    (companyId, leaveTypeId, targetLeaveTypeId, departmentCode, positionCode) [unique]
  }

  Note: '4. LEAVE SUBSTITUTION (กติกาการยืมข้ามประเภท)'
}

Table hr_leave_balances {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  employeeId Int [not null]
  employee hr_employees [not null]
  leaveTypeId Int [not null]
  leaveType hr_leave_types [not null]
  calendarId Int [not null, note: '🗓️ เชื่อมกับ Calendar โดยตรง (ระบุรอบปีปฏิทินของการลา)']
  calendar hr_calendars [not null]
  adjustments hr_leave_adjustments [not null]
  quotaAmount Decimal [not null, default: 0, note: '2. ENTITLEMENTS (ฝั่งสิทธิ์ที่ได้รับในรอบปี)']
  proRateAmount Decimal [not null, default: 0]
  broughtForward Decimal [not null, default: 0]
  adjustmentAmount Decimal [not null, default: 0]
  totalQuota Decimal [not null, default: 0, note: 'สิทธิ์รวมทั้งหมด']
  usedAmount Decimal [not null, default: 0, note: '3. USAGE (ฝั่งการใช้งาน)']
  pendingAmount Decimal [not null, default: 0, note: '🌟 เพิ่มใหม่: กั้นวงเงินวันลาที่รออนุมัติ']
  broughtForwardUsedAmount Decimal [not null, default: 0, note: '🌟 เพิ่มใหม่: แทร็กว่าใช้วันลายกยอดไปเท่าไหร่แล้ว (สำคัญมากตอนหมดอายุ)']
  remaining Decimal [not null, default: 0, note: '4. BALANCE (ยอดคงเหลือ)']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, employeeId, leaveTypeId, calendarId) [unique]
  }

  Note: 'ตารางจำนวนคงเหลือของประเภทการลา'
}

Table hr_leave_adjustments {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  balanceId Int [not null, note: '🔗 เชื่อมไปยัง Balance เพื่อให้รู้ว่าปรับยอดของ "พนักงานคนไหน + ประเภทการลาอะไร + รอบปีไหน"']
  balance hr_leave_balances [not null]
  leaveTypeId Int [not null]
  leaveType hr_leave_types [not null]
  amount Decimal [not null, note: '🔢 จำนวนวันที่ปรับ (+) เพิ่ม, (-) ลด']
  reason String [note: '📝 รายละเอียด']
  adjustedById Int [not null, note: '👤 ใครเป็นคนทำ (ควรเชื่อมกับ HrEmployee)']
  adjustedBy hr_employees [not null]
  adjustedDate DateTime [default: `now()`, not null]

  Note: 'ตารางเกี่ยวกับการเพิ่มจำนวน unit ให้ ประเภทการลา'
}

Table hr_leave_requests {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  employeeId Int [not null]
  employee hr_employees [not null]
  calendarId Int [not null]
  calendar hr_calendars [not null]
  leaveTypeId Int [not null]
  leaveType hr_leave_types [not null]
  wfRequestId Int [unique]
  wfRequest wf_requests
  startDate DateTime [not null]
  endDate DateTime [not null]
  daysCount Decimal [not null]
  isSubstituted Boolean [not null, default: false]
  substitutionLog Json
  status LeaveRequestStatus [not null, default: 'PENDING']
  reason String
  documents hr_leave_request_documents [not null, note: 'รองรับการแนบไฟล์หลายใบ เช่น ใบรับรองแพทย์หลายฉบับ หรือเอกสารประกอบอื่นๆ']
  approvedById Int
  approvedBy hr_employees
  approvedAt DateTime
  rejectedReason String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: '7. LEAVE REQUEST (ใบลา - ปรับปรุง)'
}

Table hr_leave_request_documents {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  requestId Int [not null]
  request hr_leave_requests [not null]
  mediaId Int [unique, not null, note: '📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)']
  media SysMedia [not null]
  docType String [note: 'ประเภทเอกสาร เช่น \'MEDICAL_CERT\' (ใบรับรองแพทย์), \'OTHER\'']
  createdAt DateTime [default: `now()`, not null]

  Note: '✅ [NEW] ตารางกลางสำหรับเชื่อมเอกสารแนบการลากับ DMS'
}

Table cfg_geographies {
  id Int [pk, increment, note: 'รหัสลำดับของข้อมูลภูมิศาสตร์ (Primary Key)']
  type String [not null, note: 'ประเภทหรือระดับของข้อมูล เพื่อใช้ในการกรอง (Filter) เช่น PROVINCE (จังหวัด), DISTRICT (อำเภอ/เขต), หรือ SUBDISTRICT (ตำบล/แขวง)']
  code String [not null, note: 'รหัสอ้างอิงทางภูมิศาสตร์']
  nameTh String [not null, note: 'ชื่อไทย']
  nameEn String [note: 'ชื่อภาษาอังกฤษ']
  parentId Int [note: 'อำเภอผูกกับจังหวัด, ตำบลผูกกับอำเภอ']
  parent cfg_geographies
  children cfg_geographies [not null]

  Note: 'เก็บข้อมูลที่ตั้งทางภูมิศาสตร์แบบลำดับชั้น (Hierarchy) สำหรับใช้ในระบบที่อยู่ (Address), การจัดส่งสินค้า, และการคำนวณภาษี โดยออกแบบให้เป็นตารางเดียวที่สามารถเก็บได้ทั้งระดับ จังหวัด, อำเภอ, และตำบล ผ่านการเชื่อมโยงตัวเอง (Self-Relation)'
}

Table cfg_banks {
  id Int [pk, increment, note: 'รหัสลำดับของธนาคาร (Primary Key)']
  code String [unique, not null, note: 'KBANK, SCB, BBL, KTB']
  nameTh String [not null, note: 'ชื่อภาษาไทย']
  nameEn String [not null, note: 'ชื่อภาษาอังกฤษ']
  color String [note: '#138f2d (เอาไว้ทำ UI สวยๆ)']
  logoUrl String [note: 'ที่อยู่ไฟล์รูปภาพโลโก้ของธนาคาร เพื่อใช้แสดงผลในระบบ']
  officialCode String [note: 'รหัส 3 หลักของธปท. (004, 014) ใช้ทำ Payroll']
  sortOrder Int [not null, default: 0, note: 'ลำดับการแสดงผล เพื่อให้สามารถเรียงธนาคารที่ใช้บ่อยไว้ลำดับต้นๆ ได้']
  isActive Boolean [not null, default: true, note: 'สถานะการเปิด/ปิดใช้งานข้อมูลธนาคารนั้นๆ']

  Note: 'เก็บรายชื่อธนาคารพาณิชย์และสถาบันการเงินที่รองรับในระบบ เพื่อใช้เป็นข้อมูลอ้างอิงในการตั้งค่าบัญชีรับเงินของบริษัท, การแจ้งชำระเงินของลูกค้า, และการทำระบบจ่ายเงินเดือน (Payroll) ข้อมูลส่วนนี้จะช่วยให้ UI ของระบบดูเป็นระเบียบและน่าเชื่อถือผ่านการใช้สีและโลโก้ที่ถูกต้อง'
}

Table HrRoster {
  id Int [pk, increment]
  companyId Int [not null]
  code String [not null, note: 'รหัสอ้างอิง เช่น ROSTER-2026-OFFICE']
  name String [not null, note: 'ชื่อตารางงาน']
  patternId Int [not null, note: 'เชื่อมกับรูปแบบการทำงาน']
  holidayGroupId Int [note: 'เชื่อมกับกลุ่มวันหยุด']
  startDate DateTime [not null]
  endDate DateTime [not null]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  company org_companies [not null, note: 'Relations']
  pattern hr_work_patterns [not null]
  holidayGroup hr_holiday_groups
  details HrRosterDetail [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: '📅 ระบบตารางกะกองกลาง (Master Roster) - Multi-company'
}

Table HrRosterDetail {
  id Int [pk, increment]
  rosterId Int [not null]
  companyId Int [not null]
  date DateTime [not null]
  shiftId Int [note: 'กะงาน (null = วันหยุด)']
  isHoliday Boolean [not null, default: false]
  holidayId Int
  holidayName String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  roster HrRoster [not null, note: 'Relations']
  shift hr_shifts
  holiday hr_holidays
  company org_companies [not null]

  indexes {
    (rosterId, date) [unique]
  }

  Note: 'ตารางเก็บรายละเอียดตารางงาน/กะการทำงานรายวัน (Daily Shift Schedule)'
}

Table hr_employee_patterns {
  id Int [pk, increment]
  companyId Int [not null]
  employeeId Int [not null]
  patternId Int [not null]
  startDate DateTime [not null, note: '🚩 หัวใจสำคัญของการเก็บประวัติ (Effective Dates)']
  endDate DateTime
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  company org_companies [not null, note: 'Relations']
  employee hr_employees [not null]
  pattern hr_work_patterns [not null]

  Note: '📅 ตารางประวัติการผูกพนักงานเข้ากับรูปแบบการทำงาน (เก็บ History ได้)'
}

Table wf_module_mappings {
  id Int [pk, increment]
  companyId Int [not null]
  moduleCode String [not null, note: 'รหัสโมดูลหรือเหตุการณ์ เช่น "HR_MOVEMENT", "HR_RESIGN", "COM_ORDER_DISCOUNT"']
  condition String [note: '(Advance) เผื่ออนาคตใส่เงื่อนไข เช่น "salary_increase_percent > 20"']
  workflowId Int [not null, note: 'เชื่อมไปหา WfDefinition (สายอนุมัติที่คุณมีอยู่แล้ว)']
  isActive Boolean [not null, default: true]
  company org_companies [not null]
  workflow wf_definitions [not null]

  Note: 'ตารางจับคู่ว่า "เหตุการณ์ทางธุรกิจ" (เช่น การย้ายแผนก, การลาออก) ต้องใช้ "สายอนุมัติ" ไหน'
}

Table hr_org_structure_versions {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  calendarId Int [not null]
  calendar hr_calendars [not null]
  name String [not null]
  version Int [not null, default: 1]
  status OrgVersionStatus [not null, default: 'DRAFT']
  departmentEvaluations hr_department_evaluations [not null]
  employeeEvaluations hr_employee_evaluations [not null]
  wfRequestId Int [unique, note: '🔗 สะพานเชื่อมไปหา Workflow Engine']
  wfRequest wf_requests
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  departments hr_department_versions [not null]

  indexes {
    (companyId, calendarId, version) [unique]
  }

  Note: 'ตารางนี้ทำหน้าที่จัดการและจัดเก็บ "เวอร์ชันของโครงสร้างองค์กร" (Organizational Structure Versioning) เปรียบเสมือนการทำ Snapshot ผังองค์กรในแต่ละปีปฏิทิน'
}

Table HrManpowerRequest {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 รองรับ Multi-company / Multi-tenant เต็มรูปแบบ']
  company org_companies [not null]
  departmentId Int [not null, note: 'แผนกที่ขอคน']
  positionId Int [not null, note: 'ตำแหน่งที่ขอเพิ่ม  ']
  requestedCount Int [not null, note: 'จำนวนอัตราที่ขอ (เช่น ขอเพิ่ม 2 อัตรา) ']
  reason String [not null]
  wfRequestId Int [unique, note: '🔗 สะพานเชื่อมไปหา Workflow Engine']
  wfRequest wf_requests
  createdAt DateTime [default: `now()`, not null]

  Note: 'ตารางนี้ทำหน้าที่เก็บข้อมูล "ใบคำร้องขอเพิ่มอัตรากำลังคน" (Manpower Request) เมื่อแผนกต่างๆ ต้องการคนเพิ่มในตำแหน่งใดตำแหน่งหนึ่ง'
}

Table hr_department_versions {
  id Int [pk, increment]
  companyId Int [not null, note: '🛡️ เพิ่ม Company ID เพื่อความปลอดภัยระดับ Row-Level']
  company org_companies [not null]
  versionId Int [not null]
  version hr_org_structure_versions [not null]
  originalDeptId Int
  code String [not null]
  name String [not null]
  description String
  sortOrder Int
  parentId Int
  parent hr_department_versions
  children hr_department_versions [not null]
  managerId Int
  deputyManagerId Int
  positions hr_department_position_versions [not null]

  Note: 'ตารางนี้ทำหน้าที่เก็บข้อมูลรายละเอียดของ "แผนก" ในรูปแบบฉบับร่างหรือ Snapshot ภายใต้เวอร์ชันของโครงสร้างองค์กรที่กำหนด'
}

Table hr_department_position_versions {
  id Int [pk, increment]
  companyId Int [not null, note: '🛡️ เพิ่ม Company ID เพื่อความปลอดภัยระดับ Row-Level']
  company org_companies [not null]
  deptVersionId Int [not null]
  deptVersion hr_department_versions [not null]
  positionId Int [not null]
  position hr_positions [not null]
  maxHeadcount Int
  seats hr_position_seats [not null]
  createdAt DateTime [default: `now()`, not null]

  indexes {
    (deptVersionId, positionId) [unique]
  }

  Note: 'ตารางนี้ทำหน้าที่จัดเก็บการจับคู่ระหว่าง "แผนก" และ "ตำแหน่งงาน" (Mapping) ภายในเวอร์ชันโครงสร้างองค์กรนั้นๆ รวมถึงกำหนด "กรอบอัตรากำลัง" (Headcount) ที่วางแผนไว้สำหรับตำแหน่งนั้นในแต่ละแผนก'
}

Table hr_position_seats {
  id Int [pk, increment]
  companyId Int [not null, note: '1. ระบุบริษัทเพื่อความปลอดภัยและการทำ Multi-company']
  company org_companies [not null]
  positionVerId Int [not null, note: '2. เชื่อมโยงกับผังองค์กร (เวอร์ชันปฏิทิน)']
  positionVersion hr_department_position_versions [not null]
  seatNumber String [not null, note: '3. ข้อมูลเลขที่ตำแหน่ง']
  status String [not null, default: 'VACANT', note: '4. สถานะเก้าอี้: VACANT (ว่าง), OCCUPIED (มีคนนั่ง), FROZEN (ระงับงบประมาณ)']
  currentEmployeeId Int [unique, note: '5. ใครครองตำแหน่งนี้อยู่ (เชื่อมไปที่พนักงาน)']
  currentEmployee hr_employees
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, seatNumber) [unique]
  }

  Note: '🌟 ตารางเก้าอี้ตำแหน่ง (รองรับทั้งภาครัฐและเอกชนขนาดใหญ่)'
}

Table SysMedia {
  id Int [pk, increment]
  companyId Int [not null]
  url String [unique, not null]
  size Int [not null, note: 'ขนาดไฟล์ (Bytes)']
  module String [not null, note: 'ชื่อโมดูล เช่น \'announcement\', \'product\', \'knowledge\'']
  refId Int [note: 'ID ของข้อมูลที่ผูกด้วย (ถ้าเป็น null แปลว่าไฟล์ขยะ!)']
  createdAt DateTime [default: `now()`, not null]
  company org_companies [not null]
  crmRewards crm_rewards [not null, note: '🚩 [เพิ่มใหม่] เพื่อรองรับความสัมพันธ์ย้อนกลับจากรูปภาพของรางวัล CRM']
  crmMembers crm_members [not null, note: '🚩 [เพิ่มใหม่] เพื่อรองรับความสัมพันธ์ย้อนกลับจากรูปโปรไฟล์สมาชิก CRM']
  employeeProfile hr_employees [note: '✅ [NEW] เพิ่มส่วนนี้เพื่อเชื่อมกับพนักงาน 1. เชื่อมกลับไปยังรูปโปรไฟล์พนักงาน (แบบ 1:1)']
  employeeDoc hr_employee_documents [note: '2. เชื่อมกลับไปยังเอกสารพนักงาน (แบบ 1:1 ผ่าน HrEmployeeDocument)']
  productReviewMedia com_product_review_media
  comInvoice com_invoices [note: '🚩 [เพิ่มใหม่] รองรับความสัมพันธ์ย้อนกลับจากรูป/ไฟล์ PDF ใบกำกับภาษี']
  kpiPlanDoc hr_kpi_plan_documents
  kpiEvidence hr_kpi_evidences
  disciplinaryDoc hr_disciplinary_documents [note: '✅ [NEW] เชื่อมกลับไปบทลงโทษ']
  trainingDoc hr_training_documents [note: '✅ [NEW] เชื่อมกลับไปยังเอกสารอบรม']
  meetingRoomMedia adm_meeting_room_media [note: '✅ [NEW] เชื่อมกลับไปยังรูปห้องประชุม']
  welfareRequestDoc hr_welfare_request_documents [note: '✅ [NEW] เชื่อมกลับไปยังเอกสารเบิกสวัสดิการ']
  assetAttachment adm_asset_attachments [note: '✅ [NEW] เชื่อมกลับไปยัง Asset และ Request']
  assetRequestDoc adm_asset_request_documents
  decorationDoc hr_employee_decoration_documents [note: '✅ [NEW] เชื่อมกลับไปยังเอกสารเครื่องราชฯ']
  grievanceEvidence hr_grievance_evidences [note: '✅ [NEW] เชื่อมกลับไปยังหลักฐานการร้องเรียน']
  leaveRequestDoc hr_leave_request_documents [note: '✅ [NEW] เชื่อมกลับไปยังเอกสารการลา']
  salaryAdjDoc hr_salary_adjustment_documents [note: '✅ [NEW] เชื่อมกลับไปยังระบบเงินเดือน']
  payrollSlip hr_payroll_slips
  crmRedemptionDocument crm_redemption_documents [note: '🚩 [เพิ่มใหม่] เพื่อรองรับความสัมพันธ์ย้อนกลับจากตารางหลักฐานการแลกของรางวัล crm']
  purchaseDoc ecom_purchase_documents [note: '✅ Back-relations สำหรับ E-commerce']
  paymentSlip ecom_payment_slips
  shippingDoc ecom_shipping_documents
  promotionDoc ecom_promotion_documents
  returnDoc ecom_return_documents
  announcementMedia com_announcement_media [note: '✅ Back-relation สำหรับประกาศ']
  shopDoc com_shop_documents
  shopLogoProfile com_shop_profiles [note: '✅ [NEW] Back-relation สำหรับรูปโลโก้ของหน้าร้าน']
  warehouseDoc com_warehouse_documents [note: '✅ [NEW] Back-relation สำหรับเอกสารคลังสินค้า']
  companyLogo org_company_infos [note: '✅ [NEW] Back-relation สำหรับข้อมูลบริษัท']
  companyDoc org_company_documents

  Note: 'ตารางกลางสำหรับคุมไฟล์ทุกชนิดในระบบ'
}

Table org_api_keys {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  keyName String [not null, note: 'ชื่อคีย์ (เช่น "Production Key", "Test Key")']
  apiKey String [unique, not null, note: 'รหัส API Key (เช่น "kkv_live_8f7d6a5...")']
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'จัดการ API Key สำหรับให้ลูกค้าภายนอกเชื่อมต่อระบบ KKV'
}

Table log_slip_verifications {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  transRef String [unique, not null, note: '🌟 รหัสอ้างอิงจากธนาคาร (ตั้ง Unique เพื่อป้องกันการนำสลิปเดิมมาวนใช้ซ้ำทั้งแพลตฟอร์ม)']
  senderBank String
  senderName String
  receiverBank String
  receiverName String
  amount Decimal [not null]
  transferDate DateTime
  status String [not null, note: 'สถานะการตรวจสอบ: SUCCESS, DUPLICATE, INVALID']
  source String [not null, note: 'แหล่งที่มา: \'INTERNAL_ORDER\' (ลูกค้ากดสั่งซื้อหน้าเว็บ), \'EXTERNAL_API\' (ลูกค้า B2B ยิงมา)']
  createdAt DateTime [default: `now()`, not null]

  Note: 'สมุดข่อยบันทึกประวัติการตรวจสอบสลิป (ป้องกันสลิปซ้ำและใช้คิดเงิน API)'
}

Table sec_otps {
  id Int [pk, increment]
  companyId Int
  company org_companies
  shopId Int [note: '🌟 เพิ่มการผูกกับหน้าร้านค้า']
  shop com_shop_profiles
  email String [not null]
  code String [not null]
  purpose String [not null, default: 'LOGIN']
  isUsed Boolean [not null, default: false]
  expiresAt DateTime [not null]
  createdAt DateTime [default: `now()`, not null]

  Note: 'จัดการและเก็บประวัติรหัสผ่านแบบใช้ครั้งเดียว (OTP) ที่ส่งผ่านระบบอีเมล สำหรับใช้ในการยืนยันตัวตนและรักษาความปลอดภัยของระบบครับ'
}

Table hr_kpi_plan_versions {
  id Int [pk, increment]
