  items hr_kpi_plan_items [not null]
  deptEvaluations hr_department_evaluations [not null]
  empEvaluations hr_employee_evaluations [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'ตารางเก็บ "เวอร์ชันของแผนเป้าหมาย" (ล็อกเป้าหมายต้นปี/กลางปี)'
}

Table hr_kpi_plan_items {
