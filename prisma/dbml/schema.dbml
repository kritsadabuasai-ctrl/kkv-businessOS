  company org_companies [not null]
  employeeId Int [not null]
  employee hr_employees [not null]
  cycleId Int [not null]
  cycle hr_kpi_cycles [not null]
  orgVersionId Int [not null, note: 'ล็อก Snapshot ตามโครงสร้างองค์กร (ป้องกันเวลาย้ายแผนก)']
  orgVersion hr_org_structure_versions [not null]
  departmentNodeId Int [not null]
  managerId Int [note: 'ล็อกหัวหน้างานผู้ประเมิน ณ เวลานั้น   ']
  manager hr_employees
  planVersionId Int [note: 'อ้างอิงแผนเผื่อกรณีมีการดึงเป้าองค์กรมาให้คน']
  planVersion hr_kpi_plan_versions
  workflowRequestId Int [note: 'Workflow สำหรับอนุมัติประเมินผลของบุคคล']
  status KpiEvaluationStatus [not null, default: 'GOAL_SETTING', note: 'การให้คะแนน (ดึงจากของเดิมคุณมาใส่ให้ครบ)']
  totalKpiScore Decimal
  totalComScore Decimal [note: 'สำหรับคะแนน Competency/Behavior']
  finalScore Decimal
  grade String [note: 'A, B, C, D']
  selfRemark String [note: 'ความเห็น']
  managerRemark String
  items hr_employee_evaluation_items [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'ตารางเก็บ "หัวใบประเมินของพนักงาน" (แทนที่ HrKpiEvaluation เดิม)'
}

Table hr_employee_evaluation_items {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
