  companyId Int [not null]
  company org_companies [not null]
  cycleId Int [not null]
  cycle hr_kpi_cycles [not null]
  orgVersionId Int [not null, note: 'ล็อก Snapshot ตามโครงสร้างองค์กร']
  orgVersion hr_org_structure_versions [not null]
  departmentNodeId Int [not null]
  planVersionId Int [not null, note: 'ล็อกตามแผนตัวชี้วัดที่ใช้']
  planVersion hr_kpi_plan_versions [not null]
  workflowRequestId Int
  totalScore Decimal
  status KpiEvaluationStatus [not null, default: 'GOAL_SETTING']
  items hr_department_evaluation_items [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'ตารางเก็บ "หัวใบประเมินของแผนก"'
}

Table hr_department_evaluation_items {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  evaluationId Int [not null]
  evaluation hr_department_evaluations [not null]
  kpiId Int [not null]
  kpiMaster hr_kpi_libraries [not null]
  evidences hr_kpi_evidences [not null, note: '✅ เพิ่มความสัมพันธ์ไปยังตารางหลักฐาน']
  weight Decimal [not null]
  targetValue Decimal [not null]
  actualValue Decimal [note: 'ผลงานจริง']
  score Decimal [note: 'คะแนนที่แปลงแล้ว']
  alignedEmployeeItems hr_kpi_alignments [not null]

  Note: 'ตารางเก็บ "คะแนนรายข้อของแผนก"'
}

Table hr_employee_evaluations {
  id Int [pk, increment]
