}

Table hr_kpi_cycles {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  calendarId Int [not null, note: '🌟 1. ผูกเข้ากับ HrCalendar โครงสร้างหลักของคุณ']
