  shop com_shop_profiles
  providerName String [not null, note: 'ชื่อขนส่ง เช่น \'FLASH\', \'KERRY\', \'JNT\', \'THAIPOST\', \'NINJAVAN\'']
  isActive Boolean [not null, default: true]
  apiKey String [note: 'ข้อมูลเชื่อมต่อ API ของขนส่งเจ้านั้นๆ']
  apiSecret String
  merchantId String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, shopId, providerName) [unique]
  }

  Note: '🚚 [NEW] ตั้งค่าการเชื่อมต่อ API ขนส่งภายนอก (รองรับรายบริษัท และรายสาขา)'
}

Table cfg_payment_gateways {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  shopId Int [note: '🌟 [เพิ่มใหม่] รองรับ Multi-Shop (Null = ใช้การตั้งค่าส่วนกลางของบริษัท)']
  shop com_shop_profiles
  providerName String [not null, note: 'ชื่อผู้ให้บริการ เช่น \'OMISE\', \'GBPRIME\', \'STRIPE\', \'KSHER\'']
  isActive Boolean [not null, default: true]
  publicKey String [note: 'ข้อมูลเชื่อมต่อ API ']
  secretKey String
  merchantId String
  webhookSecret String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

