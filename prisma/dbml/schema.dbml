Table doc_file_access {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null, note: '🌟 เพิ่มบรรทัดนี้: เชื่อมกลับไปหา OrgCompany']
  fileId Int [not null]
  file doc_files [not null]
  roleId Int
  role sec_roles [note: '🌟 เพิ่มบรรทัดนี้: เชื่อมกลับไปหา SecRole']
  userId Int
  user sec_users
  canView Boolean [not null, default: false]
  canDownload Boolean [not null, default: false]
  expiresAt DateTime
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: 'ตารางกำหนดสิทธิ์ระดับไฟล์แยกย่อย (File RBAC) - เผื่อกรณีไฟล์ลับพิเศษ'
}

Table doc_file_share_links {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  fileId Int [not null]
  file doc_files [not null]
  token String [unique, not null, note: 'รหัสสุ่มสำหรับแชร์ เช่น kkv.com/share/abc123xyz']
  password String [note: 'รหัสผ่าน (ถ้ามีการตั้งรหัสผ่านก่อนโหลด)']
  expiresAt DateTime [note: 'วันหมดอายุของลิงก์นี้']
  maxDownloads Int [note: 'จำนวนครั้งที่อนุญาตให้โหลด (เช่น โหลดได้แค่ 1 ครั้ง)']
  currentDownloads Int [not null, default: 0]
  createdBy Int [not null]
  createdAt DateTime [default: `now()`, not null]

  Note: '2. เพิ่มตารางใหม่สำหรับ External Sharing'
}

Table doc_signature_requests {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 รองรับ Multi-company']
  company org_companies [not null]
  fileId Int [not null]
  file doc_files [not null]
  wfRequestId Int [note: '🌟 [เพิ่มใหม่] 1. ผูกกับ Workflow Request เพื่อให้รู้ว่าคำขอเซ็นนี้มาจากโฟลว์ไหน']
  wfRequest wf_requests
  stepOrder Int [not null, default: 1, note: '🌟 [เพิ่มใหม่] 2. ลำดับขั้นตอนการเซ็น (เช่น 1 = หัวหน้าเซ็น, 2 = ผอ.เซ็น)']
  signerId Int [note: '👤 ผู้ที่ต้องเซ็น (รองรับทั้งคนในระบบ และคนนอกผ่าน Email)']
  signer sec_users
  signerName String [not null, note: 'ชื่อที่แสดงตอนเซ็น']
  signerEmail String [not null, note: 'อีเมลผู้รับคำขอ (ใช้ส่งแจ้งเตือน หรือระบุตัวตนคนนอก) ']
  status String [not null, default: 'PENDING', note: '🚩 สถานะของคำขอ (เช่น PENDING, SIGNED, REJECTED, CANCELED)']
  pageNumber Int [default: 1, note: '📍 ตำแหน่งที่ระบุให้เซ็นบน PDF (Frontend จะใช้ค่านี้ไปวางหน้าจอ)']
  posX Float
  posY Float
  expiredAt DateTime [note: '🕒 ข้อมูลเวลา']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  signature doc_signatures [note: 'เชื่อมไปยังผลลัพธ์การเซ็น']

  Note: '🖋️ ตารางคำขอเซ็นเอกสาร (Signature Request) ใช้สำหรับจัดการว่าไฟล์นี้ใครต้องเป็นคนเซ็นบ้าง และสถานะเป็นอย่างไร'
}

Table doc_signatures {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  requestId Int [unique, not null]
  request doc_signature_requests [not null]
  signatureImage String [note: '🖼️ ข้อมูลลายเซ็น เก็บเป็น URL รูปภาพ (PNG/SVG) หรือ Base64 ของลายเซ็นที่วาด']
  signedAt DateTime [default: `now()`, not null, note: '🔐 ข้อมูลเพื่อความปลอดภัยทางกฎหมาย (e-Signature Compliance)']
  ipAddress String
  userAgent String
  fileHashAtSigning String [note: '🛡️ ระบบป้องกันการแก้ไขไฟล์ (Data Integrity) เก็บ Hash ของไฟล์ ณ จังหวะที่เซ็น ถ้าไฟล์ถูกแก้หลังจากนี้ Hash จะไม่ตรง']
  digitalCertificateId String [note: '🔒 ลายเซ็นแบบดิจิทัล (ถ้ามีระบบ PKI/Certificate ในอนาคต)']

  Note: '📑 ตารางเก็บข้อมูลลายเซ็นที่เกิดขึ้นจริง'
}

Table sec_login_logs {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  userId Int [not null]
  user sec_users [not null]
  loginAt DateTime [default: `now()`, not null]
  ipAddress String [note: 'เก็บ IP ของผู้ใช้งาน']
  userAgent String [note: 'เก็บเบราว์เซอร์และอุปกรณ์ที่ใช้ (Chrome, Mac, iPhone)']
  status String [not null, note: '"SUCCESS" หรือ "FAILED"']
  failureReason String [note: 'เช่น "Invalid Password" หรือ "Account Locked"  ']

  Note: 'ตารางบันทึกการเข้าสู่ระบบ (SecLoginLog) ใครแอบเข้าใช้งานบัญชีนี้จากที่ไหน" และ "มีการพยายามสุ่มรหัสผ่าน (Brute Force) หรือไม่'
}

Table crm_referrals {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 รองรับ Multi-company (ล็อกว่าชวนกันในบริษัท/แบรนด์ไหน)']
  company org_companies [not null]
  referrerId Int [not null, note: '🗣️ คนชวน (Referrer / Affiliate)']
  referrer crm_members [not null]
  refereeId Int [unique, not null, note: '👤 คนถูกชวน (Referee / Invitee)']
  referee crm_members [not null]
  status String [not null, default: 'PENDING', note: '🚩 สถานะ: เช่น PENDING (แค่สมัครแต่ยังไม่ซื้อ), SUCCESS (ซื้อของแล้ว คนชวนได้ค่าคอม)']
  rewardEarned Decimal [not null, default: 0, note: '💰 ยอดรวมค่าคอมมิชชันหรือแต้มที่คนชวนได้จากคนนี้']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: '🤝 ตารางเก็บความสัมพันธ์การแนะนำเพื่อน/ตัวแทน (Referral)'
}

Table crm_commission_logs {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  memberId Int [not null, note: '👤 ตัวแทนที่ได้รับค่าคอม']
  member crm_members [not null]
  amount Decimal [not null, note: '💸 จำนวนเงินที่เข้า/ออก']
  balanceAfter Decimal [not null]
  type String [not null, note: '🏷️ ประเภทรายการ: "EARN" (ได้ค่าคอม), "WITHDRAW" (ถอนเงิน), "REFUND" (โดนดึงคืนเพราะลูกค้าคืนของ)']
  status String [not null, default: 'APPROVED', note: '🚩 สถานะ: "PENDING" (รอตรวจสอบการจ่าย), "APPROVED" (จ่ายเงินแล้ว)']
  refOrderId Int [note: '🧾 อ้างอิงว่าได้ค่าคอมจาก Order ไหน']
  note String
  createdAt DateTime [default: `now()`, not null]

  Note: '💰 ตารางบันทึกรายได้จากค่าคอมมิชชัน (Commission Ledger)'
}

Table hr_offense_types {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null]
  name String [not null]
  severity OffenseSeverity [not null, default: 'MINOR']
  description String
  incidents hr_disciplinary_incidents [not null]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: '📋 1. Master Data: หมวดหมู่ความผิด (แยกตามบริษัท)'
}

Table hr_penalty_types {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null, note: 'เช่น "WARNING_1", "SUSPENSION", "FIRE"']
  name String [not null, note: 'เช่น "ตักเตือนด้วยวาจา", "ตักเตือนเป็นลายลักษณ์อักษร", "พักงาน", "เลิกจ้าง"']
  isSuspension Boolean [not null, default: false, note: '🚩 Flags สำหรับนำไปผูกกับระบบอื่น (เช่น Payroll หรือ Time Attendance) ถ้าเป็น true หมายถึงห้ามมาทำงาน/งดจ่ายเงิน']
  isTermination Boolean [not null, default: false, note: 'ถ้าเป็น true หมายถึงให้พ้นสภาพพนักงาน']
  description String
  actions hr_disciplinary_actions [not null]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: '📋 2. Master Data: ประเภทบทลงโทษ (แยกตามบริษัท)'
}

Table hr_disciplinary_incidents {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  docNo String [not null, note: 'เลขที่ใบแจ้งความผิด เช่น DIS-2026-0001']
  employeeId Int [not null, note: '👤 ผู้กระทำผิด']
  employee hr_employees [not null]
  reporterId Int [not null, note: '🕵️ ผู้แจ้งเบาะแส / ผู้ตั้งเรื่อง (เช่น HR หรือ หัวหน้างาน)']
  reporter sec_users [not null]
  offenseTypeId Int [not null]
  offenseType hr_offense_types [not null]
  incidentDate DateTime [not null, note: 'วันที่และเวลาเกิดเหตุ']
  location String [note: 'สถานที่เกิดเหตุ ']
  description String [not null, note: 'พฤติการณ์การกระทำความผิด (บรรยาย) ']
  evidenceUrls String[] [not null, note: 'รูปภาพ/หลักฐานไฟล์แนบ (เก็บลิงก์ GCS เป็น Array)']
  status DisciplinaryStatus [not null, default: 'DRAFT']
  wfRequestId Int [unique, note: '🔗 เชื่อมเข้ากับ WfRequest (ระบบ Workflow) เพื่อส่งเรื่องให้ ผอ./คณะกรรมการ อนุมัติบทลงโทษ']
  wfRequest wf_requests
  actions hr_disciplinary_actions [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, docNo) [unique]
  }

  Note: '🚨 3. Transaction: บันทึกเหตุการณ์กระทำความผิด (Incident / Ticket)'
}

Table hr_disciplinary_actions {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  incidentId Int [not null]
  incident hr_disciplinary_incidents [not null]
  penaltyTypeId Int [not null]
  penaltyType hr_penalty_types [not null]
  startDate DateTime [note: '🗓️ ระยะเวลาบังคับใช้ (เช่น พักงานตั้งแต่วันที่ 1-3 หรือ คุมประพฤติ 6 เดือน)']
  endDate DateTime
  remark String [note: 'ข้อมูลประกอบการพิจารณาโทษ หรือ บทสรุปจากคณะกรรมการ']
  appealedGrievances hr_grievance_tickets [not null]
  approvedById Int [note: 'ผู้มีอำนาจสั่งลงโทษ (มักจะมาจากคนที่กด Approve ขั้นสุดท้ายใน Workflow)']
  approvedBy sec_users
  documents hr_disciplinary_documents [not null, note: '✅ [NEW] บรรทัดที่ต้องเพิ่ม: เชื่อมโยงไปหาเอกสารประกอบการลงโทษ (1 Action มีได้หลาย Document)']
  createdAt DateTime [default: `now()`, not null]

  Note: '⚖️ 4. Transaction: บทลงโทษที่ได้รับจากเหตุการณ์นั้น'
}

Table hr_training_courses {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null, note: 'รหัสหลักสูตร เช่น "TR-LEAD-01" ']
  name String [not null, note: 'ชื่อหลักสูตร เช่น "หลักสูตรผู้นำยุคใหม่"']
  description String
  category String [note: 'จัดหมวดหมู่ (อาจจะผูกกับตาราง Category อีกทีก็ได้) เช่น "Soft Skills", "Technical", "Mandatory"']
  creditHours Decimal [note: 'จำนวนชั่วโมง/เครดิตที่ได้เมื่อเรียนจบ']
  sessions hr_training_sessions [not null]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: '📚 1. Master Data: ทะเบียนหลักสูตร (แยกตามบริษัท)'
}

Table hr_training_sessions {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  courseId Int [not null]
  course hr_training_courses [not null]
  calendarYear Int [not null, note: '🎯 ผูกกับ Calendar Year ของคุณ (สมมติเก็บเป็น Int เช่น 2026 หรือ ID ของตาราง Calendar)']
  batchName String [not null, note: 'ชื่อรุ่น เช่น "รุ่นที่ 1/2569"']
  location String [note: 'สถานที่จัด (ห้องประชุม, โรงแรม, หรือ Online Link)']
  instructor String [note: 'ชื่อวิทยากร (หรือผูกกับตารางผู้เชี่ยวชาญถ้ามี)']
  startDate DateTime [not null]
  endDate DateTime [not null]
  capacity Int [note: 'จำนวนที่เปิดรับ (ถ้ามีจำกัด)']
  budget Decimal [note: 'งบประมาณที่ใช้จัด']
  status TrainingSessionStatus [not null, default: 'PLANNING']
  wfRequestId Int [unique, note: '🔗 เชื่อมกับระบบ Workflow (เช่น ขออนุมัติงบประมาณจัดอบรม)']
  wfRequest wf_requests
  enrollments hr_training_enrollments [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: '🗓️ 2. Transaction: รอบการจัดอบรม (ผูกกับ Calendar Year)'
}

Table hr_training_enrollments {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  sessionId Int [not null]
  session hr_training_sessions [not null]
  employeeId Int [not null]
  employee hr_employees [not null]
  status EnrollmentStatus [not null, default: 'REGISTERED']
  preTestScore Decimal [note: '📊 ผลการประเมิน']
  postTestScore Decimal
  isPassed Boolean
  certificateUrl String [note: '📜 ไฟล์ใบประกาศนียบัตร (ถ้ามี)']
  remark String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, sessionId, employeeId) [unique]
  }

  Note: '🎓 3. Transaction: ผู้ลงทะเบียนและผลการอบรม (พนักงาน 1 คน ต่อ 1 รอบ)'
}

Table hr_royal_decorations {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null, note: 'ตัวย่อ เช่น "บ.ม.", "ต.ช.", "ท.ม.", "ป.ช."']
  name String [not null, note: 'ชื่อเต็ม เช่น "เบญจมาภรณ์มงกุฎไทย", "ตริตาภรณ์ช้างเผือก"']
  classLevel Int [not null, note: 'ระดับชั้นตรา (ใช้สำหรับการ Sorting และคำนวณว่าต้องคืนตราชั้นต่ำกว่าหรือไม่) เช่น 1 = ชั้นประถมาภรณ์, 5 = ชั้นเบญจมาภรณ์, 8 = เหรียญจักรพรรดิมาลา']
  description String
  isReturnRequired Boolean [not null, default: true, note: 'ตั้งค่าว่าเครื่องราชชั้นนี้ เมื่อได้ชั้นสูงกว่า ต้องคืนหรือไม่']
  records hr_employee_decorations [not null]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: '🎖️ 1. Master Data: แคตตาล็อกตระกูลและชั้นตราเครื่องราชอิสริยาภรณ์ (แยกตามบริษัท/หน่วยงาน)'
}

Table hr_employee_decorations {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  employeeId Int [not null]
  employee hr_employees [not null]
  decorationId Int [not null]
  decoration hr_royal_decorations [not null]
  gazetteDate DateTime
  gazetteVolume String
  gazettePart String
  gazettePage String
  receivedDate DateTime
  returnStatus DecorationReturnStatus [not null, default: 'NOT_REQUIRED']
  returnedDate DateTime
  documents hr_employee_decoration_documents [not null, note: '1 ประวัติ อาจแนบทั้งใบกำกับ, หน้าประกาศราชกิจจาฯ, และรูปถ่ายวันรับมอบ']
  remark String
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, employeeId, decorationId) [unique]
  }

  Note: '📜 2. Transaction: ทะเบียนประวัติการได้รับเครื่องราชฯ (ปรับปรุง)'
}

Table hr_employee_decoration_documents {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  decorationRecordId Int [not null]
  decorationRecord hr_employee_decorations [not null]
  mediaId Int [unique, not null, note: '📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)']
  media SysMedia [not null]
  docType String [note: 'ประเภทเอกสาร: \'GAZETTE\' (ราชกิจจา), \'CERTIFICATE\' (ใบกำกับ), \'RETURN_RECEIPT\' (ใบรับส่งคืน)']
  createdAt DateTime [default: `now()`, not null]

  Note: '✅ [NEW] ตารางกลางสำหรับเชื่อมเอกสารหลักฐานเครื่องราชฯ กับ DMS'
}

Table adm_meeting_rooms {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  name String [not null]
  location String
  capacity Int [not null]
  images adm_meeting_room_media [not null, note: 'รองรับ 1 ห้องมีหลายรูปภาพ (เช่น รูปมุมกว้าง, รูปอุปกรณ์, รูปผังที่นั่ง)']
  basePrice Decimal
  amenities String[] [not null]
  colorCode String [default: '#3b82f6']
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  bookings adm_meeting_bookings [not null]

  Note: '🏢 1. Master Data: ข้อมูลห้องประชุม (ปรับปรุง)'
}

Table adm_meeting_bookings {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  roomId Int [not null]
  room adm_meeting_rooms [not null]
  requesterId Int [not null, note: '👤 ผู้จอง (Employee)']
  requester hr_employees [not null]
  subject String [not null]
  description String
  startDateTime DateTime [not null, note: '🕒 วันเวลา']
  endDateTime DateTime [not null]
  participantCount Int [not null, default: 0, note: '👥 จำนวนผู้เข้าร่วมจริง (เพื่อจัดเตรียมอาหาร/ที่นั่ง)']
  isExternalGuest Boolean [not null, default: false, note: '📝 รายละเอียดเพิ่มเติมสำหรับภาครัฐ']
  cateringDetails String
  status BookingStatus [not null, default: 'DRAFT']
  wfRequestId Int [unique, note: '🔗 เชื่อมเข้ากับ WfRequest (ระบบ Workflow)']
  wfRequest wf_requests
  attendees adm_meeting_attendees [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: '📅 2. Transaction: ข้อมูลการจอง'
}

Table adm_meeting_attendees {
  id Int [pk, increment]
  bookingId Int [not null]
  booking adm_meeting_bookings [not null]
  employeeId Int [note: 'กรณีเป็นคนในระบบ']
  employee hr_employees
  externalName String [note: 'กรณีเป็นบุคคลภายนอก (ราชการมักต้องเก็บชื่อ-นามสกุล)']
  externalEmail String

  Note: '👥 3. รายชื่อผู้เข้าร่วมประชุม'
}

Table adm_meeting_room_media {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  roomId Int [not null]
  room adm_meeting_rooms [not null]
  mediaId Int [unique, not null, note: '📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)']
  media SysMedia [not null]
  sortOrder Int [not null, default: 0]
  createdAt DateTime [default: `now()`, not null]

  Note: '✅ [NEW] ตารางกลางสำหรับเชื่อมรูปภาพห้องประชุมกับ DMS'
}

Table hr_welfare_types {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null]
  name String [not null]
  category WelfareCategory [not null, default: 'OTHER']
  description String
  isFamilyEligible Boolean [not null, default: false, note: '🚩 Flag สำหรับภาครัฐโดยเฉพาะ เบิกให้บุคคลในครอบครัวได้หรือไม่']
  policies hr_welfare_policies [not null]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: '🎁 1. Master Data: ประเภทสวัสดิการ (แยกตามบริษัท)'
}

Table hr_welfare_policies {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  welfareTypeId Int [not null]
  welfareType hr_welfare_types [not null]
  calendarYear Int [not null]
  maxAmountPerYear Decimal [note: '💰 การตั้งค่างบประมาณ วงเงินสูงสุดต่อปี (ต่อคน)']
  maxAmountPerTime Decimal [note: 'วงเงินสูงสุดต่อครั้งการเบิก']
  maxTimesPerYear Int [note: 'จำนวนครั้งที่เบิกได้สูงสุดต่อปี']
  eligibleLevels Int[] [not null, note: '👥 สิทธิ์การเบิก (Level 1-10 ของ KKV) - ถ้าว่างแปลว่าได้ทุกคน']
  requests hr_welfare_requests [not null]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, welfareTypeId, calendarYear) [unique]
  }

  Note: '📅 2. Config Data: นโยบายและวงเงินสวัสดิการ (ผูกตามปีปฏิทิน)'
}

Table hr_welfare_requests {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  policyId Int [not null]
  policy hr_welfare_policies [not null]
  employeeId Int [not null]
  employee hr_employees [not null]
  dependentName String
  dependentRel String
  receiptNo String
  receiptDate DateTime
  amountRequested Decimal [not null]
  amountApproved Decimal
  remark String
  documents hr_welfare_request_documents [not null, note: '1 การเบิก อาจแนบไฟล์ได้หลายอย่าง เช่น ใบเสร็จ + ใบรับรองแพทย์']
  status WelfareRequestStatus [not null, default: 'DRAFT']
  wfRequestId Int [unique]
  wfRequest wf_requests
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: '📝 3. Transaction: การทำเรื่องเบิกส��ัสดิการ (ปรับปรุง)'
}

Table hr_welfare_request_documents {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  requestId Int [not null]
  request hr_welfare_requests [not null]
  mediaId Int [unique, not null, note: '📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)']
  media SysMedia [not null]
  docType String [note: 'ประเภทเอกสาร เช่น \'RECEIPT\', \'MEDICAL_CERT\', \'OTHER\'']
  createdAt DateTime [default: `now()`, not null]

  Note: '✅ [NEW] ตารางกลางสำหรับเชื่อมเอกสารการเบิกสวัสดิการกับ DMS'
}

Table hr_salary_structures {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  level Int [not null, note: 'ผูกกับ Level 1-10 ในระบบ KKV']
  name String [not null]
  minSalary Decimal [not null, note: '💰 โครงสร้างตัวเงิน เงินเดือนขั้นต่ำ']
  maxSalary Decimal [not null, note: 'เงินเดือนขั้นสูง (เพดาน)']
  baseSalary Decimal [note: '🚩 "ฐานคำนวณกลาง" สำหรับใช้คูณ % (สำคัญมากสำหรับราชการ)']
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, level) [unique]
  }

  Note: 'สำหรับเอกชน: ใช้กำหนด Min-Max เพื่อควบคุมไม่ให้เงินเดือนล้นกระบอก  สำหรับราชการ: ใช้กำหนด "ฐานคำนวณ" (Median) ของแต่ละระดับ (Level 1-10)'
}

Table hr_salary_adjustments {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  employeeId Int [not null]
  employee hr_employees [not null]
  reason AdjustmentReason [not null, note: '📝 ข้อมูลการปรับ']
  effectiveDate DateTime [not null, note: 'วันที่มีผล (เช่น 1 เม.ย. หรือ 1 ต.ค.)']
  calcMethod CalculationMethod [not null, note: '🧮 วิธีการคำนวณ และ ตัวเลข']
  calcValue Decimal [not null]
  documents hr_salary_adjustment_documents [not null, note: '✅ [NEW] เชื่อมกับตาราง DMS เพื่อเก็บ "คำสั่งเลื่อนขั้นเงินเดือน" เช่น สแกนไฟล์คำสั่งรายบุคคล หรือ บันทึกข้อความอนุมัติ']
  oldSalary Decimal [not null, note: '💵 สรุปยอดเงิน (ระบบคำนวณแล้วบันทึกค่าตายตัวไว้เป็น History)']
  adjustmentAmount Decimal [not null]
  newSalary Decimal [not null]
  performanceScore Decimal [note: '🔗 เชื่อมกับผลประเมิน (KPI) ถ้ามี']
  wfRequestId Int [unique, note: '🔗 วิ่ง Workflow ขออนุมัติบัญชีรายชื่อเลื่อนเงินเดือน']
  wfRequest wf_requests
  remark String
  createdAt DateTime [default: `now()`, not null]

  Note: '📈 2. Transaction: ประวัติการพิจารณาเลื่อนขั้นเงินเดือน (Salary Adjustment History)'
}

Table hr_salary_adjustment_documents {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  adjustmentId Int [not null]
  adjustment hr_salary_adjustments [not null]
  mediaId Int [unique, not null]
  media SysMedia [not null]
  createdAt DateTime [default: `now()`, not null]

  Note: '✅ [NEW] ตารางกลางสำหรับหลักฐานการปรับเงินเดือน'
}

Table hr_payroll_cycles {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  cycleCode String [not null, note: 'เช่น "2026-04" (เดือน 4 ปี 2026) หรือ "2026-04-P1" (ครึ่งเดือนแรก)']
  startDate DateTime [not null, note: 'วันเริ่มตัดรอบ  ']
  endDate DateTime [not null, note: 'วันสิ้นสุดตัดรอบ']
  paymentDate DateTime [not null, note: 'วันที่เงินโอนเข้าบัญชี (เช่น ทุกวันที่ 25)']
  status PayrollCycleStatus [not null, default: 'DRAFT']
  totalEmployees Int [not null, default: 0]
  totalGrossPay Decimal [not null, default: 0, note: 'รายรับรวมทั้งบริษัท']
  totalDeductions Decimal [not null, default: 0, note: 'รายจ่าย/หักรวม']
  totalNetPay Decimal [not null, default: 0, note: 'ยอดจ่ายสุทธิ']
  wfRequestId Int [unique, note: '🔗 Workflow สำหรับส่งอนุมัติงบเดือนนั้นๆ ให้ CEO/อธิบดี']
  wfRequest wf_requests
  slips hr_payroll_slips [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, cycleCode) [unique]
  }

  Note: '🗓️ 3. Integration: รอบการจ่ายเงินเดือน (Payroll Cycle)'
}

Table hr_payroll_slips {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  cycleId Int [not null]
  cycle hr_payroll_cycles [not null]
  employeeId Int [not null]
  employee hr_employees [not null]
  baseSalary Decimal [not null, note: '💰 ยอดสรุปของพนักงานคนนี้ในรอบนี้']
  totalAllowances Decimal [not null, default: 0, note: 'รวมรายรับอื่นๆ (ค่าตำแหน่ง, โอที, สวัสดิการ)']
  totalDeductions Decimal [not null, default: 0, note: 'รวมรายการหัก (ภาษี, ประกันสังคม, กบข., ขาดงาน)']
  netPay Decimal [not null]
  detailsJson Json [not null, note: 'ตัวอย่าง: { "earnings": [{"name": "โอที", "amount": 1500}], "deductions": [{"name": "ประกันสังคม", "amount": 750}] }']
  pdfMediaId Int [unique, note: 'เพื่อให้พนักงาน Download หรือส่งอีเมล']
  pdfMedia SysMedia
  isPublished Boolean [not null, default: false, note: 'พนักงานจะเห็นสลิปในแอปได้ก็ต่อเมื่อเป็น true']
  createdAt DateTime [default: `now()`, not null]

  indexes {
    (companyId, cycleId, employeeId) [unique]
  }

  Note: '🧾 4. Integration: สลิปเงินเดือนรายบุคคล (Payroll Slip)'
}

Table adm_asset_categories {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null, note: 'เช่น "IT", "FURNITURE", "VEHICLE"']
  name String [not null, note: 'เช่น "ครุภัณฑ์คอมพิวเตอร์", "ครุภัณฑ์สำนักงาน"']
  prefixNumber String [note: 'ตัวอักษรนำหน้าเลขครุภัณฑ์ เช่น "คพ.", "สพ."']
  depreciationYears Int [not null, default: 5, note: 'อายุการใช้งาน/การเสื่อมราคา (ปี)']
  assets adm_assets [not null]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: '📦 1. Master Data: หมวดหมู่ครุภัณฑ์'
}

Table adm_assets {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  categoryId Int [not null]
  category adm_asset_categories [not null]
  assetNumber String [not null, note: '🏷️ ข้อมูลระบุตัวตน เลขครุภัณฑ์ (เช่น 7110-001-0001/2569) **สำคัญมากสำหรับราชการ**']
  serialNumber String [note: 'Serial Number จากผู้ผลิต (เช่น S/N ของ Notebook)']
  name String [not null, note: 'ชื่อรายการ เช่น "MacBook Pro 16-inch M3 Max"']
  brandModel String [note: 'ยี่ห้อ/รุ่น   ']
  fiscalYear Int [not null, note: '📅 ข้อมูลการได้มาและงบประมาณ ปีงบประมาณ/ปีปฏิทิน ที่จัดซื้อ (Calendar Base)']
  acquisitionDate DateTime [not null, note: 'วันที่ตรวจรับพัสดุ']
  acquisitionMethod AcquisitionMethod [not null, default: 'PURCHASE']
  purchasePrice Decimal [not null, note: 'ราคาที่ได้มา']
  vendorName String [note: 'ชื่อร้านค้า/บริษัทที่ซื้อมา']
  attachments adm_asset_attachments [not null, note: 'เก็บรูปถ่ายครุภัณฑ์ 4 ด้าน, Serial Number plate, คู่มือการใช้งาน (PDF)']
  status AssetStatus [not null, default: 'AVAILABLE', note: '📍 สถานะและการครอบครองปัจจุบัน']
  currentLocation String [note: 'สถานที่ตั้งปัจจุบัน (เช่น ห้อง IT, โต๊ะทำงาน A1)']
  assignedToId Int [note: 'ผู้เบิก/ผู้ครอบครองปัจจุบัน (ถ้าเป็น Null คืออยู่ในคลัง)']
  assignedTo hr_employees
  requestItems adm_asset_request_items [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, assetNumber) [unique]
  }

  Note: '🖥️ 2. Core Data: ทะเบียนครุภัณฑ์ (รายตัว)'
}

Table adm_asset_requests {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  docNo String [not null, note: 'เลขที่เอกสาร (เช่น PR-2026-001, WR-2026-015)']
  requestType AssetRequestType [not null]
  fiscalYear Int [not null, note: 'ผูกกับปีงบประมาณ/ปฏิทิน (Calendar Base)']
  requesterId Int [not null]
  requester hr_employees [not null]
  subject String [not null, note: 'หัวข้อคำร้อง']
  reason String [note: 'เหตุผลความจำเป็น  ']
  status AssetRequestStatus [not null, default: 'DRAFT']
  wfRequestId Int [unique, note: '🔗 เชื่อมเข้ากับ WfRequest (ระบบ Workflow)']
  wfRequest wf_requests
  documents adm_asset_request_documents [not null, note: '✅ [NEW] ตารางเชื่อมเอกสารแนบในคำร้อง (เช่น ใบเสนอราคาซ่อม, รูปของพัง)']
  items adm_asset_request_items [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, docNo) [unique]
  }

  Note: '📝 3. Transaction: เอกสารคำร้องเกี่ยวกับครุภัณฑ์ (ขอซื้อ, ขอเบิก, ขอซ่อม, ขอจำหน่าย)'
}

Table adm_asset_request_items {
  id Int [pk, increment]
  requestId Int [not null]
  request adm_asset_requests [not null]
  assetId Int [note: 'กรณีเป็นคำร้องขอ "จัดซื้อ" (PROCUREMENT) จะยังไม่มี assetId ผูกมาด้วย ให้ใส่ชื่อ/ราคาประเมินไปก่อน กรณีเป็นคำร้อง "ขอเบิก/ขอซ่อม/ขอจำหน่าย" จะต้องระบุ assetId ตัวที่มีอยู่จริงในระบบ']
  asset adm_assets
  itemName String [not null, note: 'ชื่อรายการ (กรณีขอซื้อใหม่) หรือ ดึงมาจาก Asset (กรณีซ่อม/จำหน่าย)']
  estimatedPrice Decimal [note: 'ราคาประเมิน (ตอนขอซื้อ) หรือ ราคาประเมินซ่อม']
  quantity Int [not null, default: 1, note: 'จำนวน (มักจะใช้ตอนขอซื้อ ถ้าเบิก/ซ่อมจะเป็น 1 เสมอเพราะผูก ID)']
  remark String

  Note: '📎 4. Transaction Detail: รายการครุภัณฑ์ในเอกสารคำร้อง'
}

Table adm_asset_attachments {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  assetId Int [not null]
  asset adm_assets [not null]
  mediaId Int [unique, not null, note: '📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)']
  media SysMedia [not null]
  attachmentType String [note: 'ประเภทไฟล์: \'PHOTO\' (รูปตัวเครื่อง), \'WARRANTY\' (ใบรับประกัน), \'MANUAL\' (คู่มือ)']
  createdAt DateTime [default: `now()`, not null]

  Note: '✅ [NEW] ตารางกลางสำหรับเชื่อม "ตัวครุภัณฑ์" กับ DMS'
}

Table adm_asset_request_documents {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  requestId Int [not null]
  request adm_asset_requests [not null]
  mediaId Int [unique, not null]
  media SysMedia [not null]
  createdAt DateTime [default: `now()`, not null]

  Note: '✅ [NEW] ตารางกลางสำหรับเชื่อม "ใบคำร้อง" กับ DMS'
}

Table hr_grievance_types {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  code String [not null, note: 'เช่น "HARASSMENT", "APPEAL", "UNFAIR"']
  name String [not null, note: 'เช่น "การคุกคาม/ข่มขู่", "อุทธรณ์บทลงโทษ", "การปฏิบัติไม่เป็นธรรม"']
  description String
  isConfidential Boolean [not null, default: true, note: '🔒 ควบคุมการเข้าถึง: ถ้าเป็นเรื่องลับมาก (เช่น ทุจริตผู้บริหาร) จะเห็นได้เฉพาะคณะกรรมการเฉพาะกิจเท่านั้น']
  tickets hr_grievance_tickets [not null]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, code) [unique]
  }

  Note: '⚖️ 1. Master Data: ประเภทการร้องเรียน (แยกตามบริษัท)'
}

Table hr_grievance_tickets {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  docNo String [not null]
  typeId Int [not null]
  type hr_grievance_types [not null]
  requesterId Int [note: '👤 ผู้ร้องเรียน (เป็น Null ได้ ถ้าระบบอนุญาตให้ร้องเรียนแบบไม่เปิดเผยตัวตน - Whistleblower)']
  requester hr_employees
  isAnonymous Boolean [not null, default: false, note: '🎭 ต้องการปกปิดชื่อหรือไม่ (ถ้า True หน้าบ้านระบบจะไม่โชว์ชื่อผู้ร้องให้คู่กรณีหรือหัวหน้าเห็น)']
  accusedId Int [note: '🎯 ผู้ถูกร้องเรียน (คู่กรณี) - (เป็น Null ได้ ถ้าร้องเรียนนโยบายบริษัท ไม่ได้เจาะจงตัวบุคคล)']
  accused hr_employees
  refDisciplinaryActionId Int [note: '🔗 อ้างอิงกรณี "อุทธรณ์บทลงโทษ" (ดึง ID จากใบลงโทษเดิมมาเพื่อขอความเมตตาลดโทษ)']
  refDisciplinaryAction hr_disciplinary_actions
  subject String [not null, note: 'หัวข้อเรื่องร้องเรียน']
  description String [not null, note: 'รายละเอียดเหตุการณ์']
  severity GrievanceSeverity [not null, default: 'MEDIUM']
  incidentDate DateTime [note: 'วันที่เกิดเหตุ (ถ้าระบุได้)']
  evidences hr_grievance_evidences [not null, note: 'รองรับไฟล์หลากหลาย: รูปภาพแชท, คลิปเสียงเหตุการณ์, เอกสาร PDF อ้างอิง']
  status GrievanceStatus [not null, default: 'DRAFT']
  resolutionSummary String [note: '⚖️ ผลการสอบสวน / ข้อสรุปจากคณะกรรมการหรือ HR']
  resolvedAt DateTime
  wfRequestId Int [unique, note: '*** โฟลว์นี้มักจะข้ามหัวหน้างานปกติ ไปหา HR Manager หรือ "คณะกรรมการพิจารณาเรื่องร้องทุกข์" ทันที']
  wfRequest wf_requests
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, docNo) [unique]
  }

  Note: '📝 2. Transaction: ใบคำร้องเรียนขอความเป็นธรรม / ใบอุทธรณ์'
}

