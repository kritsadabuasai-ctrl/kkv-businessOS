Table com_invoices {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 ล็อกสิทธิ์ของ SME เจ้าของข้อมูล (Multi-tenancy)']
  company org_companies [not null]
  shopId Int [not null, note: '🏪 รองรับระบบหลายสาขา (ออกเอกสารในนามชื่อและที่ตั้งของสาขาไหน)']
  shop com_shop_profiles [not null]
  orderId Int [unique, not null, note: '🛒 ผูกกับคำสั่งซื้อต้นทาง (1 คำสั่งซื้อ มีสิทธิ์ออกใบกำกับภาษีได้ 1 ใบ)']
  order com_orders [not null]
  invoiceNo String [not null, note: '🆔 เลขที่เอกสารใบกำกับภาษี เช่น INV2026050001 (รันระบบนับแยกรายบริษัท/สาขา)']
  type String [not null, default: 'TAX_INVOICE', note: 'ประเภทเอกสาร: \'TAX_INVOICE\' (ใบกำกับภาษีเต็มรูป), \'RECEIPT\' (ใบเสร็จรับเงินทั่วไป)']
  status String [not null, default: 'ISSUED', note: 'สถานะเอกสาร: \'ISSUED\' (ออกแล้ว), \'CANCELLED\' (ยกเลิก/ออกใบแทน)']
  taxId String [not null, note: 'เลขประจำตัวผู้เสียภาษี 13 หลัก หรือ เลขบัตรประชาชน']
  branchCode String [not null, default: '00000', note: 'รหัสสาขา 5 หลัก (เช่น \'00000\' สำหรับสำนักงานใหญ่ หรือ \'00001\' สำหรับสาขา)']
  name String [not null, note: 'ชื่อบริษัท/ห้างหุ้นส่วน หรือ ชื่อ-นามสกุล ของผู้เสียภาษี']
  phone String
  email String
  address String [not null, note: 'ที่อยู่เต็มสำหรับการเปิดบิลใบกำกับภาษี']
  subTotal Decimal [not null, note: 'ยอดรวมราคาสินค้าก่อนหักส่วนลด']
  discountAmount Decimal [not null, default: 0, note: 'ส่วนลดท้ายบิล']
  vatableAmount Decimal [not null, note: 'ยอดรวมที่นำไปคิดภาษี (ฐานภาษี)']
  vatAmount Decimal [not null, note: 'ยอดภาษีมูลค่าเพิ่ม (ปกติ 7%)']
  netAmount Decimal [not null, note: 'ยอดเงินสุทธิรวม VAT (ยอดรวมที่จ่ายจริง)']
  mediaId Int [unique, note: 'เชื่อมโยงเข้าศูนย์กลางคลังไฟล์ DMS เก็บเป็นไฟล์ PDF ใบกำกับภาษีจริง']
  media SysMedia
  isETax Boolean [not null, default: false, note: 'รองรับระบบใบกำกับภาษีอิเล็กทรอนิกส์ในอนาคต (E-Tax Invoice ready)']
  eTaxRefId String [note: 'รหัสอ้างอิงเอกสารที่ได้รับคืนมาจากระบบ Provider หรือสรรพากร']
  cancelReason String
  cancelledAt DateTime
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, invoiceNo) [unique]
  }

  Note: '📄 [NEW] ตารางใบเสร็จรับเงิน / ใบกำกับภาษี (Tax Invoice / Receipt)'
}

Table int_product_mappings {
  id Int [pk, increment]
  companyId Int [not null, note: '🏢 รองรับ Multi-company (แต่ละบริษัทผูกของใครของมัน)']
  company org_companies [not null]
  productId Int [not null, note: '📦 โยงไปหาสินค้าหลัก (Master Product) ในระบบ KKV Business OS']
  product com_products [not null]
  marketplaceProductId Int [note: '🔗 [เพิ่มใหม่] โยงไปหาตารางพักข้อมูลสินค้า (Marketplace Cache) ']
  marketplaceProduct int_marketplace_products
  platform MarketplaceType [not null, note: '🛒 ข้อมูลแพลตฟอร์ม']
  storeAccountId String [note: 'ID ของร้านค้าบนแพลตฟอร์มนั้นๆ (รองรับกรณี 1 บริษัทเปิดร้าน Shopee 3 ร้าน)']
  externalProductId String [not null, note: '🔑 ข้อมูลอ้างอิงฝั่งแพลตฟอร์มภายนอก (ได้มาจาก API ของ Shopee/Lazada)']
  externalVariationId String
  externalSku String
  externalName String [not null]
  mappingStatus MappingStatus [not null, default: 'PENDING', note: '🚦 ระบบ AI Matching & Confirmation']
  aiMatchScore Float [note: 'เก็บเปอร์เซ็นต์ความเหมือนที่ AI (Gemini) วิเคราะห์ให้ (เช่น 0.75 หมายถึง 75%)']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, platform, storeAccountId, externalProductId, externalVariationId) [unique]
  }

  Note: 'ตารางตัวกลางสำหรับ Mapping สินค้า ERP กับแพลตฟอร์มภายนอก (รองรับ Multi-company)'
}

Table int_marketplace_products {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  platform MarketplaceType [not null]
  storeAccountId String [not null, note: 'ID ร้านค้า เช่น shop_mall_01']
  externalProductId String [not null, note: 'Item ID จาก Shopee/Lazada']
  name String [not null, note: 'ชื่อสินค้าบน Shopee']
  description String
  rawPrice Decimal [not null, note: 'ราคาบนแพลตฟอร์ม']
  rawStock Int [not null, default: 0, note: 'สต๊อกบนแพลตฟอร์ม']
  imageUrl String [note: '🖼️ ลิงก์รูปภาพ (ตอนแรกเป็น URL ของ Shopee พอโหลดเสร็จจะเปลี่ยนเป็น GCS URL ของเรา)']
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]
  mappings int_product_mappings [not null]

  indexes {
    (companyId, platform, storeAccountId, externalProductId) [unique]
  }

  Note: 'ตารางพักข้อมูลสินค้าจากมาร์เก็ตเพลสภายนอก (Marketplace Product Cache)'
}

