  mediaId Int [unique, not null, note: '📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)']
  media SysMedia [not null]
  remark String
  createdAt DateTime [default: `now()`, not null]

  Note: '✅ [NEW] ตารางกลางสำหรับหลักฐานยืนยันผลงาน (Evidence of Achievement)  ใช้ได้ทั้งระดับแผนก และ ระดับบุคคล'
}

Table doc_folders {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  name String [not null]
  description String
  isWorkspace Boolean [not null, default: false, note: '🌟 1. เพิ่ม Flag เพื่อบอกว่าโฟลเดอร์นี้ทำงานแบบ Workspace (สำหรับ Enterprise)']
  isWatermarkEnabled Boolean [not null, default: false, note: '💧 Future Feature: Dynamic Watermark']
  defaultWorkflowId Int [note: '🌟 2. เพิ่มการผูก Workflow เข้ากับโฟลเดอร์นี้']
  defaultWorkflow wf_definitions
  deleteWorkflowId Int [note: '🌟 [เพิ่มใหม่] สายอนุมัติสำหรับ "ลบทำลาย" เอกสาร']
  deleteWorkflow wf_definitions
  parentId Int [note: 'โครงสร้าง Parent-Child เพื่อทำ Sub-folder']
  parent doc_folders
  children doc_folders [not null]
  files doc_files [not null]
  accessRoles doc_folder_access [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (companyId, parentId, name) [unique]
  }

  Note: 'ตารางเก็บโครงสร้างแฟ้มข้อมูล (Folders) แบบ Tree (ซ้อนกันได้ไม่จำกัดชั้น)'
}

Table doc_files {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  folderId Int
  folder doc_folders
  fileName String [not null, note: 'ข้อมูลที่แสดงผลปัจจุบัน (จะ Update เมื่อมีการสร้าง Version ใหม่)']
  fileExtension String [not null]
  currentSize BigInt [not null, note: 'ขนาดไฟล์ของเวอร์ชันล่าสุด']
  currentUrl String [not null, note: 'ลิงก์ GCS ของเวอร์ชันล่าสุด    ']
  isSensitiveData Boolean [not null, default: false, note: '🚨 Future Feature: Data Loss Prevention (DLP) มีเลขบัตร ปชช, บัตรเครดิต หรือไม่']
  sensitivityScore Int [not null, default: 0, note: 'ระดับความความลับ (0-100 ประเมินโดย AI)']
  isWatermarkEnabled Boolean [not null, default: false, note: '💧 Future Feature: Dynamic Watermark']
  sourceArchiveId Int
  sourceArchive doc_files
  extractedFiles doc_files [not null]
  uploadedById Int [not null]
  uploadedBy sec_users [not null]
  filePassword String [note: 'ถ้ามี password ก่อนเข้าดู']
  isSyncToAi Boolean [not null, default: false, note: '🤖 จุดเชื่อมต่อกับ AI (คงไว้ที่ตัวหลัก เพื่อให้ AI มองเป็นเอกสารฉบับเดียว)']
  knowledgeBaseId Int [unique]
  knowledgeBase int_knowledge_bases
  wfRequestId Int [unique, note: '🔄 จุดเชื่อมต่อกับ Workflow (ล็อกที่ตัวหลัก เพื่อคุมสถานะการแก้ไข)']
  wfRequest wf_requests
  autoDeleteAt DateTime [note: '🕒 กำหนดวันหมดอายุของไฟล์ (ถ้ามีค่า CronJob จะลบทิ้งอัตโนมัติ)']
  versions doc_file_versions [not null, note: 'เก็บประวัติทุกเวอร์ชัน']
  metadata doc_file_metadata [not null, note: 'สำหรับ Advanced Search']
  docFileShareLink doc_file_share_links [not null]
  docSignatureRequest doc_signature_requests [not null]
  accessRoles doc_file_access [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  Note: '📂 ตารางหลักของไฟล์ (ปรับปรุงให้เป็น Parent ของ Versions)'
}

Table doc_file_versions {
  id Int [pk, increment]
  fileId Int [not null]
  file doc_files [not null]
  companyId Int [not null, note: '🏢 ระบุบริษัทเพื่อความปลอดภัยสูงสุด']
  company org_companies [not null]
  extractedText String [note: '🔍 Future Feature: Full-Text Search (เก็บข้อความที่สกัดจาก PDF/รูปภาพ)']
  version Int [not null, default: 1, note: '1, 2, 3...']
  url String [not null, note: 'ลิงก์ไฟล์ใน GCS ของเวอร์ชันนั้นๆ']
  size BigInt [not null]
  mimeType String [note: 'เช่น application/pdf']
  changeLog String [note: 'บันทึกว่าแก้ไขอะไรในเวอร์ชันนี้ ']
  isCurrent Boolean [not null, default: false, note: '🌟 เพิ่มฟิลด์นี้เข้าไป เพื่อใช้บอกว่าเวอร์ชันไหนคือไฟล์ใช้งานจริงปัจจุบัน']
  uploadedById Int [not null]
  uploadedBy sec_users [not null]
  createdAt DateTime [default: `now()`, not null]

  Note: '📑 ตารางเก็บประวัติเวอร์ชันไฟล์ (New)'
}

Table doc_file_metadata {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null]
  fileId Int [not null]
  file doc_files [not null]
  key String [not null, note: 'เช่น "department", "doc_type", "priority"']
  value String [not null, note: 'เช่น "accounting", "invoice", "urgent"']

  Note: '🏷️ ตารางเก็บ Metadata สำหรับ Advanced Search (New)'
}

Table doc_folder_access {
  id Int [pk, increment]
  companyId Int [not null]
  company org_companies [not null, note: '🌟 เพิ่มบรรทัดนี้: เชื่อมกลับไปหา OrgCompany']
