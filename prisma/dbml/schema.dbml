  cycleName String [not null]
  startDate DateTime [not null, note: '3. วันที่เริ่มและสิ้นสุด (ต้องอยู่ภายใต้ startDate/endDate ของ HrCalendar)']
  endDate DateTime [not null]
  isActive Boolean [not null, default: true]
  planVersions hr_kpi_plan_versions [not null]
  deptEvals hr_department_evaluations [not null]
  empEvals hr_employee_evaluations [not null]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

