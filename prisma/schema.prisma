// ==========================================
// PRISMA CONFIGURATION
// ==========================================

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-1.1.x"]
  previewFeatures = ["postgresqlExtensions"]
}

generator markdown {
  provider = "prisma-markdown"
  output   = "./DATABASE.md"
  title    = "KKV Database Documentation"
}

generator dbml {
  provider = "prisma-dbml-generator"
  output   = "./dbml"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ==========================================
// ENUMS (GLOBAL)
// ==========================================

enum ResetCriteria {
  DAILY
  MONTHLY
  YEARLY
  NEVER
}

enum WorkflowStatus {
  PENDING // 🚩 เพิ่มใหม่: งานที่รอเข้าคิว
  IN_PROGRESS // กำลังประมวลผล (Worker หยิบไปแล้ว)
  APPROVED // เสร็จสมบูรณ์ (หรือใช้ COMPLETED ถ้าต้องการเปลี่ยน)
  REJECTED // ล้มเหลว/ผิดพลาด
  CANCELLED // ยกเลิกโดยผู้ใช้
}

enum VoteRule {
  ANY_APPROVE // ใครก็ได้อนุมัติ 1 คน = ผ่าน
  ALL_MUST_APPROVE // ต้องทุกคนอนุมัติ = ผ่าน
  CUSTOM_PERCENTAGE
}

enum CompanyType {
  INDIVIDUAL
  CORPORATE
  BRANCH
}

/// ตารางเก็บบันทึกประวัติการเปลี่ยนแพ็กเกจ/ต่ออายุ (Billing & Subscription History)
model OrgBillingHistory {
  /// รหัสลำดับรายการ
  id Int @id @default(autoincrement())

  /// บริษัทที่ถูกดำเนินการ
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// การกระทำ เช่น 'NEW_PACKAGE', 'UPGRADE', 'CANCEL'
  action String

  /// แพ็กเกจที่ทำรายการ
  packageId Int?
  package   SysPackage? @relation(fields: [packageId], references: [id])

  /// 💰 [สำคัญ] Snapshot ราคา ณ วันที่ทำรายการ (เผื่ออนาคตแพ็กเกจขึ้นราคา Log ตัวนี้จะไม่เพี้ยน)
  price         Decimal? @db.Decimal(10, 2)
  resellerPrice Decimal? @db.Decimal(10, 2)

  /// ใครเป็นคนกดทำรายการให้ (User ID ของเซลส์/แอดมิน)
  operatorId Int?
  operator   SecUser? @relation(fields: [operatorId], references: [id])

  /// หมายเหตุเพิ่มเติม
  note String? @db.Text

  createdAt       DateTime          @default(now())
  OrgSubscription OrgSubscription[]

  @@index([companyId])
  @@map("org_billing_histories")
}

/// 🚩 ตารางเก็บราคาพิเศษที่ตัวแทนกำหนดให้ลูกข่ายของตัวเอง
model OrgPackagePrice {
  id                  Int     @id @default(autoincrement())
  /// ID ของบริษัทตัวแทน (คนตั้งราคา)
  companyId           Int 
  /// ID ของแพ็กเกจที่ต้องการตั้งราคา
  packageId           Int 
  /// ราคาขายปลีกที่ตัวแทนคนนี้อยากขาย
  customPrice         Decimal
  /// ราคาส่งที่ตัวแทนคนนี้อยากขายให้ Sub-agent ลูกทีม
  customResellerPrice Decimal 

  company OrgCompany @relation(fields: [companyId], references: [id])
  package SysPackage @relation(fields: [packageId], references: [id])

  @@unique([companyId, packageId])
}


///ตาราง SysPackage (หรือ sys_packages) คือหัวใจสำคัญของระบบ SaaS (Software as a Service) ครับ มันทำหน้าที่เป็น "แคตตาล็อกสินค้า" ที่กำหนดว่าลูกค้า (Company) จะได้รับอะไรบ้างเมื่อจ่ายเงินซื้อแพ็กเกจนี้
model SysPackage {
  ///รหัสลำดับของแพ็กเกจ (รันอัตโนมัติ)
  id Int @id @default(autoincrement())

  companyId     Int?
  ///รหัสอ้างอิงของแพ็กเกจ เช่น STARTER, PRO, หรือ ENTERPRISE (ใช้สำหรับอ้างอิงใน Code และต้องไม่ซ้ำกัน)
  code          String   @unique // เช่น STARTER, PRO, ENTERPRISE
  ///ชื่อเรียกแพ็กเกจที่แสดงให้ผู้ใช้เห็น เช่น "SME Starter Pack" หรือ "Professional Plan"
  name          String // เช่น "SME Starter Pack"
  ///ราคาค่าบริการของแพ็กเกจนี้ (รองรับทศนิยม 2 ตำแหน่ง)
  price         Decimal  @default(0) @db.Decimal(10, 2)
  ///ราคาค่าบริการของแพ็กเกจนี้(ตัวแทน) (รองรับทศนิยม 2 ตำแหน่ง)
  resellerPrice Decimal? @db.Decimal(10, 2) // ราคาขายส่ง (ตัวแทนเห็นเท่านั้น)

  // ✅ กำหนดโควตาที่นี่
  ///จำนวนบริษัทสูงสุดที่ผู้ซื้อแพ็กเกจนี้จะสร้างได้ (รวมทั้งบริษัทแม่และบริษัทลูก)
  maxCompanies Int @default(1) // สร้างได้กี่บริษัท (รวมทั้งแม่และลูก)
  ///จำนวนผู้ใช้งาน (Users) ทั้งหมดที่สามารถสร้างได้ภายใต้แพ็กเกจนี้
  maxUsers     Int @default(5) // จำนวน User รวมทั้งหมด
  ///พื้นที่เก็บข้อมูลรวมที่อนุญาตให้ใช้ (หน่วยเป็น Megabytes)
  maxStorageMB Int @default(1000)

  /// จำนวนหน้าร้าน (ComShopProfile) สูงสุดที่สร้างได้รวมกันทุกบริษัทในแพ็กเกจนี้
  maxShops     Int @default(1) 

  aiTokenLimit BigInt?

  /// ประวัติการต่ออายุแพ็กเกจ
  billingHistories OrgBillingHistory[]

  /// รายการโมดูลมาตรฐานที่แถมมากับแพ็กเกจนี้ (เชื่อมไปที่ตาราง SysPackageModule)
  defaultModules  SysPackageModule[]
  ///รายชื่อบริษัททั้งหมดที่กำลังเลือกใช้งานแพ็กเกจนี้อยู่ (เชื่อมไปที่ตาราง OrgCompany)
  companies       OrgCompany[] // บริษัทไหนใช้ Package นี้บ้าง
  ///สถานะการเปิดใช้งานแพ็กเกจ (ถ้าเป็น false จะไม่สามารถเลือกซื้อแพ็กเกจนี้ได้ใหม่)
  isActive        Boolean            @default(true)
  OrgPackagePrice OrgPackagePrice[]

  @@map("sys_packages")
}

///ตาราง SysPackageModule (หรือ sys_package_modules) คือ "ตารางจับคู่" (Junction Table) ที่ทำหน้าที่บอกว่า "ในแพ็กเกจนี้... แถมโมดูลอะไรไปให้บ้าง?"
model SysPackageModule {
  ///รหัสอ้างอิงของแพ็กเกจ (เชื่อมไปยังตาราง sys_packages)
  packageId Int
  ///เป็นการรักษาความสะอาดของข้อมูล (Data Integrity) ถ้าคุณลบแพ็กเกจทิ้ง ระบบจะลบรายการเชื่อมโยงในตารางนี้ออกให้ทันที ไม่เกิดข้อมูลกำพร้าในระบบครับ
  package   SysPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  ///รหัสอ้างอิงของโมดูล (เชื่อมไปยังตาราง sys_modules)
  moduleId  Int
  ///เป็นการรักษาความสะอาดของข้อมูล (Data Integrity) ถ้าคุณลบโมดูลทิ้ง ระบบจะลบรายการเชื่อมโยงในตารางนี้ออกให้ทันที ไม่เกิดข้อมูลกำพร้าในระบบครับ
  module    SysModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  ///เป็นการกำหนด "คีย์หลักร่วม (Composite Primary Key)" หมายความว่าในหนึ่งแพ็กเกจ ห้ามใส่โมดูลซ้ำกัน
  @@id([packageId, moduleId])
  @@map("sys_package_modules")
}

enum KycStatus {
  UNVERIFIED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

///ตารางนี้เป็น "ศูนย์กลางจักรวาล" ของระบบ Multi-tenant ทำหน้าที่เก็บข้อมูลพื้นฐานของบริษัท, การจัดการแพ็กเกจ (License), โครงสร้างองค์กร (Parent-Child), และกระเป๋าเงินสำหรับใช้งาน AI
model OrgCompany {
  ///รหัสบริษัท (รันอัตโนมัติ)
  id             Int         @id @default(autoincrement())
  ///รหัสอ้างอิงบริษัท (เช่น KKV-HQ, SHOP-01) ต้องไม่ซ้ำกันในระบบ
  code           String      @unique
  ///ชื่อบริษัทหรือชื่อร้านค้าที่ใช้เรียก
  name           String
  ///เลขประจำตัวผู้เสียภาษี (สำหรับใช้อ้างอิงเบื้องต้น)

  /// 🌐 [NEW] โดเมนเฉพาะสำหรับหน้าล็อกอิน/ระบบจัดการหลังบ้าน (Company Level ERP Dashboard)
  customDomain    String?   @unique


  taxId          String?
  ///ลิงก์รูปโลโก้บริษัท
  logoUrl        String?
  ///สีธีมหลักของบริษัท (ใช้สำหรับปรับแต่งหน้า UI ให้เป็น White-label)
  primaryColor   String?     @default("#4F46E5")
  ///ธีมสีรองของบริษัท (ใช้สำหรับปรับแต่งหน้า UI ให้เป็น White-label)
  secondaryColor String?
  ///ประเภทของหน่วยงาน เช่น CORPORATE (สำนักงานใหญ่) หรือ BRANCH (สาขา)
  companyType     CompanyType @default(CORPORATE)
  ///KYC - Know Your Customer
  kycStatus       KycStatus @default(UNVERIFIED)

  /// สีปุ่มในระบบ
  buttonColor  String?  @default("#10B981") 
  ///เป็นตัวแทนหรือไม
  isReseller     Boolean     @default(false)

  /// Font หลักขององค์กร
  fontFamily        String? @default("Kanit")
  /// Font สำหรับหัวข้อ
  fontHeadingFamily String? @default("Kanit")
  /// ขนาด Font เริ่มต้น (px)
  fontSizeBase      Int?    @default(16)

   ///ระบุว่าบริษัทนี้ใช้แพ็กเกจอะไรอยู่ (เช่น Free, Pro)
  packageId Int?
  ///ข้อมูลรายละเอียดของแพ็กเกจที่เลือกใช้
  package   SysPackage?  @relation(fields: [packageId], references: [id])
  ///รายชื่อบริษัทลูกที่อยู่ภายใต้การดูแล
  children  OrgCompany[] @relation("CompTree")
  ///รหัสบริษัทแม่ (สำหรับจัดโครงสร้างบังคับบัญชา)
  parentId  Int?
  ///ข้อมูลบริษัทแม่
  parent    OrgCompany?  @relation("CompTree", fields: [parentId], references: [id])

  ///วันที่หมดอายุของแพ็กเกจ (ถ้าว่าง = ใช้ได้ตลอด)
  packageExpiresAt DateTime?

  ///รหัสบริษัทที่เป็น "เจ้ามือ" (ผู้จ่ายเงิน)
  licenseHolderId Int?
  ///- ถ้าเป็นบริษัทแม่ (คนจ่ายเงิน) -> field นี้จะเป็น Null หรือชี้หาตัวเอง - ถ้าเป็นบริษัทลูก/บริษัทในเครือ -> field นี้จะชี้ไปหาบริษัทแม่
  licenseHolder   OrgCompany? @relation("LicenseGroup", fields: [licenseHolderId], references: [id])

  ///รายชื่อบริษัทลูกข่ายทั้งหมดที่มาขอใช้โควตาจากบริษัทนี้
