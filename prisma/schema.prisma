  @@index([taxId])

  // 3. Index สำหรับฟิลเตอร์สถานะและประเภทบริษัท
  // เพราะ Query ส่วนใหญ่ในระบบจะต้องพ่วง where: { isActive: true } เสมอ
  @@index([isActive])
  @@index([companyType])

  // 4. (Optional) Composite Index: ถ้าหน้าระบบมีการดึงรายชื่อ "สาขาที่ยังเปิดใช้งานอยู่" บ่อยๆ
  @@index([parentId, isActive])
}

///ตารางนี้แยกออกมาจากตารางบริษัทหลัก (OrgCompany) เพื่อเก็บข้อมูลรายละเอียดทางกฎหมายและข้อมูลสำหรับออกใบกำกับภาษีโดยเฉพาะ (Normalization) เพื่อไม่ให้ตารางหลักบวมเกินไป
model OrgCompanyInfo {
  id             Int        @id @default(autoincrement())
  companyId      Int        @unique
  company        OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  taxId          String?
  branchCode     String?    @default("00000")
  registeredName String?
  website        String?

  // ❌ ลบ logoUrl String? ออก
  // ✅ [NEW] เปลี่ยนมาใช้ Relation เชื่อมกับ SysMedia (DMS) สำหรับรูปโลโก้บริษัท
  logoMediaId    Int?       @unique
  logoMedia      SysMedia?  @relation("CompanyLogo", fields: [logoMediaId], references: [id])

  // ✅ [NEW] เชื่อมโยงกับตารางเอกสารสำคัญของบริษัท (DBD, ภพ.20)
  documents      OrgCompanyDocument[]

  email          String?
  phone          String?
  fax            String?
  address        String?    @db.Text
  subDistrict    String?
  district       String?
  province       String?
  zipCode        String?
  updatedAt      DateTime   @updatedAt

  @@map("org_company_infos")
}

/// ✅ [NEW] ตารางกลางสำหรับเอกสารทางกฎหมายของบริษัท
model OrgCompanyDocument {
  id              Int      @id @default(autoincrement())
  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id])

  companyInfoId   Int
  companyInfo     OrgCompanyInfo @relation(fields: [companyInfoId], references: [id], onDelete: Cascade)

  /// 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId         Int      @unique
  media           SysMedia @relation(fields: [mediaId], references: [id])

  /// ประเภทเอกสาร: 'AFFIDAVIT' (หนังสือรับรอง), 'VAT_REGISTRATION' (ภพ.20), 'DIRECTOR_ID'
  docType         String?   
  createdAt       DateTime @default(now())

  @@index([companyId, companyInfoId])
  @@map("org_company_documents")
}

///ตารางนี้มีความสำคัญมากในส่วนของ Integration เพราะใช้เก็บข้อมูลลับหรือกุญแจ (Credentials) ที่ใช้เชื่อมต่อกับบริการภายนอก
model IntCloudConfig {
  ///รหัสลำดับของการตั้งค่า (รันอัตโนมัติ)
  id         Int        @id @default(autoincrement())
  ///รหัสอ้างอิงบริษัทที่เป็นเจ้าของการตั้งค่านี้ (เชื่อมไปยังตาราง org_companies)
  companyId  Int
  ///ข้อมูลบริษัทที่เกี่ยวข้อง โดยระบุ onDelete: Cascade เพื่อให้การตั้งค่าถูกลบออกทันทีหากบริษัทถูกลบ เพื่อความปลอดภัยของข้อมูล
  company    OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ///ระบุผู้ให้บริการ Cloud เช่น GOOGLE_DRIVE หรือ AWS_S3 เพื่อให้ระบบเลือกใช้ Driver ได้ถูกต้อง
  provider   String 
  ///ชื่อที่ผู้ใช้ตั้งขึ้นเพื่อจำแนกการเชื่อมต่อ เช่น "Google Drive ฝ่ายบัญชี" หรือ "S3 สำรองข้อมูลรูปภาพ"
  configName String 

  ///เนื้อหาการตั้งค่าในรูปแบบ JSON (เช่น Client ID, Secret Key) ซึ่งเก็บเป็นข้อความขนาดใหญ่ (Text) (แนะนำอย่างยิ่งให้ทำการเข้ารหัส (Encrypt) ก่อนเก็บลงฟิลด์นี้)
  configData String   @db.Text
  ///สถานะการเปิดใช้งานการเชื่อมต่อนี้
  isActive   Boolean  @default(true)
  ///วันที่และเวลาที่สร้างรายการตั้งค่านี้ขึ้นมา
  createdAt  DateTime @default(now())

  @@map("int_cloud_configs")
}

/// เก็บข้อมูล smtp สำหรับส่งเมล์
model IntSmtpConfig {
  ///รหัสอ้างอิง
  id Int @id @default(autoincrement())

  /// รหัสบริษัท (ถ้า Null และ shopId Null = เป็นของส่วนกลาง KKV)
  companyId Int?
  company   OrgCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🌟 เพิ่มฟิลด์นี้: รหัสร้านค้า (ถ้ามีค่า แสดงว่าตั้งค่าให้เฉพาะร้านค้านี้)
  shopId      Int?
  shop        ComShopProfile? @relation(fields: [shopId], references: [id], onDelete: Cascade)
  /// เช่น "Kookshop", "บริษัท A", "ร้านเสื้อผ้าแฟชั่น"
  senderName  String
  /// เช่น "noreply@kookshop.com"
  senderEmail String
  ///ที่อยู่เซิร์ฟเวอร์ SMTP (เช่น "smtp.gmail.com")   
  host        String
  ///พอร์ตสำหรับส่งอีเมล (เช่น 465, 587, 25)   
  port        Int
  ///ชื่อผู้ใช้งาน (มักจะเป็นอีเมล)      
  username    String
  ///รหัสผ่าน (แนะนำอย่างยิ่งให้เข้ารหัส Encrypt ก่อนบันทึกลงฐานข้อมูล)
  password    String          @db.Text
  ///ใช้งาน SSL/TLS หรือไม่ (ส่วนใหญ่เป็น true)
  isSecure    Boolean         @default(true)
  ///สถานะการเปิดใช้งาน
  isActive    Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  @@unique([shopId])
  @@unique([companyId, shopId])
  @@map("int_smtp_configs")
}

/// ตารางเก็บ "ข้อความย่อย" แต่ละบรรทัด (Chat Messages)
model IntChatMessage {
  /// รหัสข้อความ (Primary Key)
  id Int @id @default(autoincrement())

  /// 🌟 เชื่อมโยงกลับไปหาแฟ้มการสนทนา (Session) 🌟
  sessionId Int
  session   IntChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  /// เพื่อความเร็วในการ Query และทำ Data Isolation ของแต่ละบริษัท
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// ID ข้อความจาก Platform ภายนอก (เช่น Message ID จาก Webhook ของ LINE) เผื่อใช้ลบหรืออ้างอิง
  externalId String?

  /// ใครเป็นคนพิมพ์ข้อความนี้? ("CUSTOMER" = ลูกค้า, "AGENT" = แอดมินคน, "AI" = บอทตอบอัตโนมัติ)
  senderType String

  /// ประเภทของข้อความ ("TEXT", "IMAGE", "FILE", "STICKER", "LOCATION")
  messageType String
  /// เนื้อหาของข้อความ หรือ ลิงก์รูปภาพ
  content     String @db.Text
  /// เก็บข้อมูลดิบ (Raw Data) หรือพิกัด Location / Sticker ID จาก Webhook
  metadata    Json?

  /// สถานะว่าข้อความนี้ถูกอ่านโดยแอดมิน/ลูกค้าหรือยัง
  isRead Boolean @default(false)

  createdAt DateTime @default(now())

 
  @@index([sessionId, isRead, senderType])
  @@map("int_chat_messages")
}

/// แฟ้มรวบรวมการสนทนา (Chat Session) ทำหน้าที่เป็นตารางหลัก (Header)  เพื่อให้ AI เข้ามาสรุปแชท วิเคราะห์อารมณ์ และให้แอดมินจัดการสถานะเคสได้ง่ายขึ้น
model IntChatSession {
  /// รหัสแฟ้มการสนทนา (Primary Key)
  id Int @id @default(autoincrement())

  /// รหัสบริษัทที่เป็นเจ้าของแชทนี้
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// (Optional) ผูกกับหน้าร้านค้า กรณีที่บริษัทมีหลายหน้าร้าน
  shopId Int?
  // shop      ComShopProfile? @relation(fields: [shopId], references: [id]) // ปลดคอมเมนต์ถ้าอยากทำ Relation จริง

  /// ช่องทางที่ลูกค้าทักมา เช่น "LINE", "FACEBOOK", "WEBCHAT"
  channel String

  /// ID ผู้ส่ง (เช่น Line userId หรือ Facebook psid) ใช้เป็นกุญแจหลักในการรวมแชท
  senderId   String
  /// ชื่อของลูกค้าที่ดึงมาจาก Social Media
  senderName String?

  
  /// สรุปใจความสำคัญของการสนทนาในแฟ้มนี้ (ให้ AI สรุปแล้วมาเซฟเก็บไว้)
  aiSummary String? @db.Text
  /// อารมณ์ของลูกค้าในเซสชันนี้ (เช่น POSITIVE, NEUTRAL, NEGATIVE, ANGRY)
  sentiment String?
  /// จุดประสงค์หลักที่ลูกค้าทักมา (เช่น INQUIRY, COMPLAINT, BUY_PRODUCT)
  intent    String?


  /// สถานะของแฟ้มนี้ (เช่น OPEN = กำลังคุย, WAITING = รอแอดมินตอบ, RESOLVED = แก้ปัญหาแล้ว, CLOSED = ปิดแฟ้ม)
  status String @default("OPEN")

  /// แอดมินคนที่รับผิดชอบแฟ้มนี้ (ถ้ามี)
  assigneeId Int?
  // assignee  SecUser? @relation(fields: [assigneeId], references: [id]) // ปลดคอมเมนต์ถ้าอยากเก็บว่าแอดมินคนไหนตอบ

  /// ความสัมพันธ์แบบ 1-to-Many ไปยังตารางข้อความย่อย
  messages IntChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Index สำหรับค้นหาแฟ้มของลูกค้าแต่ละคน หรือค้นหาตามสถานะได้อย่างรวดเร็ว
  @@index([companyId, status, updatedAt(sort: Desc)])
  @@map("int_chat_sessions")
}



///ตารางนี้เปรียบเสมือน "สมอง" ของระบบ AI ที่คุณพัฒนาขึ้น โดยใช้ควบคุมบุคลิกภาพและความสามารถของบอทที่นำไปใช้ในช่องทางต่างๆ เช่น LINE หรือ Facebook
model IntAiBot {
  ///รหัสลำดับของบอท (รันอัตโนมัติ)
  id        Int         @id @default(autoincrement())
  ///รหัสอ้างอิงบริษัทที่เป็นเจ้าของบอทตัวนี้
  companyId Int?
  ///ข้อมูลบริษัทที่เกี่ยวข้อง โดยระบุ onDelete: Cascade เพื่อให้บอทถูกลบออกทันทีหากบริษัทปิดตัวลง
  company   OrgCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ///รหัสอ้างอิงของบอท (ถ้ามี)
  code      String?
  ///ชื่อเรียกบอทที่ต้องการให้แสดงผล เช่น "น้องขายดี" หรือ "Admin Support"
  name      String // เช่น "น้องขายดี", "Admin Support"

  /// 🌟 เพิ่มฟิลด์นี้เพื่อบอกว่าเป็นบอทมาตรฐานของระบบ
  isSystem    Boolean @default(false)
  ///รายละเอียดเพิ่มเติมเกี่ยวกับหน้าที่ของบอทตัวนี้
  description String?

  ///ผู้ให้บริการ AI ที่เลือกใช้ เช่น OPENAI, GEMINI, หรือ CLAUDE
  provider    String // OPENAI, GEMINI, CLAUDE
  ///ชื่อรุ่นของโมเดล AI เช่น gpt-4o หรือ gemini-1.5-pro
  modelName   String // gpt-4o, gemini-pro
  ///ค่าความสร้างสรรค์ของ AI (0.0 - 1.0) โดยค่าที่สูงขึ้นจะทำให้ AI ตอบแบบมีความคิดสร้างสรรค์และไม่จำเจ
  temperature Float  @default(0.7)

  ///รายการประวัติการใช้งานและจำนวน Token ที่บอทตัวนี้ใช้ไป
  usageLogs IntAiUsageLog[]

  ///คำสั่งพื้นฐาน (System Instruction) เพื่อกำหนดบุคลิกและขอบเขตการตอบ เช่น "คุณคือพนักงานขายที่สุภาพและเน้นปิดการขาย"
  systemPrompt    String  @db.Text // "คุณคือพนักงานขายที่ร่าเริง..."
  ///ข้อความทักทายแรกสุดที่ AI จะส่งให้ลูกค้าเมื่อมีการเริ่มแชท
  greetingMessage String? @db.Text // ข้อความทักทายเมื่อลูกค้าแอดมา

  ///สถานะเปิดใช้งานเครื่องมือช่วย (Function Calling) เพื่อให้ AI สามารถตรวจสอบสต็อกสินค้าหรือเช็คสถานะออเดอร์ได้
  canUseTools Boolean @default(false) // ให้ AI เรียกดู Stock/Check Order ได้ไหม
  ///สถานะเปิด/ปิดการใช้งานบอทตัวนี้
  isActive    Boolean @default(true)

  ///รายการช่องทางโซเชียลมีเดียที่บอทตัวนี้เชื่อมต่ออยู่ (1 บอท สามารถคุมได้หลาย Line bot)
  lineChannels IntLineConfig[]
  ///รายการช่องทางโซเชียลมีเดียที่บอทตัวนี้เชื่อมต่ออยู่ (1 บอท สามารถคุมได้หลายเพจ)
  fbPages      IntFacebookPage[]

  InstagramConfig IntInstagramConfig[]
  TiktokShop      IntTiktokShop[]
  LazadaShop      IntLazadaShop[]
  ShopeeShop      IntShopeeShop[]
  ///วันที่สร้าง
  createdAt       DateTime             @default(now())
  ///แก้ไขข้อมูลบอทล่าสุด
  updatedAt       DateTime             @updatedAt

  @@unique([companyId, code])
  @@map("int_ai_bots")
}

///ตารางนี้เปรียบเสมือน "ห้องสมุด" ที่เก็บข้อมูลดิบเพื่อให้บอท AI นำไปใช้ค้นหาคำตอบ (RAG - Retrieval-Augmented Generation) ให้กับลูกค้าได้อย่างแม่นยำ
model IntKnowledgeBase {
  ///รหัสลำดับของข้อมูลความรู้ (รันอัตโนมัติ)
  id        Int        @id @default(autoincrement())
  ///หัวข้อของความรู้ เช่น "วิธีการเคลมสินค้า" หรือ "ประวัติบริษัท"
  topic     String
  ///เนื้อหาของความรู้แบบละเอียด ซึ่งจะถูกนำไปทำ Vector Search เพื่อให้ AI อ่าน
  content   String     @db.Text
  ///รหัสอ้างอิงบริษัทที่เป็นเจ้าของข้อมูลชุดนี้
  companyId Int
  ///ข้อมูลบริษัทที่เกี่ยวข้อง โดยระบุ onDelete: Cascade เพื่อให้ข้อมูลความรู้ถูกลบออกหากบริษัทถูกลบ
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ///ประเภทของแหล่งที่มาข้อมูล เช่น TEXT (พิมพ์เอง), FILE (อัปโหลดไฟล์), หรือ URL (ดึงจากหน้าเว็บ)
  sourceType KnowledgeSourceType @default(TEXT)

  ///ตรวจสอบว่าเป็นไฟล์เดิมหรือไม
  fileHash String?

  docFile DocFile?

  ///รหัสไฟล์ที่อ้างอิงจากระบบภายนอก เช่น Google Drive File ID
  fileId    String? // เก็บ ID จาก Google Drive
  ///ที่อยู่ลิงก์ของข้อมูล หรือที่อยู่ไฟล์ในระบบจัดเก็บข้อมูล (Cloud Storage)
  url       String? // เก็บ Path จาก Local Upload หรือ Link
  ///ชื่อไฟล์ต้นฉบับที่นำเข้าสู่ระบบ
  fileName  String? // เก็บชื่อไฟล์ต้นฉบับ
  ///ขนาดของไฟล์ข้อมูล (หน่วยเป็น Bytes)
  fileSize  BigInt                  @default(0)
  ///คำค้นหาหรือหมวดหมู่ที่เกี่ยวข้องเพื่อช่วยในการจัดกลุ่มความรู้
  tags      String[] // หรือ ComTag[] ถ้าทำ Relation
  ///สถานะการเปิดใช้งานข้อมูลชุดนี้ (ถ้าปิด AI จะไม่สามารถนำข้อมูลนี้ไปตอบได้)
  isActive  Boolean                 @default(true)
  ///เชื่อมไปยังตาราง  IntKnowledgeBaseChunk
  chunks    IntKnowledgeBaseChunk[]
  ///วันที่สร้าง
  createdAt DateTime                @default(now())
  ///แก้ไขข้อมูลล่าสุด
  updatedAt DateTime                @updatedAt

  @@map("int_knowledge_bases")
}

///หน้าที่หลักคือเก็บข้อมูลที่ถูก "หั่น" เป็นชิ้นเล็กๆ (Chunking) พร้อมกับค่าพิกัดทางคณิตศาสตร์ (Vector Embedding) เพื่อให้ AI สามารถค้นหาเนื้อหาที่ใกล้เคียงกับคำถามของผู้ใช้ได้อย่างรวดเร็วและแม่นยำ
model IntKnowledgeBaseChunk {
  ///รหัสประจำตัวของชิ้นส่วนข้อมูล (UUID)
  id String @id @default(uuid())

  /// เชื่อมกลับไปหาไฟล์หลัก
  knowledgeBaseId Int
  knowledgeBase   IntKnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  /// ข้อความที่ถูกหั่นแล้ว (เช่น ข้อมูล Excel 1-5 บรรทัด หรือ PDF 1 ย่อหน้า)
  content String @db.Text

  ///ค่า Vector Embedding ขนาด 768 มิติ ที่ได้จากโมเดล Gemini เพื่อใช้ในการคำนวณความเหมือนของข้อความ (Similarity Search)
  embedding Unsupported("vector(768)")?
  ///วันและเวลาที่สร้างชิ้นส่วนข้อมูลนี้ (Default: ปัจจุบัน)
  createdAt DateTime                    @default(now())

  @@map("int_knowledge_base_chunks")
}

// Enum
enum KnowledgeSourceType {
  TEXT
  LOCAL
  GOOGLE_DRIVE
  WEBSITE
}

///ตารางนี้ใช้สำหรับเชื่อมต่อระบบของคุณกับ LINE Messaging API เพื่อให้ระบบสามารถรับ-ส่งข้อความกับลูกค้าได้ รวมถึงการเลือกใช้ AI มาช่วยตอบแชทอัตโนมัติด้วยครับ
model IntLineConfig {
  ///รหัสลำดับของการตั้งค่า (รันอัตโนมัติ)
  id          Int        @id @default(autoincrement())
  ///รหัสอ้างอิงบริษัทที่เป็นเจ้าของ LINE OA นี้
  companyId   Int
  ///ข้อมูลบริษัทที่เกี่ยวข้อง โดยมีระบบ onDelete: Cascade เพื่อลบการตั้งค่านี้หากบริษัทถูกลบออกจากระบบ
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ///ชื่อเรียกช่องทาง LINE เช่น "สาขาสยาม" หรือ "ฝ่ายขาย" เพื่อให้แยกแยะได้ง่าย
  channelName String // เช่น "สาขาสยาม", "ฝ่ายขาย"

  ///รหัส Channel ID จาก LINE Developers Console
  channelId     String
  ///รหัส Channel Secret สำหรับยืนยันตัวตน
  channelSecret String
  ///รหัส Channel Access Token สำหรับใช้เรียก API ของ LINE (เก็บเป็น Text เพราะมีความยาวมาก)
  channelToken  String @db.Text

  ///รหัส LIFF ID หลัก สำหรับใช้พัฒนาหน้าจอเว็บภายในแอป LINE (Mini App)
  liffIdMain String?

  ///ที่อยู่ URL สำหรับรับข้อมูลจาก LINE (Webhook) ที่ต้องนำไปกรอกใน LINE Dev Console
  webhookUrl String? // URL ที่เรา Gen ให้ไปใส่ใน LINE Dev Console

  ///รหัสอ้างอิงของ AI Bot (สมอง) ที่ต้องการให้ดูแลตอบแชทในช่องทางนี้
  aiBotId Int?
  ///ข้อมูลของ AI Bot ที่เชื่อมต่ออยู่
  aiBot   IntAiBot? @relation(fields: [aiBotId], references: [id])

  ///สถานะเปิด/ปิดการตอบแชทด้วย AI (หากปิด พนักงานต้องมาตอบเอง)
  isAiEnabled Boolean  @default(true)
  ///วันที่สร้าง
  createdAt   DateTime @default(now())
  ///แก้ไขข้อมูลล่าสุด
  updatedAt   DateTime @updatedAt

  @@map("int_line_configs")
}

///ตารางนี้ใช้สำหรับเชื่อมต่อระบบของคุณกับ Facebook Graph API เพื่อจัดการข้อความจาก Messenger และคอมเมนต์ โดยสามารถเลือกใช้ AI Bot มาช่วยดูแลเพจได้เช่นเดียวกับช่องทาง LINE
model IntFacebookPage {
  ///รหัสลำดับของการตั้งค่า (รันอัตโนมัติ)
  id          Int        @id @default(autoincrement())
  ///รหัสอ้างอิงบริษัทที่เป็นเจ้าของ Facebook Page นี้
  companyId   Int
  ///ข้อมูลบริษัทที่เกี่ยวข้อง โดยมีระบบ onDelete: Cascade เพื่อลบการตั้งค่านี้หากบริษัทถูกลบออกจากระบบ
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ///ชื่อของแฟนเพจ Facebook เพื่อให้ง่ายต่อการเลือกใช้งานในระบบ
  pageName    String
  ///หมายเลขไอดีประจำตัวของเพจ (Page ID) จาก Facebook
  pageId      String     @unique
  ///รหัสเข้าถึงเพจ (Page Access Token) สำหรับใช้เรียกใช้ API เพื่ออ่านหรือตอบแชท (เก็บเป็น Text เพราะมีความยาวมาก)
  accessToken String     @db.Text // Page Access Token
  ///ที่อยู่ URL สำหรับรับข้อมูล Webhook จาก Facebook ที่ระบบสร้างให้เฉพาะแต่ละเพจ
  webhookUrl  String?

  // ฟิลด์ที่เพิ่มใหม่
  externalConnectionId Int?
  externalConnection   IntExternalConnection? @relation(fields: [externalConnectionId], references: [id])

  tokenType       String?             @default("PAGE_ACCESS_TOKEN")
  /// วันหมดอายุของ Token
  expiresAt       DateTime?
  /// ID ของ Admin ที่เป็นคนกดเชื่อมต่อ
  fbUserId        String?
  /// เชื่อม 1:1 กับ IG ที่ผูกกับเพจนี้
  instagramConfig IntInstagramConfig?

  ///รหัสอ้างอิงของ AI Bot (สมอง) ที่ต้องการให้ดูแลตอบแชทในเพจนี้
  aiBotId     Int?
  ///ข้อมูลของ AI Bot ที่เชื่อมต่ออยู่
  aiBot       IntAiBot? @relation(fields: [aiBotId], references: [id])
  ///สถานะเปิด/ปิดการตอบแชทด้วย AI ในเพจนี้
  isAiEnabled Boolean   @default(true)
  ///วันที่สร้าง
  createdAt   DateTime  @default(now())
  ///แก้ไขข้อมูลล่าสุด
  updatedAt   DateTime  @updatedAt

  @@map("int_facebook_pages")
}

///ตารางศูนย์กลางการล็อกอิน/OAuth Hub
model IntExternalConnection {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id])
  /// "FACEBOOK", "TIKTOK"
  provider       String 
  /// ID ของ User จาก Platform นั้นๆ
  externalUserId String 

  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?

 
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

 
  instagramConfigs IntInstagramConfig[]
  tiktokShops      IntTiktokShop[]
  FacebookPage     IntFacebookPage[]
  shopeeShops      IntShopeeShop[]
  lazadaShops      IntLazadaShop[]

  @@unique([companyId, provider, externalUserId])
  @@map("int_external_connections")
}

///เก็บข้อมูลและ Token ที่ใช้สำหรับดึงออเดอร์ จัดการสต็อก หรือตอบแชทของร้านค้าบน Shopee
model IntShopeeShop {
  id        Int @id @default(autoincrement())
  companyId Int

  /// 🔗 เชื่อมกับ OAuth Connection หลัก (ใครเป็นคนกด Login)
  externalConnectionId Int?
  externalConnection   IntExternalConnection? @relation(fields: [externalConnectionId], references: [id])

  /// 🏪 ข้อมูลร้านค้า
  shopId   String  @unique // 🚩 ต้องใส่ @unique เพื่อให้ใช้ upsert ได้
  shopName String?

  /// 🔑 โทเค็น (ลบ Partner ID/Key ออก เพราะไปอยู่ใน .env)
  accessToken           String    @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime? 
  refreshTokenExpiresAt DateTime?

  /// 🤖 AI
  isAiEnabled Boolean @default(false)
  aiBotId     Int?

 
  company OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  aiBot   IntAiBot?  @relation(fields: [aiBotId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([shopId])
  @@map("int_shopee_shops")
}

///เก็บข้อมูลและ Token ที่ใช้สำหรับดึงออเดอร์ จัดการสต็อก หรือตอบแชทของร้านค้าบน Lazada
model IntLazadaShop {
  id        Int @id @default(autoincrement())
  companyId Int

  /// 🔗 เชื่อมกับ OAuth Connection หลัก
  externalConnectionId Int?
  externalConnection   IntExternalConnection? @relation(fields: [externalConnectionId], references: [id])

  /// 🏪 ข้อมูลร้านค้า
  sellerId String  @unique // 🚩 ต้องใส่ @unique เพื่อให้ใช้ upsert ได้
  shopName String?
  region   String  @default("TH")

  /// 🔑 โทเค็น (ลบ App Key/Secret ออก เพราะไปอยู่ใน .env)
  accessToken           String    @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime? // 🚩 สำคัญมากสำหรับ Lazada
  refreshTokenExpiresAt DateTime?

  /// 🤖 AI
  isAiEnabled Boolean @default(false)
  aiBotId     Int?

  
  company OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  aiBot   IntAiBot?  @relation(fields: [aiBotId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([sellerId])
  @@map("int_lazada_shops")
}

///เก็บข้อมูลและ Token ที่ใช้สำหรับดึงออเดอร์ จัดการสต็อก หรือตอบแชทของร้านค้าบน IntInstagram
model IntInstagramConfig {
  id        Int @id @default(autoincrement())
  companyId Int

  /// 🔗 เชื่อมกลับไปหา OAuth Connection หลัก (ใครเป็นคน Auth)
  externalConnectionId Int?
  externalConnection   IntExternalConnection? @relation(fields: [externalConnectionId], references: [id])

  /// 🔗 เชื่อมกับ Facebook Page (IG Business ต้องมี FB Page เสมอ)
  fbPageId Int?             @unique
  fbPage   IntFacebookPage? @relation(fields: [fbPageId], references: [id])
  /// IG Business Account ID
  igAccountId         String  @unique 
  igUsername          String?
  /// สำหรับโชว์รูปในระบบ
  igProfilePictureUrl String? @db.Text 
  /// เก็บ Token ไว้ที่นี่เพื่อความเร็ว (หรือดึงจาก fbPage ก็ได้)
  accessToken String @db.Text 

  isAiEnabled Boolean @default(false)
  aiBotId     Int?

  isActive  Boolean  @default(true) // เปิด/ปิดการดึงแชท
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  aiBot   IntAiBot?  @relation(fields: [aiBotId], references: [id])

  @@index([companyId])
  @@index([igAccountId])
  @@map("int_instagram_configs")
}

///เก็บข้อมูลและ Token ที่ใช้สำหรับดึงออเดอร์ จัดการสต็อก หรือตอบแชทของร้านค้าบน Tiktok
model IntTiktokShop {
  id        Int @id @default(autoincrement())
  companyId Int

  /// 🔗 เชื่อมกับ OAuth Connection หลัก
  externalConnectionId Int?
  externalConnection   IntExternalConnection? @relation(fields: [externalConnectionId], references: [id])

  /// 🏪 ข้อมูลร้านค้า
  sellerId   String // ID ของบัญชีผู้ขาย
  /// ชื่อผู้ขาย
  sellerName String? 
  /// Shop ID
  shopId     String  @unique 
  /// 🚩 ต้องมี! สำหรับ API v2
  shopCipher String 
  shopName   String?
  /// 🚩 เช่น TH, VN
  region     String  @default("TH") 

  /// 🔑 การจัดการสิทธิ์ (Tokens)
  accessToken           String    @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime? // 🚩 วันหมดอายุ Access Token
  refreshTokenExpiresAt DateTime? // 🚩 วันหมดอายุ Refresh Token

  /// 🤖 การตั้งค่า AI
  isAiEnabled Boolean @default(false)
  aiBotId     Int?

  
  company OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  aiBot   IntAiBot?  @relation(fields: [aiBotId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([shopId])
  @@map("int_tiktok_shops")
}



///ตารางเก็บรายชื่อ Module ที่เรามีขาย (เช่น HR, E-COM, CRM, POS)
model SysModule {
  /// รหัสลำดับของโมดูล
  id          Int     @id @default(autoincrement())
  /// รหัสอ้างอิงโมดูล (เช่น INV, ACC, HRM)
  code        String  @unique 
  /// ชื่อโมดูลภาษาไทย
  name        String 
  /// รายละเอียดว่าโมดูลนี้ทำอะไรได้บ้าง
  description String?
  /// ราคาแยกขาย (กรณีซื้อเพิ่มแยกจากแพ็กเกจหลัก)
  price       Decimal @default(0) 

  /// ลำดับการแสดงผลในเมนู
  sortOrder Int @default(0)

  /// สถานะการเปิดใช้งาน
  isActive Boolean @default(true)

  ///เชื่อมโยงเพื่อบอกว่าโมดูลนี้ไปปรากฏอยู่ในแพ็กเกจค่าบริการ (SysPackage) ไหนบ้าง
  packageModules SysPackageModule[]

  ///เก็บข้อมูลการสมัครใช้งานของแต่ละบริษัทว่าใครใช้โมดูลนี้อยู่บ้าง
  subscriptions OrgSubscription[]
  ///เชื่อมไปยังรายการเมนูต่างๆ ที่พนักงานจะเห็นเมื่อบริษัทเปิดใช้งานโมดูลนี้
  menus         SecMenu[]
  ///กำหนดสิทธิ์การเข้าถึงทรัพยากรต่างๆ ที่ผูกอยู่กับโมดูลนี้
  permissions   SecPermission[]

  @@map("sys_modules")
}

///ตารางนี้ใช้บันทึกว่าบริษัทใดบ้างที่ได้รับสิทธิ์ใช้งานโมดูลตัวไหน และมีอายุการใช้งานถึงเมื่อไหร่
model OrgSubscription {
  ///รหัสลำดับของรายการสมัครใช้งาน
  id        Int        @id @default(autoincrement())
  ///รหัสอ้างอิงของบริษัทที่สมัครใช้งาน (เชื่อมไปยังตาราง org_companies)
  companyId Int
  ///ข้อมูลบริษัทที่สมัคร โดยมีการตั้งค่า onDelete: Cascade เพื่อให้ข้อมูลการสมัครถูกลบออกโดยอัตโนมัติหากบริษัทนั้นถูกลบจากระบบ
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 💰 ราคาที่จ่ายจริง (Snapshot ราคา ณ วันที่สมัคร/ต่ออายุ)
  paidAmount Decimal? @db.Decimal(10, 2)

  /// 🏷️ ประเภทราคา เช่น 'NORMAL' (ปกติ) หรือ 'RESELLER' (ตัวแทน)
  priceType String? @default("NORMAL")

  /// 🔗 [เพิ่มใหม่] เชื่อมโยงไปยังประวัติการทำรายการ (Billing History) ล่าสุด
  lastBillingId Int?
  lastBilling   OrgBillingHistory? @relation(fields: [lastBillingId], references: [id])

  ///รหัสอ้างอิงของโมดูลที่สมัครใช้งาน (เชื่อมไปยังตาราง sys_modules)
  moduleId  Int
  ///ข้อมูลรายละเอียดของโมดูลที่สมัคร
  module    SysModule @relation(fields: [moduleId], references: [id])
  ///วันที่เริ่มต้นการใช้งาน (ค่าเริ่มต้นคือวันที่ทำรายการ)
  startDate DateTime  @default(now())
  ///วันที่สิ้นสุดการใช้งาน หากฟิลด์นี้เป็นค่าว่าง (Null) จะหมายถึงใช้งานได้ตลอดชีพ หรือตามรอบการเรียกเก็บเงิน
  endDate   DateTime? // ถ้า Null = ใช้ได้ตลอดชีพ (หรือดูตาม Billing Cycle)
  ///สถานะของการสมัครใช้งาน เช่น ACTIVE (กำลังใช้งาน), EXPIRED (หมดอายุ), หรือ SUSPENDED (ระงับการใช้งาน)
  status    String    @default("ACTIVE") // ACTIVE, EXPIRED, SUSPENDED
  ///วันที่สร้างรายการ
  createdAt DateTime  @default(now())
  ///วันที่แก้ไขข้อมูลล่าสุด
  updatedAt DateTime  @updatedAt

  @@unique([companyId, moduleId])
  ///ข้อกำหนดที่ห้ามไม่ให้บริษัทเดิมสมัครใช้งานโมดูลซ้ำซ้อนกันในเวลาเดียวกัน
  @@index([companyId, moduleId, status])
  @@map("org_subscriptions")
}

///ตารางนี้ทำหน้าที่เก็บข้อมูลสำหรับการ Log in และการยืนยันตัวตนทั้งหมด แยกออกจากข้อมูลพนักงาน (HR) เพื่อความปลอดภัยและความยืดหยุ่น (เพราะ User บางคนอาจไม่ใช่พนักงาน เช่น Admin ภายนอก หรือ Auditor)
model SecUser {
  ///รหัสผู้ใช้งาน (Auto-increment)
  id                Int       @id @default(autoincrement())
  ///ชื่อผู้ใช้สำหรับเข้าสู่ระบบ (ห้ามซ้ำ)
  username          String    @unique
  ///อีเมลสำหรับเข้าใช้งานหรือกู้คืนรหัสผ่าน
  email             String?   @unique
  ///รหัสผ่านที่ผ่านการเข้ารหัสแล้ว (แนะนำให้ใช้ bcrypt หรือ argon2) ห้ามเก็บเป็น Plain Text เด็ดขาด
  passwordHash      String?
  ///ชื่อ-นามสกุลจริง สำหรับแสดงผลในหน้าจอต่างๆ
  fullName          String?
  ///ลิงก์รูปภาพโปรไฟล์
  avatarUrl         String?
  ///สถานะการใช้งานบัญชี (ถ้าเป็น False คือห้ามล็อกอิน)
  isActive          Boolean   @default(true)
  ///วันที่เปลี่ยนรหัสผ่านล่าสุด (ใช้สำหรับฟีเจอร์บังคับเปลี่ยนรหัสผ่านทุก 90 วัน)
  passwordUpdatedAt DateTime  @default(now())
  ///จำนวนครั้งที่พยายามล็อกอินผิด (สำหรับป้องกันการสุ่มรหัสผ่าน Brute-force)
  loginAttempts     Int       @default(0)
  ///สถานะล็อกบัญชีชั่วคราวเมื่อใส่รหัสผิดเกินกำหนด
  isLocked          Boolean   @default(false)

  // ==========================================
  // 🌟 เพิ่ม Relation สำหรับระบบขอสิทธิ์เอกสาร (DMS Access Request)
  // ==========================================
  docAccessRequests DocAccessRequest[] @relation("AccessRequester")
  docFolderAccesses DocFolderAccess[]
  docFileAccesses   DocFileAccess[]
  logDocumentTraces LogDocumentTrace[] @relation("DownloadedByTrace")

  reportedIncidents HrDisciplinaryIncident[] @relation("IncidentReporter")
  approvedPenalties HrDisciplinaryAction[]   @relation("PenaltyApprover")

  /// ประวัติการเชิญคนนอกเข้ามาช่วยพิจารณางานใน Workflow
  adhocInvites WfAction[] @relation("AdhocInviter")
  
  ///เวลาที่จะปลดล็อกบัญชีให้โดยอัตโนมัติ
  lockoutExpires    DateTime?
  ///รหัส LINE User ID สำหรับใช้ล็อกอินผ่าน LINE หรือรับแจ้งเตือน
  lineUserId        String?
  ///การตั้งค่าว่าผู้ใช้คนนี้ต้องการรับการแจ้งเตือนจากระบบหรือไม่
  isNotified        Boolean   @default(true)
  ///ฟิลด์รองรับการยืนยันตัวตน
  googleId          String?   @unique
  ///ฟิลด์รองรับการยืนยันตัวตน
  facebookId        String?   @unique
  ///ฟิลด์รองรับการยืนยันตัวตน
  thaiId            String?   @unique // สำหรับแอป ThaID (กรมการปกครอง)
  ///ฟิลด์รองรับการยืนยันตัวตน
  paotangId         String?   @unique // สำหรับแอปเป๋าตัง (Krungthai)
  ///ฟิลด์รองรับการยืนยันตัวตน
  ndidId            String?   @unique // สำหรับระบบ NDID (ธนาคารต่างๆ)

  phoneNumber       String?

  /// ข้อมูลพนักงาน (เชื่อมโยง 1-to-1 ถ้า User นี้เป็นพนักงาน)
  employee             HrEmployee?
  /// ประวัติการกดทำรายการบิลลิ่ง (พนักงานที่กด)
  billingHistories     OrgBillingHistory[]
  /// บทบาท/สิทธิ์การใช้งานระบบ
  roles                SecUserRole[]
  /// ประวัติการขออนุมัติงาน (Request)
  wfRequests           WfRequest[]         @relation("Requester")
  /// ประวัติการอนุมัติงาน (Action)
  wfActions            WfAction[]          @relation("Actor")
  /// รายการมอบหมายงานให้คนอื่นทำแทน (Delegation Owner)
  delegationsOwned     SecUserDelegation[] @relation("Owner")
  /// รายการได้รับมอบหมายงานทำแทน (Delegation Receiver)
  delegationsReceived  SecUserDelegation[] @relation("Delegate")
  /// ประวัติการใช้งานระบบ (Audit Log)
  logAudits            LogAudit[]
  /// การแจ้งเตือนที่ได้รับ
  notifications        SysNotification[]
  /// สินค้าที่สร้างโดย User นี้
  productsCreated      ComProduct[]        @relation("ProductCreator")
  /// ประวัติการตรวจสอบการชำระเงิน
  paymentVerifications ComPayment[]

  uploadedFiles        DocFile[]

  docFileVersion       DocFileVersion[]

  docSignatureRequest   DocSignatureRequest[] @relation("SignerUser")

  loginLogs             SecLoginLog[]
  
  /// วันที่สร้างบัญชี
  createdAt            DateTime            @default(now())
  /// วันที่แก้ไขข้อมูลล่าสุด
  updatedAt            DateTime            @updatedAt

  @@map("sec_users")
}

///ตารางนี้ใช้สำหรับกำหนดกลุ่มของสิทธิ์ เช่น Admin, Manager, หรือ Staff เพื่อนำไปมอบให้กับผู้ใช้งานแต่ละคน
model SecRole {
  ///รหัสลำดับของบทบาท (รันอัตโนมัติ)
  id Int @id @default(autoincrement())

  ///รหัสอ้างอิงบริษัทที่บทบาทนี้สังกัดอยู่ หากเป็นค่าว่าง (Null) อาจหมายถึงบทบาทกลางของระบบ
  companyId Int?
  ///ข้อมูลบริษัทที่เกี่ยวข้อง โดยระบุ onDelete: Cascade เพื่อให้บทบาทถูกลบออกหากบริษัทถูกลบ
  company   OrgCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ///ชื่อรหัสของบทบาท (System Name) เช่น admin, sale_manager
  name            String
  ///ชื่อที่ใช้แสดงผลบนหน้าจอให้คนอ่าน เช่น "ผู้จัดการฝ่ายขาย"
  displayName     String?
  ///รายละเอียดเพิ่มเติมว่าบทบาทนี้มีหน้าที่ทำอะไรบ้าง
  description     String?
  ///ระบุว่าเป็นบทบาทพื้นฐานที่ระบบสร้างให้หรือไม่ (ถ้าใช่ มักจะห้ามลบ)
  isSystem        Boolean             @default(false)
  ///ตั้งค่าว่าผู้ที่ถือบทบาทนี้ต้องได้รับแจ้งเตือนเมื่อมีการสั่งซื้อใหม่หรือไม่
  isOrderNotified Boolean             @default(false)
  ///รายชื่อผู้ใช้งานที่ได้รับมอบหมายบทบาทนี้
  users           SecUserRole[]
  ///รายการสิทธิ์การเข้าถึงทรัพยากรต่างๆ ที่ผูกอยู่กับบทบาทนี้
  permissions     SecRolePermission[]
  ///รายการเมนูหน้าเว็บที่บทบาทนี้ได้รับอนุญาตให้มองเห็น
  menus           SecRoleMenu[]
  ///การเชื่อมโยงกับระบบ Workflow เพื่อกำหนดว่าใครต้องเป็นผู้อนุมัติในแต่ละขั้นตอน
  wfNodes         WfNode[]

  docFolderAccesses DocFolderAccess[]
  docFileAccesses   DocFileAccess[]

  ///ข้อกำหนดห้ามตั้งชื่อบทบาทซ้ำกันภายในบริษัทเดียวกัน
  @@unique([companyId, name])
  @@map("sec_roles")
}

///ตารางนี้ทำหน้าที่บอกว่า "นาย ก. (User) เป็น ผู้จัดการ (Role) ที่ บริษัท A (Company)" การออกแบบแบบนี้ทำให้ User 1 คน สามารถเป็น Admin ในบริษัทหนึ่ง แต่เป็นแค่ User ธรรมดาในอีกบริษัทหนึ่งได้ (มีความยืดหยุ่นสูงมาก)
model SecUserRole {
  ///รหัสผู้ใช้งานที่ต้องการมอบหมายบทบาทให้
  userId    Int
  ///รหัสบทบาทที่จะมอบให้ (เช่น Admin, Sale, Stock)
  roleId    Int
  ///รหัสบริษัทที่บทบาทนี้มีผลบังคับใช้
  companyId Int
  ///เชื่อมโยงไปยังตารางผู้ใช้งาน (SecUser) โดยตั้งค่า onDelete: Cascade เพื่อให้สิทธิ์นี้หายไปทันทีถ้า User ถูกลบ
  user      SecUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// ข้อมูลบทบาท (ลบสิทธิ์ทิ้งถ้า Role หาย)
  role      SecRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  /// ข้อมูลบริษัท (ลบสิทธิ์ทิ้งถ้าบริษัทปิดตัว)
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// ป้องกันข้อมูลซ้ำ: 1 คน มี 1 บทบาท ได้ครั้งเดียวใน 1 บริษัท
  @@id([userId, roleId, companyId])
  @@map("sec_user_roles")
}

///ตารางนี้ทำหน้าที่กำหนด "กติกา" ว่าในระบบนี้ทำอะไรได้บ้าง เช่น "สร้างสินค้า", "ลบพนักงาน", หรือ "อนุมัติส่วนลด" โดยการเพิ่ม moduleId เข้ามาตามที่คุณทำนั้นถือว่า ยอดเยี่ยมมาก เพราะจะช่วยกรองสิทธิ์หน้าบ้านได้ง่ายขึ้น
model SecPermission {
  ///รหัสลำดับสิทธิ์ (รันอัตโนมัติ)
  id          Int                 @id @default(autoincrement())
  ///ชื่อทรัพยากรที่ต้องการควบคุม เช่น PRODUCT, ORDER, REPORT_SALES
  resource    String
  ///การกระทำที่อนุญาตให้ทำได้ เช่น create, view, update, delete, 
  action      String
  ///คำอธิบายสิทธิ์เพื่อให้แอดมินเข้าใจง่ายขึ้น เช่น "อนุญาตให้แก้ไขราคาสินค้าได้"
  description String?
  ///รหัสโมดูลที่สิทธิ์นี้สังกัดอยู่ (Optional) ใช้สำหรับจัดหมวดหมู่สิทธิ์ตามแพ็กเกจที่ซื้อ
  moduleId    Int? 
  ///ข้อมูลโมดูลที่เกี่ยวข้อง
  module      SysModule?          @relation(fields: [moduleId], references: [id])
  ///รายการเชื่อมโยงว่ามีบทบาท (Role) ไหนบ้างที่ถือสิทธิ์นี้อยู่
  roles       SecRolePermission[]

  ///ห้ามสร้างสิทธิ์ซ้ำซ้อน เช่น ห้ามมี PRODUCT + create สองอัน
  @@unique([resource, action])
  @@map("sec_permissions")
}

///ตารางนี้เป็น "ตารางเชื่อม (Junction Table)" ที่จะตอบคำถามว่า "Role นี้... ทำอะไรได้บ้าง?"
model SecRolePermission {
  ///รหัสบทบาทที่ต้องการกำหนดสิทธิ์ให้
  roleId       Int
  ///รหัสสิทธิ์ที่ต้องการมอบให้
  permissionId Int
  ///เชื่อมโยงไปยังตารางบทบาท (SecRole) โดยตั้งค่า onDelete: Cascade เพื่อให้สิทธิ์นี้ถูกลบออกทันทีหากบทบาทนั้นถูกลบ
  role         SecRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  ///เชื่อมโยงไปยังตารางสิทธิ์ (SecPermission) โดยตั้งค่า onDelete: Cascade เช่นกัน
  permission   SecPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  ///คีย์หลักร่วม เพื่อป้องกันไม่ให้มอบสิทธิ์เดิมซ้ำๆ ให้กับบทบาทเดิม
  @@id([roleId, permissionId])
  @@map("sec_role_permissions")
}

///ตารางนี้มีความยืดหยุ่นสูงมาก เพราะรองรับทั้ง เมนูซ้อนชั้น (Sub-menu) และ การจำกัดการมองเห็นตามโมดูล (Feature Gating) ซึ่งเหมาะกับระบบ SaaS ที่ลูกค้าแต่ละรายอาจเห็นเมนูไม่เหมือนกัน
model SecMenu {
  ///รหัสลำดับเมนู (รันอัตโนมัติ)
  id              Int                        @id @default(autoincrement())
  ///ชื่อเมนูที่จะแสดงผลบนหน้าจอ (เช่น "แดชบอร์ด", "จัดการสินค้า")
  name            String
  ///เส้นทาง URL ที่เมนูนี้จะลิ้งก์ไป (เช่น /dashboard, /products) หากเป็นเมนูแม่ (Parent) ที่มีลูกย่อยๆ ค่านี้อาจจะเป็น Null ได้
  path            String?
  ///ชื่อคลาสไอคอนหรือชื่อไฟล์รูปภาพสำหรับแสดงหน้าชื่อเมนู (เช่น fa-home, icon-settings)
  icon            String?
  ///รหัสเมนูแม่ (ถ้ามี) ใช้สำหรับทำเมนูแบบ Dropdown หรือ Accordion
  parentId        Int?
  ///ความสัมพันธ์แบบ Self-relation เพื่อสร้างโครงสร้าง Tree (แม่-ลูก) ได้ไม่จำกัดชั้น
  parent          SecMenu?                   @relation("MenuTree", fields: [parentId], references: [id])
  ///ความสัมพันธ์แบบ Self-relation เพื่อสร้างโครงสร้าง Tree (แม่-ลูก) ได้ไม่จำกัดชั้น
  children        SecMenu[]                  @relation("MenuTree")
  securityConfigs SecCompanySecurityConfig[]

  // ✅ เพิ่ม: เมนูนี้สังกัด Module ไหน (ถ้า Null = เมนูพื้นฐานที่ทุกคนต้องมี เช่น Dashboard, Profile)
  moduleId Int?
  module   SysModule? @relation(fields: [moduleId], references: [id])

  /// บ่งบอกว่าเป็นเมนูหลักของระบบหรือไม่ (ถ้า true = ห้ามลบ)
  isSystem Boolean @default(false)

  roles          SecRoleMenu[]
  displayConfigs SecCompanyMenuConfig[]
  ///ลำดับการเรียงเมนู (เลขน้อยขึ้นก่อน)
  sortOrder      Int                    @default(0)
  ///ตัวเปิด/ปิดเมนูระดับ Global (เช่น ถ้าเราทำฟีเจอร์ยังไม่เสร็จ ก็ปิด False ไว้ก่อน ลูกค้าจะได้ไม่เห็น)
  isVisible      Boolean                @default(true)

  @@map("sec_menus")
}

///ตารางนี้มีความสำคัญมากสำหรับระบบ SaaS ที่ต้องการความยืดหยุ่นสูง (Customizability) เพราะมันช่วยให้ลูกค้าแต่ละบริษัทสามารถ "จัดหน้าตาเมนู" ในแบบของตัวเองได้โดยไม่กระทบกับบริษัทอื่น
model SecCompanyMenuConfig {
  ///รหัสลำดับการตั้งค่า (รันอัตโนมัติ)
  id        Int        @id @default(autoincrement())
  ///รหัสบริษัทที่เป็นเจ้าของการตั้งค่านี้
  companyId Int
  /// ข้อมูลบริษัท (ลบการตั้งค่าทิ้งถ้าบริษัทหายไป)
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// รหัสเมนูที่ต้องการปรับแต่ง
  menuId    Int
  /// ข้อมูลเมนูเดิม (ลบการตั้งค่าทิ้งถ้าเมนูถูกลบจากระบบ)
  menu      SecMenu    @relation(fields: [menuId], references: [id], onDelete: Cascade)

  /// แสดงใน Sidebar ด้านข้างหรือไม่
  showInSidebar Boolean @default(true) // แสดงใน Sidebar ไหม
  /// แสดงเป็นเมนูลัดด้านบนหรือไม่ (Navbar)
  showInNavbar  Boolean @default(false) // แสดงเป็นเมนูลัดข้างบนไหม
  /// แสดงเป็นปุ่มลัดใน Dashboard หรือไม่
  isShortcut    Boolean @default(false) // แสดงเป็นปุ่มใหญ่ใน Dashboard ไหม

  /// ชื่อเมนูที่ตั้งเอง (Override ชื่อเดิม)
  customLabel String? // เปลี่ยนชื่อเมนู (เช่น "HR" -> "ทีมงานของเรา")
  /// ไอคอนที่ตั้งเอง (Override ไอคอนเดิม)
  customIcon  String? // เปลี่ยนไอคอน
  /// ลำดับการแสดงผลเฉพาะบริษัทนี้ (Null = ใช้ค่าเดิม)
  sortOrder   Int? // จัดลำดับใหม่เฉพาะบริษัทนี้
  /// วันที่แก้ไขล่าสุด
  updatedAt   DateTime @updatedAt

  /// ป้องกันข้อมูลซ้ำ: 1 บริษัท ตั้งค่าเมนูเดิมได้แค่ 1 ครั้ง
  @@unique([companyId, menuId]) // 1 บริษัท Config เมนูนี้ได้แบบเดียว
  @@map("sec_company_menu_configs")
}

///ตารางนี้มีความสำคัญมากในการทำ Menu Authorization หรือการซ่อนเมนูที่ไม่เกี่ยวข้องออกจากหน้าจอของพนักงานแต่ละระดับครับ
model SecRoleMenu {
  ///รหัสบทบาทที่ต้องการกำหนดการมองเห็น
  roleId    Int
  ///รหัสเมนูที่ต้องการให้บทบาทนี้มองเห็น
  menuId    Int
  ///ลำดับการแสดงผลเมนู (เฉพาะบทบาทนี้) ถ้าเป็น Null: ให้ใช้ลำดับมาตรฐานจากตาราง SecMenu ถ้ามีค่า: ให้ใช้ค่านี้นำมาจัดเรียงแทน (เช่น Admin อาจเห็นเมนูตั้งค่าอยู่บนสุด แต่ User ทั่วไปเห็นอยู่ล่างสุด)
  sortOrder Int?
  ///เชื่อมโยงไปยังตารางบทบาท (SecRole) โดยตั้งค่า onDelete: Cascade เพื่อให้สิทธิ์การมองเห็นถูกลบออกทันทีหากบทบาทถูกลบ
  role      SecRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  ///เชื่อมโยงไปยังตารางเมนู (SecMenu) โดยตั้งค่า onDelete: Cascade เช่นกัน
  menu      SecMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  ///คีย์หลักร่วม เพื่อป้องกันไม่ให้ข้อมูลซ้ำซ้อน (1 บทบาท เห็น 1 เมนูได้แค่รายการเดียว)
  @@id([roleId, menuId])
  @@map("sec_role_menus")
}

///ตารางนี้ใช้กำหนดมาตรฐานความปลอดภัยในการตั้งรหัสผ่าน การบังคับเปลี่ยนรหัสผ่านตามวงรอบ และการป้องกันการเดารหัสผ่าน (Brute-force Protection)
model SecPasswordPolicy {
  ///รหัสลำดับนโยบาย (รันอัตโนมัติ)
  id Int @id @default(autoincrement())

  ///รหัสบริษัทที่ใช้นโยบายนี้ ✅ ถ้า NULL คือ Global Policy (ใช้กับทุกบริษัทที่ไม่ได้ตั้งค่าเอง) ถ้ามีค่า: หมายถึงบริษัทนั้นๆ มีการกำหนดความเข้มงวดของรหัสผ่านด้วยตัวเอง
  companyId Int?        @unique
  /// (และจะถูกลบอัตโนมัติหากบริษัทนั้นถูกลบทิ้ง)
  company   OrgCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ///ความยาวขั้นต่ำของรหัสผ่านที่อนุญาต (ค่ามาตรฐานคือ 8 ตัวอักษร)
  minLength      Int     @default(8) // ขั้นต่ำกี่ตัวอักษร
  ///ต้องมีตัวพิมพ์ใหญ่
  requireUpper   Boolean @default(true)
  /// ต้องมีตัวพิมพ์เล็ก
  requireLower   Boolean @default(true)
  /// ต้องมีตัวเลข
  requireNumber  Boolean @default(true)
  /// ต้องมีอักขระพิเศษ
  requireSpecial Boolean @default(true)
  /// อักขระพิเศษที่อนุญาตให้ใช้
  specialChars   String  @default("!@#$%^&*")

  /// ต้องเปลี่ยนทุกๆ กี่วัน (0 = ไม่บังคับ)
  passwordAgeDays Int     @default(90)
  ///การตั้งค่าเพื่อจดจำประวัติรหัสผ่านเก่า ป้องกันไม่ให้ผู้ใช้นำรหัสผ่านเดิมที่เคยใช้ไปแล้วกลับมาตั้งซ้ำ (💡 ข้อสังเกต: ปัจจุบันคุณตั้งเป็น Boolean เพื่อเปิด/ปิดฟีเจอร์นี้ แต่ถ้าในอนาคตอยากระบุว่า "ห้ามซ้ำกับรหัสผ่านเก่า 3 หรือ 5 ครั้งล่าสุด" อาจจะพิจารณาเปลี่ยน Type เป็น Int ก็ได้
  historyCount    Boolean @default(true)

  ///จำนวนครั้งสูงสุดที่อนุญาตให้ใส่รหัสผ่านผิดก่อนที่บัญชีจะถูกล็อก (ป้องกันการสุ่มรหัส)
  maxLoginAttempts Int      @default(5)
  ///ระยะเวลาที่บัญชีจะถูกล็อก (หน่วยเป็นนาที) หลังจากที่ใส่รหัสผ่านผิดเกินโควตา
  lockoutDuration  Int      @default(30)
  ///วันที่แก้ไขการตั้งค่าล่าสุด
  updatedAt        DateTime @updatedAt

  @@map("sec_password_policies")
}

///ใช้สำหรับบันทึกประวัติและระยะเวลาที่ผู้ใช้คนหนึ่ง (Owner) อนุญาตให้อีกคนหนึ่ง (Delegate) กระทำการต่างๆ ในระบบแทนตนเอง
model SecUserDelegation {
  ///รหัสลำดับรายการมอบหมายงาน (รันอัตโนมัติ)
  id             Int      @id @default(autoincrement())
  ///รหัสผู้ใช้งานที่เป็น "เจ้าของสิทธิ์" (ผู้มอบหมายงาน / ผู้ที่ไม่อยู่หรือลางาน)
  ownerUserId    Int
  ///รหัสผู้ใช้งานที่เป็น "ตัวแทน" (ผู้รับมอบอำนาจให้ตัดสินใจหรือทำงานแทน)
  delegateUserId Int
  ///วันและเวลาที่ เริ่มต้น ให้ตัวแทนมีสิทธิ์ทำงานแทน
  startDate      DateTime
  ///วันและเวลาที่ สิ้นสุด การมอบหมายสิทธิ์ (เมื่อถึงเวลานี้ สิทธิ์ของตัวแทนจะถูกยกเลิกอัตโนมัติ)
  endDate        DateTime
  ///เหตุผลในการมอบหมายงาน เช่น "ลาพักร้อนประจำปี", "ไปราชการต่างประเทศ", หรือ "ลาป่วย"
  reason         String?
  ///เชื่อมโยงกลับไปหาข้อมูลของผู้มอบหมายในตาราง SecUser
  owner          SecUser  @relation("Owner", fields: [ownerUserId], references: [id])
  ///เชื่อมโยงกลับไปหาข้อมูลของตัวแทนในตาราง SecUser
  delegate       SecUser  @relation("Delegate", fields: [delegateUserId], references: [id])

  @@map("sec_user_delegations")
}



///ตารางนี้เป็นส่วนหัว (Header) ของระบบ Master Data Management ครับ ใช้สำหรับสร้าง "หมวดหมู่" ของข้อมูลตัวเลือกต่างๆ ที่จะนำไปใช้เป็น Dropdown ทั่วทั้งระบบ เช่น หมวดหมู่ "คำนำหน้าชื่อ", "ธนาคาร", หรือ "สถานะเอกสาร"
model CfgMasterGroup {
  ///รหัสลำดับกลุ่มข้อมูล (รันอัตโนมัติ)
  id Int @id @default(autoincrement())

  ///รหัสอ้างอิงกลุ่มข้อมูล (เช่น NAME_PREFIX, BANK_LIST, ORDER_STATUS) ใช้สำหรับให้โปรแกรมเมอร์เรียกใช้ในโค้ด (ห้ามซ้ำ)
  groupCode String @unique 

  ///ชื่อเรียกกลุ่มข้อมูลที่อ่านเข้าใจง่ายสำหรับให้ผู้ใช้ทั่วไปเห็น (เช่น "คำนำหน้าชื่อ", "รายชื่อธนาคาร")
  groupName   String?
  ///คำอธิบายเพิ่มเติมว่ากลุ่มข้อมูลนี้ใช้ทำอะไร หรือใช้ในหน้าจอไหน
  description String?
  ///ตัวป้องกันความผิดพลาด (System Lock) ถ้าเป็น True: หมายถึงกลุ่มข้อมูลนี้มีความสำคัญกับระบบมาก ห้ามผู้ใช้ลบหรือแก้ไขรหัส (เช่น สถานะเอกสารที่ผูกกับ Logic ของระบบ)
  isSystem    Boolean         @default(false)
  ///สถานะเปิด/ปิดการใช้งานกลุ่มข้อมูลนี้ (ทำ Soft Delete หรือซ่อนไว้ชั่วคราวโดยไม่ต้องลบข้อมูลจริงทิ้ง)
  isActive    Boolean         @default(true)
  ///ความสัมพันธ์แบบ 1-to-Many เชื่อมโยงไปยังตาราง CfgMasterData เพื่อเก็บ "รายการย่อย" ที่อยู่ภายใต้กลุ่มนี้ (เช่น นาย, นาง, นางสาว จะอยู่ในตารางนี้)
  items       CfgMasterData[]

  @@map("cfg_master_groups")
}

///ตารางนี้เปรียบเสมือน "ไส้ใน" ของ CfgMasterGroup ใช้สำหรับเก็บ "ตัวเลือก (Options)" ทั้งหมดที่จะนำไปแสดงใน Dropdown ทั่วระบบ ความเจ๋งคือมันรองรับทั้งระบบหลายภาษา (Multi-language) และข้อมูลแบบซ้อนทับกันเป็นลำดับชั้น (Hierarchical Data)
model CfgMasterData {
  ///รหัสลำดับรายการตัวเลือก (รันอัตโนมัติ)
  id            Int         @id @default(autoincrement())
  ///รหัสกลุ่มข้อมูลที่ตัวเลือกนี้สังกัดอยู่ (เช่น รหัสของกลุ่ม "เพศ")
  masterGroupId Int
  /// แยกให้แต่ละบริษัทสามารถมี matadata เป็นของตัวเองได้
  companyId     Int?
  company       OrgCompany? @relation(fields: [companyId], references: [id]) 

  ///รหัสตัวเลือกสำหรับการอ้างอิงในระดับโค้ดหรือเก็บลงฐานข้อมูล (เช่น M, F, PENDING, SUCCESS)
  code String

  ///ชื่อตัวเลือกสำหรับแสดงผลหลัก (เช่น "ชาย", "หญิง", "รอชำระเงิน")
  name String?

  ///ข้อมูลชื่อตัวเลือกที่รองรับหลายภาษา เก็บในรูปแบบ JSON เช่น {"th": "ชาย", "en": "Male"} ทำให้หน้าบ้านสามารถสลับภาษาได้ทันทีโดยไม่ต้องสร้างตารางแยก
  labels      Json
  ///เชื่อมโยงกลับไปยังตารางแม่ CfgMasterGroup (ตั้งค่า Cascade เพื่อให้ลบตัวเลือกเหล่านี้ทิ้งอัตโนมัติถ้ากลุ่มแม่ถูกลบ)
  masterGroup CfgMasterGroup @relation(fields: [masterGroupId], references: [id], onDelete: Cascade)

  ///รหัสรายการแม่ (ถ้ามี) ใช้สำหรับสร้างตัวเลือกแบบซ้อนชั้นกัน เช่น ประเทศ -> จังหวัด -> อำเภอ
  parentId Int?
  ///ความสัมพันธ์แบบ Self-relation ในตัวมันเอง ทำให้สร้างความลึกกี่ชั้นก็ได้
  parent   CfgMasterData?  @relation("MasterDataTree", fields: [parentId], references: [id])
  ///ความสัมพันธ์แบบ Self-relation ในตัวมันเอง ทำให้สร้างความลึกกี่ชั้นก็ได้
  children CfgMasterData[] @relation("MasterDataTree")

  ///ลำดับการเรียงตัวเลือกใน Dropdown (ตัวเลขน้อยขึ้นก่อน)
  sortOrder        Int          @default(0)
  ///สถานะเปิด/ปิดการใช้งานตัวเลือกนี้ (ถ้าปิด หน้าบ้านจะไม่เห็นตัวเลือกนี้ให้กด)
  isActive         Boolean      @default(true)
  ///รหัสสี (Hex Code เช่น #10B981) สำหรับนำไปทำ Badge หรือ Label สีในหน้า UI เช่น สถานะ "สำเร็จ" ให้โชว์สีเขียว, สถานะ "ยกเลิก" ให้โชว์สีแดง
  colorCode        String?
  ///เชื่อมกลุ่มสินค้าใน Products
  products         ComProduct[] @relation("ProductCategory")
  productsWithUnit ComProduct[] @relation("ProductUnit")
  productsWithBox  ComProduct[] @relation("ProductBoxSize")

  ///กฎเหล็กที่บังคับว่า "ในกลุ่มเดียวกัน ห้ามมีรหัสโค้ด (code) ซ้ำกันเด็ดขาด" (เช่น กลุ่มสถานะเอกสาร ห้ามมีคำว่า PENDING 2 รายการ)
  @@unique([masterGroupId, code, companyId])
  @@map("cfg_master_data")
}

///ใช้สำหรับตั้งค่าว่าเอกสารแต่ละประเภท (เช่น PO, Invoice) 
model CfgRunningFormat {
  ///รหัสลำดับรูปแบบ (รันอัตโนมัติ)
  id Int @id @default(autoincrement())

  /// 🌟 1. เพิ่มฟิลด์ companyId (null = รูปแบบส่วนกลาง, มีเลข = รูปแบบเฉพาะบริษัท)
  companyId Int?

  ///รหัสประเภทเอกสารอ้างอิง (ห้ามซ้ำ) สำหรับให้โปรแกรมเมอร์ใช้เรียกในโค้ด 
  docCode       String
  ///ชื่อเรียกประเภทเอกสารเพื่อให้ผู้ใช้เข้าใจ 
  docName       String?
  ///ครงสร้างหรือแพทเทิร์นของเลขเอกสาร (ตัวอย่างเช่น INV-{YYYY}{MM}-{RUN} ระบบก็จะสร้างเลขออกมาเป็น INV-202602-00001)
  formatPattern String
  ///จำนวนหลักของตัวเลขรันนิ่ง 
  digitLength   Int                 @default(5)
  ///เงื่อนไขการรีเซ็ตเลขรันนิ่งให้กลับไปเริ่มที่ 1 ใหม่ 
  resetCriteria ResetCriteria       @default(MONTHLY)
  ///สถานะการใช้งานรูปแบบนี้ (เปิด/ปิด)
  isActive      Boolean             @default(true)
  ///ความสัมพันธ์แบบ 1-to-Many เชื่อมไปยังตาราง CfgRunningCounter ซึ่งจะทำหน้าที่เก็บค่าตัวเลขล่าสุด (Last Value) ว่าตอนนี้รันไปถึงเลขอะไรแล้วในรอบเดือน/ปีนั้นๆ
  counters      CfgRunningCounter[]

  // 🌟 3. เพิ่ม Unique แบบ Composite Key ป้องกันการสร้างรหัสเอกสารซ้ำในบริษัทเดียวกัน
  @@unique([docCode, companyId])
  @@map("cfg_running_formats")
}

///ทำหน้าที่เป็นตัวเก็บค่าปัจจุบันของเลขรัน (Running Number) ในแต่ละรอบช่วงเวลาหรือแต่ละบริษัท เพื่อให้ระบบสามารถออกเลขเอกสารได้อย่างต่อเนื่องและไม่ซ้ำกันครับ
model CfgRunningCounter {
  ///รหัสลำดับหลักของตาราง (Primary Key) แบบรันอัตโนมัติ
  id           Int              @id @default(autoincrement())
  ///รหัสอ้างอิงไปยังตารางรูปแบบเลขรัน (CfgRunningFormat) เพื่อระบุว่าตัวนับนี้เป็นของรูปแบบใด
  formatId     Int
  ///รหัสบริษัทที่ตัวนับนี้สังกัดอยู่ (ถ้าเป็นค่าว่างอาจหมายถึงใช้ร่วมกันทั้งระบบ)
  companyId    Int?
  ///คีย์ที่ระบุรอบระยะเวลาของเลขรัน เช่น ปีเดือน (202602) หรือปี (2026) เพื่อให้เลขรันกลับไปเริ่มใหม่เมื่อขึ้นรอบใหม่
  periodKey    String
  ///ค่าตัวเลขล่าสุดที่ถูกใช้งานไป (ค่าเริ่มต้นคือ 0)
  currentValue Int              @default(0)
  format       CfgRunningFormat @relation(fields: [formatId], references: [id], onDelete: Cascade)

  @@unique([formatId, periodKey, companyId])
  @@map("cfg_running_counters")
}

///ใช้สำหรับเก็บตัวแปรการตั้งค่าของระบบที่ Super Admin หรือทีมนักพัฒนาต้องการปรับเปลี่ยนโดยไม่ต้องแก้โค้ดหรืออัปเดตระบบใหม่ 
model CfgSystem {
  ///รหัสลำดับการตั้งค่า (รันอัตโนมัติ)
  id          Int     @id @default(autoincrement())
  ///ชื่อคีย์อ้างอิงของการตั้งค่า (ต้องไม่ซ้ำกัน) เพื่อให้โปรแกรมเมอร์ใช้ดึงค่าไปใช้ในโค้ด (เช่น MAINTENANCE_MODE, DEFAULT_LANGUAGE, SYSTEM_VERSION)
  key         String  @unique
  ///ค่าของการตั้งค่านั้นๆ (เก็บเป็นข้อความ String เสมอ แต่เวลานำไปใช้ในโค้ดอาจจะแปลงค่าเป็น Boolean, Integer, หรือ JSON ก็ได้ เช่น คีย์ MAINTENANCE_MODE มีค่าเป็น "true")
  value       String
  ///คำอธิบายเพิ่มเติมว่าคีย์นี้ใช้ทำอะไร เพื่อให้ Admin คนอื่นที่เข้ามาดูแลระบบเข้าใจตรงกัน
  description String?

  @@map("cfg_system_configs")
}



///ทำหน้าที่เป็นระบบจัดการ Template ข้อความ สำหรับการส่งการแจ้งเตือนหรือข้อความสื่อสารไปยังช่องทางต่างๆ (เช่น Email, SMS, หรือ LINE) เพื่อให้คุณสามารถแก้ไขข้อความได้โดยไม่ต้องแก้โค้ดโปรแกรม
model ComTemplate {
  id Int @id @default(autoincrement())

  /// 1. เพิ่มฟิลด์ companyId และความสัมพันธ์
  companyId Int?
  company   OrgCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🏪 2. ระดับร้านค้า (Optional: ถ้าเป็น Null แสดงว่าเป็นเทมเพลตกลางของบริษัทนั้น)
  shopId Int?
  shop   ComShopProfile? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  code    String
  channel String
  locale  String  @default("th")
  subject String?
  content String  @db.Text

  /// 2. ปรับ Unique ให้รวม companyId เข้าไปด้วย
  @@unique([companyId, code, channel, locale])
  @@map("com_templates")
}

///ทำหน้าที่เป็นระบบเก็บ ประวัติการส่งข้อความ (Audit Log) ทั้งหมดของระบบ ไม่ว่าจะเป็นการส่งผ่าน Email, SMS, หรือ LINE เพื่อใช้ในการตรวจสอบสถานะการส่งย้อนหลังและวิเคราะห์ปัญหาเมื่อข้อความส่งไม่ถึงผู้รับ
model ComMessageLog {
  ///รหัสลำดับหลักของ Log (Primary Key) ใช้ BigInt เพื่อรองรับปริมาณ Log จำนวนมากในระยะยาว
  id        BigInt     @id @default(autoincrement())
  ///รหัสอ้างอิงไปยังบริษัท (OrgCompany) ที่เป็นเจ้าของรายการส่งข้อความนี้
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id])

  ///ช่องทางที่ใช้ส่ง เช่น EMAIL, SMS, LINE, FACEBOOK
  channel      String
  ///ข้อมูลผู้รับ เช่น อีเมล เบอร์โทรศัพท์ หรือ LINE User ID
  recipient    String
  ///หัวข้อของข้อความ (ถ้ามี)
  subject      String?
  ///เนื้อหาข้อความที่ส่งออกไปจริง (อาจเก็บเป็น HTML หรือ Text)
  content      String?  @db.Text
  ///สถานะการส่งปัจจุบัน เช่น SENT, FAILED, PENDING, DELIVERED
  status       String
  ///ข้อมูลที่ตอบกลับมาจาก API ของผู้ให้บริการภายนอก (เช่น Response จาก LINE หรือ AWS SES)
  apiResponse  Json?
  ///รายละเอียดข้อผิดพลาดในกรณีที่สถานะเป็น FAILED เพื่อใช้ในการวิเคราะห์ปัญหา
  errorMessage String?
  ///ระเภทของเอกสารหรือกิจกรรมที่เกี่ยวข้อง เช่น ORDER, INVOICE, OTP
  refType      String?
  ///รหัสอ้างอิงของเอกสารตาม refType เพื่อให้สามารถตรวจสอบย้อนกลับได้ง่าย
  refId        String?
  ///วันและเวลาที่มีการบันทึกหรือส่งข้อความ (Default: ปัจจุบัน)
  sentAt       DateTime @default(now())

  ///เพื่อให้การค้นหาประวัติการส่งตามบริษัท ช่องทาง และช่วงเวลา ทำได้อย่างรวดเร็ว
  @@index([companyId, channel, sentAt])
  ///เพื่อให้การค้นหาว่าเอกสารใบหนึ่งๆ (เช่น Order ID: 123) เคยมีการส่งข้อความอะไรไปบ้าง ทำได้อย่างมีประสิทธิภาพ
  @@index([refType, refId])
  @@map("com_message_logs")
}



/// Enum สำหรับสถานะพนักงาน
enum EmploymentStatus {
  PROBATION // ทดลองงาน
  CONFIRMED // บรรจุแล้ว
  NOTICE_PERIOD // ✅ เพิ่มสถานะนี้: ยังทำงานอยู่ แต่นับถอยหลังแล้ว
  RESIGNED // ลาออก
  TERMINATED // เลิกจ้าง
}

// ✅ [UPDATED] ตารางสำหรับเก็บเอกสารพนักงาน พร้อมระบบ Multi-tenant และ Index
model HrEmployeeDocument {
  id          Int      @id @default(autoincrement())

  /// 🏢 เชื่อมกับบริษัท (Multi-tenancy)
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id])

  /// 👤 เชื่อมกับพนักงาน
  employeeId  Int
  employee    HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  

  /// 📁 เชื่อมกับไฟล์ใน DMS (SysMedia) ตั้งเป็น @unique เพื่อป้องกันการใช้ไฟล์ซ้ำในหลาย Record
  mediaId     Int      @unique
  media       SysMedia   @relation(fields: [mediaId], references: [id])
  
  /// ประเภทเอกสาร (เช่น 'ID_CARD', 'HOUSE_REGISTRATION')
  docType     String   
  remark      String?
  createdAt   DateTime @default(now())

  
  /// 1. Compound Index สำหรับการค้นหาเอกสารทั้งหมดของพนักงานคนหนึ่งในบริษัท ช่วยให้หน้าจอ Employee Profile โหลดรายการเอกสารได้เร็วมาก
  @@index([companyId, employeeId])

  /// 2. Index สำหรับการค้นหาตามประเภทเอกสารภายในบริษัท เช่น ต้องการดูพนักงานทุกคนที่อัปโหลด 'ID_CARD' แล้ว
  @@index([companyId, docType])

  @@map("hr_employee_documents")
}

///ข้อมูลพนักงาน
model HrEmployee {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id])

  employeeCode   String
  employmentType String? @default("FULL_TIME")

  title     String?
  firstName String
  lastName  String
  nickName  String?
  birthDate DateTime?
  phone     String?
  lineId    String?
  email     String?
  address   String?   @db.Text

  userId Int?     @unique
  user   SecUser? @relation(fields: [userId], references: [id])

  profileImageUrl String?

  /// วันเริ่มงาน (Start Date)
  joinDate        DateTime
  /// วันผ่านโปร (Probation Date)
  confirmDate     DateTime? 
  /// วันที่ลาออก (ถ้ามี)
  resignDate      DateTime? 
  /// วันที่ใช้คำนวณอายุงานจริง (กรณี Re-hire)
  serviceBaseDate DateTime? 

  /// 2. สถานะการจ้างงาน
  status EmploymentStatus @default(PROBATION)

  evaluationsAsManager HrEmployeeEvaluation[] @relation("ManagerEvaluator")

  /// 3. รองรับ Rehire (Self-relation)
  previousEmployeeId Int?        @unique
  previousEmployee   HrEmployee? @relation("RehireHistory", fields: [previousEmployeeId], references: [id])
  nextEmployee       HrEmployee? @relation("RehireHistory")

  
  /// 4.1 แผนกที่สังกัดอยู่ (พนักงาน 1 คนสังกัด 1 แผนก)
  hrDepartmentId Int?
  department     HrDepartment? @relation("DepartmentEmployees", fields: [hrDepartmentId], references: [id])

  /// 4.2 แผนกที่คนนี้เป็น "หัวหน้า" (1 คนอาจคุมหลายแผนกได้)
  managedDepartments HrDepartment[] @relation("DepartmentManager")

  /// 4.3 แผนกที่คนนี้เป็น "รองหัวหน้า"
  deputyDepartments HrDepartment[] @relation("DepartmentDeputy")

  /// 5. สายการบังคับบัญชา (Manager/Subordinates)
  managerId           Int?
  manager             HrEmployee?  @relation("Manager", fields: [managerId], references: [id])
  subordinates        HrEmployee[] @relation("Manager")

  /// ✅ [NEW] เชื่อมกับ DMS สำหรับรูปโปรไฟล์
  profileMediaId  Int?     @unique
  profileMedia    SysMedia? @relation("EmployeeProfile", fields: [profileMediaId], references: [id])

  /// ✅ [NEW] เชื่อมกับเอกสารอื่นๆ ของพนักงาน (เช่น ทะเบียนบ้าน, วุฒิการศึกษา)
  documents       HrEmployeeDocument[]

 
  /// 🌟 เพิ่มบรรทัดนี้ เพื่อเป็นฝั่งตรงข้ามของ HistoryManager
  jobHistoriesAsManager HrJobHistory[] @relation("HistoryManager")
  
  /// 6. ตำแหน่งและรูปแบบงาน
  positionId Int?
  position   HrPosition? @relation(fields: [positionId], references: [id])

  /// 1. ใบลาที่ตนเองเป็นคนเขียน (Owner)
  leaveRequests    HrLeaveRequest[] @relation("EmployeeLeaves")

  /// 2. ใบลาที่ตนเองเป็นผู้อนุมัติ (Approver) - ถ้ามีฟิลด์ approvedById ในใบลา
  approvedLeaves   HrLeaveRequest[] @relation("LeaveApprover")


  /// 3. รายการปรับปรุงยอดลาที่ตนเองเป็นคนกดทำรายการ (Admin/Manager)
  adjustedLeaves   HrLeaveAdjustment[] @relation("AdjustedBy")

  /// 🌟 เพิ่มบรรทัดนี้ เพื่อบอกว่าพนักงานคนนี้ครอบครองเก้าอี้ (Seat) ตัวไหนอยู่
  seat HrPositionSeat? @relation("EmployeeSeat")


  employeeEvaluation      HrEmployeeEvaluation[]
  disciplinaryIncidents   HrDisciplinaryIncident[] @relation("Offender")
  trainingEnrollments     HrTrainingEnrollment[] @relation("Trainee")
  decorations             HrEmployeeDecoration[] @relation("Decorations")
  meetingRequests         AdmMeetingBooking[] @relation("MeetingRequester")
  meetingAttendances      AdmMeetingAttendee[]
  welfareRequests         HrWelfareRequest[] @relation("WelfareRequester")
  salaryHistory           HrSalaryAdjustment[] @relation("SalaryHistory")
  payrollSlips            HrPayrollSlip[]      @relation("PayrollSlips")
  assignedAssets          AdmAsset[]        @relation("AssetOwner")
  assetRequests           AdmAssetRequest[] @relation("AssetRequester")
  grievancesRequested     HrGrievanceTicket[] @relation("GrievanceRequester")
  grievancesAccused       HrGrievanceTicket[] @relation("GrievanceAccused")



  // 🌟 [เพิ่มใหม่] ชี้ไปยังตารางประวัติกะแทน
  patternHistories  HrEmployeePattern[]

  
  employeeInfo      HrEmployeeInfo?
  employmentPeriods HrEmploymentPeriod[]
  jobHistory        HrJobHistory[]
  schedules         HrEmployeeSchedule[]

  
  leaveBalances    HrLeaveBalance[]
  
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, employeeCode])
  @@map("hr_employees")
}

///ข้อมูลส่วนตัวพนักงาน
model HrEmployeeInfo {
  id Int @id @default(autoincrement())

  /// ✅ เชื่อมกับบริษัทเพื่อความปลอดภัย (Multi-tenancy) [cite: 1, 98]
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// ✅ เชื่อมกับพนักงาน (1-to-1) [cite: 4]
  employeeId Int        @unique
  employee   HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  /// เลขบัตรประชาชน (PDPA Sensitive)
  idCardNumber String? 
  /// สำหรับพนักงานต่างชาติ
  passportNo   String? 
  gender       String?
  birthDate    DateTime?
  bloodGroup   String?
  nationality  String?
  religion     String?

  /// ข้อมูลการติดต่อ
  mobilePhone                  String?
  personalEmail                String?
  emergencyContactName         String?
  emergencyContactPhone        String?
  /// ความสัมพันธ์ผู้ติดต่อฉุกเฉิน
  emergencyContactRelationship String?

  /// สถานภาพสมรส
  maritalStatus  String?
  /// สถานภาพทางทหาร
  militaryStatus String?
  /// ข้อมูลที่อยู่ (Address) 
  address        String? @db.Text
  subDistrict    String?
  district       String?
  province       String?
  zipCode        String?

  /// ข้อมูลการเงิน
  bankName        String?
  bankAccountNo   String?
  bankAccountName String?

  /// ✅ ข้อมูลอื่นๆ ที่ยืดหยุ่น (ประวัติวัคซีน, ขนาดเสื้อ, ความสนใจ)
  metadata Json?

  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("hr_employee_infos")
}

///ตารางประวัติรอบการจ้างงาน (Employment Period / Rehire History)
model HrEmploymentPeriod {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  /// 🏢 เพิ่มฟิลด์ companyId เพื่อรองรับ Multi-company
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// วันเริ่มงานของรอบนั้นๆ
  startDate DateTime 
  /// วันสิ้นสุดงานของรอบนั้นๆ (NULL = ยังทำอยู่)
  endDate   DateTime? 
  /// สาเหตุที่ออกในรอบนั้น
  reason       String? 
  /// true = ให้นับอายุงานช่วงนี้รวมด้วย
  isDeductible Boolean @default(true) 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hr_employment_periods")
}
/// แผนกในระบบ
model HrDepartment {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code        String
  name        String
  description String?

  /// 🌳 โครงสร้างต้นไม้ (แผนกหลัก/แผนกย่อย)
  parentId Int?
  parent   HrDepartment?  @relation("DeptTree", fields: [parentId], references: [id])
  children HrDepartment[] @relation("DeptTree")

  sortOrder Int?

  
  managerId       Int?
  deputyManagerId Int?

  manager       HrEmployee? @relation("DepartmentManager", fields: [managerId], references: [id])
  deputyManager HrEmployee? @relation("DepartmentDeputy", fields: [deputyManagerId], references: [id])


 
  jobHistory       HrJobHistory[]
  employees        HrEmployee[]           @relation("DepartmentEmployees")
  allowedPositions HrDepartmentPosition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@map("hr_departments")
}
/// ตำแหน่งในระบบ
model HrPosition {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code  String
  name  String
  level Int    @default(1)
  description String?

  jobHistory                HrJobHistory[]
  wfNodes                   WfNode[]
  employees                 HrEmployee[]
  allowedInDepartments      HrDepartmentPosition[]
  departmentPositionVersion HrDepartmentPositionVersion[]

  @@unique([companyId, code])
  @@map("hr_positions")
}

/// 1. เพิ่ม Enum สถานะของประวัติการทำงาน
enum JobHistoryStatus {
  PENDING // 🚩 สำหรับวางแผนล่วงหน้า (Draft Movement)
  EFFECTIVE // 🟢 มีผลใช้งานจริงแล้ว
  EXPIRED // 🔴 เป็นประวัติในอดีต (มีคนใหม่มาแทนหรือย้ายออกแล้ว)
}

///การเก็บประวัติตามช่วงเวลา (Time-Travel History): ด้วยฟิลด์ startDate และ endDate ทำให้ HR สามารถย้อนดูได้ว่า เมื่อ 2 ปีที่แล้ว พนักงานคนนี้อยู่แผนกอะไร และใครเป็นหัวหน้า (managerId)
model HrJobHistory {
  id Int @id @default(autoincrement())

  // 🏢 เพิ่มเพื่อความเป็น Multi-company
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId Int
  employee   HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  departmentId Int
  department   HrDepartment @relation(fields: [departmentId], references: [id])

  positionId Int
  position   HrPosition @relation(fields: [positionId], references: [id])

  // 🌟 เพิ่มฟิลด์นี้เพื่อให้รู้ว่าในช่วงเวลานั้น "ใครเป็นหัวหน้า"
  managerId    Int?
  manager      HrEmployee?  @relation("HistoryManager", fields: [managerId], references: [id])

  /// 🌟 เพิ่มฟิลด์สถานะ (Default เป็น EFFECTIVE เพื่อไม่ให้กระทบของเดิม)
  status JobHistoryStatus @default(EFFECTIVE)

  /// 🌟 (Optional) เพิ่ม versionId เพื่ออ้างอิงว่าการวางแผนนี้อิงจากผังเวอร์ชันไหน
  orgVersionId Int?

  action String?

  startDate DateTime
  endDate   DateTime?
  isPrimary Boolean   @default(false)

  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hr_job_history")
}

/// ตารางกำหนดโครงสร้างตำแหน่งในแต่ละแผนก (Organization Chart Definition)
model HrDepartmentPosition {
  id Int @id @default(autoincrement())

  companyId Int 

  departmentId Int
  department   HrDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  positionId Int
  position   HrPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  maxHeadcount Int?
  createdAt    DateTime @default(now())

  /// 🌟 เพิ่ม companyId เข้าไปในกฎ Unique ด้วย
  @@unique([companyId, departmentId, positionId])
  @@map("hr_department_positions")
}

///ตารางกำหนดนิยามและโครงสร้างหลักของกระบวนการทำงาน (Workflow) แยกตามบริษัท
model WfDefinition {
  ///รหัสลำดับหลักของนิยาม Workflow (Primary Key) แบบรันอัตโนมัติ
  id Int @id @default(autoincrement())

  ///รหัสอ้างอิงไปยังบริษัท (OrgCompany) เพื่อระบุว่า Workflow นี้เป็นของบริษัทใด
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ///รหัสอ้างอิงของ Workflow เช่น PO_APPROVE, LEAVE_REQ เพื่อใช้ในการเรียกใช้งานผ่านโค้ด
  code String

  ///ชื่อของกระบวนการ Workflow เช่น "อนุมัติใบสั่งซื้อ", "อนุมัติการลา"
  name String

  // 🌟 [เพิ่มใหม่] รับค่ากลับจากตาราง DocFolder
  defaultFolders DocFolder[] @relation("DefaultFolderWorkflow")
  deleteFolders  DocFolder[] @relation("DeleteFolderWorkflow")
  accessFolders  DocFolder[] @relation("AccessFolderWorkflow")

  ///รายละเอียดหรือคำอธิบายเพิ่มเติมเกี่ยวกับกระบวนการนี้
  description String?

  ///สถานะการใช้งาน (Default: true) หากเป็น false จะไม่สามารถสร้างรายการคำขอใหม่จาก Workflow นี้ได้
  isActive Boolean @default(true)

  /// 🔗 ความสัมพันธ์กับตารางอื่นๆ
  nodes          WfNode[]
  requests       WfRequest[]
  moduleMappings WfModuleMapping[] // ✨ เปลี่ยนตัวพิมพ์เล็กให้เป็น camelCase

  

  /// ✨ เพิ่ม Timestamp เพื่อเก็บประวัติการสร้างและแก้ไข
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// ✅ Unique: code ต้องไม่ซ้ำ "ภายในบริษัทเดียวกัน" (แต่ซ้ำข้ามบริษัทได้)
  @@unique([companyId, code])
  @@map("wf_definitions")
}

// ✅ 1. เพิ่ม Enum สำหรับประเภทของโหนด
enum WfNodeType {
  APPROVAL   // ต้องมีคนกดอนุมัติ (ค่า Default)
  FYI        // แค่ส่งแจ้งเตือน (CC) ไม่ต้องกดอนุมัติ ระบบจะวิ่งผ่านไปโหนดต่อไปเลย
  CONDITION  // โหนดทางแยก (เช่น ถ้ายอด > 10,000 ไปโหนด A, ถ้าน้อยกว่า ไปโหนด B)
  PARALLEL_SPLIT // 🌟 1. โหนดแยกสาย (แจกงานไป 2 แผนกพร้อมกัน)
  PARALLEL_JOIN  // 🌟 2. โหนดมัดรวม (รอด่านย่อยเสร็จครบ ถึงจะไปต่อ)
}

///ตารางเก็บรายละเอียดขั้นตอนต่างๆ ในแต่ละกระบวนการ Workflow รวมถึงผู้มีอำนาจอนุมัติและเงื่อนไขการส่งต่อ
model WfNode {
  ///รหัสลำดับหลักของโหนด (Primary Key) แบบรันอัตโนมัติ
  id         Int          @id @default(autoincrement())
  ///รหัสอ้างอิงไปยังนิยาม Workflow หลัก (WfDefinition)
  workflowId Int
  workflow   WfDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  /// ✅ 2. เพิ่มประเภทโหนด
  nodeType       WfNodeType   @default(APPROVAL)

  
  /// 3. เพิ่มฟิลด์สำหรับเก็บเงื่อนไขทางแยก (เก็บเป็น JSON) ตัวอย่างค่า: { "field": "totalAmount", "operator": ">", "value": 10000, "trueNodeId": 5, "falseNodeId": 6 }
  conditionLogic Json?

  /// 🌟 บังคับให้ผู้พิจารณาต้องแนบลายเซ็นดิจิทัล (Digital Signature) ก่อนกดอนุมัติ
  requireSignature Boolean @default(false)

  ///ชื่อเรียกของขั้นตอนนั้นๆ เช่น "หัวหน้าแผนกตรวจสอบ", "บัญชีอนุมัติ"
  nodeName       String
  ///ลำดับที่ของขั้นตอนใน Workflow เพื่อใช้จัดเรียงตามลำดับก่อน-หลัง
  stepOrder      Int
  
  ///รหัสบทบาท (SecRole) ของผู้มีสิทธิ์อนุมัติในขั้นตอนนี้ (ถ้ากำหนดตามบทบาท)
  approverRoleId Int?
  role           SecRole? @relation(fields: [approverRoleId], references: [id])

  ///รหัสตำแหน่งงาน (HrPosition) ของผู้มีสิทธิ์อนุมัติ (ถ้ากำหนดตามตำแหน่ง)
  approverPositionId Int?
  position           HrPosition? @relation(fields: [approverPositionId], references: [id])
  
  ///สูตรหรือเงื่อนไขในการหาผู้อนุมัติแบบไดนามิก เช่น ดึงตามสายการบังคับบัญชา
  dynamicApprover    String?

  
  /// เปิดให้ยิงแจ้งเตือนเข้า LINE OA ทันทีที่งานมาถึงด่านนี้
  notifyLine  Boolean @default(false)
  /// เปิดให้ส่งอีเมลแจ้งเตือนไปยังผู้อนุมัติ
  notifyEmail Boolean @default(false)

  /// จำนวนชั่วโมงที่รอก่อนจะ Auto Action (NULL = รอได้ตลอดไป)
  timeoutHours  Int?
  /// สิ่งที่จะทำเมื่อหมดเวลา: "AUTO_APPROVE", "AUTO_REJECT", "SKIP"
  timeoutAction String?

 
  /// กฎการตัดสินใจ เช่น ANY_APPROVE, ALL_MUST_APPROVE หรือ CUSTOM_PERCENTAGE
  voteRule      VoteRule @default(ANY_APPROVE)
  /// เปอร์เซ็นต์ที่ต้องการให้ผ่าน (เช่น 50, 75, 100) ใช้คู่กับ CUSTOM_PERCENTAGE
  voteThreshold Int?     

  /// ใช้สำหรับยิง API ไปบอกระบบภายนอก หรือ Module อื่นเมื่อขั้นตอนนี้สำเร็จ
  webhookUrl      String? @db.Text 
  /// โครงสร้างข้อมูล (Payload) ที่ต้องการส่งไป
  webhookPayload  Json?            
  
  ///รหัสโหนดถัดไปในกรณีที่รายการนี้ได้รับ "การอนุมัติ"
  nextApproveId Int?
  ///รหัสโหนดถัดไป (หรือย้อนกลับ) ในกรณีที่รายการนี้ถูก "ปฏิเสธ"
  nextRejectId  Int?
  nextOnApprove WfNode?  @relation("NextApprove", fields: [nextApproveId], references: [id])
  nextOnReject  WfNode?  @relation("NextReject", fields: [nextRejectId], references: [id])

  prevApprove WfNode[] @relation("NextApprove")
  prevReject  WfNode[] @relation("NextReject")

  requests WfRequest[]

  @@map("wf_nodes")
}

///ตารางเก็บบันทึกรายการคำขออนุมัติและสถานะการดำเนินการในกระบวนการ Workflow
model WfRequest {
  ///รหัสลำดับหลักของรายการคำขอ (Primary Key) แบบรันอัตโนมัติ
  id Int @id @default(autoincrement())

  /// รหัสอ้างอิงไปยังบริษัท (OrgCompany) ที่เป็นเจ้าของรายการคำขอนี้
  companyId     Int
  company       OrgCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ///รหัสอ้างอิงไปยังนิยาม Workflow (WfDefinition) ที่ใช้เป็นต้นแบบ
  workflowId    Int
  workflow      WfDefinition @relation(fields: [workflowId], references: [id])
  ///รหัสโหนดปัจจุบัน (WfNode) ที่รายการนี้กำลังค้างรอการพิจารณาอยู่
  currentNodeId Int?
  currentNode   WfNode?      @relation(fields: [currentNodeId], references: [id])

  /// 🚩 [เพิ่มใหม่] เชื่อมโยงกลับไปยังตารางสั่งซื้อสินค้า
  purchaseOrder ProPurchaseOrder?
  ///รหัสอ้างอิงของข้อมูลทางธุรกิจต้นทาง (เช่น ID ของ Order หรือ ID ของใบลา)
  businessId    String
  ///ประเภทของข้อมูลธุรกิจต้นทาง เพื่อใช้จำแนกว่า businessId นั้นมาจากตารางใด
  businessType  String

  /// 🌟 เพิ่ม Relation สำหรับคำขอสิทธิ์เข้าถึงข้อมูล
  docAccessRequest DocAccessRequest?

  leaveRequest HrLeaveRequest?

  docFile DocFile?
  signatureRequests DocSignatureRequest[]

  ///หัวข้อเรื่อง หรือชื่อรายการคำขอ เพื่อให้ผู้ใช้งานเข้าใจเนื้อหาคร่าวๆ ได้ทันที
  topic       String?
  ///รหัสผู้ใช้งาน (SecUser) ที่เป็นผู้สร้างหรือส่งคำขอนี้เข้าสู่ระบบ
  requesterId Int
  requester   SecUser @relation("Requester", fields: [requesterId], references: [id])

  returnRequest ComReturnRequest?
  ///สถานะปัจจุบันของคำขอ เช่น IN_PROGRESS (กำลังดำเนินการ), APPROVED, REJECTED
  status        WorkflowStatus    @default(IN_PROGRESS)
  ///ข้อมูลเพิ่มเติมในรูปแบบ JSON ที่เกี่ยวข้องกับคำขอนั้นๆ
  data          Json?


  /// 🔗 เพิ่มส่วนนี้เพื่อเชื่อมโยงกลับไปยังตารางใหม่
  orgStructureVersion  HrOrgStructureVersion? // เชื่อมกับใบขอ Publish ผัง
  manpowerRequest      HrManpowerRequest?     // เชื่อมกับใบขออัตรากำลัง

  /// 🚩 [เพิ่มใหม่] เชื่อมโยงกลับไปยังตารางใบแลกของรางวัล
  crmRedemption CrmRedemption?


  /// เวลาที่เอกสารวิ่งเข้ามาถึงโหนดปัจจุบัน
  currentStepEnteredAt DateTime?
  /// เวลาที่จะครบกำหนด Timeout (คำนวณจากตอนเข้าโหนด + timeoutHours) เพื่อให้ Cron Job หรือ Worker มาเช็คและ Auto-Action ได้ง่ายๆ
  currentStepTimeoutAt DateTime? 

  
  /// จะทำให้การดึงข้อมูลหน้า Dashboard แอดมินรวดเร็วมาก (WHERE myId IN currentApproverIds)
  currentApproverIds   Int[]

  disciplinaryIncident    HrDisciplinaryIncident?
  trainingSession         HrTrainingSession?
  meetingBooking          AdmMeetingBooking?
  welfareRequest          HrWelfareRequest?
  salaryAdjustment        HrSalaryAdjustment?
  payrollCycle            HrPayrollCycle?
  assetRequest            AdmAssetRequest?
  grievanceTicket         HrGrievanceTicket?

  actions   WfAction[]
  /// เป็น Optional เพราะไม่ใช่ทุก Workflow จะมาจาก OrderItem
  orderItem ComOrderItem?
  ///วันและเวลาที่สร้างคำขอ
  createdAt DateTime      @default(now())
  ///วันและเวลาที่มีการปรับปรุงข้อมูลล่าสุด (เช่น เมื่อมีการเปลี่ยนสถานะหรือเปลี่ยนโหนด)
  updatedAt DateTime      @updatedAt

  /// ✅ เพิ่ม Index เพื่อให้ดึงรายการของบริษัทได้ไวๆ
  @@index([companyId, status])
  @@index([businessId, businessType])
  @@map("wf_requests")
}

///ตารางเก็บประวัติการดำเนินการ (Audit Trail) ในแต่ละขั้นตอนของรายการคำขออนุมัติ
model WfAction {
  ///รหัสลำดับหลักของรายการบันทึก (Primary Key) แบบรันอัตโนมัติ
  id           Int       @id @default(autoincrement())
  ///รหัสอ้างอิงไปยังรายการคำขอหลัก (WfRequest) ที่มีการดำเนินการ
  requestId    Int
  request      WfRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  ///รหัสผู้ใช้งาน (SecUser) ที่เป็นผู้กดดำเนินการในขั้นตอนนี้จริง
  actorId      Int
  actor        SecUser   @relation("Actor", fields: [actorId], references: [id])

  /// 🌟 เก็บ IP และอุปกรณ์ที่กดอนุมัติ (Audit Trail สำหรับ Enterprise)
  ipAddress    String?
  userAgent    String?

  /// 🌟 [เพิ่มใหม่] เพื่อระบุว่า Action นี้ทำโดยระบบอัตโนมัติ (เช่น Timeout Auto-Approve) หรือไม่
  isSystemAction Boolean @default(false)
  ///รหัสผู้ใช้งานที่ถูกมอบอำนาจให้ทำแทน (ในกรณีที่มีการตั้งค่า Delegate/Acting แทนกัน)
  onBehalfOfId Int?
  ///ชื่อขั้นตอนในขณะที่กดดำเนินการ (คัดลอกมาจาก nodeName ของ WfNode ณ ขณะนั้น)
  stepName     String
  ///ประเภทการตัดสินใจ เช่น APPROVE, REJECT, SEND_BACK, หรือ CANCEL
  action       String


  /// ระบุว่าเป็นงานที่ถูกเชิญเข้ามาชั่วคราว (ไม่ได้อยู่ใน Flow ปกติ)
  isAdhoc     Boolean @default(false)
  
  /// รหัสคนที่กดเชิญเข้ามา (เพื่อให้รู้ว่าใครเป็นคนลากคนนอกเข้ามา)
  invitedById Int?
  invitedBy   SecUser? @relation("AdhocInviter", fields: [invitedById], references: [id])

  ///หมายเหตุหรือเหตุผลประกอบการตัดสินใจจากผู้ดำเนินการ
  comment      String?   @db.Text
  ///วันและเวลาที่เกิดกิจกรรมการตัดสินใจนี้ขึ้น (Default: ปัจจุบัน)
  createdAt    DateTime  @default(now())

  @@map("wf_actions")
}



///ตารางเก็บบันทึกประวัติการเปลี่ยนแปลงข้อมูลทุกเหตุการณ์ (Insert, Update, Delete) แยกตามบริษัทและผู้ใช้งาน
model LogAudit {
  ///รหัสลำดับหลักของ Log (Primary Key) ใช้ BigInt เพื่อรองรับปริมาณบันทึกมหาศาล
  id BigInt @id @default(autoincrement())

  ///รหัสอ้างอิงไปยังบริษัท (OrgCompany) เพื่อแยกประวัติการตรวจสอบตามองค์กร
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ///ประเภทของกิจกรรมที่เกิดขึ้น เช่น CREATE, UPDATE, DELETE
  action    String
  ///ชื่อตารางในฐานข้อมูลที่มีการเปลี่ยนแปลงข้อมูล
  tableName String
  ///รหัส Primary Key ของข้อมูลในตารางนั้นๆ ที่ถูกกระทำ
  recordId  String
  ///รหัสผู้ใช้งาน (SecUser) ที่เป็นคนกระทำการ (เป็น Null ได้หากเกิดจากระบบอัตโนมัติ)
  userId    Int?

  user      SecUser? @relation(fields: [userId], references: [id])
  ///ข้อมูลเดิมก่อนการเปลี่ยนแปลง (มักใช้ในกรณี Update หรือ Delete)
  oldValues Json?
  ///ข้อมูลใหม่หลังการเปลี่ยนแปลง (มักใช้ในกรณี Create หรือ Update)
  newValues Json?
  ///หมายเลข IP Address ของเครื่องที่ส่งคำขอเข้ามา
  ipAddress String?
  ///ข้อมูลเบราว์เซอร์หรืออุปกรณ์ที่ใช้ในการทำรายการ
  userAgent String?
  ///วันและเวลาที่เกิดเหตุการณ์บันทึกนี้ (Default: ปัจจุบัน)
  createdAt DateTime @default(now())

  ///  ปรับ Index ให้ค้นหาแยกตามบริษัทได้ไวขึ้น
  @@index([companyId, tableName, recordId])
  @@index([companyId, userId])
  @@map("log_audits")
}



///ตารางหลักที่ใช้เก็บข้อมูล "ลูกค้าหรือสมาชิก" ในระบบ CRM ของคุณ โดยมีการออกแบบให้รองรับการเชื่อมต่อกับ LINE OA และการปฏิบัติตามกฎหมายคุ้มครองข้อมูลส่วนบุคคล (PDPA) ไว้อย่างชัดเจนครับ
model CrmMember {
  id              Int          @id @default(autoincrement())
  
  /// 🏢 เปลี่ยนเป็น Int (ห้ามเป็น Null) เพื่อล็อกว่า SME เจ้าไหนเป็นเจ้าของข้อมูล
  companyId       Int
  company         OrgCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🆔 Identity (ล็อก 1 บริษัท มี 1 เบอร์/LineID เท่านั้น)
  memberCode      String       // รหัสสมาชิกหลักของบริษัท เช่น M0001
  lineUserId      String?
  lineName        String?
  linePicture     String?
  idCardNumber    String?
  phone           String?
  email           String?
  firstName       String?
  lastName        String?


  
  profileMediaId  Int?         
  profileMedia    SysMedia?    @relation(fields: [profileMediaId], references: [id], onDelete: SetNull)

  thaiId          String?

  ///  consentimiento (PDPA)
  isMarketingConsent Boolean @default(true)

  /// 🔗 Relations
  addresses      CrmAddress[]
  /// 🌟 เชื่อมไปยังตารางสมาชิกรายร้าน
  shopMemberships CrmMemberShop[]
  
  /// ประวัติส่วนกลาง (ถ้าบอสต้องการเก็บแยกรายบริษัท)
  pointLogs      CrmPointLog[]
  notifications  SysNotification[]

  redemptions    CrmRedemption[]

  // ข้อมูลที่ยังอ้างอิงระดับ Member (เนื่องจากออเดอร์มักจะผูกกับตัวบุคคล)
  orders         ComOrder[]
  returnRequests ComReturnRequest[] 
  wishlists      ComWishlist[]
  productReview  ComProductReview[]
  carts          ComCart[]

  referralsMade      CrmReferral[] @relation("Referrer") // คนที่เราไปชวนมา
  referredBy         CrmReferral?  @relation("Referee")  // ใครเป็นคนชวนเรามา (มีได้คนเดียว)
  commissionLogs     CrmCommissionLog[] @relation("CommissionMember") // ประวัติรับค่าคอม
  commissionBalance  Decimal       @default(0) @db.Decimal(18, 2) // ยอดเงินค่าคอมสะสมปัจจุบัน

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// 🛡️ ล็อกความซ้ำซ้อนในระดับบริษัท
  @@unique([companyId, phone])
  @@unique([companyId, lineUserId])
  @@map("crm_members")
}

///ตารางเก็บสมาชิกของแต่ละร้าน
model CrmMemberShop {
  id        Int      @id @default(autoincrement())
  
  /// 🔒 Double-Locking
  companyId Int
  memberId  Int
  shopId    Int

  /// 🏢 ความสัมพันธ์
  company   OrgCompany     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  member    CrmMember      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  shop      ComShopProfile @relation(fields: [shopId], references: [id], onDelete: Cascade)

  /// 🎁 ข้อมูลที่บอสอยากให้แยกตามร้าน
  pointBalance    Int    @default(0)           // แต้มสะสมแยกรายร้าน
  memberLevelCode String @default("NORMAL")    // ระดับสมาชิกแยกรายร้าน (เช่น ร้าน A เป็น VIP แต่ร้าน B เป็นคนธรรมดา)
  
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// 🛡️ 1 คน เป็นสมาชิกร้านเดิมซ้ำไม่ได้ แต่สมัครร้านอื่นในบริษัทเดียวกันได้
  @@unique([memberId, shopId])
  @@index([companyId, shopId])
  @@map("crm_member_shops")
}

///ตาราง CrmAddress คือตารางที่ใช้สำหรับเก็บข้อมูล "ที่อยู่จัดส่งสินค้าหรือที่อยู่สำหรับออกใบเสร็จ" ของสมาชิก โดยออกแบบมาให้ลูกค้านึงคนสามารถมีได้หลายที่อยู่
model CrmAddress {
  id        Int       @id @default(autoincrement())
  
  /// 🏢 เพิ่มเพื่อให้รองรับ Multi-company แบบ 100%
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  memberId Int
  member   CrmMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  
  type      String
  address   String    @db.Text
  province  String?
  zipcode   String?
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())

  /// 🚀 เพิ่ม Index เพื่อความเร็วในการค้นหา
  @@index([companyId])
  @@index([memberId])
  @@map("crm_addresses")
}



/// 1. เพิ่ม Enum
enum ProductSalesType {
  RETAIL 
  WHOLESALE 
  BOTH 
}

/// เพิ่ม Enum สถานะสินค้า
enum ProductStatus {
  /// แบบร่าง (เห็นเฉพาะคนสร้าง)
  DRAFT
  /// เผยแพร่ (เห็นทุกคน)
  PUBLISHED
  /// เก็บเข้ากรุ (ไม่แสดงผล)
  ARCHIVED
}


enum WarehouseType {
  CENTRAL   // คลังกลาง
  BRANCH    // คลังสาขา / หน้าร้าน
  VIRTUAL   // คลังเสมือน (เช่น สำหรับกันสต็อก Shopee)
  TRANSIT   // คลังสินค้าระหว่างทาง (เวลาโอนย้าย)
  RETURN    // คลังสินค้าตีกลับ/รอเคลม
}

enum StockChangeType {
  SALE       // ขาย (ตัดสต็อก)
  PURCHASE   // ซื้อเข้าจาก PO (เพิ่มสต็อก)
  RETURN_IN  // รับคืนจากลูกค้า (เพิ่มสต็อก)
  RETURN_OUT // ส่งคืน Supplier (ตัดสต็อก)
  ADJUSTMENT // ปรับปรุงยอด (เช่น ของหาย, นับสต็อกผิด)
  WASTE      // ของเสีย/ชำรุด
  
  // 🌟 เพิ่ม 2 ตัวนี้ สำหรับการย้ายของระหว่างคลัง
  TRANSFER_OUT // โอนออกไปคลังอื่น (ตัดสต็อกคลังต้นทาง)
  TRANSFER_IN  // รับเข้าจากคลังอื่น (เพิ่มสต็อกคลังปลายทาง)
}

/// ตารางจัดการคลังสินค้า (รองรับคลังกลางและคลังสาขา)
model ComWarehouse {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// (Optional) ถ้าระบุ shopId หมายถึงเป็น "คลังย่อยประจำหน้าร้านนั้นๆ" ถ้า Null หมายถึงเป็นคลังกลาง
  shopId    Int?
  shop      ComShopProfile? @relation(fields: [shopId], references: [id], onDelete: Cascade)
  /// รหัสคลัง เช่น WH-CENTER, WH-BKK
  code      String   
  /// ชื่อคลัง เช่น "คลังสินค้ากลางปทุมธานี"
  name      String   
  type      WarehouseType @default(CENTRAL)
  address   String?  @db.Text
  isDefault   Boolean  @default(false)

  isActive  Boolean  @default(true)

  /// 📁 เอกสารคลังสินค้า
  documents ComWarehouseDocument[]

  /// ความสัมพันธ์
  stocks           ComWarehouseStock[]
  stockLogs        ComStockLog[]       @relation("WarehouseLog")
  transferLogs     ComStockLog[]       @relation("TransferWarehouseLog")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@map("com_warehouses")
}

/// ตารางเก็บยอดสินค้าคงเหลือ "แยกตามคลัง"
model ComWarehouseStock {
  id          Int @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  warehouseId Int
  warehouse   ComWarehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  productId   Int
  product     ComProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// ยอดคงเหลือของสินค้านี้ "ในคลังนี้"
  qty         Int @default(0)

  updatedAt   DateTime @updatedAt

  /// ป้องกันข้อมูลซ้ำ: 1 สินค้า จะมี record ใน 1 คลังได้แค่แถวเดียว
  @@unique([warehouseId, productId])
  @@index([companyId, productId])
  @@map("com_warehouse_stocks")
}

enum ProductType {
  PHYSICAL
  DIGITAL
}

///เก็บข้อมูลพื้นฐานของสินค้าทั้งหมดในระบบ รองรับระบบหลายบริษัท (Multi-tenancy)
model ComProduct {
  ///รหัสลำดับภายในระบบ ใช้เป็น Primary Key
  id          Int        @id @default(autoincrement())
  ///รหัสบริษัทที่เจ้าของสินค้านี้ เพื่อแยกข้อมูลตามลูกค้าแต่ละเจ้า
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id])
  ///รหัสสินค้า (Stock Keeping Unit) ที่ผู้ใช้กำหนด ต้องไม่ซ้ำกันภายในบริษัทเดียวกัน
  sku         String
  ///ชื่อสินค้า
  name        String
  ///รายละเอียดเชิงลึก
  description String?    @db.Text

  ///สถานะการดำเนินงานของสินค้า (เช่น DRAFT, PUBLISHED, ARCHIVED)
  status ProductStatus @default(DRAFT)

  ///รหัสผู้ใช้งานที่เป็นคนสร้างสินค้าตัวนี้
  createdById Int?

  createdBy SecUser? @relation("ProductCreator", fields: [createdById], references: [id])

  productType   ProductType @default(PHYSICAL)
  ///กำหนดว่าสินค้านี้อนุญาตให้ลูกค้ายกเลิกคำสั่งซื้อได้หรือไม่
  isCancellable Boolean     @default(true)

  ///ราคาขายตั้งต้นหรือราคาขายปลีก
  price        Decimal  @db.Decimal(10, 2)
  ///ราคาสินค้าที่ต่ำที่สุดที่เป็นไปได้เมื่อซื้อตามจำนวนที่กำหนด
  minTierPrice Decimal? @db.Decimal(10, 2)

  warehouseStocks ComWarehouseStock[]
  marketplaceMappings IntProductMapping[]

  unitId Int?
  unit   CfgMasterData? @relation("ProductUnit", fields: [unitId], references: [id])

  ///ตราสินค้า
  brand String?
  ///ที่อยู่ URL สำหรับหน้ารายละเอียดสินค้า (SEO Friendly)
  slug  String? @unique

  /// ✅ เพิ่ม: Supplier ขาประจำ (Default)
  defaultSupplierId Int?
  defaultSupplier   ProSupplier? @relation(fields: [defaultSupplierId], references: [id])

  /// ✅ เพิ่ม: ประเภทการขาย
  salesType ProductSalesType @default(BOTH)

  ///น้ำหนักสินค้า (กิโลกรัม) สำหรับคำนวณค่าส่ง
  weight Decimal? @db.Decimal(10, 3)
  /// กว้าง (cm)
  width  Decimal? @db.Decimal(10, 2)
  /// ยาว (cm)
  length Decimal? @db.Decimal(10, 2)
  /// สูง (cm)
  height Decimal? @db.Decimal(10, 2)

  /// ✅ เพิ่มบรรทัดนี้: เชื่อมโยงกับขนาดกล่องมาตรฐาน
  boxSizeId Int?
  boxSize   CfgMasterData? @relation("ProductBoxSize", fields: [boxSizeId], references: [id])

  ///ค่าเฉลี่ยคะแนน
  ratingAvg   Decimal            @default(0) @db.Decimal(2, 1)
  ///จำนวนรีวิวสะสม
  reviewCount Int                @default(0) // เช่น 120 รีวิว
  ///การรีวิว 
  reviews     ComProductReview[]

  ///ป้ายกำกับวิธีการใช้งาน(เก็บแบบ Array) เพื่อให้ AI ช่วยจัดกลุ่ม เช่น ["ต้ม", "ทอด", "เข้าไมโครเวฟได้"]
  usageTags      String[] 
  ///วัสดุ (เก็บแบบ Array) เพื่อให้ AI ช่วยจัดกลุ่ม
  materialTags   String[] 
  rptPerformance RptProductPerformance[]
  carts          ComCart[]

  /// ✅ 4. เพิ่มรูปปก (Cache) เพื่อความไวในการโหลดหน้า List
  featuredImageUrl String?

  /// เก็บ "ความหมาย" ของสินค้า (สำหรับ Text Search) ขนาด 1536 คือมาตรฐานของ OpenAI (text-embedding-3-small)
  descriptionVector Unsupported("vector(1536)")?

  /// ✅ เพิ่มบรรทัดนี้ครับ: บอกว่าสินค้านี้ เคยถูกเลือกเป็น "เป้าหมายการเปลี่ยนสินค้า" (Exchange Target) ในใบเคลมไหนบ้าง
  exchangeTargetItems ComReturnItem[]
  wishlists           ComWishlist[]
  ///จำนวนสินค้าคงเหลือปัจจุบัน
  stockQty            Int             @default(0)
  costPrice           Decimal         @default(0) @db.Decimal(10, 2)

  ///ระบุว่าเป็นสินค้าสั่งซื้อล่วงหน้าหรือไม่
  isPreOrder Boolean @default(false)

  ///ระยะเวลาที่ใช้ในการเตรียมจัดส่ง (หน่วยเป็นวัน)
  daysToShip Int @default(2)

  /// ✅ เพิ่ม: ความสัมพันธ์ไปหาตารางช่วงราคา
  tierPrices ComProductPriceSet[]

  stockLogs ComStockLog[]

  purchaseItems ProPurchaseItem[]

  /// ✅ เพิ่มใหม่: ความสัมพันธ์กับรูปภาพ
  images ComProductImage[]

  /// เก็บ ID ของตัวแม่ (ถ้าเป็น NULL = เป็นแม่เอง หรือสินค้าเดี่ยว)
  parentId          Int?
  parent            ComProduct?  @relation("ProductVariants", fields: [parentId], references: [id])
  /// ลิสต์ลูกๆ ของตัวนี้
  variants          ComProduct[] @relation("ProductVariants")
  ///ข้อมูลคุณสมบัติแยกย่อย เก็บเป็น JSON เช่น { "Color": "Red", "Size": "L" }
  variantAttributes Json?

  /// (ถ้าอยากทำ Relation กับรูปภาพแบบ Official ให้เพิ่มบรรทัดนี้ด้วย)
  variantImages ComProductImage[] @relation("VariantImages")

  /// ระดับการมองเห็นสินค้า (ผูกกับรหัส Master Data: PRODUCT_VISIBILITY)
  visibilityCode String @default("PUBLIC")

  /// ✅ 1. ความสัมพันธ์ไปยังตารางหมวดหมู่หลัก (Optional - ไม่บังคับเลือก)
  categoryId Int?
  category   CfgMasterData? @relation("ProductCategory", fields: [categoryId], references: [id])

  /// ✅ 2. ป้ายกำกับทั่วไป (เก็บแบบ Array) ให้ผู้ใช้พิมพ์จัดกลุ่มเองได้อิสระ เช่น ["ขายดี", "โปรปีใหม่"]
  tags     String[]
  ///สวิตช์เปิด/ปิดการใช้งานทั่วไป
  isActive Boolean  @default(true)

  orderItems ComOrderItem[]

  shopProducts ComShopProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, sku])
  @@map("com_products")
}


///ตะกร้าสั่งสินค้า
model ComCart {
  id Int @id @default(autoincrement())

  /// ใครเป็นเจ้าของตะกร้า (ผูกกับสมาชิก)
  memberId Int
  member   CrmMember @relation(fields: [memberId], references: [id])

  /// สินค้าจากร้านไหน
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id])

  shopId    Int?
  shop      ComShopProfile? @relation(fields: [shopId], references: [id])

  /// สินค้าตัวไหน
  productId Int
  product   ComProduct @relation(fields: [productId], references: [id])

  quantity   Int     @default(1)
  priceAtAdd Decimal @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([companyId])
  @@index([shopId])
  @@map("com_carts")
}

/// สร้างตารางเก็บประวัติการใช้โค้ดหลายอันต่อ 1 ออเดอร์
model ComOrderDiscount {
  id              Int         @id @default(autoincrement())
  
  /// 🏢 เพิ่มเพื่อความเป็น Multi-company
  companyId       Int
  company         OrgCompany  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  orderId         Int
  order           ComOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  discountId      Int
  discount        ComDiscount @relation(fields: [discountId], references: [id])
  
  discountAmount  Decimal     @db.Decimal(10, 2)
  
  createdAt       DateTime    @default(now())

  @@index([companyId])
  @@map("com_order_discounts")
}

/// 1. สร้าง Enum เพื่อระบุแหล่งที่มา
enum ImageSource {
  GOOGLE_CLOUD // ✅ พระเอกของเรา (Google Cloud Storage)
  EXTERNAL // เผื่อดึงรูปจากเว็บ Supplier หรือ CDN อื่น
  LOCAL // เก็บไว้เผื่อตอน Dev เครื่องตัวเอง (แต่ Production ไม่ใช้)
  GOOGLE_DRIVE
}

/// ✅ เพิ่ม Enum นี้สำหรับแยกประเภทรูป (ตามที่เราคุยกันตะกี้)
enum ImageGenerationType {
  ORIGINAL // รูปต้นฉบับที่ลูกค้าอัป
  AI_NO_BG // รูป AI ลบพื้นหลัง
  AI_ENHANCED // รูป AI ปรับชัด
}

enum MediaType {
  IMAGE
  VIDEO
}

///Table ComProductImage คือตารางสำหรับเก็บข้อมูล รูปภาพและวิดีโอของสินค้า ในระบบของคุณ โดยมีการออกแบบให้รองรับทั้งการจัดการไฟล์ทั่วไป การทำประวัติรูปภาพ (Version Control) และการประมวลผลด้วย AI ครับ
model ComProductImage {
  ///รหัสรูปภาพสินค้า (รันอัตโนมัติ)
  id        Int        @id @default(autoincrement())

  // 🏢 เพิ่มเพื่อความเป็น Multi-company และความปลอดภัยของระบบ AI
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)


  ///เชื่อมโยงว่ารูปนี้เป็นของสินค้าชิ้นไหน หากลบสินค้า รูปภาพที่เกี่ยวข้องจะถูกลบออกไปด้วย
  productId Int
  product   ComProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  ///เพื่อระบุว่าเป็นรูปหรือวิดีโอ
  mediaType MediaType   @default(IMAGE)
  ///แหล่งที่เก็บไฟล์ เช่น GOOGLE_CLOUD (ค่าเริ่มต้น), GOOGLE_DRIVE, หรือ LOCAL
  source    ImageSource @default(GOOGLE_CLOUD)

  ///ระบุว่ารูปนี้เป็นเวอร์ชันไหน เช่น รูปต้นฉบับ (ORIGINAL) หรือรูปที่ผ่านการแต่งเพิ่ม
  generationType ImageGenerationType @default(ORIGINAL)

  ///เป็นระบบ Self-relation (ความสัมพันธ์ในตารางตัวเอง) เพื่อเก็บประวัติว่ารูปนี้ถูกแก้ไขมาจากรูปไหน ช่วยให้สามารถทำระบบ Undo หรือดูประวัติการเปลี่ยนแปลงรูปภาพได้
  parentId Int?
  parent   ComProductImage?  @relation("ImageHistory", fields: [parentId], references: [id])
  children ComProductImage[] @relation("ImageHistory")

  ///ที่อยู่เต็มของไฟล์สำหรับเรียกใช้งาน
  url String

  ///(Option) เชื่อมรูปภาพเข้ากับ รุ่นย่อยของสินค้า (Variant) เช่น รูปนี้สำหรับเสื้อสีแดงเท่านั้น
  variantId Int?
  variant   ComProduct? @relation("VariantImages", fields: [variantId], references: [id])

  /// ชื่อสำหรับแสดงผล (ตั้งเองได้)
  displayName String?

  ///ไอดีเฉพาะของไฟล์จากระบบจัดเก็บ (เช่น ID จาก Google Drive)
  fileId    String?
  ///เก็บค่าสีประจำรูปภาพ สำหรับใช้แสดงผลปุ่มเลือกสี (Color Swatches)
  colorCode String?

  ///เพื่อให้คุณจัดเรียงได้ว่าอยากให้วิดีโอขึ้นก่อนหรือหลังรูป
  sortOrder Int     @default(0)
  ///ชื่อไฟล์เดิมเพื่อใช้อ้างอิง
  fileName  String?
  ///กำหนดว่าเป็นรูปภาพหลักที่จะโชว์ในหน้าแรกของสินค้าหรือไม่ (Default เป็น false)
  isMain    Boolean @default(false)
  ///ขนาดของไฟล์ข้อมูล
  fileSize  BigInt?

  imageVector Unsupported("vector(1536)")?

  ///สถานะการประมวลผลของ AI (เช่น PENDING, PROCESSING, SUCCESS)
  aiStatus    AiProcessStatus?
  ///บันทึกข้อความ Error หาก AI ประมวลผลรูปภาพนี้ไม่สำเร็จ
  aiError     String?
  ///บันทึกเวลาล่าสุดที่ AI ทำงานกับรูปนี้ เพื่อตรวจสอบว่าข้อมูลยังเป็นปัจจุบันหรือไม่
  aiLastRunAt DateTime? // วันที่รัน AI ล่าสุด (เอาไว้เช็คเผื่อรูปมีการแก้ไข)
  /// เก็บค่า MD5 Hash ของไฟล์รูปภาพ เพื่อใช้ตรวจสอบรูปซ้ำ (ลดการเรียก AI ซ้ำซ้อนและประหยัด Quota)
  checksum    String?          @db.VarChar(255)

  tags ComTag[]

  @@index([companyId])
  @@index([productId])
  @@map("com_product_images")
}

// ✅ เพิ่ม Enum สำหรับสถานะ AI
enum AiProcessStatus {
  PENDING // รอคิว
  PROCESSING // กำลังส่งให้ AI วิเคราะห์
  COMPLETED // ติด Tag สำเร็จ
  FAILED // เกิดข้อผิดพลาด
  SKIPPED // ข้ามไป (กรณี User กำหนดเอง)
}

///ตารางนี้ใช้สำหรับบันทึกสถานะและความคืบหน้าของงานที่ต้องให้ AI ประมวลผลทีละมากๆ เพื่อให้ผู้ใช้งานสามารถกดสั่งงานทิ้งไว้ แล้วค่อยกลับมาดูผลลัพธ์ทีหลังได้ (Asynchronous Processing)
model IntAiBatchJob {
  ///รหัสลำดับคิวงาน (รันอัตโนมัติ)
  id             Int            @id @default(autoincrement())
  ///รหัสบริษัทที่เป็นเจ้าของคิวงานนี้ (เพื่อแยกบิลค่าใช้จ่าย AI และความปลอดภัยของข้อมูล)
  companyId      Int
  ///ข้อมูลบริษัทที่เกี่ยวข้อง (ลบอัตโนมัติหากบริษัทถูกลบ)
  company        OrgCompany     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ///ประเภทของงานที่สั่งให้ AI ทำ เช่น IMAGE_TAGGING (แท็กรูปภาพอัตโนมัติ), TEXT_SUMMARY (สรุปข้อความ), DATA_EXTRACTION (ดึงข้อมูลจากไฟล์เอกสาร)
  jobType        String         @default("IMAGE_TAGGING")
  ///สถานะปัจจุบันของงาน (อ้างอิงจาก Enum WorkflowStatus) เช่น IN_PROGRESS (กำลังทำงาน), COMPLETED (เสร็จสมบูรณ์), FAILED (ล้มเหลว)
  status         WorkflowStatus @default(IN_PROGRESS)
  ///จำนวนชิ้นงานทั้งหมดที่ต้องประมวลผลในรอบนี้ (เช่น อัปโหลดรูปมา 500 รูป)
  totalItems     Int            @default(0)
  ///จำนวนชิ้นงานที่ AI ประมวลผลเสร็จแล้ว (ใช้คำนวณ Progress Bar หน้าบ้าน เช่น 250/500 = 50%)
  processedItems Int            @default(0)
  ///จำนวนชิ้นงานที่ประมวลผลไม่สำเร็จ (เช่น รูปเสีย, ไฟล์ใหญ่เกิน, หรือ AI Error)
  failedItems    Int            @default(0)
  /// ✅ ข้อมูลรายละเอียดของงาน (เช่น [fileId1, fileId2] หรือ params ต่างๆ)
  payload        Json?
  ///สรุปสาเหตุของปัญหาภาพรวม กรณีที่มีรายการที่พัง เพื่อให้ Admin เข้ามาดู log ได้
  errorSummary   String?
  ///วันและเวลาที่เริ่มรันคิวงานนี้
  startedAt      DateTime       @default(now())
  ///วันและเวลาที่งานนี้ประมวลผลเสร็จสิ้น (รวมถึงกรณีที่ล้มเหลวด้วย)
  completedAt    DateTime?

  @@map("int_ai_batch_jobs")
}



///ตารางนี้ใช้สำหรับจัดการรายชื่อโมเดล AI ที่ระบบรองรับ (เช่น GPT-4o, Gemini 1.5 Pro) รวมถึงการกำหนด "เรทราคา" ในการตัดเครดิตผู้ใช้งาน โดยรองรับทั้งราคากลางของระบบ และราคาที่ตัวแทนจำหน่ายตั้งเองเพื่อบวกกำไร
model SysAiModelConfig {
  ///รหัสลำดับการตั้งค่า (รันอัตโนมัติ)
  id Int @id @default(autoincrement())

  /// ส่วนเชื่อมโยงบริษัท (ตัวแทน)- ถ้าเป็น NULL: หมายถึง "ราคากลางของ KKV" ที่ใช้กับลูกค้าทั่วไปทุกคน - ถ้าระบุ ID: หมายถึง "ราคาที่ตัวแทนตั้งเอง" เพื่อใช้กับลูกค้าภายใต้เครือข่ายของเขา
  companyId Int?
  ///ข้อมูลบริษัทที่เกี่ยวข้อง (ลบอัตโนมัติหากบริษัทถูกลบ)
  company   OrgCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ///ชื่อค่ายผู้ให้บริการ AI เช่น GOOGLE, OPENAI, ANTHROPIC
  provider  String
  ///รหัสรุ่นโมเดลที่ใช้ยิง API จริง เช่น gemini-1.5-flash, gpt-4o
  modelCode String
  ///ชื่อโมเดลสำหรับแสดงผลให้ลูกค้าเห็นในหน้าจอ เช่น "Gemini 1.5 Flash (ทำงานไว ราคาประหยัด)"
  modelName String

  ///อัตราการหักเครดิตพื้นฐาน (Base Cost) ต่อการใช้ 1,000 โทเคน (Tokens) เช่น ตั้งไว้ 1.0 แปลว่าทุกๆ 1,000 โทเคน จะหักเงิน 1 เครดิต
  creditPer1kTokens Float @default(1.0)

  ///ตัวคูณเพื่อทำกำไร (Profit Margin) เช่น เรทตั้งต้น 1.0 แต่ตัวแทนจำหน่ายตั้ง Multiplier เป็น 1.5 ลูกค้าของตัวแทนคนนี้จะถูกหักเครดิตแพงขึ้น 50% (ส่วนต่างคือกำไรของตัวแทน)
  markupMultiplier Float @default(1.0)

  ///ความจุสมองของ AI ใน 1 รอบการสนทนา (Context Window) เช่น 128000 โทเคน (ช่วยให้หน้าบ้านสามารถแจ้งเตือนลูกค้าได้ว่าส่งไฟล์ใหญ่เกินไปไหม)
  maxContextTokens  Int?    @default(128000)
  ///ระบุว่าโมเดลนี้ "ตาบอด" หรือไม่ (ถ้าเป็น True คือส่งรูปภาพให้ AI ดูวิเคราะห์ได้)
  isVisionSupported Boolean @default(false)
  ///สถานะเปิด/ปิดการให้บริการโมเดลนี้
  isActive          Boolean @default(true)

  /// เวลาที่สร้าง
  createdAt DateTime @default(now())
  /// เวลาที่แก้ไข
  updatedAt DateTime @updatedAt

  ///ระบบป้องกันความผิดพลาด บังคับว่า "1 บริษัท (หรือระบบกลาง) จะตั้งราคาให้โมเดลรหัสเดียวกันซ้ำ 2 รอบไม่ได้"
  @@unique([companyId, modelCode])
  @@map("sys_ai_model_configs")
}

///ตาราง ComTag เป็นตารางที่ใช้สำหรับเก็บข้อมูล "ป้ายกำกับ" (Tags) เพื่อใช้ในการจำแนกคุณลักษณะของรูปภาพสินค้า โดยทำงานร่วมกับตาราง ComProductImage แบบ Many-to-Many
model ComTag {
  id        Int               @id @default(autoincrement())

  /// 🏢 เพิ่มเพื่อให้ Tag เป็นของใครของมัน
  companyId Int
  company   OrgCompany        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🚩 เอา @unique ออกจากตรงนี้
  name      String            
  images    ComProductImage[]

  @@unique([companyId, name]) // 🔒 ล็อกว่าใน 1 บริษัท ชื่อ Tag ต้องไม่ซ้ำกัน
  @@index([companyId])
  @@map("com_tags")
}

///ตารางสำหรับจัดการ "ชุดโครงสร้างราคา" ของสินค้า ซึ่งถูกออกแบบมาให้รองรับการวางแผนราคาล่วงหน้า (Price Scheduling) และการทำโปรโมชั่นตามช่วงเวลาครับ
model ComProductPriceSet {
  id        Int        @id @default(autoincrement())
  
  /// 🏢 เพิ่มเพื่อความเป็น Multi-company
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  productId Int
  product   ComProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  effectiveFrom DateTime
  effectiveTo   DateTime?
  note          String?
  isActive      Boolean @default(true)
  tiers         ComProductTierPrice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([productId])
  @@map("com_product_price_sets")
}

///ตาราง ComProductTierPrice คือตารางที่เก็บ "ตัวเลขราคาจริง" โดยแบ่งตามระดับจำนวนสั่งซื้อ (Tiers) ซึ่งจะทำงานสัมพันธ์โดยตรงกับตาราง ComProductPriceSet
model ComProductTierPrice {
  id Int @id @default(autoincrement())

 
  /// แต่แนะนำให้ใส่ครับ เพื่อให้ทุก Query ในระบบใช้ Standard เดียวกันหมด
  companyId Int
  priceSetId Int
  priceSet   ComProductPriceSet @relation(fields: [priceSetId], references: [id], onDelete: Cascade)
  
  minQty     Int
  maxQty     Int?
  unitPrice  Decimal            @db.Decimal(10, 2)

  @@index([companyId])
  @@map("com_product_tier_prices")
}

///ตารางหลักที่ใช้สำหรับจัดการ "คูปองส่วนลด" หรือ "โปรโมชั่น" ของบริษัท โดยถูกออกแบบมาให้มีความยืดหยุ่นสูง รองรับทั้งส่วนลดแบบจำนวนเงิน เปอร์เซ็นต์ และการส่งฟรี
model ComDiscount {
  ///รหัสหลักของส่วนลด
  id        Int        @id @default(autoincrement())
  ///เชื่อมโยงกับบริษัทเจ้าของส่วนลด
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🏪 1. เพิ่มฟิลด์ Shop ID (ถ้า Null = ใช้ได้ทุกร้านในเครือ)
  shopId Int?
  shop   ComShopProfile? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  ///รหัสคูปอง (เช่น NEWYEAR2026) โดยมีการตั้งค่า @unique ร่วมกับ companyId เพื่อไม่ให้รหัสซ้ำกันภายในบริษัทเดียวกัน
  code              String
  ///คำอธิบายสั้นๆ ของโปรโมชั่น
  description       String?
  ///ประเภทของส่วนลด เช่น FIXED (ลดเป็นจำนวนเงิน) หรือ PERCENTAGE (ลดเป็นเปอร์เซ็นต์)
  discountType      String    @default("FIXED")
  ///มูลค่าของส่วนลด
  discountValue     Float     @default(0)
  ///ยอดซื้อขั้นต่ำที่จะสามารถใช้ส่วนลดนี้ได้
  minPurchaseAmount Float     @default(0)
  ///จำนวนเงินส่วนลดสูงสุด (ใช้บ่อยในกรณีลดเป็น % เพื่อจำกัดเพดานส่วนลด)
  maxDiscountAmount Float?
  ///กำหนดว่าเป็นส่วนลดประเภท "ส่งฟรี" หรือไม่
  isFreeShipping    Boolean   @default(false)
  ///ขอบเขตการใช้งาน เช่น ALL (ทั้งร้าน), CATEGORY (เฉพาะหมวดหมู่), หรือ PRODUCT (เฉพาะสินค้าบางรายการ)
  appliesTo         String    @default("ALL")
  ///เก็บลิสต์ ID ของหมวดหมู่หรือสินค้าที่ระบุไว้ใน appliesTo ในรูปแบบ JSON
  targetIds         Json?
  ///จำนวนสิทธิ์ทั้งหมดที่ใช้ได้ (เช่น 100 สิทธิ์แรก)
  maxUsageTotal     Int?
  ///จำนวนที่มีการใช้ไปแล้วจริง
  usedCount         Int       @default(0)
  ///จำกัดจำนวนครั้งที่ลูกค้า 1 คนจะใช้รหัสนี้ได้
  maxUsagePerUser   Int       @default(1)
  ///เชื่อม dms
  documents         EcomPromotionDocument[]
  ///ช่วงวันที่โค้ดนี้
  startDate         DateTime?
  ///หมดอายุ
  endDate           DateTime?
  ///การเปิด-ปิดการใช้งานด้วยตัวเอง
  isActive          Boolean   @default(true)

  orders        ComOrder[]
  orderDiscount ComOrderDiscount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, shopId, code])
  @@map("com_discounts")
}

enum ShippingCalcType {
  PRICE_BASED // ตามยอดเงิน (Default)
  WEIGHT_BASED // ตามน้ำหนัก
  FLAT_RATE // ราคาเดียวเหมาจ่าย
}

///เก็บรูปแบบหรือช่องทางการจัดส่งสินค้าที่แต่ละบริษัทเปิดให้บริการ (เช่น Flash Express, Kerry, หรือการเข้ารับสินค้าเอง) โดยรองรับการกำหนดเงื่อนไขการคำนวณค่าบริการที่หลากหลาย
model ComShippingMethod {
  ///รหัสลำดับภายในของวิธีการจัดส่ง (Primary Key)
  id          Int              @id @default(autoincrement())
  ///รหัสอ้างอิงบริษัทเจ้าของวิธีการจัดส่ง เพื่อรองรับระบบ Multi-tenancy
  companyId   Int
  company     OrgCompany       @relation(fields: [companyId], references: [id])
  ///ชื่อเรียกวิธีการจัดส่งที่จะแสดงให้ลูกค้าเห็น เช่น "Standard Delivery", "EMS", "ส่งด่วนภายในวัน"
  name        String
  ///รายละเอียดเพิ่มเติมหรือเงื่อนไขเบื้องต้นของช่องทางนั้นๆ เช่น "ระยะเวลาจัดส่ง 1-3 วันทำการ"
  description String?
  /// ✅ เพิ่ม: ให้เลือกได้ว่าจะคำนวณแบบไหน PRICE_BASED ,WEIGHT_BASED,FLAT_RATE
  calcType    ShippingCalcType @default(PRICE_BASED)
  ///สถานะการเปิด-ปิดใช้งานช่องทางการจัดส่งนี้
  isActive    Boolean          @default(true)

  /// วิธีการจัดส่ง มีได้หลายช่วงราคา (Rules)
  rules ComShippingRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("com_shipping_methods")
}

///เก็บรายละเอียดกฎเกณฑ์หรือ "ขั้นบันไดราคา" ของการจัดส่งแต่ละประเภท โดยตารางนี้จะทำงานร่วมกับ calcType ในตารางหลักเพื่อตัดสินใจว่าจะคิดค่าส่งเท่าไหร่ตามยอดซื้อหรือน้ำหนักสินค้า
model ComShippingRule {
  id             Int              @id @default(autoincrement())
  
  /// 🌟 เพิ่มส่วนนี้เพื่อให้รองรับ Multi-company
  companyId      Int
  company        OrgCompany       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  methodId       Int
  shippingMethod ComShippingMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)

  minAmount      Decimal          @default(0) @db.Decimal(10, 2)
  maxAmount      Decimal?         @db.Decimal(10, 2)
  minWeight      Decimal          @default(0)
  maxWeight      Decimal?
  boxSize        String?          @default("NONE") @db.VarChar(50)
  cost           Decimal          @default(0) @db.Decimal(10, 2)

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([companyId]) // 🚀 เพิ่ม Index เพื่อให้ query เร็วขึ้น
  @@map("com_shipping_rules")
}

/// ประกาศต่างๆ
model ComAnnouncement {
  id Int @id @default(autoincrement())

  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  targetShops ComShopProfile[] @relation("ShopAnnouncements")

  title        String
  content      String?          @db.Text
  linkUrl      String?
  type         String           @default("BANNER")
  position     String           @default("HOME_HERO")
  displayOrder Int              @default(0)
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  notifications SysNotification[]


  /// รองรับทั้งรูป Banner และไฟล์ PDF แนบประกาศ
  media         ComAnnouncementMedia[]

  @@index([companyId, isActive, position])
  @@map("com_announcements")
}

/// ตารางการสั่งสินค้าในระบบ
model ComOrder {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id])

  memberId Int
  member   CrmMember @relation(fields: [memberId], references: [id])

  orderNo String
  status  String @default("PENDING")

  /// ✅ เพิ่ม: ระบุว่าออเดอร์นี้เกิดที่หน้าร้านไหน
  shopId Int
  shop   ComShopProfile @relation(fields: [shopId], references: [id])

  shippingDocs    EcomShippingDocument[]

  /// Payment Setup
  paymentStatus String  @default("UNPAID")
  paymentType   String  @default("FULL")
  totalAmount   Decimal @default(0) @db.Decimal(10, 2)
  paidAmount    Decimal @default(0) @db.Decimal(10, 2)


  ///[ปรับปรุง] รองรับช่องทางการชำระเงินแบบ API เช่น 'MANUAL_TRANSFER', 'PROMPTPAY_QR', 'CREDIT_CARD'
  paymentMethod   String?  
  /// เช่น 'OMISE', 'GBPRIME'
  paymentProvider String?  
  /// รหัส Charge ID ที่ Payment Gateway ออกให้ (เช่น ch_123456789)
  paymentRefId    String?  
  isPaid          Boolean  @default(false)
  paidAt          DateTime?

  /// Discount & Shipping
  discountId     Int?
  discount       ComDiscount?       @relation(fields: [discountId], references: [id])
  discountAmount Decimal            @default(0) @db.Decimal(10, 2)
  returnRequests ComReturnRequest[] // ✅ เพิ่ม (1 Order เคลมได้หลายรอบ)
  productReview  ComProductReview[]
  orderDiscount  ComOrderDiscount[]
  /// 🚩 [เพิ่มใหม่] เพื่อเชื่อมโยงย้อนกลับมาหาตารางใบกำกับภาษี
  invoice       ComInvoice?

  shippingRuleId  Int?
  shippingCost    Decimal @default(0) @db.Decimal(10, 2)
  shippingAddress String? @db.Text
  trackingNumber  String?

  /// รหัสอ้างอิงออเดอร์ในระบบขนส่ง (เอาไว้ใช้ยิง API ไปอัปเดต/ยกเลิกพัสดุ)
  courierTicketId  String?  
  /// ลิงก์ไฟล์ PDF ใบปะหน้า (Waybill) ที่ขนส่งส่งกลับมาให้พิมพ์
  shippingLabelUrl String?  
  /// สถานะเรียลไทม์จากขนส่ง (เช่น PICKED_UP, IN_TRANSIT, DELIVERED)
  courierStatus    String?  

  items    ComOrderItem[]
  payments ComPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, orderNo])
  @@map("com_orders")
}

/// ตารางเก็บสินค้าที่สั่งใน แต่ละ order
model ComOrderItem {
  id      Int      @id @default(autoincrement())
  orderId Int
  order   ComOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id])

  productId Int
  product   ComProduct @relation(fields: [productId], references: [id])

  productName String
  productSku  String?
  qty         Int
  price       Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  /// ✅ เพิ่ม: รายการนี้ถูกสั่งซื้อไปหรือยัง? (Link ไปหา PO)
  purchaseItemId Int?
  purchaseItem   ProPurchaseItem? @relation(fields: [purchaseItemId], references: [id])
  returnedItems  ComReturnItem[] // ✅ เพิ่ม (รายการนี้เคยถูกเคลมไปแล้วหรือยัง)

  cancelReason  String? // 
  cancelledById Int? // ใครเป็นคนสั่งยกเลิก (Admin)

  /// เชื่อมกับ Workflow เพื่อดูประวัติการอนุมัติยกเลิก
  wfRequestId Int?       @unique
  wfRequest   WfRequest? @relation(fields: [wfRequestId], references: [id])

 
  /// ✅ เพิ่ม: สถานะของสินค้ารายตัว (Tracking) WAITING_PO (รอรวมยอด), PO_CREATED (สั่งแล้ว), ARRIVED_TH (ถึงไทย), RECEIVED (ร้านได้รับแล้ว)
  itemStatus String  @default("WAITING_PO")
  comment    String?

  /// 🚀 เพิ่ม Index ให้ค้นหาและทำ Report ได้เร็วปรู๊ดปร๊าด
  @@index([companyId])
  @@index([companyId, productId]) // Index คู่สำหรับหน้ารายงานยอดขายรายสินค้า
  @@map("com_order_items")
}

///เก็บรูปแบบหรือช่องทางการชำระเงินที่แต่ละบริษัทอนุญาตให้ลูกค้าใช้ (เช่น โอนเงินผ่านธนาคาร, ชำระผ่านบัตรเครดิต, หรือ Rabbit LINE Pay) โดยรองรับการตั้งค่าที่ยืดหยุ่นตามประเภทของระบบชำระเงิน
model ComPaymentMethod {
  ///รหัสลำดับภายในของวิธีการชำระเงิน (Primary Key)
  id          Int        @id @default(autoincrement())
  ///รหัสอ้างอิงบริษัท เพื่อรองรับระบบ Multi-tenancy ให้แต่ละบริษัทมีช่องทางชำระเงินของตัวเอง
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ///รหัสอ้างอิงของวิธีการชำระเงิน เช่น BANK_TRANSFER, CREDIT_CARD, PROMPTPAY (ต้องไม่ซ้ำกันในหนึ่งบริษัท)
  code        String
  ///ชื่อเรียกช่องทางชำระเงินที่จะแสดงให้ลูกค้าเห็น เช่น "โอนเงินผ่านบัญชีธนาคาร", "ชำระผ่าน QR Code"
  name        String
  ///ประเภทของระบบชำระเงิน (Default: BANK_TRANSFER) เพื่อให้ระบบเลือกกระบวนการจัดการได้ถูกต้อง
  type        String     @default("BANK_TRANSFER")
  ///ข้อมูลการตั้งค่าเชิงเทคนิคในรูปแบบ JSON (เช่น API Key, Merchant ID สำหรับระบบตัดบัตรเครดิต)
  config      Json?
  ///ข้อความแนะนำขั้นตอนการชำระเงินสำหรับลูกค้า เช่น "กรุณาโอนเงินภายใน 24 ชม. และแนบสลิป"
  instruction String?    @db.Text
  ///ลิงก์รูปภาพ QR Code สำหรับการรับชำระเงิน (เช่น รูป QR PromptPay ของร้าน)
  qrImage     String?
  ///สถานะการเปิด/ปิดใช้งานช่องทางชำระเงินนี้
  isActive    Boolean    @default(true)

  payments ComPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@map("com_payment_methods")
}

///เก็บข้อมูลการชำระเงินของลูกค้าที่เกิดขึ้นจริงในแต่ละออเดอร์ ใช้สำหรับบันทึกหลักฐานการโอนเงิน (Slip) และเป็นฐานข้อมูลให้แอดมินเข้ามาตรวจสอบเพื่ออนุมัติหรือปฏิเสธยอดเงินนั้นๆ
model ComPayment {
  ///รหัสลำดับของรายการชำระเงิน (Primary Key)
  id            Int              @id @default(autoincrement())
  ///รหัสบริษัทที่ได้รับชำระเงินก้อนนี้
  companyId     Int
  company       OrgCompany       @relation(fields: [companyId], references: [id])
  ///รหัสออเดอร์ที่ถูกชำระเงิน โดยระบุ onDelete: Cascade เพื่อให้ประวัติการจ่ายเงินถูกลบหากออเดอร์นั้นถูกลบทิ้ง
  orderId       Int
  order         ComOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ///รหัสอ้างอิงไปยังช่องทางการชำระเงินที่ลูกค้าเลือกใช้ (เชื่อมกับตาราง ComPaymentMethod)
  methodId      Int
  method        ComPaymentMethod @relation(fields: [methodId], references: [id])
  ///ยอดเงินที่ลูกค้าระบุว่าชำระเข้ามาจริง
  amount        Decimal          @db.Decimal(10, 2)
  ///วันและเวลาที่ลูกค้าแจ้งว่าได้ทำการโอนเงิน
  transferredAt DateTime         @default(now())
  ///ที่อยู่ไฟล์รูปภาพหลักฐานการโอนเงิน (Slip) ที่ลูกค้าอัปโหลด
  slipUrl       String?
  ///หมายเลขอ้างอิงการทำรายการจากธนาคารหรือระบบชำระเงินภายนอก
  refNo         String?
  ///สถานะของรายการชำระเงินนี้ เช่น PENDING (รอนุมัติ), SUCCESS (ยืนยันแล้ว), หรือ REJECTED
  status        String           @default("PENDING")
  ///รหัสผู้ใช้งาน (แอดมิน) ที่เป็นคนตรวจสอบรายการนี้
  verifiedBy    Int?
  verifier      SecUser?         @relation(fields: [verifiedBy], references: [id])
  ///วันและเวลาที่มีการกดอนุมัติรายการ
  verifiedAt    DateTime?
  ///เหตุผลที่ปฏิเสธการชำระเงิน (กรณีสถานะเป็น REJECTED) เช่น "ยอดเงินไม่ตรง" หรือ "สลิปซ้ำ"
  rejectReason  String?
  slips         EcomPaymentSlip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@map("com_payments")
}

/// 📦 IntMessageQueue: ระบบศูนย์กระจายข้อความ (External Message Dispatcher) พักข้อมูลข้อความ (LINE, SMS, Email) ไว้ก่อนส่งจริง เพื่อไม่ให้ระบบหลักทำงานช้าลง (Asynchronous) ,รองรับการตั้งเวลาส่งล่วงหน้า (Scheduled Task) ผ่านฟิลด์ scheduledTime
model IntMessageQueue {
  id        Int  @id @default(autoincrement())
  /// ผูกกับบริษัทเจ้าของข้อความ
  companyId Int
  /// (เพิ่ม) กรณีส่งในนามร้านค้าใดร้านค้าหนึ่ง
  shopId    Int?

  /// (เพิ่ม) ช่องทาง เช่น LINE, SMS, EMAIL, FACEBOOK
  channel   String
  /// Line User ID, เบอร์โทร หรือ Email
  recipient String
  /// หัวข้อ (สำหรับ Email) 
  subject   String?
  /// เนื้อหาข้อความ
  content   String  @db.Text

  /// เวลาที่กำหนดให้ส่ง
  scheduledTime DateTime
  /// PENDING, PROCESSING, SENT, FAILED, CANCELLED
  status        String   @default("PENDING")
  /// จำนวนครั้งที่พยายามส่งใหม่หากพัง
  retryCount    Int      @default(0)
  /// (เพิ่ม) กำหนดเพดานการส่งซ้ำ
  maxRetries    Int      @default(3)

  /// อ้างอิงว่าส่งจากส่วนไหน เช่น PROMOTION, ORDER_NOTIFY
  refType      String?
  /// ID อ้างอิงของงานนั้นๆ
  refId        String?
  /// เก็บสาเหตุถ้าส่งไม่สำเร็จ
  errorMessage String?
  /// เวลาที่ส่งออกไปจริง
  sentAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company OrgCompany @relation(fields: [companyId], references: [id])

  @@index([status, scheduledTime])
  @@index([companyId])
  @@map("int_message_queue")
}



///ตารางเก็บข้อมูลรายละเอียดคู่ค้า ผู้ขาย และผู้ผลิตสินค้าที่บริษัททำการติดต่อสั่งซื้อ
model ProSupplier {
  ///รหัสลำดับหลักของคู่ค้า (Primary Key) แบบรันอัตโนมัติ
  id        Int        @id @default(autoincrement())
  ///รหัสอ้างอิงไปยังบริษัท (OrgCompany) เพื่อแยกรายชื่อคู่ค้าตามแต่ละองค์กร
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ///รหัสอ้างอิงคู่ค้าที่กำหนดขึ้นเอง เช่น SUP-001, HK-SUP-01
  code      String
  ///ชื่อร้านค้า หรือชื่อบริษัทคู่ค้า
  name      String
  /// เลขผู้เสียภาษี
  taxId     String?

  /// ชื่อบุคคลที่ติดต่อได้ของบริษัทคู่ค้า
  contactName String?
  ///เบอร์โทรศัพท์สำหรับติดต่อ
  phone       String?
  ///อีเมลสำหรับติดต่อหรือส่งใบสั่งซื้อ (PO)
  email       String?
  ///ที่อยู่ตามทะเบียนภาษีหรือสถานที่จัดส่งของคู่ค้า
  address     String? @db.Text

  /// เครดิตเทอม (จำนวนวัน)
  creditTerm Int @default(0)

  /// ✅ 1. เพิ่ม Relation นี้ครับ (สินค้าที่ Supplier เจ้านี้เป็นคนขายหลัก)
  products ComProduct[]

  /// ✅ (Optional) แนะนำเพิ่ม: สกุลเงินหลัก (เช่น CNY, USD, THB) จะช่วยตอนเปิด PO
  currency String @default("THB")

  /// ✅ (Optional) แนะนำเพิ่ม: ประเภท Supplier (ในประเทศ / นำเข้า)
  type String @default("LOCAL") // LOCAL, IMPORT

  purchaseOrders ProPurchaseOrder[]
  ///สถานะการเปิดใช้งาน (หากเป็น false จะไม่สามารถเลือกไปออก PO ใหม่ได้)
  isActive       Boolean            @default(true)
  ///วันและเวลาที่สร้างข้อมูลคู่ค้า
  createdAt      DateTime           @default(now())
  ///วันและเวลาที่แก้ไขข้อมูลล่าสุด
  updatedAt      DateTime           @updatedAt

  @@unique([companyId, code])
  @@map("pro_suppliers")
}

///เก็บข้อมูลหลัก (Header) ของใบสั่งซื้อสินค้าที่บริษัทออกให้แก่ซัพพลายเออร์ (Supplier) ทำหน้าที่ควบคุมยอดเงิน สถานะการสั่งซื้อ และกำหนดการส่งมอบสินค้า เพื่อใช้ในกระบวนการเติมสต็อกสินค้าให้เพียงพอต่อการขาย
model ProPurchaseOrder {
  id            Int             @id @default(autoincrement())
  companyId     Int
  company       OrgCompany      @relation(fields: [companyId], references: [id])
  supplierId    Int
  supplier      ProSupplier     @relation(fields: [supplierId], references: [id])
  docNo         String
  docDate       DateTime        @default(now())
  dueDate       DateTime?
  status        String          @default("DRAFT")
  note          String?         @db.Text
  totalAmount   Decimal         @default(0) @db.Decimal(10, 2)
  vatAmount     Decimal         @default(0) @db.Decimal(10, 2)
  netAmount     Decimal         @default(0) @db.Decimal(10, 2)
  documents     EcomPurchaseDocument[]
  items         ProPurchaseItem[]


  // 🚩 [เพิ่มใหม่] เชื่อมโยงกับสายอนุมัติ Workflow 
  wfRequestId   Int?       @unique 
  wfRequest     WfRequest? @relation(fields: [wfRequestId], references: [id], onDelete: SetNull)

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([companyId, docNo])
  /// 🚀 เพิ่ม Index เพื่อให้หน้า List PO โหลดไว
  @@index([companyId])
  @@index([supplierId])
  @@map("pro_purchase_orders")
}

///เก็บรายละเอียดรายการสินค้าแต่ละชนิดที่ระบุอยู่ในใบสั่งซื้อ (Purchase Order) ทำหน้าที่เชื่อมโยงระหว่าง "ความต้องการซื้อ" กับ "ตัวสินค้าจริง" ในระบบ พร้อมทั้งติดตามสถานะการรับของว่าได้รับครบตามจำนวนที่สั่งหรือไม่
model ProPurchaseItem {
  id               Int              @id @default(autoincrement())
  
  /// 🏢 เพิ่ม companyId ในระดับ Item 
  companyId        Int
  company          OrgCompany       @relation(fields: [companyId], references: [id])

  purchaseOrderId  Int
  purchaseOrder    ProPurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId        Int
  product          ComProduct       @relation(fields: [productId], references: [id])
  productName      String
  qty              Int
  qtyReceived      Int              @default(0)
  unitCost         Decimal          @db.Decimal(10, 2)
  totalCost        Decimal          @db.Decimal(10, 2)
  customerOrderItems ComOrderItem[]

  /// 🚀 เพิ่ม Index เพื่อความเร็วในการคำนวณต้นทุน/สต็อก
  @@index([companyId])
  @@index([companyId, productId])
  @@map("pro_purchase_items")
}

///จุดประสงค์หลักของตารางนี้คือการรองรับโครงสร้างแบบ Multi-Storefront ซึ่งหมายความว่า 1 บริษัท (Company) สามารถแตกสาขาหรือแตกหน้าร้านออกไปได้หลายช่องทาง เช่น มี "ร้านขายปลีก", "ร้านขายส่ง", หรือ "หน้าร้านสาขาเชียงใหม่" โดยแต่ละร้านสามารถมีการตั้งค่าหน้าตา โลโก้ นโยบายภาษี และโกดังแยกกันได้อย่างอิสระ
model ComShopProfile {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  googleAnalyticsId String?
  facebookPixelId   String?
  tiktokPixelId     String?
  headingFont       String? @default("Kanit")
  bodyFont          String? @default("Prompt")

  shopCode          String  @unique
  shopName          String

  /// 🌐 [NEW] โดเมนเฉพาะสำหรับหน้าร้านค้าออนไลน์ขายปลีก (Shop Level Storefront)
  customDomain      String?   @unique

 
  /// ✅ [NEW] เปลี่ยนมาใช้ Relation เชื่อมกับ SysMedia (DMS) สำหรับรูปโลโก้ร้าน
  logoMediaId Int?      @unique
  logoMedia   SysMedia? @relation("ShopLogo", fields: [logoMediaId], references: [id])

  /// ✅ [NEW] เชื่อมโยงกับตารางเอกสารยืนยันตัวตนร้านค้า (KYC, ทะเบียนพาณิชย์, หน้าบุ๊คแบงก์)
  documents   ComShopDocument[]

  /// 🚩 [เพิ่มใหม่] ความสัมพันธ์สำหรับการตั้งค่าแยกรายสาขา
  logisticsProviders CfgLogisticsProvider[]
  paymentGateways    CfgPaymentGateway[]
  /// 🚩 [เพิ่มใหม่] เพื่อรองรับประวัติใบกำกับภาษีแยกตามรายสาขา
  invoices  ComInvoice[]

  webBaseUrl     String?
  lineOaUrl      String?
  primaryColor   String? @default("#4F46E5")
  secondaryColor String?

  comWarehouse   ComWarehouse[]
  crmMemberShops CrmMemberShop[]
  carts          ComCart[]

  warehouseAddress String? @db.Text
  pickupAddress    String? @db.Text
  returnAddress    String? @db.Text

  returnRequests ComReturnRequest[] 
  rptDailySales  RptDailySales[]
  comDiscount    ComDiscount[]
  otps           SecOtp[]
  announcements  ComAnnouncement[]  @relation("ShopAnnouncements")

  currency      String  @default("THB")
  timezone      String  @default("Asia/Bangkok")
  taxRate       Decimal @default(7.0)
  isVatIncluded Boolean @default(true)

  address     String? @db.Text
  subDistrict String?
  district    String?
  province    String?
  zipCode     String?

  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  phone     String?

  isMainShop Boolean @default(false)
  isActive   Boolean @default(true)

  bankAccounts ComBankAccount[]
  shopProducts ComShopProduct[]
  orders       ComOrder[]

  rewards     CrmReward[]
  redemptions CrmRedemption[]
  SmtpConfig  IntSmtpConfig[]
  Template    ComTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, shopCode])
  @@map("com_shop_profiles")
}

/// ✅ Table ใหม่: บัญชีธนาคารของร้านค้า (สำหรับโชว์ในใบเสร็จ / Footer เว็บ / หรือ Payment Method)
model ComBankAccount {
  id     Int            @id @default(autoincrement())
  shopId Int
  shop   ComShopProfile @relation(fields: [shopId], references: [id], onDelete: Cascade)

  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// รหัสธนาคาร
  bankCode    String
  /// ชื่อธนาคาร
  bankName    String
  /// หมายเลขบัญชีธนาคาร
  accountNo   String
  /// ชื่อบัญชี ธนาคาร
  accountName String
  /// สาขาธนาคาร
  branch      String?

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("com_bank_accounts")
}

/// ทำหน้าที่เชื่อมสินค้าหลัก (Master Product) เข้ากับหน้าร้านแต่ละสาขา ทำให้แต่ละร้านสามารถตั้งราคา (Price Override), เปลี่ยนชื่อ, เปลี่ยนรูป และเปิด/ปิดการขายแยกกันได้อย่างอิสระ
model ComShopProduct {
  shopId    Int
  productId Int
  companyId Int

  shop    ComShopProfile @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product ComProduct     @relation(fields: [productId], references: [id], onDelete: Cascade)
  company OrgCompany     @relation(fields: [companyId], references: [id], onDelete: Cascade)




  /// ✅ เพิ่มตัวนี้: เผื่อหน้าร้านอยากใช้รหัสสินค้าคนละรหัสกับคลังกลาง
  skuOverride      String?

  /// เปิด/ปิด การขายในร้านนี้
  isActive      Boolean  @default(true)
  /// (Optional) ตั้งราคาต่างกันแต่ละร้านได้
  priceOverride Decimal? @db.Decimal(10, 2)

  /// ✅ เพิ่ม: รูปปกเฉพาะร้านนี้
  featuredImageUrl String?

  /// ✅ (Optional) เพิ่ม: ชื่อสินค้าเฉพาะร้านนี้ (เผื่ออยากตั้งชื่อให้ดูไม่เหมือนกันเลย)
  nameOverride String?

  // (ถ้า Stock แยกกันแต่ละร้าน ก็เพิ่ม stockQty ตรงนี้ได้)
  // stockQty   Int? 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Composite Primary Key (ใช้คู่เดิมได้เลย เพราะยังไงสินค้ากับร้านก็ห้ามซ้ำกันอยู่แล้ว)
  @@id([shopId, productId]) 
  /// 🌟 [เพิ่มใหม่] ทำ Index ไว้ให้ดึงรายงานรายบริษัทได้เร็วปรู๊ดปร๊าด
  @@index([companyId]) 
  @@map("com_shop_products")
}



enum RmaType {
  REFUND // คืนของขอเงินคืน
  EXCHANGE // เปลี่ยนสินค้า (เช่น ผิดไซส์)
  REPAIR // ส่งซ่อม/เคลม (สินค้ามีปัญหา)
}

enum RmaStatus {
  PENDING // รอลูกค้ายื่นเรื่อง / รอร้านอนุมัติ
  APPROVED // ร้านอนุมัติแล้ว (รอลูกค้าส่งของมา)
  SHIPPING // ลูกค้ากรอกเลขพัสดุส่งกลับมาแล้ว
  RECEIVED // ร้านได้รับของแล้ว (รอตรวจสภาพ)
  CHECKING // กำลังตรวจสอบสินค้า

  // ผลลัพธ์
  COMPLETED // จบงาน (คืนเงินแล้ว/ส่งตัวใหม่แล้ว)
  REJECTED // ปฏิเสธ (เช่น ไม่อยู่ในเงื่อนไข)
  CANCELLED // ลูกค้ายกเลิกเอง
}

///ก็บข้อมูลภาพรวมของการขอคืนสินค้า เช่น ใครเป็นคนขอคืน (memberId), คืนจากออเดอร์ไหน (orderId), คืนสาขาไหน (shopId)
model ComReturnRequest {
  id Int @id @default(autoincrement())

  /// ✅ 1. Multi-Company Support
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// ✅ 2. รองรับ Multi-Shop (คืนเข้าร้านไหน)
  shopId Int
  shop   ComShopProfile @relation(fields: [shopId], references: [id])

  /// ข้อมูลอ้างอิง
  orderId Int
  order   ComOrder @relation(fields: [orderId], references: [id])

  memberId Int
  member   CrmMember @relation(fields: [memberId], references: [id])
  /// เลขที่ใบเคลม (RMA-2024-0001)
  docNo String 

  documents EcomReturnDocument[]

  type   RmaType
  status RmaStatus @default(PENDING)
  /// เหตุผล (เช่น "สินค้าชำรุด", "ใส่ไม่ได้")
  reason      String 
  description String? @db.Text // รายละเอียดเพิ่มเติม

  /// หลักฐาน (รูปภาพ/วิดีโอ)
  proofImages String[] 

  /// การส่งของคืน (Logistics) เลขพัสดุที่ลูกค้าส่งกลับมา 
  customerTrackingNo String? 
  /// ขนส่งที่ลูกค้าใช้
  customerCourier    String? 
  /// เลขพัสดุที่เราส่งตัวใหม่/ตัวซ่อม กลับไปให้ลูกค้า
  shopTrackingNo String? 

  /// การเงิน (กรณี Refund)
  refundAmount  Decimal? @db.Decimal(10, 2)
  refundSlipUrl String? // สลิปโอนเงินคืน

  /// รายการสินค้าที่ส่งมาเคลม
  items ComReturnItem[]

  /// 1 RMA ผูกกับ 1 Workflow Request
  wfRequestId Int?       @unique 
  wfRequest   WfRequest? @relation(fields: [wfRequestId], references: [id])

  /// Admin Note (บันทึกภายใน)
  adminNote String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, docNo])
  @@map("com_return_requests")
}

///ระบุเจาะจงลงไปเลยว่า "สินค้าชิ้นไหน" ในออเดอร์นั้นที่ถูกส่งเคลม (orderItemId) และเคลมจำนวนกี่ชิ้น (qty)
model ComReturnItem {
  id              Int              @id @default(autoincrement())
  companyId       Int
  returnRequestId Int
  returnRequest   ComReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  /// อ้างอิงว่าคืนรายการไหนใน Order เดิม
  orderItemId Int
  orderItem   ComOrderItem @relation(fields: [orderItemId], references: [id])
  /// จำนวนที่เคลม
  qty Int 

  /// กรณี Exchange: ต้องการเปลี่ยนเป็นสินค้าตัวไหน (เช่น เปลี่ยนจาก Size S -> M)
  targetProductId Int?
  targetProduct   ComProduct? @relation(fields: [targetProductId], references: [id])
  /// สภาพสินค้าที่ได้รับ (เช่น "กล่องบุบ", "มีรอยขีดข่วน")
  condition String? 

  @@index([companyId])
  @@map("com_return_items")
}


///บันทึกทุกๆ การขยับของสต็อก ไม่ว่าจะเป็นของเข้า ของออก หรือของพัง ระบบจะบันทึกว่า ขยับกี่ชิ้น (changeQty), ยอดคงเหลือตอนนั้นคือเท่าไหร่ (balanceAfter), และขยับด้วยสาเหตุอะไร (type เช่น SALE, PURCHASE, TRANSFER)
model ComStockLog {
  id BigInt @id @default(autoincrement())

  /// 1. ผูกกับบริษัท (Multi-Tenant)
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 2. ผูกกับสินค้า
  productId Int
  product   ComProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// 🌟 1. คลังสินค้าที่เกิดเหตุการณ์นี้ขึ้น
  warehouseId Int
  warehouse   ComWarehouse @relation("WarehouseLog", fields: [warehouseId], references: [id])

  /// 🌟 2. คลังต้นทาง/ปลายทาง (ใช้เฉพาะตอนโอนย้าย Transfer)
  refWarehouseId Int?
  refWarehouse   ComWarehouse? @relation("TransferWarehouseLog", fields: [refWarehouseId], references: [id])

  /// เปลี่ยนแปลงเท่าไหร่ (เช่น +10, -5)
  changeQty    Int 
  /// ยอดคงเหลือหลังจากเปลี่ยน (Snapshot ไว้ดูย้อนหลัง)
  balanceAfter Int 
  /// สาเหตุ (ขาย/ซื้อ/คืน)
  type StockChangeType 

  /// มาจาก Order ID ไหน
  refOrderId        Int? 
  /// มาจาก PO Item ID ไหน
  refPurchaseItemId Int? 
  /// มาจากใบรับคืน (RMA) ไหน
  refReturnId       Int? 
  /// หมายเหตุเพิ่มเติม
  note      String? 
  /// User ID คนทำรายการ (เก็บแค่ ID พอ)
  createdBy Int?

  createdAt DateTime @default(now())

  @@index([companyId, warehouseId, productId, createdAt])
  @@map("com_stock_logs")
}



///สร้างขึ้นมาเพื่อ ควบคุมไม่ให้บริษัทใดบริษัทหนึ่งใช้งาน AI หนักเกินไปจนคุณขาดทุน และใช้เพื่อแบ่งระดับการให้บริการตามแพ็กเกจ (Tier) ครับ
model IntAiQuota {
  id Int @id @default(autoincrement())

  /// เชื่อมกับบริษัท (1 บริษัท มี 1 โควตา)
  companyId Int        @unique
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// แพ็กเกจการใช้งาน (เช่น FREE, PRO, ENTERPRISE)
  tier String @default("FREE")

  /// ✅ [NEW] ขนาดไฟล์สูงสุดต่อการอัปโหลด 1 ครั้ง (Default 10MB)
  maxSingleFileSize Int @default(10485760)

  // โควตารายเดือน (หน่วยเป็น Tokens)
  monthlyLimit  BigInt @default(100000) // เช่น 1 แสน tokens
  usedThisMonth BigInt @default(0) // จำนวนที่ใช้ไปแล้วในรอบเดือน

  /// --- 📁 Storage Quota (Bytes) ค่า Default 500MB (500 * 1024 * 1024)
  maxStorageBytes  BigInt @default(524288000)
  /// ผลรวมขนาดไฟล์ที่อัปโหลดทั้งหมด
  usedStorageBytes BigInt @default(0)

  /// จำนวนโควตาการตรวจสลิปที่ได้ต่อเดือน (0 = ไม่ได้ซื้อแพ็กเกจนี้)
  slipVerifyLimit Int @default(0)

  /// จำนวนโควตาที่ใช้ไปแล้วในเดือนนี้
  slipVerifyUsed Int @default(0)

  /// --- ⏳ Validity (ช่วงที่มีผล) ---
  startDate DateTime  @default(now())
  ///ถ้าเป็น NULL = ไม่มีวันหมดอายุ
  endDate   DateTime?

  /// เครดิตคงเหลือที่ซื้อเพิ่ม (Top-up) กรณีใช้โควตาเดือนนั้นหมดแล้ว
  extraCredit BigInt @default(0)

  lastResetDate DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("int_ai_quotas")
}

///มิเตอร์น้ำ/มิเตอร์ไฟประจำระบบ AI (AI Meter & Billing Log)" ครับทุกครั้งที่บอทน้องขายดีคิดคำตอบ, ทุกครั้งที่ AI ช่วยสกัดข้อมูลจาก PDF หรือทุกครั้งที่ระบบช่วยคิด Tag สินค้า... ข้อมูลทั้งหมดจะถูกบันทึกลงตารางนี้
model IntAiUsageLog {
  ///รหัสรายการ (ใช้ BigInt ถูกต้องมากครับ เพราะ Log แบบนี้ข้อมูลจะโตไวมาก อาจจะทะลุล้านบรรทัดในไม่กี่เดือน)
  id        BigInt     @id @default(autoincrement())
  ///ระบุว่าบิลค่า AI รอบนี้เป็นของบริษัทไหน (ใครต้องถูกหักโควตา)
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ///ระบุเจาะจงลงไปอีกว่า บอทตัวไหนของบริษัทนั้นที่เป็นคนเรียกใช้ (เผื่อบริษัทนึงมีบอท 3 ตัว จะได้รู้ว่าตัวไหนทำงานหนักสุด)
  aiBotId Int?
  aiBot   IntAiBot? @relation(fields: [aiBotId], references: [id])

  ///ชื่อสมองกลที่ใช้ทำงาน เช่น gpt-4o หรือ gemini-1.5-pro (สำคัญมากเพราะโมเดลแต่ละตัวราคาไม่เท่ากัน) // เช่น gpt-4o, gemini-1.5-pro
  modelName        String
  ///จำนวน Token "ขาไป" (คำถามที่ลูกค้าพิมพ์ + ข้อความ System Prompt + ข้อมูลที่ดึงจาก Knowledge Base)
  promptTokens     Int
  ///จำนวน Token "ขากลับ" (คำตอบที่ AI พิมพ์ตอบกลับมา)
  completionTokens Int
  /// ผลรวมของขาไปและขากลับ (นี่คือตัวเลขที่เราใช้เอาไปหักลบออกจากโควตารายเดือนของลูกค้าครับ)
  totalTokens      Int

  ///ระบุว่า AI ถูกเรียกใช้งานจากฟีเจอร์ไหน เช่น มาจากแชทบอท ("CHAT_BOT"), ดึงข้อมูลจากเอกสาร ("KNOWLEDGE_BASE_RAG"), หรือปุ่มกดสร้าง Tag สินค้าอัตโนมัติ ("PRODUCT_TAGGING")
  source String?

  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@map("int_ai_usage_logs")
}

///ตารางกำหนดนโยบายความปลอดภัยพิเศษ (เช่น การบังคับใส่รหัสซ้ำ) สำหรับการเข้าถึงเมนูต่างๆ แยกตามบริษัท
model SecCompanySecurityConfig {
  ///รหัสลำดับหลักของนโยบาย (Primary Key) แบบรันอัตโนมัติ
  id Int @id @default(autoincrement())

  // เชื่อมกับบริษัท
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// รหัสอ้างอิงไปยังเมนู (SecMenu) ที่ต้องการควบคุมความปลอดภัยเป็นพิเศษ
  menuId Int
  menu   SecMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  ///หากเป็น true ผู้ใช้ต้องใส่รหัสผ่านซ้ำอีกครั้ง (Re-authenticate) ก่อนเข้าถึงเมนูนี้
  requireReAuth Boolean @default(true)

  /// ✅ (เพิ่มเติม) บังคับใช้ OTP หรือ Biometric แทนรหัสผ่านปกติ
  requireMfa Boolean @default(false)

  /// ✅ ระยะเวลาที่อนุญาตให้ไม่ต้องใส่รหัสซ้ำ (Sudo Mode duration) หน่วยเป็นนาที
  gracePeriod Int      @default(15)
  /// วันและเวลาที่ปรับปรุงนโยบายล่าสุด
  updatedAt   DateTime @updatedAt

  @@unique([companyId, menuId]) // 1 บริษัท กำหนดนโยบาย 1 เมนูได้ 1 แบบ
  @@map("sec_company_security_configs")
}

///ประวัติการได้แต้ม/ใช้แต้ม
model CrmPointLog {
  id        BigInt    @id @default(autoincrement())
  companyId Int
  // company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberId  Int
  member    CrmMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  amount       Int // บวก (+) คือได้แต้ม, ลบ (-) คือใช้แต้ม
  balanceAfter Int // แต้มคงเหลือหลังทำรายการ

  /// สาเหตุ
  action String // EARN_FROM_ORDER, REDEEM_REWARD, ADJUSTMENT, EXPIRE

  /// อ้างอิง
  refOrderId      Int? // มาจาก Order ไหน (ถ้ามี)
  refRedemptionId Int? // มาจากการแลกของรางวัลไหน (ถ้ามี)

  note      String?
  expiredAt DateTime? // แต้มก้อนนี้หมดอายุเมื่อไหร่ (ถ้าทำระบบแต้มหมดอายุ)

  createdAt DateTime @default(now())

  @@index([memberId, createdAt])
  @@map("crm_point_logs")
}

///ของรางวัล (Catalog)
model CrmReward {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  description String?

  /// 🚩 [แก้ไข] เปลี่ยนจาก imageUrl String? มาผูกกับศูนย์กลาง DMS
  mediaId     Int?       
  media       SysMedia?  @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  /// ใช้กี่แต้มแลก
  pointCost Int 
  /// COUPON, PHYSICAL_GOOD, EXTERNAL_CODE
  type String @default("DISCOUNT_COUPON") 

  /// ถ้าเป็นคูปอง ให้ผูกกับ ComDiscount ที่เราทำไว้
  discountTemplateId Int?

  /// รองรับการระบุสาขาที่ให้แลก ถ้าเป็น null แลกได้ในเครือทั้งหมด
  shopId Int?
  shop   ComShopProfile? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  /// ถ้าเป็น Physical Good (เช่น แก้วน้ำ) ให้ผูกกับ Product เพื่อตัดสต็อก
  productId Int?
  /// จำกัดจำนวนสิทธิ์ไหม (Null = ไม่จำกัด)
  stockQty Int? 
  isActive Boolean @default(true)

  redemptions CrmRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("crm_rewards")
}

///ประวัติการแลกรางวัล
model CrmRedemption {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  shopId Int?
  shop   ComShopProfile? @relation(fields: [shopId], references: [id])

  memberId Int
  member   CrmMember @relation(fields: [memberId], references: [id])

  rewardId Int
  reward   CrmReward @relation(fields: [rewardId], references: [id])
  pointUsed Int 

  status String @default("PENDING") // 🔄 แนะนำเปลี่ยนจาก COMPLETED เป็น PENDING เพื่อให้รอผ่านอนุมัติ/รอส่งของก่อน

  redeemCode String?

  /// 🚩 [เพิ่มใหม่] เชื่อมโยงกับสายอนุมัติ Workflow (1 ใบแลกของ ต่อ 1 คำร้อง)
  wfRequestId Int?       @unique 
  wfRequest   WfRequest? @relation(fields: [wfRequestId], references: [id], onDelete: SetNull)

  /// 🚩 [เพิ่มใหม่] เชื่อมโยงประวัติเอกสาร/หลักฐานรูปภาพที่อัปโหลดเข้า DMS
  documents   CrmRedemptionDocument[]

  createdAt DateTime @default(now())

  @@map("crm_redemptions")
}

/// 📂 [NEW] ตารางผูกหลักฐานการแลกของรางวัลเข้าศูนย์จัดเก็บไฟล์กลาง DMS (SysMedia)
model CrmRedemptionDocument {
  id           Int           @id @default(autoincrement())
  
  /// 🏢 Multi-tenancy
  companyId    Int
  company      OrgCompany    @relation(fields: [companyId], references: [id])
  
  /// 🎁 เชื่อมใบแลกของรางวัล
  redemptionId Int
  redemption   CrmRedemption @relation(fields: [redemptionId], references: [id], onDelete: Cascade)
  
  /// 📁 ผูกกับไฟล์บนศูนย์กลาง DMS
  mediaId      Int           @unique
  media        SysMedia      @relation(fields: [mediaId], references: [id])
  
  /// ประเภทเอกสาร เช่น 'DELIVERY_SLIP' (ใบจัดส่ง), 'CLAIM_PROOF' (ภาพหลักฐานการรับของ)
  docType      String?       
  createdAt    DateTime      @default(now())

  @@index([companyId, redemptionId])
  @@map("crm_redemption_documents")
}

///การตั้งค่าระบบสมาชิกและแต้ม
model CrmCompanyConfig {
  id        Int        @id @default(autoincrement())
  companyId Int        @unique
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 💰 กติกาการได้แต้ม
  isPointEnabled Boolean @default(true) // เปิด/ปิดระบบแต้ม
  earnRatio      Int     @default(100) // ซื้อครบกี่บาท ได้ 1 แต้ม (เช่น 100)

  /// ⏳ กติกาการหมดอายุ
  pointExpiryMonths Int? // แต้มหมดอายุในกี่เดือน (Null = ไม่หมดอายุ)

  /// 🏷️ ชื่อเรียกแต้ม (Branding)  เช่น "Coin", "Star", "แต้ม"
  pointName String @default("Point") 

  updatedAt DateTime @updatedAt

  @@map("crm_company_configs")
}

///ตารางเก็บเกี่ยวกับ ความสนใจสินค้าของสมาชิก
model ComWishlist {
  /// ใช้ BigInt เผื่ออนาคตคนกดเยอะ
  id BigInt @id @default(autoincrement()) 

  /// ✅ 1. เพิ่ม Company ID
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  memberId Int
  member   CrmMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  productId Int
  product   ComProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([memberId, productId]) 
  @@index([companyId]) 
  @@map("com_wishlists")
}

/// ตารางเกี่ยวกับการ review สินค้า
model ComProductReview {
  id        BigInt     @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  productId Int
  product   ComProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  memberId Int
  member   CrmMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// อ้างอิง Order เพื่อยืนยันว่า "ซื้อจริง" (Verified Buyer)
  orderId Int?
  order   ComOrder? @relation(fields: [orderId], references: [id])
  /// 1-5 ดาว
  rating  Int      @default(5) 
  comment String?  @db.Text
  
  
  reviewMedias ComProductReviewMedia[]

  /// ร้านตอบกลับ
  replyMessage String?   @db.Text
  repliedAt    DateTime?

  isHidden Boolean @default(false) // เผื่อรีวิวหยาบคาย Admin ซ่อนได้

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, rating])
  @@map("com_product_reviews")
}

/// 📸 ตารางกลางสำหรับเชื่อมรูปภาพรีวิวเข้ากับศูนย์เก็บไฟล์ (SysMedia)
model ComProductReviewMedia {
  id        BigInt   @id @default(autoincrement())
  
  /// 🏢 Multi-tenancy
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// ⭐️ เชื่อมกับรีวิว (ระบุเป็น BigInt ตามตารางหลัก)
  reviewId  BigInt
  review    ComProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  /// 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId   Int      @unique
  media     SysMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  /// ลำดับการแสดงผลของรูป (ถ้ารีวิวมีหลายรูป)
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())

  @@index([companyId, reviewId])
  @@map("com_product_review_media")
}

enum NotificationType {
  ORDER_UPDATE // สถานะคำสั่งซื้อเปลี่ยน
  PROMOTION // แจ้งโปรโมชั่น
  SYSTEM // แจ้งเตือนระบบ
  REWARD // แจ้งเตือนแต้ม/รางวัล
}

///ทำหน้าที่เป็น ระบบแจ้งเตือนภายใน (In-app Notification) เพื่อส่งข้อมูลข่าวสาร สถานะกิจกรรม หรือประกาศสำคัญไปยังผู้ใช้งานโดยตรง ไม่ว่าจะเป็นลูกค้า (Members) หรือพนักงานหลังบ้าน (Admin Users) ภายในระบบของคุณ
model SysNotification {
  ///รหัสลำดับหลักของการแจ้งเตือน (Primary Key) ใช้ BigInt เพื่อรองรับปริมาณข้อมูลสะสม
  id BigInt @id @default(autoincrement())

  ///รหัสอ้างอิงไปยังบริษัท (OrgCompany) เพื่อระบุความเป็นเจ้าของข้อมูลแจ้งเตือน
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ///รหัสอ้างอิงไปยังลูกค้า (CrmMember) ในกรณีที่ส่งหาลูกค้าฝั่งหน้าบ้าน
  recipientMemberId Int?
  /// (Optional) ผูก Relation เผื่อไว้
  member CrmMember? @relation(fields: [recipientMemberId], references: [id], onDelete: Cascade) 

  recipientUserId Int? 
  /// (Optional) ผูก Relation เผื่อไว้
  user            SecUser? @relation(fields: [recipientUserId], references: [id], onDelete: Cascade) 

  ///รหัสอ้างอิงไปยังประกาศหลัก (ComAnnouncement) หากการแจ้งเตือนนี้มาจากประกาศ
  announcementId Int?
  announcement   ComAnnouncement? @relation(fields: [announcementId], references: [id])
  ///ประเภทของการแจ้งเตือน เช่น INFO, ORDER_STATUS, PROMOTION, SYSTEM
  type           NotificationType
  ///หัวข้อของการแจ้งเตือน
  title          String
  ///เนื้อหาหรือรายละเอียดของการแจ้งเตือน
  message        String           @db.Text
  ///ลิงก์รูปภาพไอคอนที่แสดงประกอบการแจ้งเตือน
  iconUrl        String?

  ///ลิงก์ปลายทาง (Deep Link) ที่ต้องการให้ผู้ใช้ไปเมื่อกดที่รายการแจ้งเตือน
  actionUrl String?
  ///สถานะการอ่าน (Default: false)
  isRead    Boolean   @default(false)
  ///วันและเวลาที่ผู้ใช้กดอ่านข้อมูล
  readAt    DateTime?
  ///วันและเวลาที่สร้างรายการแจ้งเตือน (Default: ปัจจุบัน)
  createdAt DateTime  @default(now())

  @@index([recipientMemberId, isRead])
  @@index([recipientUserId, isRead]) // เพิ่ม Index ให้ฝั่ง Admin ด้วย
  @@map("sys_notifications")
}


///ตารางนี้เปรียบเสมือนสมุดบัญชีปิดยอดรายวันของแต่ละสาขาครับ
model RptDailySales {
  id        Int      @id @default(autoincrement())
  companyId Int
  /// แยกตามหน้าร้าน (ถ้า null = รวมทั้งบริษัท)
  shopId    Int? 
  /// วันที่ของยอดขาย (เช่น 2023-10-25)
  date      DateTime @db.Date 
  /// ยอดขายรวม (Gross)
  totalSales    Decimal @default(0) @db.Decimal(10, 2) 
  /// ส่วนลดรวม
  totalDiscount Decimal @default(0) @db.Decimal(10, 2) 
  /// ยอดขายสุทธิ (Net)
  netSales      Decimal @default(0) @db.Decimal(10, 2) 
  totalOrders   Int     @default(0) // จำนวนออเดอร์

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company OrgCompany      @relation(fields: [companyId], references: [id])
  shop    ComShopProfile? @relation(fields: [shopId], references: [id])

  @@unique([companyId, shopId, date]) // ห้ามซ้ำวัน/ร้านเดิม
  @@map("rpt_daily_sales")
}

///ตารางนี้เปรียบเสมือนใบจัดอันดับความฮอตของสินค้าแบบรายเดือนครับ
model RptProductPerformance {
  id        Int      @id @default(autoincrement())
  companyId Int
  productId Int
  shopId    Int?
  month     DateTime @db.Date // ประจำเดือนไหน (เช่น 2023-10-01)

  totalSoldQty Int     @default(0) // ขายไปกี่ชิ้น
  totalRevenue Decimal @default(0) @db.Decimal(10, 2) // ทำเงินได้เท่าไหร่

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company OrgCompany @relation(fields: [companyId], references: [id])
  product ComProduct @relation(fields: [productId], references: [id])

  @@unique([companyId, productId, shopId, month])
  @@map("rpt_product_performance")
}

// ==========================================
// AUTH CONFIGURATION
// ==========================================

enum AuthProviderType {
  EMAIL
  GOOGLE
  FACEBOOK
  LINE
  THAID
  PAOTANG
  NDID
}

///ตาราง Master ควบคุมการเปิด/ปิด ระดับ Global (Admin สูงสุดเป็นคนคุม)
model SysAuthProvider {
  /// ใช้เป็น Code ไปเลย เช่น "LINE", "GOOGLE"
  id            String  @id
  /// เช่น "Line Login", "ThaID"
  name          String
  /// รูปปุ่ม Login
  iconUrl       String?
  /// เปิดใช้งานหรือไม่
  isEnabled     Boolean @default(true)
  /// ปิดปรับปรุงชั่วคราวหรือไม่
  isMaintenance Boolean @default(false)
  /// เรียงลำดับปุ่ม
  sortOrder     Int     @default(0)

  companyConfigs SecCompanyAuthConfig[]

  updatedAt DateTime @updatedAt

  @@map("sys_auth_providers")
}

///เก็บการตั้งค่าการยืนยันตัวตน (Authentication) แยกตามแต่ละบริษัท ทำหน้าที่ควบคุมว่าบริษัทนั้นๆ อนุญาตให้พนักงานล็อกอินผ่านช่องทางใดบ้าง (เช่น Google, LINE) และรองรับการใช้แอปพลิเคชันส่วนตัวของบริษัทเอง (Custom OAuth App)
model SecCompanyAuthConfig {
  ///รหัสลำดับของการตั้งค่า (Primary Key)
  id         Int             @id @default(autoincrement())
  ///รหัสอ้างอิงบริษัท เพื่อระบุว่าการตั้งค่านี้เป็นของบริษัทใด โดยใช้ onDelete: Cascade เพื่อให้ข้อมูลการตั้งค่าถูกลบหากบริษัทถูกลบออกจากระบบ
  companyId  Int
  company    OrgCompany      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ///รหัสอ้างอิงประเภทของผู้ให้บริการล็อกอิน (เชื่อมโยงกับตาราง SysAuthProvider) เช่น "GOOGLE", "LINE", หรือ "APPLE"
  providerId String
  ///เชื่อมโยงไปยังระบบหลักเพื่อดูรายละเอียดทางเทคนิคของแต่ละช่องทางล็อกอิน SysAuthProvider
  provider   SysAuthProvider @relation(fields: [providerId], references: [id])
  ///สถานะการเปิด/ปิดใช้งานผู้ให้บริการรายนี้สำหรับบริษัทนั้นๆ หากตั้งเป็น false พนักงานในบริษัทนี้จะไม่เห็นตัวเลือกล็อกอินด้วยช่องทางดังกล่าว
  isEnabled  Boolean         @default(true)

  ///รหัสประจำตัวแอปพลิเคชัน (App ID) กรณีที่บริษัทต้องการใช้บัญชีนักพัฒนาของตนเอง หากเป็นค่าว่าง (Null) ระบบจะดึงค่ามาตรฐาน (Default System Key) มาใช้แทน
  clientId     String?
  ///รหัสลับแอปพลิเคชัน (App Secret) ที่ใช้คู่กับ Client ID เพื่อยืนยันความปลอดภัย     
  clientSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, providerId])
  @@map("sec_company_auth_configs")
}

// ==========================================
// MODULE: CMS / PAGE BUILDER
// ==========================================

///เก็บข้อมูลโครงสร้างหน้าเว็บไซต์หรือหน้า Landing Page ที่แต่ละบริษัทสร้างขึ้นเอง โดยใช้เทคโนโลยีแบบ No-code/Low-code (เช่น Lovable หรือ Puck) ในการออกแบบเลย์เอาต์ เพื่อให้แต่ละร้านค้ามีหน้าเว็บที่เป็นเอกลักษณ์ของตนเองได้โดยไม่ต้องเขียนโค้ดเพิ่ม
model CmsPage {
  ///รหัสลำดับของหน้าเพจ (Primary Key)
  id Int @id @default(autoincrement())

  /// ✅ ผูกกับบริษัท (สำคัญมาก เพื่อให้ลูกค้า A ไม่เห็นหน้าของลูกค้า B)
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// URL ของหน้านั้นๆ เช่น "about-us", "promotion"
  slug String

  /// ชื่อหน้า (ไว้แสดงในรายการหลังบ้าน)
  title String?

  /// 🔥 หัวใจสำคัญ: เก็บ JSON Layout ที่ได้จาก Lovable/Puck
  content Json?

  /// ข้อมูลสำหรับการทำ Search Engine Optimization เพื่อให้หน้าเว็บติดอันดับการค้นหาบน Google ได้ดีขึ้น และแสดงรูปภาพพรีวิวที่สวยงามเวลาแชร์ลงโซเชียล
  seoTitle       String?
  ///ข้อมูลสำหรับการทำ Search Engine Optimization เพื่อให้หน้าเว็บติดอันดับการค้นหาบน Google ได้ดีขึ้น และแสดงรูปภาพพรีวิวที่สวยงามเวลาแชร์ลงโซเชียล
  seoDescription String?
  ///ข้อมูลสำหรับการทำ Search Engine Optimization เพื่อให้หน้าเว็บติดอันดับการค้นหาบน Google ได้ดีขึ้น และแสดงรูปภาพพรีวิวที่สวยงามเวลาแชร์ลงโซเชียล
  seoImage       String?
  ///สถานะการเผยแพร่หน้าเว็บ (True = ออนไลน์ให้คนทั่วไปเห็น, False = ฉบับร่างที่เห็นเฉพาะหลังบ้าน)
  isPublished    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 1 บริษัท ห้ามมี Slug ซ้ำกัน (แต่บริษัทอื่นมี Slug ชื่อเดียวกันได้)
  @@unique([companyId, slug])
  @@map("cms_pages")
}

/// ระบบจัดการเมนูหน้าเว็บไซต์ (Storefront Navigation)
model CmsMenu {
  id Int @id @default(autoincrement())

  /// ผูกกับบริษัท เพื่อให้แต่ละร้านมีเมนูไม่เหมือนกัน
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// ชื่อเมนูที่แสดงบนหน้าเว็บ (เช่น "หน้าแรก", "สินค้าของเรา", "ติดต่อเรา")
  label String

  /// URL เป้าหมาย (อาจจะเป็น Path ในเว็บเรา เช่น "/about-us" หรือเว็บนอก เช่น "https://facebook.com/...")
  url String

  /// ระบุว่าให้เปิดในแท็บใหม่หรือไม่ (กรณีเป็นลิงก์เว็บนอก)
  isExternal Boolean @default(false)

  /// ลำดับการแสดงผล (เรียงจากซ้ายไปขวา หรือบนลงล่าง) ใช้สำหรับทำ Drag & Drop
  sortOrder   Int     @default(0)
  /// คำอธิบายย่อยใต้ชื่อเมนู (เช่น "รวมเสื้อผ้าคอลเลกชันใหม่ล่าสุด")
  description String?
  /// รูปภาพประกอบเมนู
  imageUrl    String?
  /// สวิตช์บอกหน้าบ้านว่าเมนูนี้ให้กางออกแบบ Mega Menu นะ
  isMegaMenu  Boolean @default(false)

  /// 🌟 ระบบรองรับเมนูย่อย (Sub-menu / Dropdown) 🌟 ถ้า parentId เป็น null แสดงว่าเป็นเมนูหลัก ถ้ามี parentId แสดงว่าเป็นเมนูย่อยที่อยู่ภายใต้เมนูหลักนั้นๆ
  parentId Int?
  parent   CmsMenu?  @relation("MenuToSubmenu", fields: [parentId], references: [id], onDelete: Cascade)
  children CmsMenu[] @relation("MenuToSubmenu")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, parentId])
  @@map("cms_menus")
}

// ==========================================
// 1. ENUMS (เหมือนเดิม)
// ==========================================
enum DayRelative {
  PREVIOUS // (P) วันก่อนหน้า
  CURRENT // (C) วันปัจจุบัน
  NEXT // (N) วันถัดไป
}

enum ShiftType {
  WORK_DAY // วันทำงานปกติ
  OFF_DAY // วันหยุด
}


/// 2. SHIFT MASTER
model HrShift {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code      String
  name      String
  color     String?
  type      ShiftType  @default(WORK_DAY)

  // --- 2. เวลาทำงานจริง (อยู่ Master ถือว่าถูกต้อง!) ---
  workStartTime String?
  workStartRel  DayRelative @default(CURRENT)
  workEndTime   String?
  workEndRel    DayRelative @default(CURRENT)

  // --- 3. ข้อมูลคำนวณ Leave/Time ---
  totalDayHours   Decimal @default(8.0) @db.Decimal(4, 2)
  firstHalfHours  Decimal @default(4.0) @db.Decimal(4, 2)
  secondHalfHours Decimal @default(4.0) @db.Decimal(4, 2)

  // 🌟 --- 4. เงื่อนไขการคิด OT (Overtime Rules) --- 🌟
  // OT ก่อนเข้ากะ (OT Before Shift)
  isOtBeforeShift    Boolean @default(false) // อนุญาตให้คิด OT ก่อนกะหรือไม่
  minOtBeforeMinutes Int     @default(0)     // ต้องทำ OT ก่อนกะขั้นต่ำกี่นาทีถึงจะได้ (เช่น มาก่อน 30 นาที)

  // OT หลังเลิกกะ (OT After Shift)
  isOtAfterShift     Boolean @default(false) // อนุญาตให้คิด OT หลังกะหรือไม่
  minOtAfterMinutes  Int     @default(0)     // ต้องทำ OT หลังกะขั้นต่ำกี่นาทีถึงจะได้ (เช่น ทำเกิน 30 นาที)

  // ----------------------------------------
  // RELATIONS
  // ----------------------------------------
  schedules              HrEmployeeSchedule[]
  details                HrShiftDetail[]
  asPreviousShiftDetails HrShiftDetail[]      @relation("PreviousShiftCondition")
  patternItems           HrWorkPatternItem[]

  // 🚩 ปรับแก้: Breaks เรามีตารางเชื่อมชื่อ HrShiftBreak อยู่แล้ว
  breaks HrShiftBreak[]

  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  HrRosterDetail HrRosterDetail[]

  @@unique([companyId, code])
  @@map("hr_shifts")
}


/// 3. SHIFT DETAIL (ขอบเขตวัน - Boundary Only)
model HrShiftDetail {
  id        Int     @id @default(autoincrement())
  companyId Int
  shiftId   Int
  shift     HrShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  // --- Condition ---
  previousShiftId Int?
  previousShift   HrShift? @relation("PreviousShiftCondition", fields: [previousShiftId], references: [id])

  // --- 1. ขอบเขตของวัน (Day Boundary) ---
  boundaryStartTime String      @default("00:00")
  boundaryStartRel  DayRelative @default(CURRENT)
  boundaryEndTime   String      @default("00:00")
  boundaryEndRel    DayRelative @default(NEXT)

  priority Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shiftId, previousShiftId])
  @@map("hr_shift_details")
}

// เพิ่ม Enum ประเภทการพัก
enum BreakType {
  FIXED_TIME // พักตามเวลาเป๊ะๆ (เช่น 12:00 - 13:00)
  FLEXIBLE // พักแบบยืดหยุ่น (เช่น พัก 60 นาที หลังจากทำงานครบ 5 ชั่วโมง)
}


/// BREAK MASTER (หัว - ชุดเวลาพัก)
model HrTimeBreakGroup {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code String
  name String

  /// 🚩 ย้าย type ขึ้นมาไว้ที่ Master
  type BreakType @default(FIXED_TIME)

  isActive Boolean @default(true)

  details HrTimeBreakDetail[]
  shifts  HrShiftBreak[]

  @@unique([companyId, code])
  @@map("hr_time_break_groups")
}


/// BREAK DETAIL (หาง - ช่วงเวลาพักย่อย)
model HrTimeBreakDetail {
  id        Int @id @default(autoincrement())
  companyId Int

  groupId Int
  group   HrTimeBreakGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  name String


  startTime         String?
  endTime           String?
  triggerAfterHours Decimal? @db.Decimal(4, 2)

  duration Int

  @@map("hr_time_break_details")
}


/// SHIFT BREAK (Junction Table)
model HrShiftBreak {
  id        Int     @id @default(autoincrement())
  companyId Int
  shiftId   Int
  shift     HrShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  groupId Int // 🚩 เปลี่ยนจาก breakId มาเป็น groupId แทน
  group   HrTimeBreakGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([companyId, shiftId, groupId])
  @@map("hr_shift_breaks")
}

/// ประเภทของปฏิทิน
enum CalendarType {
  CALENDAR
  FISCAL
}

enum HolidayCategory {
  PUBLIC
  COMPANY
  SPECIAL
}

enum HolidayGroupStatus {
  DRAFT // กำลังร่าง แก้ไขได้เต็มที่
  PUBLISHED // ประกาศใช้แล้ว (เริ่มมีผลกับกะงานและพนักงาน)
  CANCELLED // ยกเลิกทั้งชุด (ถ้าจำเป็น)
}

/// รอบปฏิทิน (รองรับทั้งปีปฏิทิน และ ปีงบประมาณ)
model HrCalendar {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// ชื่อเรียก เช่น "ปีงบประมาณ 2569", "ปีปฏิทิน 2026"
  name String

  /// ปีที่อ้างอิง (เช่น 2026)
  year Int

  /// 🌟 เพิ่ม Relation ไปหา KPI Cycle
  kpiCycles           HrKpiCycle[]

  /// ประเภท: FISCAL (งบประมาณ), CALENDAR (ปฏิทินปกติ)
  type             CalendarType @default(CALENDAR)
  /// กฎการชดเชยวันหยุด: NEXT_WORKING_DAY (เลื่อนไปวันทำการถัดไป), NONE (ไม่ชดเชย)
  compensationRule String       @default("NEXT_WORKING_DAY")

  /// วันที่เริ่มรอบ (เช่น 2025-10-01 สำหรับปีงบประมาณ 2026)
  startDate DateTime

  /// วันที่สิ้นสุดรอบ (เช่น 2026-09-30)
  endDate DateTime

  holidayGroups       HrHolidayGroup[]
  workPatterns        HrWorkPattern[]
  orgStructureVersion HrOrgStructureVersion[]
  
  leaveBalance        HrLeaveBalance[]
  LeaveRequest        HrLeaveRequest[]

  /// สถานะการใช้งาน (ในหนึ่งบริษัทควรมี Active แค่ 1 อันต่อประเภทปี)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hr_calendars")
}


/// 1. HOLIDAY GROUP (Master - หัว)
model HrHolidayGroup {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 📌 ผูกกับ Calendar (บอกว่าชุดวันหยุดนี้เป็นของปีไหน/รอบไหน)
  calendarId Int
  calendar   HrCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  /// รหัสชุดวันหยุด เช่น "OFFICE_2026", "FACTORY_2026"
  code   String
  /// คำอธิบาย (ภาษาไทย) เช่น "วันหยุดประจำปี พนักงานออฟฟิศ"
  nameTh String
  /// คำอธิบาย (ภาษาอังกฤษ)
  nameEn String?
  /// สถานะของกลุ่มวันหยุด
  status HolidayGroupStatus @default(DRAFT)

  /// วันที่กด Published (เอาไว้ดูว่าประกาศเมื่อไหร่)
  publishedAt DateTime?

  /// 📌 กฎการชดเชย: ถ้าวันหยุดตรงกับวันหยุดประจำสัปดาห์ (Off-day) ให้ชดเชยหรือไม่?
  isCompensateWhenOffDay Boolean @default(true)

  /// ความสัมพันธ์ไปหา Detail (วันหยุดย่อย) และกะงาน
  holidays     HrHoliday[]
  workPatterns HrWorkPattern[]
  HrRoster     HrRoster[]

  @@unique([companyId, calendarId, code]) // โค้ดห้ามซ้ำในปฏิทินเดียวกัน
  @@map("hr_holiday_groups")
}


/// 2. HOLIDAY DETAIL (Detail - หาง)
model HrHoliday {
  id Int @id @default(autoincrement())

  /// 🌟 เพิ่ม companyId และ Relation กลับไปที่บริษัท
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 📌 ชี้กลับไปที่หัว (Holiday Group)
  groupId Int
  group   HrHolidayGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  /// วันที่หยุดจริง
  date   DateTime
  /// ชื่อวันหยุด (ภาษาไทย) เช่น "วันสงกรานต์"
  nameTh String
  /// ชื่อวันหยุด (ภาษาอังกฤษ) เช่น "Songkran Festival"
  nameEn String?

  category HolidayCategory @default(PUBLIC)

  /// เปิด/ปิด การใช้งานวันหยุดนี้ (มีผล/ยกเลิก)
  isActive       Boolean          @default(true)
  HrRosterDetail HrRosterDetail[]

  // 🌟 อัปเดต Unique โดยเอา companyId มาครอบไว้เพื่อความชัวร์
  @@unique([companyId, groupId, date])
  @@map("hr_holidays")
}


/// WORK PATTERN MASTER (หัว - แม่พิมพ์รูปแบบการทำงาน)
model HrWorkPattern {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code String
  name String

  cycleDays Int @default(7)

  isActive Boolean @default(true)


  

  /// 2. ชี้กลับไปหาปฏิทิน (HrCalendar)
  calendarId Int?
  calendar   HrCalendar? @relation(fields: [calendarId], references: [id])

  /// 3. ชี้กลับไปหาชุดวันหยุด (HrHolidayGroup)
  holidayGroupId Int?
  holidayGroup   HrHolidayGroup? @relation(fields: [holidayGroupId], references: [id])

  /// 🌟 [เพิ่มบรรทัดนี้เข้าไปครับ] เพื่อรับ Relation จากประวัติกะ
  employeeHistories HrEmployeePattern[]
  items     HrWorkPatternItem[]
  schedules HrEmployeeSchedule[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  HrRoster  HrRoster[]

  @@unique([companyId, code])
  @@map("hr_work_patterns")
}


/// WORK PATTERN ITEM (หาง - กำหนดกะในแต่ละวันของรอบ)
model HrWorkPatternItem {
  id        Int        @id @default(autoincrement())
  
  /// 🌟 จุดที่ 1: เพิ่ม Relation ชี้กลับไปที่ OrgCompany ให้ชัดเจน
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  patternId Int
  pattern   HrWorkPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  /// ลำดับวันที่ในรอบ เช่น 1=จันทร์, 2=อังคาร ... 7=อาทิตย์ หรือถ้าทำ 4 หยุด 2 ก็จะมี index 1 ถึง 6
  dayIndex  Int

  /// 🚩 กะการทำงาน (ถ้าเป็น Null แปลว่าวันนั้นคือ "วันหยุดประจำสัปดาห์ (Off Day)")
  shiftId   Int?
  shift     HrShift?   @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  /// 🌟 จุดที่ 2: เพิ่ม companyId นำหน้าใน Unique Constraint
  @@unique([companyId, patternId, dayIndex]) 
  @@map("hr_work_pattern_items")
}


/// ⭐️ EMPLOYEE SCHEDULE (ตารางทำงานรายวันของพนักงาน)
model HrEmployeeSchedule {
  id Int @id @default(autoincrement())

  /// 🚩 1. เพิ่มเพื่อความปลอดภัยและ Performance
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId Int
  employee   HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date DateTime @db.Date // เช่น 2026-02-15

  shiftId Int
  shift   HrShift @relation(fields: [shiftId], references: [id])

  workPatternId Int?
  workPattern   HrWorkPattern? @relation(fields: [workPatternId], references: [id])

  /// Flag สำหรับ Overrides
  isPublicHoliday Boolean @default(false)
  /// ก๊อปปี้จาก shift.type มาไว้ เพื่อให้แก้ไขรายวันได้โดยไม่กระทบกะหลัก
  isDayOff        Boolean @default(false) 

  note String? // เช่น "สลับเวรกับนาย B", "วันหยุดชดเชยพิเศษ"

  /// 🚩 2. เพิ่มเพื่อการตรวจสอบ
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date]) // 1 คน 1 วัน มีได้ 1 แถวเท่านั้น
  @@index([companyId, date]) // ช่วยให้การดึงตารางทำงานของทั้งบริษัทใน 1 เดือนเร็วขึ้นมาก
  @@map("hr_employee_schedules")
}

// ==========================================
// 1. ENUMS (ตัวเลือกต่างๆ)
// ==========================================

enum GenderRule {
  ALL
  MALE
  FEMALE
}

enum AccrualType {
  LUMP_SUM // แจกตูมเดียวต้นปี
  MONTHLY_ACCRUAL // ทยอยแจกทุกสิ้นเดือน
}

enum RoundingRule {
  NO_ROUNDING
  ROUND_UP_FULL
  ROUND_DOWN_FULL
  ROUND_UP_HALF
  ROUND_DOWN_HALF
  ROUND_NEAREST_HALF
}

enum RoundingType {
  WHOLE // ปัดเศษจากค่าทั้งหมด
  DIGIT // ปัดเศษตามหลักทศนิยมที่กำหนด
}

// ==========================================
// ROUNDING CONFIGURATION
// ==========================================

///ระบบกำหนดกฎเกณฑ์การปัดเศษ (Rounding Configuration Master) ซึ่งช่วยให้ระบบสามารถคำนวณราคา ภาษี หรือยอดเงินต่าง ๆ ได้ตามมาตรฐานที่แต่ละบริษัทต้องการ (เช่น กฎการปัดเศษสตางค์ตามมาตรฐานบัญชี หรือการปัดเศษทศนิยมสำหรับราคาสินค้า)
model CfgRoundingRule {
  ///รหัสลำดับหลักของกฎการปัดเศษ (Primary Key) แบบรันอัตโนมัติ
  id Int @id @default(autoincrement())

  ///รหัสอ้างอิงไปยังบริษัท (OrgCompany) เพื่อแยกกฎเกณฑ์ตามแต่ละองค์กร
  companyId Int?
  company   OrgCompany?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ///รหัสอ้างอิงของกฎ เช่น R_001, RETAIL_ROUND เพื่อใช้เรียกใช้งานในโปรแกรม
  code      String
  ///ชื่อที่ใช้อธิบายกฎ เช่น "ปัดเศษสตางค์ (0.25, 0.50, 0.75)", "ปัดทิ้งทศนิยมหลักที่ 3"
  name      String
  ///ประเภทของการปัดเศษ (เช่น DIGIT สำหรับปัดตามตำแหน่ง หรือประเภทอื่น ๆ)
  type      RoundingType @default(DIGIT)

  ///ตำแหน่งทศนิยมที่ต้องการให้นำมาพิจารณาเพื่อปัดเศษ (Default: 2) ✅ Option เสริม: ระบุตำแหน่งทศนิยม (ใช้เฉพาะเมื่อ type = DIGIT) เช่น 3 หมายถึงตัด 2 หลักแรกทิ้ง แล้วเอาหลักที่ 3 เป็นต้นไปมาเทียบ Range
  digitIndex Int? @default(2)

  /// Link ไปหา Detail
  ranges    CfgRoundingRange[]
  ///สถานะการเปิดใช้งานกฎ (Default: true)
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  // ห้ามตั้งชื่อ Code ซ้ำกันในบริษัทเดียวกัน
  @@unique([companyId, code])
  @@map("cfg_rounding_rules")
}

///ทำหน้าที่เก็บ รายละเอียดเงื่อนไขในช่วงตัวเลข (Range Logic) เพื่อกำหนดว่าถ้าตัวเลขตกอยู่ในช่วงที่ระบุ จะให้ปัดเศษเป็นค่าใด โดยทำงานเป็นตารางลูก (Child Table) ที่เชื่อมโยงกับ CfgRoundingRule เพื่อให้การปัดเศษมีความยืดหยุ่นสูงมาก เช่น การปัดเศษสตางค์แบบขั้นบันได
model CfgRoundingRange {
  ///รหัสลำดับหลักของรายการ (Primary Key) แบบรันอัตโนมัติ
  id     Int @id @default(autoincrement())
  ///รหัสอ้างอิงไปยังกฎหลัก (CfgRoundingRule)
  ruleId Int

  rule CfgRoundingRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  ///ค่าต่ำสุดของช่วงข้อมูลที่ต้องการตรวจสอบ (รวมค่านี้)
  minVal Decimal @db.Decimal(18, 6) // เช่น 0.001
  ///ค่าสูงสุดของช่วงข้อมูลที่ต้องการตรวจสอบ (รวมค่านี้)
  maxVal Decimal @db.Decimal(18, 6) // เช่น 0.005

  /// ค่าที่จะให้นำไปใช้หลังจากผ่านเงื่อนไขในช่วงนี้
  result Decimal @db.Decimal(18, 6) // เช่น 0.000 หรือ 0.01

  /// ลำดับการตรวจสอบข้อมูล (ใช้ในกรณีที่มีช่วงข้อมูลซ้อนทับกัน เพื่อระบุว่าจะให้เช็คเงื่อนไขใดก่อน)
  sortOrder Int @default(0)

  @@map("cfg_rounding_ranges")
}

enum AdjustmentType {
  INCREASE // เพิ่มวันลา (เช่น ให้รางวัล, ชดเชย)
  DECREASE // ลดวันลา (เช่น ลงโทษ, หักคืน)
  SET // ตั้งค่าใหม่ (Override)
}

enum LeaveDurationRule {
  FULL_DAY_ONLY // ลาได้แค่ 1 วันเต็มเท่านั้น
  HALF_DAY_RESOLUTION // ลาได้ทีละ 0.5 วัน (เต็มวัน หรือ ครึ่งวัน)
  HOURLY // ลาเป็นนาที/ชั่วโมงได้เลย (ละเอียดสุด)
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// ประเภทของการลา
model HrLeaveType {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code  String 
  name  String
  /// 🎨 สีสำหรับแสดงผลหน้าบ้าน
  color String? @default("#4F46E5")

  /// --- กติกาการแจกสิทธิ์ ---
  accrualType AccrualType @default(LUMP_SUM) 
  
  /// --- นโยบายทบวันลา (แยก Master-Detail) ---
  carryOverPolicyId Int?
  carryOverPolicy   HrCarryOverPolicy? @relation(fields: [carryOverPolicyId], references: [id])


  /// Back-relation สำหรับการยืมวันลา
  substitutions       HrLeaveSubstitution[] @relation("SourceLeave")
  substitutedBy       HrLeaveSubstitution[] @relation("TargetLeave")
  
  /// Back-relation สำหรับการปรับปรุงยอด
  adjustments         HrLeaveAdjustment[]
  

  entitlementTiers HrLeaveEntitlementTier[]
  balances         HrLeaveBalance[]
  requests         HrLeaveRequest[]
  

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@map("hr_leave_types")
}

/// ตัว detail สำหรับกฎการแจกสิทธิ์ของ Leave แต่ละประเภท
model HrLeaveEntitlementTier {
  id          Int         @id @default(autoincrement())
  leaveTypeId Int
  leaveType   HrLeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  /// เงื่อนไข แผนก/ตำแหน่ง (ใช้ "*" แทน ทั้งหมด)
  departmentCode String @default("*")
  positionCode   String @default("*")

  minServiceMonths Int    @default(0)
  maxServiceMonths Int?   

  quotaAmount Decimal @db.Decimal(5, 2)

  @@map("hr_leave_entitlement_tiers")
}

/// ตัวหัว กฎการ carry Over ของ Leave แต่ละประเภท
model HrCarryOverPolicy {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  description String?

  maxCarryDays         Decimal @default(0) @db.Decimal(5, 2)
  carryOverExpiryMonth Int?    

  details    HrCarryOverDetail[]
  leaveTypes HrLeaveType[]

  @@map("hr_carry_over_policies")
}

/// ตัว detail สำหรับ carryOver policy
model HrCarryOverDetail {
  id               Int               @id @default(autoincrement())
  
  /// 🌟 1. ฝัง companyId เพื่อให้เป็น Multi-company สมบูรณ์แบบ
  companyId        Int
  company          OrgCompany        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  policyId         Int
  policy           HrCarryOverPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  departmentCode   String   @default("*")
  positionCode     String   @default("*")
  minServiceMonths Int      @default(0)

  carryAmount      Decimal? @db.Decimal(5, 2) // ทบแบบจำนวนวันคงที่
  carryPercent     Decimal? @db.Decimal(5, 2) // ทบเป็น % ของยอดคงเหลือ

  // 🌟 2. เพิ่ม Index เพื่อให้ Database ค้นหาข้อมูลของบริษัทนั้นๆ ได้เร็วปรู๊ดปร๊าด
  @@index([companyId, policyId])
  @@map("hr_carry_over_details")
}


/// 4. LEAVE SUBSTITUTION (กติกาการยืมข้ามประเภท)
model HrLeaveSubstitution {
  id Int @id @default(autoincrement())
  
  /// 🏢 เพิ่ม Company ID เพื่อความปลอดภัย
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🚩 เงื่อนไข: การยืมนี้ใช้กับใคร (Master-Detail Condition) "*" = ทั้งหมด, หรือระบุเฉพาะตำแหน่ง/แผนกที่อนุญาตให้ยืมข้ามประเภทได้
  departmentCode String @default("*")
  positionCode   String @default("*")

  /// ต้นทาง: วันลาที่ถูกใช้จนหมด (เช่น ลาป่วย)
  leaveTypeId Int
  leaveType   HrLeaveType @relation("SourceLeave", fields: [leaveTypeId], references: [id], onDelete: Cascade)

  /// ปลายทาง: วันลาที่จะไปขอยืมมาใช้ (เช่น พักร้อน)
  targetLeaveTypeId Int
  targetLeaveType   HrLeaveType @relation("TargetLeave", fields: [targetLeaveTypeId], references: [id], onDelete: Cascade)

  priority    Int     @default(1) // ลำดับการยืม (1 มาก่อน)
  deductRatio Decimal @default(1.0) @db.Decimal(5, 2) // อัตราแลกเปลี่ยน

  isActive    Boolean @default(true)

  @@unique([companyId, leaveTypeId, targetLeaveTypeId, departmentCode, positionCode])
  @@index([leaveTypeId, priority])
  @@map("hr_leave_substitutions")
}

///ตารางจำนวนคงเหลือของประเภทการลา
model HrLeaveBalance {
  id               Int        @id @default(autoincrement())
  
  
  companyId        Int
  company          OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId       Int
  employee         HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  leaveTypeId      Int
  leaveType        HrLeaveType @relation(fields: [leaveTypeId], references: [id])

  /// 🗓️ เชื่อมกับ Calendar โดยตรง (ระบุรอบปีปฏิทินของการลา)
  calendarId       Int
  calendar         HrCalendar @relation(fields: [calendarId], references: [id])

  adjustments      HrLeaveAdjustment[]

  
  /// 2. ENTITLEMENTS (ฝั่งสิทธิ์ที่ได้รับในรอบปี)
  quotaAmount      Decimal @default(0) @db.Decimal(5, 2) 
  proRateAmount    Decimal @default(0) @db.Decimal(5, 2) 
  broughtForward   Decimal @default(0) @db.Decimal(5, 2) 
  adjustmentAmount Decimal @default(0) @db.Decimal(5, 2) 

  /// สิทธิ์รวมทั้งหมด
  totalQuota       Decimal @default(0) @db.Decimal(5, 2) 

 
  /// 3. USAGE (ฝั่งการใช้งาน)
  usedAmount       Decimal @default(0) @db.Decimal(5, 2) 
  
  /// 🌟 เพิ่มใหม่: กั้นวงเงินวันลาที่รออนุมัติ
  pendingAmount    Decimal @default(0) @db.Decimal(5, 2) 
  
  /// 🌟 เพิ่มใหม่: แทร็กว่าใช้วันลายกยอดไปเท่าไหร่แล้ว (สำคัญมากตอนหมดอายุ)
  broughtForwardUsedAmount Decimal @default(0) @db.Decimal(5, 2) 

  
  /// 4. BALANCE (ยอดคงเหลือ)
  remaining        Decimal @default(0) @db.Decimal(5, 2) 

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  /// 🛡️ ปรับแก้: เพิ่ม companyId เข้าไปใน Unique Constraint เพื่อความปลอดภัยของระบบ Multi-tenant
  @@unique([companyId, employeeId, leaveTypeId, calendarId])
  @@map("hr_leave_balances")
}
///ตารางเกี่ยวกับการเพิ่มจำนวน unit ให้ ประเภทการลา
model HrLeaveAdjustment {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🔗 เชื่อมไปยัง Balance เพื่อให้รู้ว่าปรับยอดของ "พนักงานคนไหน + ประเภทการลาอะไร + รอบปีไหน"
  balanceId Int
  balance   HrLeaveBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)

  leaveTypeId Int
  leaveType   HrLeaveType @relation(fields: [leaveTypeId], references: [id])

  /// 🔢 จำนวนวันที่ปรับ (+) เพิ่ม, (-) ลด
  amount    Decimal @db.Decimal(5, 2) 
  
  /// 📝 รายละเอียด
  reason    String? // เช่น "รางวัลพนักงานดีเด่น", "ชดเชยวันหยุดที่ไม่ได้ลา"
  
  /// 👤 ใครเป็นคนทำ (ควรเชื่อมกับ HrEmployee)
  adjustedById Int
  adjustedBy   HrEmployee @relation("AdjustedBy", fields: [adjustedById], references: [id])

  adjustedDate DateTime @default(now())

  @@map("hr_leave_adjustments")
}


/// 7. LEAVE REQUEST (ใบลา - ปรับปรุง)
model HrLeaveRequest {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId  Int
  employee    HrEmployee @relation("EmployeeLeaves", fields: [employeeId], references: [id], onDelete: Cascade)

  calendarId  Int
  calendar    HrCalendar @relation(fields: [calendarId], references: [id])

  leaveTypeId Int
  leaveType   HrLeaveType @relation(fields: [leaveTypeId], references: [id])

  wfRequestId Int?       @unique
  wfRequest   WfRequest? @relation(fields: [wfRequestId], references: [id])

  startDate   DateTime 
  endDate     DateTime 

  daysCount   Decimal    @db.Decimal(5, 2)

  isSubstituted   Boolean @default(false)
  substitutionLog Json?   

  status      LeaveRequestStatus @default(PENDING)
  reason      String?            @db.Text

 
  /// รองรับการแนบไฟล์หลายใบ เช่น ใบรับรองแพทย์หลายฉบับ หรือเอกสารประกอบอื่นๆ
  documents   HrLeaveRequestDocument[]

  approvedById Int?
  approvedBy   HrEmployee? @relation("LeaveApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  rejectedReason String?   @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, status])
  @@index([employeeId, startDate])
  @@map("hr_leave_requests")
}

/// ✅ [NEW] ตารางกลางสำหรับเชื่อมเอกสารแนบการลากับ DMS
model HrLeaveRequestDocument {
  id            Int      @id @default(autoincrement())
  companyId     Int
  company       OrgCompany @relation(fields: [companyId], references: [id])

  requestId     Int
  request       HrLeaveRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  /// 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId       Int      @unique
  media         SysMedia @relation(fields: [mediaId], references: [id])
  
  /// ประเภทเอกสาร เช่น 'MEDICAL_CERT' (ใบรับรองแพทย์), 'OTHER'
  docType       String?   
  createdAt     DateTime @default(now())

  @@index([companyId, requestId])
  @@map("hr_leave_request_documents")
}

// ==========================================
// STATIC DATA MASTERS (GEO & BANK)
// ข้อมูลนิ่งๆ ที่ใช้ร่วมกันทั้งระบบ
// ==========================================

///เก็บข้อมูลที่ตั้งทางภูมิศาสตร์แบบลำดับชั้น (Hierarchy) สำหรับใช้ในระบบที่อยู่ (Address), การจัดส่งสินค้า, และการคำนวณภาษี โดยออกแบบให้เป็นตารางเดียวที่สามารถเก็บได้ทั้งระดับ จังหวัด, อำเภอ, และตำบล ผ่านการเชื่อมโยงตัวเอง (Self-Relation)
model CfgGeography {
  ///รหัสลำดับของข้อมูลภูมิศาสตร์ (Primary Key)
  id Int @id @default(autoincrement())

  ///ประเภทหรือระดับของข้อมูล เพื่อใช้ในการกรอง (Filter) เช่น PROVINCE (จังหวัด), DISTRICT (อำเภอ/เขต), หรือ SUBDISTRICT (ตำบล/แขวง)
  type   String
  ///รหัสอ้างอิงทางภูมิศาสตร์
  code   String
  ///ชื่อไทย
  nameTh String
  ///ชื่อภาษาอังกฤษ
  nameEn String?
  /// อำเภอผูกกับจังหวัด, ตำบลผูกกับอำเภอ
  parentId Int? 
  parent   CfgGeography?  @relation("GeoTree", fields: [parentId], references: [id])
  children CfgGeography[] @relation("GeoTree")

  @@index([type])
  @@index([parentId])
  @@map("cfg_geographies")
}

///เก็บรายชื่อธนาคารพาณิชย์และสถาบันการเงินที่รองรับในระบบ เพื่อใช้เป็นข้อมูลอ้างอิงในการตั้งค่าบัญชีรับเงินของบริษัท, การแจ้งชำระเงินของลูกค้า, และการทำระบบจ่ายเงินเดือน (Payroll) ข้อมูลส่วนนี้จะช่วยให้ UI ของระบบดูเป็นระเบียบและน่าเชื่อถือผ่านการใช้สีและโลโก้ที่ถูกต้อง
model CfgBank {
  ///รหัสลำดับของธนาคาร (Primary Key)
  id           Int     @id @default(autoincrement())
  /// KBANK, SCB, BBL, KTB
  code         String  @unique
  ///ชื่อภาษาไทย
  nameTh       String
  ///ชื่อภาษาอังกฤษ
  nameEn       String
  /// #138f2d (เอาไว้ทำ UI สวยๆ)
  color        String?
  ///ที่อยู่ไฟล์รูปภาพโลโก้ของธนาคาร เพื่อใช้แสดงผลในระบบ
  logoUrl      String?
  /// รหัส 3 หลักของธปท. (004, 014) ใช้ทำ Payroll
  officialCode String?
  ///ลำดับการแสดงผล เพื่อให้สามารถเรียงธนาคารที่ใช้บ่อยไว้ลำดับต้นๆ ได้
  sortOrder    Int     @default(0)
  ///สถานะการเปิด/ปิดใช้งานข้อมูลธนาคารนั้นๆ
  isActive     Boolean @default(true)

  @@map("cfg_banks")
}


/// 📅 ระบบตารางกะกองกลาง (Master Roster) - Multi-company
model HrRoster {
  id        Int @id @default(autoincrement())
  companyId Int // 🚩 ระบุ ID บริษัท
  /// รหัสอ้างอิง เช่น ROSTER-2026-OFFICE
  code String 
  /// ชื่อตารางงาน
  name String 
  /// เชื่อมกับรูปแบบการทำงาน
  patternId      Int 
  /// เชื่อมกับกลุ่มวันหยุด
  holidayGroupId Int? 

  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Relations
  company      OrgCompany       @relation(fields: [companyId], references: [id])
  pattern      HrWorkPattern    @relation(fields: [patternId], references: [id])
  holidayGroup HrHolidayGroup?  @relation(fields: [holidayGroupId], references: [id])
  details      HrRosterDetail[]

  /// 🚩 ป้องกันรหัสซ้ำ "ภายในบริษัทเดียวกัน" เท่านั้น
  @@unique([companyId, code])
  @@index([companyId])
}

///ตารางเก็บรายละเอียดตารางงาน/กะการทำงานรายวัน (Daily Shift Schedule)
model HrRosterDetail {
  id        Int @id @default(autoincrement())
  rosterId  Int
  companyId Int // 🚩 ต้องมี companyId เพื่อความรวดเร็วในการ Query และความปลอดภัย

  date    DateTime @db.Date
  /// กะงาน (null = วันหยุด)
  shiftId Int? 

  isHoliday   Boolean @default(false)
  holidayId   Int?
  holidayName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Relations
  roster  HrRoster   @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  shift   HrShift?   @relation(fields: [shiftId], references: [id])
  holiday HrHoliday? @relation(fields: [holidayId], references: [id])
  company OrgCompany @relation(fields: [companyId], references: [id])

  /// 🚩 ป้องกันวันที่ซ้ำในหนึ่ง Roster
  @@unique([rosterId, date])
  /// 🚩 Index เพื่อความเร็วในการดึงข้อมูลรายเดือนของบริษัท
  @@index([companyId, date])
}

/// 📅 ตารางประวัติการผูกพนักงานเข้ากับรูปแบบการทำงาน (เก็บ History ได้)
model HrEmployeePattern {
  id          Int       @id @default(autoincrement())
  companyId   Int       
  
  employeeId  Int       
  patternId   Int       

  /// 🚩 หัวใจสำคัญของการเก็บประวัติ (Effective Dates)
  startDate   DateTime  @db.Date // วันที่เริ่มต้นบังคับใช้กะนี้
  endDate     DateTime? @db.Date // วันที่สิ้นสุด (ถ้าเป็น null = คือกะที่กำลังใช้อยู่ปัจจุบัน)

  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  /// Relations
  company     OrgCompany    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    HrEmployee    @relation(fields: [employeeId], references: [id], onDelete: Cascade) 
  pattern     HrWorkPattern @relation(fields: [patternId], references: [id])

  /// 🚩 ป้องกันพนักงาน 1 คน มีกะทำงานซ้ำซ้อนกันในวันเดียวกัน
  @@index([companyId, employeeId])
  @@index([startDate, endDate])
  @@map("hr_employee_patterns")
}

// ==========================================
// เพิ่มตารางนี้ใต้กลุ่ม CORE 4: WORKFLOW (Prefix: WF_)
// ==========================================

/// ตารางจับคู่ว่า "เหตุการณ์ทางธุรกิจ" (เช่น การย้ายแผนก, การลาออก) ต้องใช้ "สายอนุมัติ" ไหน
model WfModuleMapping {
  id        Int @id @default(autoincrement())
  companyId Int

  /// รหัสโมดูลหรือเหตุการณ์ เช่น "HR_MOVEMENT", "HR_RESIGN", "COM_ORDER_DISCOUNT"
  moduleCode String

  /// (Advance) เผื่ออนาคตใส่เงื่อนไข เช่น "salary_increase_percent > 20"
  condition String? @db.Text

  /// เชื่อมไปหา WfDefinition (สายอนุมัติที่คุณมีอยู่แล้ว)
  workflowId Int

  isActive Boolean @default(true)

  company  OrgCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workflow WfDefinition @relation(fields: [workflowId], references: [id])

  /// 1 บริษัท ควรกำหนดสายอนุมัติหลักให้โมดูลนั้นๆ ได้เพียง 1 แบบ (เว้นแต่มี condition ค่อยแยก)
  @@index([companyId, moduleCode])
  @@map("wf_module_mappings")
}

// ==========================================
// 🏗️ HR ORGANIZATION STRUCTURE VERSIONING
// ==========================================

// 1. เพิ่ม Enum ใหม่ไว้ด้านล่างสุดของไฟล์หรือใกล้ๆ กับกลุ่ม HR
enum OrgVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  CANCELLED
  PENDING_APPROVAL
}

///ตารางนี้ทำหน้าที่จัดการและจัดเก็บ "เวอร์ชันของโครงสร้างองค์กร" (Organizational Structure Versioning) เปรียบเสมือนการทำ Snapshot ผังองค์กรในแต่ละปีปฏิทิน
model HrOrgStructureVersion {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  calendarId Int
  calendar   HrCalendar @relation(fields: [calendarId], references: [id])

  name    String
  version Int    @default(1)

  status OrgVersionStatus @default(DRAFT)

  departmentEvaluations HrDepartmentEvaluation[]
  employeeEvaluations   HrEmployeeEvaluation[]

  /// 🔗 สะพานเชื่อมไปหา Workflow Engine
  wfRequestId Int?       @unique
  wfRequest   WfRequest? @relation(fields: [wfRequestId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments HrDepartmentVersion[]

  @@unique([companyId, calendarId, version])
  @@map("hr_org_structure_versions")
}

///ตารางนี้ทำหน้าที่เก็บข้อมูล "ใบคำร้องขอเพิ่มอัตรากำลังคน" (Manpower Request) เมื่อแผนกต่างๆ ต้องการคนเพิ่มในตำแหน่งใดตำแหน่งหนึ่ง
model HrManpowerRequest {
  id             Int      @id @default(autoincrement())
  
  /// 🏢 รองรับ Multi-company / Multi-tenant เต็มรูปแบบ
  companyId      Int
  company        OrgCompany @relation(fields: [companyId], references: [id]) 
  
  /// แผนกที่ขอคน
  departmentId   Int    
  /// ตำแหน่งที่ขอเพิ่ม  
  positionId     Int     
  /// จำนวนอัตราที่ขอ (เช่น ขอเพิ่ม 2 อัตรา) 
  requestedCount Int      
  reason         String   @db.Text 
  
  /// 🔗 สะพานเชื่อมไปหา Workflow Engine
  wfRequestId    Int?       @unique
  wfRequest      WfRequest? @relation(fields: [wfRequestId], references: [id])
  
  createdAt      DateTime   @default(now())
}

///ตารางนี้ทำหน้าที่เก็บข้อมูลรายละเอียดของ "แผนก" ในรูปแบบฉบับร่างหรือ Snapshot ภายใต้เวอร์ชันของโครงสร้างองค์กรที่กำหนด
model HrDepartmentVersion {
  id Int @id @default(autoincrement())

  /// 🛡️ เพิ่ม Company ID เพื่อความปลอดภัยระดับ Row-Level
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  versionId Int
  version   HrOrgStructureVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  originalDeptId Int?

  code        String
  name        String
  description String?
  sortOrder   Int?

  parentId Int?
  parent   HrDepartmentVersion?  @relation("DeptVersionTree", fields: [parentId], references: [id])
  children HrDepartmentVersion[] @relation("DeptVersionTree")

  managerId       Int?
  deputyManagerId Int?

  positions HrDepartmentPositionVersion[]

  /// สร้าง Index เพื่อให้ดึงผังจำลองของบริษัทนั้นๆ ได้ไวขึ้น
  @@index([companyId, versionId])
  @@map("hr_department_versions")
}

///ตารางนี้ทำหน้าที่จัดเก็บการจับคู่ระหว่าง "แผนก" และ "ตำแหน่งงาน" (Mapping) ภายในเวอร์ชันโครงสร้างองค์กรนั้นๆ รวมถึงกำหนด "กรอบอัตรากำลัง" (Headcount) ที่วางแผนไว้สำหรับตำแหน่งนั้นในแต่ละแผนก
model HrDepartmentPositionVersion {
  id Int @id @default(autoincrement())

  /// 🛡️ เพิ่ม Company ID เพื่อความปลอดภัยระดับ Row-Level
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  deptVersionId Int
  deptVersion   HrDepartmentVersion @relation(fields: [deptVersionId], references: [id], onDelete: Cascade)

  positionId Int
  position   HrPosition @relation(fields: [positionId], references: [id])

  maxHeadcount Int?
  seats        HrPositionSeat[]

  createdAt DateTime @default(now())

  /// ป้องกันการใส่ตำแหน่งซ้ำในแผนกจำลองเดียวกัน
  @@unique([deptVersionId, positionId])
  /// Index สำหรับดึงข้อมูลตำแหน่งทั้งหมดในเวอร์ชันของบริษัทนี้
  @@index([companyId, deptVersionId])
  @@map("hr_department_position_versions")
}

/// 🌟 ตารางเก้าอี้ตำแหน่ง (รองรับทั้งภาครัฐและเอกชนขนาดใหญ่)
model HrPositionSeat {
  id Int @id @default(autoincrement())

  /// 1. ระบุบริษัทเพื่อความปลอดภัยและการทำ Multi-company
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 2. เชื่อมโยงกับผังองค์กร (เวอร์ชันปฏิทิน)
  positionVerId   Int
  positionVersion HrDepartmentPositionVersion @relation(fields: [positionVerId], references: [id], onDelete: Cascade)

  /// 3. ข้อมูลเลขที่ตำแหน่ง
  seatNumber String // เช่น "ว.1023", "ค.005"

  /// 4. สถานะเก้าอี้: VACANT (ว่าง), OCCUPIED (มีคนนั่ง), FROZEN (ระงับงบประมาณ)
  status String @default("VACANT")

  /// 5. ใครครองตำแหน่งนี้อยู่ (เชื่อมไปที่พนักงาน)
  currentEmployeeId Int?        @unique
  currentEmployee   HrEmployee? @relation("EmployeeSeat", fields: [currentEmployeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// 🔒 ป้องกันการตั้งเลขที่ตำแหน่งซ้ำกันในบริษัทเดียวกัน
  @@unique([companyId, seatNumber])
  @@index([companyId])
  @@map("hr_position_seats")
}

/// ตารางกลางสำหรับคุมไฟล์ทุกชนิดในระบบ
model SysMedia {
  id        Int      @id @default(autoincrement())
  companyId Int
  url       String   @unique
  /// ขนาดไฟล์ (Bytes)
  size      Int 
  /// ชื่อโมดูล เช่น 'announcement', 'product', 'knowledge'
  module    String 
  /// ID ของข้อมูลที่ผูกด้วย (ถ้าเป็น null แปลว่าไฟล์ขยะ!)
  refId     Int? 
  createdAt DateTime @default(now())

  company OrgCompany @relation(fields: [companyId], references: [id])
 
  /// 🚩 [เพิ่มใหม่] เพื่อรองรับความสัมพันธ์ย้อนกลับจากรูปภาพของรางวัล CRM
  crmRewards CrmReward[]

  /// 🚩 [เพิ่มใหม่] เพื่อรองรับความสัมพันธ์ย้อนกลับจากรูปโปรไฟล์สมาชิก CRM
  crmMembers CrmMember[]
  
  /// ✅ [NEW] เพิ่มส่วนนี้เพื่อเชื่อมกับพนักงาน 1. เชื่อมกลับไปยังรูปโปรไฟล์พนักงาน (แบบ 1:1)
  employeeProfile HrEmployee? @relation("EmployeeProfile")

  /// 2. เชื่อมกลับไปยังเอกสารพนักงาน (แบบ 1:1 ผ่าน HrEmployeeDocument)
  employeeDoc     HrEmployeeDocument?

  productReviewMedia ComProductReviewMedia?

  /// 🚩 [เพิ่มใหม่] รองรับความสัมพันธ์ย้อนกลับจากรูป/ไฟล์ PDF ใบกำกับภาษี
  comInvoice ComInvoice?

  kpiPlanDoc      HrKpiPlanDocument?
  kpiEvidence     HrKpiEvidence?
  
  /// ✅ [NEW] เชื่อมกลับไปบทลงโทษ
  disciplinaryDoc HrDisciplinaryDocument?

  /// ✅ [NEW] เชื่อมกลับไปยังเอกสารอบรม
  trainingDoc HrTrainingDocument?

  /// ✅ [NEW] เชื่อมกลับไปยังรูปห้องประชุม
  meetingRoomMedia AdmMeetingRoomMedia?

  /// ✅ [NEW] เชื่อมกลับไปยังเอกสารเบิกสวัสดิการ
  welfareRequestDoc HrWelfareRequestDocument?

  /// ✅ [NEW] เชื่อมกลับไปยัง Asset และ Request
  assetAttachment   AdmAssetAttachment?
  assetRequestDoc   AdmAssetRequestDocument?

  /// ✅ [NEW] เชื่อมกลับไปยังเอกสารเครื่องราชฯ
  decorationDoc HrEmployeeDecorationDocument?

  /// ✅ [NEW] เชื่อมกลับไปยังหลักฐานการร้องเรียน
  grievanceEvidence HrGrievanceEvidence?

  /// ✅ [NEW] เชื่อมกลับไปยังเอกสารการลา
  leaveRequestDoc HrLeaveRequestDocument?

  /// ✅ [NEW] เชื่อมกลับไปยังระบบเงินเดือน
  salaryAdjDoc    HrSalaryAdjustmentDocument?
  payrollSlip     HrPayrollSlip?

  /// 🚩 [เพิ่มใหม่] เพื่อรองรับความสัมพันธ์ย้อนกลับจากตารางหลักฐานการแลกของรางวัล crm
  crmRedemptionDocument CrmRedemptionDocument?

  /// ✅ Back-relations สำหรับ E-commerce
  purchaseDoc    EcomPurchaseDocument?
  paymentSlip    EcomPaymentSlip?
  shippingDoc    EcomShippingDocument?
  promotionDoc   EcomPromotionDocument?
  returnDoc      EcomReturnDocument?
  /// ✅ Back-relation สำหรับประกาศ
  announcementMedia ComAnnouncementMedia?
  shopDoc           ComShopDocument?
  /// ✅ [NEW] Back-relation สำหรับรูปโลโก้ของหน้าร้าน
  shopLogoProfile ComShopProfile? @relation("ShopLogo")
  /// ✅ [NEW] Back-relation สำหรับเอกสารคลังสินค้า
  warehouseDoc      ComWarehouseDocument?

  /// ✅ [NEW] Back-relation สำหรับข้อมูลบริษัท
  companyLogo      OrgCompanyInfo? @relation("CompanyLogo")
  companyDoc       OrgCompanyDocument?

  @@index([companyId])
  @@index([module, refId]) // Index เพื่อให้ค้นหาตอนลบได้เร็วขึ้น
}

/// จัดการ API Key สำหรับให้ลูกค้าภายนอกเชื่อมต่อระบบ KKV
model OrgApiKey {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// ชื่อคีย์ (เช่น "Production Key", "Test Key")
  keyName String

  /// รหัส API Key (เช่น "kkv_live_8f7d6a5...")
  apiKey String @unique

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("org_api_keys")
}

/// สมุดข่อยบันทึกประวัติการตรวจสอบสลิป (ป้องกันสลิปซ้ำและใช้คิดเงิน API)
model LogSlipVerification {
  id        Int        @id @default(autoincrement())
  companyId Int // รหัสบริษัทที่เรียกใช้ (เพื่อรู้ว่าใครเป็นคนจ่ายโควตา)
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🌟 รหัสอ้างอิงจากธนาคาร (ตั้ง Unique เพื่อป้องกันการนำสลิปเดิมมาวนใช้ซ้ำทั้งแพลตฟอร์ม)
  transRef String @unique

  senderBank   String? // ธนาคารต้นทาง
  senderName   String? // ชื่อคนโอน
  receiverBank String? // ธนาคารปลายทาง
  receiverName String? // ชื่อคนรับ
  amount       Decimal   @db.Decimal(10, 2)
  transferDate DateTime? // วันเวลาที่โอนจริงตามสลิป

  /// สถานะการตรวจสอบ: SUCCESS, DUPLICATE, INVALID
  status String

  /// แหล่งที่มา: 'INTERNAL_ORDER' (ลูกค้ากดสั่งซื้อหน้าเว็บ), 'EXTERNAL_API' (ลูกค้า B2B ยิงมา)
  source String

  createdAt DateTime @default(now())

  @@index([companyId])
  @@map("log_slip_verifications")
}

///จัดการและเก็บประวัติรหัสผ่านแบบใช้ครั้งเดียว (OTP) ที่ส่งผ่านระบบอีเมล สำหรับใช้ในการยืนยันตัวตนและรักษาความปลอดภัยของระบบครับ
model SecOtp {
  id Int @id @default(autoincrement())

  companyId Int?
  company   OrgCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🌟 เพิ่มการผูกกับหน้าร้านค้า
  shopId Int?
  shop   ComShopProfile? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  email     String
  code      String
  purpose   String   @default("LOGIN")
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  /// อัปเดต Index เพื่อความเร็ว
  @@index([companyId, shopId, email, code])
  @@map("sec_otps")
}

// ==========================================
// 🌟 ENUMS สำหรับระบบประเมินผล (KPI & Evaluation)
// ==========================================

enum KpiTargetType {
  CORPORATE   // ระดับองค์กร
  DEPARTMENT  // ระดับแผนก/ฝ่าย
  INDIVIDUAL  // ระดับบุคคล
}

enum PlanStatus {
  DRAFT             // ร่างแผน
  PENDING_APPROVAL  // รออนุมัติ (อยู่ใน Workflow)
  PUBLISHED         // ประกาศใช้เป็นทางการ
  REVISED           // ถูกแก้ไข/แทนที่ไปแล้ว
}

enum KpiEvaluationStatus {
  GOAL_SETTING           // ช่วงตั้งเป้าหมาย
  PENDING_PLAN_APPROVAL  // รออนุมัติเป้าหมายต้นปี (Workflow)
  SELF_EVALUATION        // พนักงานประเมินตนเอง
  MANAGER_EVALUATION     // หัวหน้าประเมิน
  COMMITTEE_EVALUATION   // คณะกรรมการประเมิน (สำหรับราชการ)
  COMPLETED              // สิ้นสุดกระบวนการ
  CANCELLED              // ยกเลิก
}

// ==========================================
// 🌟 1. กลุ่มวางแผนตัวชี้วัด (KPI Plan Versioning)
// ==========================================


/// ตารางเก็บ "เวอร์ชันของแผนเป้าหมาย" (ล็อกเป้าหมายต้นปี/กลางปี)
model HrKpiPlanVersion {
  id                Int        @id @default(autoincrement())
  companyId         Int
  company           OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  cycleId           Int        // อ้างอิง Calendar/รอบการประเมิน
  cycle             HrKpiCycle @relation(fields: [cycleId], references: [id])
  /// เช่น "KPI-2569-V1"
  versionCode       String     
  /// เช่น "แผนยุทธศาสตร์องค์กร ปี 2569"
  versionName       String     

  /// ✅ เพิ่มความสัมพันธ์ไปยังตารางเอกสารแผน
  documents       HrKpiPlanDocument[] 
  
  status            PlanStatus @default(DRAFT)
  isActive          Boolean    @default(false)

  /// เชื่อมโยงกับ Workflow เพื่ออนุมัติแผนเป้าหมาย
  workflowRequestId Int?       

  items             HrKpiPlanItem[]
  deptEvaluations   HrDepartmentEvaluation[]
  empEvaluations    HrEmployeeEvaluation[]

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([companyId, cycleId])
  @@map("hr_kpi_plan_versions")
}



/// ตารางเก็บ "เป้าหมายรายข้อ" ในเวอร์ชันนั้นๆ
model HrKpiPlanItem {
  id                Int        @id @default(autoincrement())
  companyId         Int
  company           OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  planVersionId     Int
  planVersion       HrKpiPlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  kpiId             Int
  kpiMaster         HrKpiLibrary @relation(fields: [kpiId], references: [id])

  targetValue       Decimal    @db.Decimal(10, 2) // เป้าที่ตั้งไว้
  weight            Decimal    @db.Decimal(5, 2)  // น้ำหนัก %

  @@index([companyId, planVersionId])
  @@map("hr_kpi_plan_items")
}

// ==========================================
// 🌟 2. กลุ่มประเมินผลระดับองค์กร/หน่วยงาน (Department Evaluation)
// ==========================================



/// ตารางเก็บ "หัวใบประเมินของแผนก"
model HrDepartmentEvaluation {
  id               Int        @id @default(autoincrement())
  companyId        Int
  company          OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  cycleId          Int
  cycle            HrKpiCycle @relation(fields: [cycleId], references: [id])

  /// ล็อก Snapshot ตามโครงสร้างองค์กร
  orgVersionId     Int        
  orgVersion       HrOrgStructureVersion @relation(fields: [orgVersionId], references: [id])
  departmentNodeId Int        

  /// ล็อกตามแผนตัวชี้วัดที่ใช้
  planVersionId    Int
  planVersion      HrKpiPlanVersion @relation(fields: [planVersionId], references: [id])

  workflowRequestId Int?      // Workflow สำหรับอนุมัติผลงานแผนก
  
  totalScore       Decimal?   @db.Decimal(5, 2)
  status           KpiEvaluationStatus @default(GOAL_SETTING)

  items            HrDepartmentEvaluationItem[]

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([companyId, cycleId, orgVersionId])
  @@map("hr_department_evaluations")
}



/// ตารางเก็บ "คะแนนรายข้อของแผนก"
model HrDepartmentEvaluationItem {
  id               Int        @id @default(autoincrement())
  companyId        Int
  company          OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  evaluationId     Int
  evaluation       HrDepartmentEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  
  kpiId            Int
  kpiMaster        HrKpiLibrary @relation(fields: [kpiId], references: [id])

  /// ✅ เพิ่มความสัมพันธ์ไปยังตารางหลักฐาน
  evidences       HrKpiEvidence[] 

  weight           Decimal    @db.Decimal(5, 2)
  targetValue      Decimal    @db.Decimal(10, 2)
  /// ผลงานจริง
  actualValue      Decimal?   @db.Decimal(10, 2) 
  /// คะแนนที่แปลงแล้ว
  score            Decimal?   @db.Decimal(5, 2)  

  alignedEmployeeItems HrKpiAlignment[]

  @@index([companyId, evaluationId])
  @@map("hr_department_evaluation_items")
}

// ==========================================
// 🌟 3. กลุ่มประเมินผลระดับบุคคล (Employee Evaluation) ทับของเดิม
// ==========================================



/// ตารางเก็บ "หัวใบประเมินของพนักงาน" (แทนที่ HrKpiEvaluation เดิม)
model HrEmployeeEvaluation {
  id               Int        @id @default(autoincrement())
  companyId        Int
  company          OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  employeeId       Int
  employee         HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  cycleId          Int
  cycle            HrKpiCycle @relation(fields: [cycleId], references: [id])

  /// ล็อก Snapshot ตามโครงสร้างองค์กร (ป้องกันเวลาย้ายแผนก)
  orgVersionId     Int
  orgVersion       HrOrgStructureVersion @relation(fields: [orgVersionId], references: [id])
  departmentNodeId Int     
  /// ล็อกหัวหน้างานผู้ประเมิน ณ เวลานั้น   
  managerId        Int?       
  manager          HrEmployee? @relation("ManagerEvaluator", fields: [managerId], references: [id])
  /// อ้างอิงแผนเผื่อกรณีมีการดึงเป้าองค์กรมาให้คน
  planVersionId    Int?       
  planVersion      HrKpiPlanVersion? @relation(fields: [planVersionId], references: [id])
  /// Workflow สำหรับอนุมัติประเมินผลของบุคคล
  workflowRequestId Int?      

  /// การให้คะแนน (ดึงจากของเดิมคุณมาใส่ให้ครบ)
  status           KpiEvaluationStatus @default(GOAL_SETTING)
  totalKpiScore    Decimal? @db.Decimal(5, 2)
  /// สำหรับคะแนน Competency/Behavior
  totalComScore    Decimal? @db.Decimal(5, 2) 
  finalScore       Decimal? @db.Decimal(5, 2)
  /// A, B, C, D
  grade            String?  

  /// ความเห็น
  selfRemark       String? @db.Text
  managerRemark    String? @db.Text

  items            HrEmployeeEvaluationItem[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId, employeeId, cycleId])
  @@map("hr_employee_evaluations")
}



/// ตารางเก็บ "คะแนนรายข้อของพนักงาน" (แทนที่ HrKpiEvaluationItem เดิม)
model HrEmployeeEvaluationItem {
  id               Int        @id @default(autoincrement())
  companyId        Int
  company          OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  evaluationId     Int
  evaluation       HrEmployeeEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  kpiId            Int
  kpiMaster        HrKpiLibrary @relation(fields: [kpiId], references: [id])

  weight           Decimal    @db.Decimal(5, 2)
  targetValue      Decimal    @db.Decimal(10, 2)
  actualValue      Decimal?   @db.Decimal(10, 2)
  score            Decimal?   @db.Decimal(5, 2)

  alignedDeptItems HrKpiAlignment[]
  
  /// ✅ เพิ่มความสัมพันธ์ไปยังตารางหลักฐาน
  evidences       HrKpiEvidence[] 

  @@index([companyId, evaluationId])
  @@map("hr_employee_evaluation_items")
}

// ==========================================
// 🌟 4. ตาราง Alignment (เชื่อมเป้าหมายคน เข้ากับองค์กร)
// ==========================================


/// ผูก KPI พนักงานว่าส่งผลต่อ KPI แผนกข้อไหน (OKRs / Scorecard)
model HrKpiAlignment {
  id                    Int        @id @default(autoincrement())
  companyId             Int
  company               OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  deptEvaluationItemId  Int
  deptItem              HrDepartmentEvaluationItem @relation(fields: [deptEvaluationItemId], references: [id], onDelete: Cascade)

  empEvaluationItemId   Int
  empItem               HrEmployeeEvaluationItem @relation(fields: [empEvaluationItemId], references: [id], onDelete: Cascade)

  /// Contribution (%) ที่พนักงานคนนี้รับผิดชอบเป้าหมายของแผนก
  weightContribution    Decimal    @db.Decimal(5, 2) 

  @@index([companyId, deptEvaluationItemId, empEvaluationItemId])
  @@map("hr_kpi_alignments")
}

// ==========================================
// 🌟 5. Master Data สำหรับระบบ KPI (คลัง & รอบประเมิน)
// ==========================================


/// คลังตัวชี้วัด (Master KPI Library)
model HrKpiLibrary {
  id          Int      @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code        String?  // รหัสตัวชี้วัด (เช่น KPI-001)
  name        String   // ชื่อตัวชี้วัด (เช่น ยอดขายรวม)
  description String?  @db.Text
  
  /// ระบุว่า KPI นี้ใช้วัดระดับไหน (อ้างอิง Enum KpiTargetType)
  targetType  KpiTargetType @default(INDIVIDUAL)

  /// 🔗 Relation กลับไปยังตารางประเมิน (ที่ Prisma ถามหา)
  planItems   HrKpiPlanItem[]
  deptItems   HrDepartmentEvaluationItem[]
  empItems    HrEmployeeEvaluationItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@map("hr_kpi_libraries")
}

/// รอบการประเมินผล (ย่อย) ที่ผูกอยู่ภายใต้ ปีปฏิทิน (HrCalendar)
model HrKpiCycle {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🌟 1. ผูกเข้ากับ HrCalendar โครงสร้างหลักของคุณ
  calendarId  Int
  calendar    HrCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  /// 2. ชื่อรอบประเมินย่อย
  cycleCode   String     // เช่น "Q1", "MID-YEAR", "YEAR-END"
  cycleName   String     // เช่น "การประเมินไตรมาส 1", "ประเมินผลงานครึ่งปีแรก"
  
  /// 3. วันที่เริ่มและสิ้นสุด (ต้องอยู่ภายใต้ startDate/endDate ของ HrCalendar)
  startDate   DateTime
  endDate     DateTime
  
  isActive    Boolean    @default(true)

  planVersions HrKpiPlanVersion[]
  deptEvals    HrDepartmentEvaluation[]
  empEvals     HrEmployeeEvaluation[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([companyId, calendarId])
  @@map("hr_kpi_cycles")
}


/// ✅ [NEW] ตารางกลางสำหรับเอกสารประกอบแผนยุทธศาสตร์ (Strategic Plan Docs)
model HrKpiPlanDocument {
  id              Int      @id @default(autoincrement())
  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id])

  planVersionId   Int
  planVersion     HrKpiPlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  /// 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId         Int      @unique
  media           SysMedia @relation(fields: [mediaId], references: [id])

  createdAt       DateTime @default(now())

  @@index([companyId, planVersionId])
  @@map("hr_kpi_plan_documents")
}

/// ✅ [NEW] ตารางกลางสำหรับหลักฐานยืนยันผลงาน (Evidence of Achievement)  ใช้ได้ทั้งระดับแผนก และ ระดับบุคคล
model HrKpiEvidence {
  id                Int      @id @default(autoincrement())
  companyId         Int
  company           OrgCompany @relation(fields: [companyId], references: [id])

  // เชื่อมกับผลงานรายข้อของแผนก (ถ้ามี)
  deptEvaluationItemId Int?
  deptItem             HrDepartmentEvaluationItem? @relation(fields: [deptEvaluationItemId], references: [id], onDelete: Cascade)

  // เชื่อมกับผลงานรายข้อของพนักงาน (ถ้ามี)
  empEvaluationItemId  Int?
  empItem              HrEmployeeEvaluationItem? @relation(fields: [empEvaluationItemId], references: [id], onDelete: Cascade)

  /// 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId           Int      @unique
  media             SysMedia @relation(fields: [mediaId], references: [id])
  
  remark            String?  @db.Text
  createdAt         DateTime @default(now())

  @@index([companyId])
  @@map("hr_kpi_evidences")
}

// ==========================================
// MODULE: DOCUMENT MANAGEMENT (DMS)
// ==========================================

/// ตารางเก็บโครงสร้างแฟ้มข้อมูล (Folders) แบบ Tree (ซ้อนกันได้ไม่จำกัดชั้น)
model DocFolder {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  description String?    @db.Text

  /// 🌟 1. เพิ่ม Flag เพื่อบอกว่าโฟลเดอร์นี้ทำงานแบบ Workspace (สำหรับ Enterprise)
  isWorkspace Boolean    @default(false)

  /// 💧 Future Feature: Dynamic Watermark
  isWatermarkEnabled Boolean  @default(false)

  /// 🌟 2. เพิ่มการผูก Workflow เข้ากับโฟลเดอร์นี้
  defaultWorkflowId Int?
  defaultWorkflow   WfDefinition? @relation("DefaultFolderWorkflow", fields: [defaultWorkflowId], references: [id])

  /// 🌟 [เพิ่มใหม่] สายอนุมัติสำหรับ "ลบทำลาย" เอกสาร
  deleteWorkflowId  Int?      @map("delete_workflow_id")
  deleteWorkflow    WfDefinition? @relation("DeleteFolderWorkflow", fields: [deleteWorkflowId], references: [id])

  // 🌟 เพิ่มฟิลด์นี้เข้าไป เพื่อกำหนดสายอนุมัติการขอสิทธิ์เฉพาะโฟลเดอร์
  accessWorkflowId  Int?
  accessWorkflow    WfDefinition? @relation("AccessFolderWorkflow", fields: [accessWorkflowId], references: [id])
  
  /// โครงสร้าง Parent-Child เพื่อทำ Sub-folder
  parentId    Int?
  parent      DocFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children    DocFolder[] @relation("FolderTree")

  files       DocFile[]
  accessRoles DocFolderAccess[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// ป้องกันการตั้งชื่อโฟลเดอร์ซ้ำกันในชั้นเดียวกัน (Level เดียวกัน)
  @@unique([companyId, parentId, name]) 
  @@map("doc_folders")
}

/// 📂 ตารางหลักของไฟล์ (ปรับปรุงให้เป็น Parent ของ Versions)
model DocFile {
  id            Int            @id @default(autoincrement())
  companyId     Int
  company       OrgCompany     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  folderId      Int?
  folder        DocFolder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)

  /// ข้อมูลที่แสดงผลปัจจุบัน (จะ Update เมื่อมีการสร้าง Version ใหม่)
  fileName      String
  fileExtension String
  /// ขนาดไฟล์ของเวอร์ชันล่าสุด
  currentSize   BigInt    
  /// ลิงก์ GCS ของเวอร์ชันล่าสุด    
  currentUrl    String         

  /// 🚨 Future Feature: Data Loss Prevention (DLP) มีเลขบัตร ปชช, บัตรเครดิต หรือไม่
  isSensitiveData    Boolean  @default(false) 
  /// ระดับความความลับ (0-100 ประเมินโดย AI)
  sensitivityScore   Int      @default(0)     

  sarabanRecord   DocSarabanRecord?

  /// 💧 Future Feature: Dynamic Watermark
  isWatermarkEnabled Boolean  @default(false)

  sourceArchiveId Int?
  sourceArchive   DocFile?   @relation("ArchiveToFiles", fields: [sourceArchiveId], references: [id], onDelete: SetNull)
  extractedFiles  DocFile[]  @relation("ArchiveToFiles")

  logDocumentTraces LogDocumentTrace[]
  
  uploadedById  Int
  uploadedBy    SecUser        @relation(fields: [uploadedById], references: [id])
  ///ถ้ามี password ก่อนเข้าดู
  filePassword  String?

  /// 🤖 จุดเชื่อมต่อกับ AI (คงไว้ที่ตัวหลัก เพื่อให้ AI มองเป็นเอกสารฉบับเดียว)
  isSyncToAi      Boolean      @default(false)
  knowledgeBaseId Int?         @unique
  knowledgeBase   IntKnowledgeBase? @relation(fields: [knowledgeBaseId], references: [id])

  /// 🔄 จุดเชื่อมต่อกับ Workflow (ล็อกที่ตัวหลัก เพื่อคุมสถานะการแก้ไข)
  wfRequestId     Int?         @unique
  wfRequest       WfRequest?   @relation(fields: [wfRequestId], references: [id])

  /// 🕒 กำหนดวันหมดอายุของไฟล์ (ถ้ามีค่า CronJob จะลบทิ้งอัตโนมัติ)
  autoDeleteAt  DateTime?

  /// เก็บประวัติทุกเวอร์ชัน
  versions      DocFileVersion[] 
  /// สำหรับ Advanced Search
  metadata      DocFileMetadata[] 
  docFileShareLink    DocFileShareLink[]
  docSignatureRequest     DocSignatureRequest[]

  accessRoles   DocFileAccess[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyId, folderId])
  @@map("doc_files")
}

// 🌟 ตารางสำหรับเก็บข้อมูลสารบรรณอิเล็กทรอนิกส์ (TH e-Saraban)
model DocSarabanRecord {
  id              Int        @id @default(autoincrement())
  
  // 🏢 ผูก Relation กับ Company (Multi-Tenant Isolation)
  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // 📄 ผูก Relation กับไฟล์เอกสาร
  fileId          Int        @unique // 1 ไฟล์ มีข้อมูลสารบรรณได้ 1 ชุด
  file            DocFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  // 📌 ข้อมูลหลักของหนังสือราชการ
  bookNumber      String?    // เลขที่หนังสือ (เช่น กค ๐๔๐๒.๑/ว ๑๒๓)
  receiveNumber   String?    // เลขรับ (กรณีเป็นหนังสือรับเข้า)
  bookDate        DateTime?  // ลงวันที่ (วันที่บนตัวหนังสือ)
  receiveDate     DateTime?  // วันที่รับหนังสือเข้าสู่ระบบ
  subject         String     @db.Text // เรื่อง
  toPerson        String?    @db.Text // เรียน (ถึงใคร/ตำแหน่งใด)
  fromPerson      String?    @db.Text // จาก (หน่วยงาน/บุคคลใด)

  // 🚨 ชั้นความเร่งด่วน (NORMAL=ปกติ, URGENT=ด่วน, VERY_URGENT=ด่วนมาก, MOST_URGENT=ด่วนที่สุด)
  urgencyLevel    String     @default("NORMAL") 

  // 🔒 ชั้นความลับ (NORMAL=ปกติ, SECRET=ลับ, TOP_SECRET=ลับมาก, TOP_SECRET_STRICT=ลับที่สุด)
  secretLevel     String     @default("NORMAL") 

  // 📂 ชนิดหนังสือ (INTERNAL=หนังสือภายใน, EXTERNAL=หนังสือภายนอก, COMMAND=คำสั่ง/ประกาศ)
  bookType        String     @default("EXTERNAL") 

  // 📎 ข้อมูลประกอบ
  reference       String?    @db.Text // อ้างถึง
  attachment      String?    @db.Text // สิ่งที่ส่งมาด้วย
  remark          String?    @db.Text // หมายเหตุ

  // 🌐 ฟิลด์สำหรับเชื่อมต่อ TH e-Document API (ระบบกลางภาครัฐ)
  eDocumentId     String?    // รหัสเอกสารอิเล็กทรอนิกส์อ้างอิงจากระบบภาครัฐ (ถ้ามี)
  isSyncedToGov   Boolean    @default(false) // เช็กว่าส่งข้อมูลเข้าระบบรัฐสำเร็จหรือยัง
  govSyncDate     DateTime?  // วันเวลาที่ Sync ข้อมูลสำเร็จ

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // ⚡ Index เพื่อให้การค้นหาด้วย Smart Search / RAG เร็วขึ้น
  @@index([companyId])
  @@index([bookNumber])
  @@index([receiveNumber])
}

/// 📑 ตารางเก็บประวัติเวอร์ชันไฟล์ (New)
model DocFileVersion {
  id           Int      @id @default(autoincrement())
  fileId       Int
  file         DocFile  @relation(fields: [fileId], references: [id], onDelete: Cascade)

  /// 🏢 ระบุบริษัทเพื่อความปลอดภัยสูงสุด
  companyId    Int
  company      OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🔍 Future Feature: Full-Text Search (เก็บข้อความที่สกัดจาก PDF/รูปภาพ)
  extractedText      String?  @db.Text
  /// 1, 2, 3...
  version      Int      @default(1) 
  /// ลิงก์ไฟล์ใน GCS ของเวอร์ชันนั้นๆ
  url          String  
  size         BigInt
  /// เช่น application/pdf
  mimeType     String? 
  /// บันทึกว่าแก้ไขอะไรในเวอร์ชันนี้ 
  changeLog    String?  

  /// 🌟 เพิ่มฟิลด์นี้เข้าไป เพื่อใช้บอกว่าเวอร์ชันไหนคือไฟล์ใช้งานจริงปัจจุบัน
  isCurrent      Boolean  @default(false)
  
  uploadedById Int
  uploadedBy   SecUser  @relation(fields: [uploadedById], references: [id])
  
  createdAt    DateTime @default(now())

  @@index([companyId, fileId]) // 🚀 Index คู่เพื่อให้หาประวัติในบริษัทนั้นๆ ได้ไว
  @@map("doc_file_versions")
}

/// 🏷️ ตารางเก็บ Metadata สำหรับ Advanced Search (New)
model DocFileMetadata {
  id        Int      @id @default(autoincrement())

  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  fileId    Int
  file      DocFile  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  /// เช่น "department", "doc_type", "priority"
  key       String  
  /// เช่น "accounting", "invoice", "urgent"
  value     String   
  
  @@index([companyId, key, value]) 
  @@index([fileId, key])
  @@map("doc_file_metadata")
}

/// ตารางกำหนดสิทธิ์ระดับโฟลเดอร์ (Folder RBAC)
model DocFolderAccess {
  id          Int        @id @default(autoincrement())
  companyId   Int
  /// 🌟 เพิ่มบรรทัดนี้: เชื่อมกลับไปหา OrgCompany
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  folderId    Int
  folder      DocFolder  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  
  roleId      Int?
  /// 🌟 เพิ่มบรรทัดนี้: เชื่อมกลับไปหา SecRole
  role        SecRole?   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  userId      Int?
  user        SecUser?   @relation(fields: [userId], references: [id])

  canView     Boolean    @default(false)
  canUpload   Boolean    @default(false)
  canDelete   Boolean    @default(false)

  expiresAt   DateTime?  
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([companyId, folderId])
  @@index([companyId, userId])
  @@index([companyId, roleId])
  @@index([expiresAt])

  @@map("doc_folder_access")
}


/// 🛡️ ส่วนที่เพิ่มใหม่: ระบบคำขอเข้าถึงข้อมูล
model DocAccessRequest {
  id            Int      @id @default(autoincrement())
  companyId     Int
  company       OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 👤 ผู้ที่ต้องการขอสิทธิ์
  requesterId   Int
  requester     SecUser    @relation("AccessRequester", fields: [requesterId], references: [id])

  /// 📂 ข้อมูลที่ขอเข้าถึง
  targetType    String     // "FOLDER" หรือ "FILE"
  targetId      Int        // ID ของ Folder หรือ File นั้นๆ
  
  /// 📝 รายละเอียดคำขอ
  reason        String?    @db.Text
  durationDays  Int        @default(1) // จำนวนวันที่ขอเข้าใช้งาน
  
  /// ⛓️ เชื่อมกับระบบ Workflow เดิม
  wfRequestId   Int?       @unique
  wfRequest     WfRequest? @relation(fields: [wfRequestId], references: [id])

  status        String     @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  /// 🔍 ค้นหาประวัติ "คำขอของฉัน" ในบริษัทนี้
  @@index([companyId, requesterId])  
  /// 🔍 ค้นหาว่า "ไฟล์/โฟลเดอร์นี้" มีใครมาขอสิทธิ์บ้าง และกันคนกดขอซ้ำ           
  @@index([companyId, targetType, targetId])   
  /// 🔍 สำหรับทำหน้า Dashboard ดึงเฉพาะคำขอที่ PENDING หรือ EXPIRED
  @@index([companyId, status])                   

  @@map("doc_access_requests")
}

/// ตารางกำหนดสิทธิ์ระดับไฟล์แยกย่อย (File RBAC) - เผื่อกรณีไฟล์ลับพิเศษ
model DocFileAccess {
  id          Int        @id @default(autoincrement())
  companyId   Int
  /// 🌟 เพิ่มบรรทัดนี้: เชื่อมกลับไปหา OrgCompany
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  fileId      Int
  file        DocFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  
  roleId      Int?
  /// 🌟 เพิ่มบรรทัดนี้: เชื่อมกลับไปหา SecRole
  role        SecRole?   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  userId      Int?       
  user        SecUser?   @relation(fields: [userId], references: [id])

  canView     Boolean    @default(false)
  canDownload Boolean    @default(false)

  expiresAt   DateTime?  
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([companyId, fileId])     
  @@index([companyId, userId])     
  @@index([companyId, roleId])     
  @@index([expiresAt])             

  @@map("doc_file_access")
}

/// 2. เพิ่มตารางใหม่สำหรับ External Sharing
model DocFileShareLink {
  id          Int      @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  fileId      Int
  file        DocFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  
  /// รหัสสุ่มสำหรับแชร์ เช่น kkv.com/share/abc123xyz
  token       String     @unique 
  
  /// รหัสผ่าน (ถ้ามีการตั้งรหัสผ่านก่อนโหลด)
  password    String?    
  
  /// วันหมดอายุของลิงก์นี้
  expiresAt   DateTime?  
  
  /// จำนวนครั้งที่อนุญาตให้โหลด (เช่น โหลดได้แค่ 1 ครั้ง)
  maxDownloads Int?
  currentDownloads Int   @default(0)

  createdBy   Int
  createdAt   DateTime   @default(now())

  @@index([token])
  @@index([companyId, fileId])
  @@map("doc_file_share_links")
}



/// 🖋️ ตารางคำขอเซ็นเอกสาร (Signature Request) ใช้สำหรับจัดการว่าไฟล์นี้ใครต้องเป็นคนเซ็นบ้าง และสถานะเป็นอย่างไร
model DocSignatureRequest {
  id        Int      @id @default(autoincrement())
  
  /// 🏢 รองรับ Multi-company
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  fileId    Int
  file      DocFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  /// 🌟 [เพิ่มใหม่] 1. ผูกกับ Workflow Request เพื่อให้รู้ว่าคำขอเซ็นนี้มาจากโฟลว์ไหน
  wfRequestId Int?
  wfRequest   WfRequest? @relation(fields: [wfRequestId], references: [id], onDelete: Cascade)

  /// 🌟 [เพิ่มใหม่] 2. ลำดับขั้นตอนการเซ็น (เช่น 1 = หัวหน้าเซ็น, 2 = ผอ.เซ็น)
  stepOrder   Int      @default(1)

  /// 👤 ผู้ที่ต้องเซ็น (รองรับทั้งคนในระบบ และคนนอกผ่าน Email)
  signerId    Int?     // ถ้าเป็นพนักงานในระบบ
  signer      SecUser? @relation("SignerUser", fields: [signerId], references: [id])
  
  /// ชื่อที่แสดงตอนเซ็น
  signerName  String  
  /// อีเมลผู้รับคำขอ (ใช้ส่งแจ้งเตือน หรือระบุตัวตนคนนอก) 
  signerEmail String   
  
  /// 🚩 สถานะของคำขอ (เช่น PENDING, SIGNED, REJECTED, CANCELED)
  status      String   @default("PENDING")
  
  /// 📍 ตำแหน่งที่ระบุให้เซ็นบน PDF (Frontend จะใช้ค่านี้ไปวางหน้าจอ)
  pageNumber  Int?     @default(1)
  posX        Float?   // ตำแหน่งแนวนอน (เปอร์เซ็นต์ หรือพิกัด)
  posY        Float?   // ตำแหน่งแนวตั้ง
  
  /// 🕒 ข้อมูลเวลา
  expiredAt   DateTime? // วันหมดอายุของคำขอเซ็น
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  /// เชื่อมไปยังผลลัพธ์การเซ็น
  signature   DocSignature?

  @@index([companyId, fileId])
  @@index([signerEmail])
  @@map("doc_signature_requests")
}

/// 📑 ตารางเก็บข้อมูลลายเซ็นที่เกิดขึ้นจริง
model DocSignature {
  id        Int      @id @default(autoincrement())
  
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  requestId Int      @unique
  request   DocSignatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  
  /// 🖼️ ข้อมูลลายเซ็น เก็บเป็น URL รูปภาพ (PNG/SVG) หรือ Base64 ของลายเซ็นที่วาด
  signatureImage String? @db.Text
  
  /// 🔐 ข้อมูลเพื่อความปลอดภัยทางกฎหมาย (e-Signature Compliance)
  signedAt       DateTime @default(now())
  ipAddress      String?  // ไอพีของผู้เซ็น
  userAgent      String?  // เบราว์เซอร์/อุปกรณ์ที่ใช้เซ็น
  
   
  /// 🛡️ ระบบป้องกันการแก้ไขไฟล์ (Data Integrity) เก็บ Hash ของไฟล์ ณ จังหวะที่เซ็น ถ้าไฟล์ถูกแก้หลังจากนี้ Hash จะไม่ตรง
  fileHashAtSigning String?

  /// 🔒 ลายเซ็นแบบดิจิทัล (ถ้ามีระบบ PKI/Certificate ในอนาคต)
  digitalCertificateId String?

  @@index([companyId])
  @@map("doc_signatures")
}

///ตารางบันทึกการเข้าสู่ระบบ (SecLoginLog) ใครแอบเข้าใช้งานบัญชีนี้จากที่ไหน" และ "มีการพยายามสุ่มรหัสผ่าน (Brute Force) หรือไม่
model SecLoginLog {
  id          Int      @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  userId      Int
  user        SecUser    @relation(fields: [userId], references: [id], onDelete: Cascade)

  loginAt     DateTime   @default(now())
  /// เก็บ IP ของผู้ใช้งาน
  ipAddress   String?    
  /// เก็บเบราว์เซอร์และอุปกรณ์ที่ใช้ (Chrome, Mac, iPhone)
  userAgent   String?    
  /// "SUCCESS" หรือ "FAILED"
  status      String   
  /// เช่น "Invalid Password" หรือ "Account Locked"  
  failureReason String?  

  @@index([companyId, userId])
  @@index([ipAddress])
  @@map("sec_login_logs")
}





/// 🤝 ตารางเก็บความสัมพันธ์การแนะนำเพื่อน/ตัวแทน (Referral)
model CrmReferral {
  id          Int      @id @default(autoincrement())
  
  /// 🏢 รองรับ Multi-company (ล็อกว่าชวนกันในบริษัท/แบรนด์ไหน)
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🗣️ คนชวน (Referrer / Affiliate)
  referrerId  Int
  referrer    CrmMember @relation("Referrer", fields: [referrerId], references: [id])

  /// 👤 คนถูกชวน (Referee / Invitee)
  refereeId   Int       @unique // 1 คนถูกชวนได้แค่ครั้งเดียว (1 Upline)
  referee     CrmMember @relation("Referee", fields: [refereeId], references: [id])

  /// 🚩 สถานะ: เช่น PENDING (แค่สมัครแต่ยังไม่ซื้อ), SUCCESS (ซื้อของแล้ว คนชวนได้ค่าคอม)
  status      String    @default("PENDING") 
  
  /// 💰 ยอดรวมค่าคอมมิชชันหรือแต้มที่คนชวนได้จากคนนี้
  rewardEarned Decimal  @default(0) @db.Decimal(18, 2) 

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId, referrerId])
  @@map("crm_referrals")
}

/// 💰 ตารางบันทึกรายได้จากค่าคอมมิชชัน (Commission Ledger)
model CrmCommissionLog {
  id          Int      @id @default(autoincrement())
  
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 👤 ตัวแทนที่ได้รับค่าคอม
  memberId    Int
  member      CrmMember @relation("CommissionMember", fields: [memberId], references: [id])

  /// 💸 จำนวนเงินที่เข้า/ออก
  amount      Decimal  @db.Decimal(18, 2) 
  balanceAfter Decimal @db.Decimal(18, 2) // ยอดเงินคงเหลือ ณ ตอนนั้น
  
  /// 🏷️ ประเภทรายการ: "EARN" (ได้ค่าคอม), "WITHDRAW" (ถอนเงิน), "REFUND" (โดนดึงคืนเพราะลูกค้าคืนของ)
  type        String   
  
  /// 🚩 สถานะ: "PENDING" (รอตรวจสอบการจ่าย), "APPROVED" (จ่ายเงินแล้ว)
  status      String   @default("APPROVED") 
  
  /// 🧾 อ้างอิงว่าได้ค่าคอมจาก Order ไหน
  refOrderId  Int?     
  note        String?

  createdAt   DateTime @default(now())

  @@index([companyId, memberId])
  @@index([refOrderId])
  @@map("crm_commission_logs")
}

// ==========================================
// MODULE: HR DISCIPLINARY (ระบบวินัยและบทลงโทษ)
// ==========================================

enum OffenseSeverity {
  MINOR    // ความผิดเล็กน้อย (เช่น มาสาย, แต่งกายผิดระเบียบ)
  MAJOR    // ความผิดร้ายแรง (เช่น ทะเลาะวิวาท, ขัดคำสั่ง)
  SEVERE   // ความผิดร้ายแรงมาก (เช่น ทุจริต, คุกคามทางเพศ, เลิกจ้างทันที)
}

enum DisciplinaryStatus {
  DRAFT            // ร่าง/กำลังรวบรวมหลักฐาน
  INVESTIGATING    // กำลังสอบสวน/รอคณะกรรมการ
  PENDING_APPROVAL // รออนุมัติบทลงโทษ (เข้า Workflow)
  EFFECTIVE        // มีผลบังคับใช้แล้ว (ปิดเคส)
  APPEALED         // อยู่ระหว่างอุทธรณ์
  CANCELLED        // ยกเลิก/พิจารณาแล้วไม่มีความผิด
}

/// 📋 1. Master Data: หมวดหมู่ความผิด (แยกตามบริษัท)
model HrOffenseType {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code        String     // เช่น "LATE", "THEFT"
  name        String     // เช่น "การขาด/ลา/มาสาย", "การทุจริต"
  severity    OffenseSeverity @default(MINOR)
  description String?    @db.Text

  incidents   HrDisciplinaryIncident[]

  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([companyId, code])
  @@map("hr_offense_types")
}

/// 📋 2. Master Data: ประเภทบทลงโทษ (แยกตามบริษัท)
model HrPenaltyType {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// เช่น "WARNING_1", "SUSPENSION", "FIRE"
  code        String  
  /// เช่น "ตักเตือนด้วยวาจา", "ตักเตือนเป็นลายลักษณ์อักษร", "พักงาน", "เลิกจ้าง"
  name        String     
  
  /// 🚩 Flags สำหรับนำไปผูกกับระบบอื่น (เช่น Payroll หรือ Time Attendance) ถ้าเป็น true หมายถึงห้ามมาทำงาน/งดจ่ายเงิน
  isSuspension  Boolean  @default(false) 
  /// ถ้าเป็น true หมายถึงให้พ้นสภาพพนักงาน
  isTermination Boolean  @default(false) 
  
  description String?    @db.Text

  actions     HrDisciplinaryAction[]

  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([companyId, code])
  @@map("hr_penalty_types")
}

/// 🚨 3. Transaction: บันทึกเหตุการณ์กระทำความผิด (Incident / Ticket)
model HrDisciplinaryIncident {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// เลขที่ใบแจ้งความผิด เช่น DIS-2026-0001
  docNo       String     

  /// 👤 ผู้กระทำผิด
  employeeId  Int
  employee    HrEmployee @relation("Offender", fields: [employeeId], references: [id], onDelete: Cascade)

  /// 🕵️ ผู้แจ้งเบาะแส / ผู้ตั้งเรื่อง (เช่น HR หรือ หัวหน้างาน)
  reporterId  Int
  reporter    SecUser    @relation("IncidentReporter", fields: [reporterId], references: [id])

  offenseTypeId Int
  offenseType   HrOffenseType @relation(fields: [offenseTypeId], references: [id])
  /// วันที่และเวลาเกิดเหตุ
  incidentDate DateTime 
  /// สถานที่เกิดเหตุ 
  location     String? 
  /// พฤติการณ์การกระทำความผิด (บรรยาย) 
  description  String    @db.Text 
  /// รูปภาพ/หลักฐานไฟล์แนบ (เก็บลิงก์ GCS เป็น Array)
  evidenceUrls String[]  

  status       DisciplinaryStatus @default(DRAFT)

  /// 🔗 เชื่อมเข้ากับ WfRequest (ระบบ Workflow) เพื่อส่งเรื่องให้ ผอ./คณะกรรมการ อนุมัติบทลงโทษ
  wfRequestId  Int?      @unique
  wfRequest    WfRequest? @relation(fields: [wfRequestId], references: [id])

  actions      HrDisciplinaryAction[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([companyId, docNo])
  @@index([companyId, employeeId]) // เพื่อให้ค้นหาประวัติการทำผิดของพนักงานได้ไว
  @@map("hr_disciplinary_incidents")
}

/// ⚖️ 4. Transaction: บทลงโทษที่ได้รับจากเหตุการณ์นั้น
model HrDisciplinaryAction {
  id            Int        @id @default(autoincrement())
  companyId     Int
  company       OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  incidentId    Int
  incident      HrDisciplinaryIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  penaltyTypeId Int
  penaltyType   HrPenaltyType @relation(fields: [penaltyTypeId], references: [id])

  /// 🗓️ ระยะเวลาบังคับใช้ (เช่น พักงานตั้งแต่วันที่ 1-3 หรือ คุมประพฤติ 6 เดือน)
  startDate     DateTime?  @db.Date
  endDate       DateTime?  @db.Date

  /// ข้อมูลประกอบการพิจารณาโทษ หรือ บทสรุปจากคณะกรรมการ
  remark        String?    @db.Text

  appealedGrievances  HrGrievanceTicket[] // เผื่อโดนอุทธรณ์หลายรอบ

  /// ผู้มีอำนาจสั่งลงโทษ (มักจะมาจากคนที่กด Approve ขั้นสุดท้ายใน Workflow)
  approvedById  Int?
  approvedBy    SecUser?   @relation("PenaltyApprover", fields: [approvedById], references: [id])

  /// ✅ [NEW] บรรทัดที่ต้องเพิ่ม: เชื่อมโยงไปหาเอกสารประกอบการลงโทษ (1 Action มีได้หลาย Document)
  documents       HrDisciplinaryDocument[]

  createdAt     DateTime   @default(now())

  @@index([companyId, incidentId])
  @@map("hr_disciplinary_actions")
}

// ==========================================
// MODULE: HR TRAINING (ระบบฝึกอบรมบุคลากร)
// ==========================================

enum TrainingSessionStatus {
  PLANNING      // กำลังวางแผน / รออนุมัติจัด
  PUBLISHED     // ประกาศแล้ว (เปิดรับสมัคร)
  IN_PROGRESS   // กำลังดำเนินการอบรม
  COMPLETED     // อบรมเสร็จสิ้น (รอประเมิน/สรุปผล)
  CANCELLED     // ยกเลิก
}

enum EnrollmentStatus {
  PENDING       // 🌟 รออนุมัติเข้าอบรม (เพิ่มใหม่สำหรับ Workflow)
  REGISTERED    // ลงทะเบียนแล้ว (อนุมัติแล้ว)
  ATTENDED      // เข้าร่วมอบรม (เช็คชื่อผ่าน)
  NO_SHOW       // ขาดการอบรม
  REJECTED      // 🌟 หัวหน้าไม่อนุมัติ (เพิ่มใหม่สำหรับ Workflow)
  CANCELLED     // ยกเลิกการลงทะเบียน
}

/// 📚 1. Master Data: ทะเบียนหลักสูตร (แยกตามบริษัท)
model HrTrainingCourse {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
   
  /// รหัสหลักสูตร เช่น "TR-LEAD-01" 
  code        String     
  /// ชื่อหลักสูตร เช่น "หลักสูตรผู้นำยุคใหม่"
  name        String     
  description String?    @db.Text
  
  /// จัดหมวดหมู่ (อาจจะผูกกับตาราง Category อีกทีก็ได้) เช่น "Soft Skills", "Technical", "Mandatory"
  category    String?    
  
  /// จำนวนชั่วโมง/เครดิตที่ได้เมื่อเรียนจบ
  creditHours Decimal?   @db.Decimal(5, 2)

  sessions    HrTrainingSession[]

  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([companyId, code])
  @@map("hr_training_courses")
}

/// 🗓️ 2. Transaction: รอบการจัดอบรม (ผูกกับ Calendar Year)
model HrTrainingSession {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  courseId    Int
  course      HrTrainingCourse @relation(fields: [courseId], references: [id])

  /// 🎯 ผูกกับ Calendar Year ของคุณ (สมมติเก็บเป็น Int เช่น 2026 หรือ ID ของตาราง Calendar)
  calendarYear Int       
  /// ชื่อรุ่น เช่น "รุ่นที่ 1/2569"
  batchName   String  
  /// สถานที่จัด (ห้องประชุม, โรงแรม, หรือ Online Link)
  location    String?  
  /// ชื่อวิทยากร (หรือผูกกับตารางผู้เชี่ยวชาญถ้ามี)
  instructor  String?    
  startDate   DateTime
  endDate     DateTime
  /// จำนวนที่เปิดรับ (ถ้ามีจำกัด)
  capacity    Int?       
  /// งบประมาณที่ใช้จัด
  budget      Decimal?   @db.Decimal(18, 2) 
  status      TrainingSessionStatus @default(PLANNING)

  /// 🔗 เชื่อมกับระบบ Workflow (เช่น ขออนุมัติงบประมาณจัดอบรม)
  wfRequestId Int?       @unique
  wfRequest   WfRequest? @relation(fields: [wfRequestId], references: [id])

  enrollments HrTrainingEnrollment[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([companyId, calendarYear]) // เพื่อให้ดึงข้อมูลตามปีได้รวดเร็ว
  @@map("hr_training_sessions")
}

/// 🎓 3. Transaction: ผู้ลงทะเบียนและผลการอบรม (พนักงาน 1 คน ต่อ 1 รอบ)
model HrTrainingEnrollment {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  sessionId   Int
  session     HrTrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  employeeId  Int
  employee    HrEmployee @relation("Trainee", fields: [employeeId], references: [id], onDelete: Cascade)

  status      EnrollmentStatus @default(REGISTERED)

  /// 📊 ผลการประเมิน
  preTestScore  Decimal? @db.Decimal(5, 2)
  postTestScore Decimal? @db.Decimal(5, 2)
  isPassed      Boolean? // ผ่านหลักสูตรหรือไม่

  /// 📜 ไฟล์ใบประกาศนียบัตร (ถ้ามี)
  certificateUrl String?

  remark      String?    @db.Text

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([companyId, sessionId, employeeId]) // พนักงาน 1 คนลงทะเบียนรอบเดียวกันซ้ำไม่ได้
  @@index([companyId, employeeId]) // สำหรับดูประวัติการอบรมรายบุคคล
  @@map("hr_training_enrollments")
}

// ==========================================
// MODULE: HR ROYAL DECORATION (ระบบเครื่องราชอิสริยาภรณ์)
// ==========================================

enum DecorationReturnStatus {
  NOT_REQUIRED     // ไม่ต้องส่งคืน
  PENDING_RETURN   // ต้องส่งคืน (แต่ยังไม่ส่ง)
  RETURNED         // ส่งคืนเรียบร้อยแล้ว
  LOST             // สูญหาย (ต้องชดใช้ราคา)
}

/// 🎖️ 1. Master Data: แคตตาล็อกตระกูลและชั้นตราเครื่องราชอิสริยาภรณ์ (แยกตามบริษัท/หน่วยงาน)
model HrRoyalDecoration {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// ตัวย่อ เช่น "บ.ม.", "ต.ช.", "ท.ม.", "ป.ช."
  code        String     
  /// ชื่อเต็ม เช่น "เบญจมาภรณ์มงกุฎไทย", "ตริตาภรณ์ช้างเผือก"
  name        String     
  /// ระดับชั้นตรา (ใช้สำหรับการ Sorting และคำนวณว่าต้องคืนตราชั้นต่ำกว่าหรือไม่) เช่น 1 = ชั้นประถมาภรณ์, 5 = ชั้นเบญจมาภรณ์, 8 = เหรียญจักรพรรดิมาลา
  classLevel  Int        
                           
  description String?    @db.Text

  /// ตั้งค่าว่าเครื่องราชชั้นนี้ เมื่อได้ชั้นสูงกว่า ต้องคืนหรือไม่
  isReturnRequired Boolean @default(true)

  records     HrEmployeeDecoration[]

  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([companyId, code])
  @@map("hr_royal_decorations")
}

/// 📜 2. Transaction: ทะเบียนประวัติการได้รับเครื่องราชฯ (ปรับปรุง)
model HrEmployeeDecoration {
  id              Int        @id @default(autoincrement())
  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId      Int
  employee        HrEmployee @relation("Decorations", fields: [employeeId], references: [id], onDelete: Cascade)

  decorationId    Int
  decoration      HrRoyalDecoration @relation(fields: [decorationId], references: [id])

  gazetteDate     DateTime?  @db.Date 
  gazetteVolume   String?   
  gazettePart     String?  
  gazettePage     String?    
  receivedDate    DateTime?  @db.Date 
  
  returnStatus    DecorationReturnStatus @default(NOT_REQUIRED)
  returnedDate    DateTime?  @db.Date 
  
 
  /// 1 ประวัติ อาจแนบทั้งใบกำกับ, หน้าประกาศราชกิจจาฯ, และรูปถ่ายวันรับมอบ
  documents       HrEmployeeDecorationDocument[]

  remark          String?    @db.Text

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([companyId, employeeId, decorationId]) 
  @@index([companyId, employeeId]) 
  @@map("hr_employee_decorations")
}

/// ✅ [NEW] ตารางกลางสำหรับเชื่อมเอกสารหลักฐานเครื่องราชฯ กับ DMS
model HrEmployeeDecorationDocument {
  id                Int      @id @default(autoincrement())
  companyId         Int
  company           OrgCompany @relation(fields: [companyId], references: [id])

  decorationRecordId Int
  decorationRecord   HrEmployeeDecoration @relation(fields: [decorationRecordId], references: [id], onDelete: Cascade)

  /// 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId           Int      @unique
  media             SysMedia @relation(fields: [mediaId], references: [id])
  
  /// ประเภทเอกสาร: 'GAZETTE' (ราชกิจจา), 'CERTIFICATE' (ใบกำกับ), 'RETURN_RECEIPT' (ใบรับส่งคืน)
  docType           String?   
  createdAt         DateTime @default(now())

  @@index([companyId, decorationRecordId])
  @@map("hr_employee_decoration_documents")
}

// ==========================================
// MODULE: ADMIN MEETING ROOM (ระบบจองห้องประชุม)
// ==========================================

enum BookingStatus {
  DRAFT            // ร่างข้อมูล
  PENDING_APPROVE  // อยู่ระหว่างขออนุมัติ (วิ่ง Workflow)
  APPROVED         // อนุมัติแล้ว (ห้องถูกจอง)
  REJECTED         // ไม่ได้รับการอนุมัติ
  CANCELLED        // ยกเลิกโดยผู้จอง
  COMPLETED        // การประชุมเสร็จสิ้นแล้ว
}


/// 🏢 1. Master Data: ข้อมูลห้องประชุม (ปรับปรุง)
model AdmMeetingRoom {
  id           Int      @id @default(autoincrement())
  companyId    Int
  company      OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  name         String   
  location     String?  
  capacity     Int      
  

  /// รองรับ 1 ห้องมีหลายรูปภาพ (เช่น รูปมุมกว้าง, รูปอุปกรณ์, รูปผังที่นั่ง)
  images       AdmMeetingRoomMedia[]

  basePrice    Decimal?   @db.Decimal(18, 2)
  amenities    String[]   
  colorCode    String?    @default("#3b82f6") 
  
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  bookings     AdmMeetingBooking[]

  @@index([companyId])
  @@map("adm_meeting_rooms")
}

/// 📅 2. Transaction: ข้อมูลการจอง
model AdmMeetingBooking {
  id              Int        @id @default(autoincrement())
  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  roomId          Int
  room            AdmMeetingRoom @relation(fields: [roomId], references: [id])

  /// 👤 ผู้จอง (Employee)
  requesterId     Int
  requester       HrEmployee @relation("MeetingRequester", fields: [requesterId], references: [id])

  subject         String     // หัวข้อการประชุม
  description     String?    @db.Text
  
  /// 🕒 วันเวลา
  startDateTime   DateTime
  endDateTime     DateTime

  /// 👥 จำนวนผู้เข้าร่วมจริง (เพื่อจัดเตรียมอาหาร/ที่นั่ง)
  participantCount Int       @default(0)

  /// 📝 รายละเอียดเพิ่มเติมสำหรับภาครัฐ
  isExternalGuest Boolean    @default(false) // มีบุคคลภายนอกเข้าร่วมหรือไม่
  cateringDetails String?    @db.Text        // รายละเอียดอาหารว่าง/อาหารกลางวัน
  
  status          BookingStatus @default(DRAFT)

  /// 🔗 เชื่อมเข้ากับ WfRequest (ระบบ Workflow)
  wfRequestId     Int?       @unique
  wfRequest       WfRequest? @relation(fields: [wfRequestId], references: [id])

  attendees       AdmMeetingAttendee[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([companyId, roomId, startDateTime, endDateTime])
  @@map("adm_meeting_bookings")
}

/// 👥 3. รายชื่อผู้เข้าร่วมประชุม
model AdmMeetingAttendee {
  id          Int        @id @default(autoincrement())
  bookingId   Int
  booking     AdmMeetingBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  /// กรณีเป็นคนในระบบ
  employeeId  Int?
  employee    HrEmployee? @relation(fields: [employeeId], references: [id])

  /// กรณีเป็นบุคคลภายนอก (ราชการมักต้องเก็บชื่อ-นามสกุล)
  externalName  String?
  externalEmail String?

  @@map("adm_meeting_attendees")
}

/// ✅ [NEW] ตารางกลางสำหรับเชื่อมรูปภาพห้องประชุมกับ DMS
model AdmMeetingRoomMedia {
  id           Int      @id @default(autoincrement())
  companyId    Int
  company      OrgCompany @relation(fields: [companyId], references: [id])

  roomId       Int
  room         AdmMeetingRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  /// 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId      Int      @unique
  media        SysMedia @relation(fields: [mediaId], references: [id])

  sortOrder    Int      @default(0) // สำหรับจัดลำดับรูปภาพที่จะแสดงเป็นรูปหลัก
  createdAt    DateTime @default(now())

  @@index([companyId, roomId])
  @@map("adm_meeting_room_media")
}

// ==========================================
// MODULE: HR WELFARE (ระบบสวัสดิการพนักงาน)
// ==========================================

enum WelfareCategory {
  MEDICAL       // ค่ารักษาพยาบาล (รวมตนเอง/ครอบครัว)
  EDUCATION     // ค่าเล่าเรียน (ตนเอง/บุตร)
  HOUSING       // ค่าเช่าบ้าน/ที่พัก
  ALLOWANCE     // เงินช่วยเหลือ (เช่น แต่งงาน, คลอดบุตร, งานศพ)
  LIFESTYLE     // ไลฟ์สไตล์ (เช่น ฟิตเนส, ท่องเที่ยว - มักใช้ในเอกชน)
  OTHER
}

enum WelfareRequestStatus {
  DRAFT            // ร่างข้อมูล
  PENDING_APPROVE  // รออนุมัติ (วิ่ง Workflow)
  APPROVED         // อนุมัติแล้ว (รอจ่ายเงิน)
  PAID             // จ่ายเงินเรียบร้อยแล้ว
  REJECTED         // ไม่อนุมัติ
  CANCELLED        // ยกเลิก
}

/// 🎁 1. Master Data: ประเภทสวัสดิการ (แยกตามบริษัท)
model HrWelfareType {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code        String     // เช่น "MED-01", "EDU-CHILD"
  name        String     // เช่น "ค่ารักษาพยาบาลบิดามารดา", "งบไลฟ์สไตล์ประจำปี"
  category    WelfareCategory @default(OTHER)
  description String?    @db.Text

  /// 🚩 Flag สำหรับภาครัฐโดยเฉพาะ เบิกให้บุคคลในครอบครัวได้หรือไม่
  isFamilyEligible Boolean @default(false)

  policies    HrWelfarePolicy[]

  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([companyId, code])
  @@map("hr_welfare_types")
}

/// 📅 2. Config Data: นโยบายและวงเงินสวัสดิการ (ผูกตามปีปฏิทิน)
model HrWelfarePolicy {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  welfareTypeId Int
  welfareType   HrWelfareType @relation(fields: [welfareTypeId], references: [id])

  calendarYear  Int      // ปีปฏิทิน หรือ ปีงบประมาณ เช่น 2026 (พ.ศ. 2569)

  /// 💰 การตั้งค่างบประมาณ วงเงินสูงสุดต่อปี (ต่อคน)
  maxAmountPerYear Decimal? @db.Decimal(18, 2) 
  /// วงเงินสูงสุดต่อครั้งการเบิก
  maxAmountPerTime Decimal? @db.Decimal(18, 2) 
  /// จำนวนครั้งที่เบิกได้สูงสุดต่อปี
  maxTimesPerYear  Int?     

  /// 👥 สิทธิ์การเบิก (Level 1-10 ของ KKV) - ถ้าว่างแปลว่าได้ทุกคน
  eligibleLevels   Int[]    // เช่น [1, 2, 3, 4] (ให้เฉพาะผู้บริหาร) 

  requests    HrWelfareRequest[]

  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([companyId, welfareTypeId, calendarYear]) // 1 ประเภท มีได้ 1 นโยบายต่อปี
  @@map("hr_welfare_policies")
}

/// 📝 3. Transaction: การทำเรื่องเบิกสวัสดิการ (ปรับปรุง)
model HrWelfareRequest {
  id              Int        @id @default(autoincrement())
  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  policyId        Int
  policy          HrWelfarePolicy @relation(fields: [policyId], references: [id])

  employeeId      Int
  employee        HrEmployee @relation("WelfareRequester", fields: [employeeId], references: [id])

  dependentName   String?  
  dependentRel    String?   

  receiptNo       String?   
  receiptDate     DateTime?  @db.Date 
  amountRequested Decimal    @db.Decimal(18, 2) 
  amountApproved  Decimal?   @db.Decimal(18, 2) 
  
  remark          String?    @db.Text


  /// 1 การเบิก อาจแนบไฟล์ได้หลายอย่าง เช่น ใบเสร็จ + ใบรับรองแพทย์
  documents       HrWelfareRequestDocument[]

  status          WelfareRequestStatus @default(DRAFT)

  wfRequestId     Int?       @unique
  wfRequest       WfRequest? @relation(fields: [wfRequestId], references: [id])

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([companyId, employeeId, policyId])
  @@map("hr_welfare_requests")
}

/// ✅ [NEW] ตารางกลางสำหรับเชื่อมเอกสารการเบิกสวัสดิการกับ DMS
model HrWelfareRequestDocument {
  id                Int      @id @default(autoincrement())
  companyId         Int
  company           OrgCompany @relation(fields: [companyId], references: [id])

  requestId         Int
  request           HrWelfareRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  /// 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId           Int      @unique
  media             SysMedia @relation(fields: [mediaId], references: [id])
  
  /// ประเภทเอกสาร เช่น 'RECEIPT', 'MEDICAL_CERT', 'OTHER'
  docType           String?   
  createdAt         DateTime @default(now())

  @@index([companyId, requestId])
  @@map("hr_welfare_request_documents")
}

// ==========================================
// MODULE: HR SALARY & PAYROLL (ระบบเงินเดือนและเลื่อนขั้น)
// ==========================================

enum AdjustmentReason {
  ANNUAL_MERIT    // เลื่อนขั้นประจำปี (เช่น รอบ เม.ย. / ต.ค.)
  PROMOTION       // เลื่อนตำแหน่ง
  PROBATION       // ผ่านทดลองงาน
  COST_OF_LIVING  // ปรับฐานค่าครองชีพ
  SPECIAL         // ความดีความชอบกรณีพิเศษ
}

enum CalculationMethod {
  BASE_PERCENTAGE     // คิด % จาก "ฐานคำนวณกลาง" (รูปแบบราชการยุคใหม่)
  CURRENT_PERCENTAGE  // คิด % จาก "เงินเดือนปัจจุบัน" (รูปแบบเอกชน)
  FIXED_AMOUNT        // ระบุจำนวนเงินที่เพิ่มขึ้นตรงๆ (เช่น เพิ่ม 1,500 บาท)
  NEW_BASE_SALARY     // ระบุฐานเงินเดือนใหม่ไปเลย
}

enum PayrollCycleStatus {
  DRAFT       // กำลังคำนวณ/ตรวจสอบ
  REVIEWING   // ส่งให้ผู้บริหารตรวจ (วิ่ง Workflow)
  APPROVED    // อนุมัติแล้ว (เตรียมส่งไฟล์เข้าธนาคาร)
  PAID        // จ่ายเงินเรียบร้อย
}


/// สำหรับเอกชน: ใช้กำหนด Min-Max เพื่อควบคุมไม่ให้เงินเดือนล้นกระบอก  สำหรับราชการ: ใช้กำหนด "ฐานคำนวณ" (Median) ของแต่ละระดับ (Level 1-10)
model HrSalaryStructure {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// ผูกกับ Level 1-10 ในระบบ KKV
  level       Int        
  
  name        String     // เช่น "แท่งวิชาการ ระดับชำนาญการ", "Band C (Manager)"
  
  /// 💰 โครงสร้างตัวเงิน เงินเดือนขั้นต่ำ
  minSalary   Decimal    @db.Decimal(18, 2) 
  /// เงินเดือนขั้นสูง (เพดาน)
  maxSalary   Decimal    @db.Decimal(18, 2) 
  /// 🚩 "ฐานคำนวณกลาง" สำหรับใช้คูณ % (สำคัญมากสำหรับราชการ)
  baseSalary  Decimal?   @db.Decimal(18, 2) 
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([companyId, level])
  @@map("hr_salary_structures")
}

/// 📈 2. Transaction: ประวัติการพิจารณาเลื่อนขั้นเงินเดือน (Salary Adjustment History)
model HrSalaryAdjustment {
  id              Int        @id @default(autoincrement())
  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId      Int
  employee        HrEmployee @relation("SalaryHistory", fields: [employeeId], references: [id], onDelete: Cascade)

  /// 📝 ข้อมูลการปรับ
  reason          AdjustmentReason
  /// วันที่มีผล (เช่น 1 เม.ย. หรือ 1 ต.ค.)
  effectiveDate   DateTime   @db.Date 
  
  /// 🧮 วิธีการคำนวณ และ ตัวเลข
  calcMethod      CalculationMethod
  calcValue       Decimal    @db.Decimal(18, 4) // เช่น ถ้าเลือก CURRENT_PERCENTAGE และใส่ 5.0000 คือปรับขึ้น 5%

  
  /// ✅ [NEW] เชื่อมกับตาราง DMS เพื่อเก็บ "คำสั่งเลื่อนขั้นเงินเดือน" เช่น สแกนไฟล์คำสั่งรายบุคคล หรือ บันทึกข้อความอนุมัติ
  documents        HrSalaryAdjustmentDocument[]
  
  /// 💵 สรุปยอดเงิน (ระบบคำนวณแล้วบันทึกค่าตายตัวไว้เป็น History)
  oldSalary       Decimal    @db.Decimal(18, 2) // เงินเดือนเดิม
  adjustmentAmount Decimal   @db.Decimal(18, 2) // จำนวนเงินที่ได้เพิ่ม
  newSalary       Decimal    @db.Decimal(18, 2) // เงินเดือนใหม่ที่อนุมัติ

  /// 🔗 เชื่อมกับผลประเมิน (KPI) ถ้ามี
  performanceScore Decimal?  @db.Decimal(5, 2)  // คะแนนประเมินรอบนั้นๆ

  /// 🔗 วิ่ง Workflow ขออนุมัติบัญชีรายชื่อเลื่อนเงินเดือน
  wfRequestId     Int?       @unique
  wfRequest       WfRequest? @relation(fields: [wfRequestId], references: [id])

  remark          String?    @db.Text
  createdAt       DateTime   @default(now())

  @@index([companyId, employeeId])
  @@map("hr_salary_adjustments")
}

/// ✅ [NEW] ตารางกลางสำหรับหลักฐานการปรับเงินเดือน
model HrSalaryAdjustmentDocument {
  id                Int      @id @default(autoincrement())
  companyId         Int
  company           OrgCompany @relation(fields: [companyId], references: [id])

  adjustmentId      Int
  adjustment        HrSalaryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)

  mediaId           Int      @unique
  media             SysMedia @relation(fields: [mediaId], references: [id])

  createdAt         DateTime @default(now())

  @@index([companyId, adjustmentId])
  @@map("hr_salary_adjustment_documents")
}

/// 🗓️ 3. Integration: รอบการจ่ายเงินเดือน (Payroll Cycle)
model HrPayrollCycle {
  id              Int        @id @default(autoincrement())
  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// เช่น "2026-04" (เดือน 4 ปี 2026) หรือ "2026-04-P1" (ครึ่งเดือนแรก)
  cycleCode       String  
  /// วันเริ่มตัดรอบ  
  startDate       DateTime   @db.Date 
  /// วันสิ้นสุดตัดรอบ
  endDate         DateTime   @db.Date 
  /// วันที่เงินโอนเข้าบัญชี (เช่น ทุกวันที่ 25)
  paymentDate     DateTime   @db.Date 

  status          PayrollCycleStatus @default(DRAFT)
  
  totalEmployees  Int        @default(0)
  /// รายรับรวมทั้งบริษัท
  totalGrossPay   Decimal    @default(0) @db.Decimal(18, 2) 
  /// รายจ่าย/หักรวม
  totalDeductions Decimal    @default(0) @db.Decimal(18, 2) 
  /// ยอดจ่ายสุทธิ
  totalNetPay     Decimal    @default(0) @db.Decimal(18, 2) 
  /// 🔗 Workflow สำหรับส่งอนุมัติงบเดือนนั้นๆ ให้ CEO/อธิบดี
  wfRequestId     Int?       @unique
  wfRequest       WfRequest? @relation(fields: [wfRequestId], references: [id])

  slips           HrPayrollSlip[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([companyId, cycleCode])
  @@map("hr_payroll_cycles")
}

/// 🧾 4. Integration: สลิปเงินเดือนรายบุคคล (Payroll Slip)
model HrPayrollSlip {
  id              Int        @id @default(autoincrement())
  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  cycleId         Int
  cycle           HrPayrollCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  employeeId      Int
  employee        HrEmployee @relation("PayrollSlips", fields: [employeeId], references: [id], onDelete: Cascade)

  /// 💰 ยอดสรุปของพนักงานคนนี้ในรอบนี้
  baseSalary      Decimal    @db.Decimal(18, 2) // เงินเดือนฐาน
  /// รวมรายรับอื่นๆ (ค่าตำแหน่ง, โอที, สวัสดิการ)
  totalAllowances Decimal    @default(0) @db.Decimal(18, 2) 
  /// รวมรายการหัก (ภาษี, ประกันสังคม, กบข., ขาดงาน)
  totalDeductions Decimal    @default(0) @db.Decimal(18, 2) 
  netPay          Decimal    @db.Decimal(18, 2) // รับสุทธิ

 
  /// ตัวอย่าง: { "earnings": [{"name": "โอที", "amount": 1500}], "deductions": [{"name": "ประกันสังคม", "amount": 750}] }
  detailsJson     Json       

  /// เพื่อให้พนักงาน Download หรือส่งอีเมล
  pdfMediaId       Int?       @unique
  pdfMedia         SysMedia?  @relation(fields: [pdfMediaId], references: [id])
  /// พนักงานจะเห็นสลิปในแอปได้ก็ต่อเมื่อเป็น true
  isPublished     Boolean    @default(false) 

  createdAt       DateTime   @default(now())

  @@unique([companyId, cycleId, employeeId])
  @@map("hr_payroll_slips")
}

// ==========================================
// MODULE: ADMIN ASSET (ระบบบริหารจัดการพัสดุและครุภัณฑ์)
// ==========================================

enum AssetStatus {
  AVAILABLE     // ว่าง/อยู่ในคลังพัสดุ
  IN_USE        // ถูกเบิกไปใช้งานแล้ว
  IN_REPAIR     // อยู่ระหว่างซ่อมแซม
  LOST          // สูญหาย
  WRITTEN_OFF   // จำหน่ายออกแล้ว (พ้นสภาพ/ขายซาก/บริจาค)
}

enum AcquisitionMethod {
  PURCHASE      // จัดซื้อ
  DONATION      // ได้รับบริจาค
  TRANSFER      // โอนย้ายมาจากหน่วยงานอื่น
  OTHER
}

enum AssetRequestType {
  PROCUREMENT   // ขออนุมัติจัดซื้อ/จัดหา
  BORROW        // ขอเบิก/ขอยืมไปใช้งาน
  REPAIR        // ขอแจ้งซ่อม
  DISPOSAL      // ขออนุมัติจำหน่ายพัสดุ (Write-off)
}

enum AssetRequestStatus {
  DRAFT
  PENDING_APPROVE // รออนุมัติ (วิ่ง Workflow)
  APPROVED        // อนุมัติแล้ว
  REJECTED        // ไม่อนุมัติ
  COMPLETED       // ดำเนินการเสร็จสิ้น (เช่น ซื้อของเข้าคลังแล้ว, หรือขายซากเสร็จแล้ว)
}

/// 📦 1. Master Data: หมวดหมู่ครุภัณฑ์
model AdmAssetCategory {
  id               Int        @id @default(autoincrement())
  companyId        Int
  company          OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// เช่น "IT", "FURNITURE", "VEHICLE"
  code             String     
  /// เช่น "ครุภัณฑ์คอมพิวเตอร์", "ครุภัณฑ์สำนักงาน"
  name             String     
  /// ตัวอักษรนำหน้าเลขครุภัณฑ์ เช่น "คพ.", "สพ."
  prefixNumber     String?    
  /// อายุการใช้งาน/การเสื่อมราคา (ปี)
  depreciationYears Int       @default(5) 

  assets           AdmAsset[]

  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([companyId, code])
  @@map("adm_asset_categories")
}

/// 🖥️ 2. Core Data: ทะเบียนครุภัณฑ์ (รายตัว)
model AdmAsset {
  id               Int        @id @default(autoincrement())
  companyId        Int
  company          OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  categoryId       Int
  category         AdmAssetCategory @relation(fields: [categoryId], references: [id])

  /// 🏷️ ข้อมูลระบุตัวตน เลขครุภัณฑ์ (เช่น 7110-001-0001/2569) **สำคัญมากสำหรับราชการ**
  assetNumber      String     
  /// Serial Number จากผู้ผลิต (เช่น S/N ของ Notebook)
  serialNumber     String?    
  /// ชื่อรายการ เช่น "MacBook Pro 16-inch M3 Max"
  name             String  
  /// ยี่ห้อ/รุ่น   
  brandModel       String?    

  /// 📅 ข้อมูลการได้มาและงบประมาณ ปีงบประมาณ/ปีปฏิทิน ที่จัดซื้อ (Calendar Base)
  fiscalYear       Int        
  /// วันที่ตรวจรับพัสดุ
  acquisitionDate  DateTime   @db.Date 
  acquisitionMethod AcquisitionMethod @default(PURCHASE)
  /// ราคาที่ได้มา
  purchasePrice    Decimal    @db.Decimal(18, 2) 
  /// ชื่อร้านค้า/บริษัทที่ซื้อมา
  vendorName       String?    

  /// เก็บรูปถ่ายครุภัณฑ์ 4 ด้าน, Serial Number plate, คู่มือการใช้งาน (PDF)
  attachments      AdmAssetAttachment[]

  /// 📍 สถานะและการครอบครองปัจจุบัน
  status           AssetStatus @default(AVAILABLE)
  /// สถานที่ตั้งปัจจุบัน (เช่น ห้อง IT, โต๊ะทำงาน A1)
  currentLocation  String?    
  /// ผู้เบิก/ผู้ครอบครองปัจจุบัน (ถ้าเป็น Null คืออยู่ในคลัง)
  assignedToId     Int?      
  assignedTo       HrEmployee? @relation("AssetOwner", fields: [assignedToId], references: [id])

  requestItems     AdmAssetRequestItem[]

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([companyId, assetNumber]) // เลขครุภัณฑ์ห้ามซ้ำในบริษัท/หน่วยงานเดียวกัน
  @@index([companyId, fiscalYear])   // เพื่อให้ดึงรายงานทะเบียนทรัพย์สินประจำปีได้ไว
  @@map("adm_assets")
}

/// 📝 3. Transaction: เอกสารคำร้องเกี่ยวกับครุภัณฑ์ (ขอซื้อ, ขอเบิก, ขอซ่อม, ขอจำหน่าย)
model AdmAssetRequest {
  id               Int        @id @default(autoincrement())
  companyId        Int
  company          OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// เลขที่เอกสาร (เช่น PR-2026-001, WR-2026-015)
  docNo            String     
  requestType      AssetRequestType
  /// ผูกกับปีงบประมาณ/ปฏิทิน (Calendar Base)
  fiscalYear       Int        

  requesterId      Int
  requester        HrEmployee @relation("AssetRequester", fields: [requesterId], references: [id])
  /// หัวข้อคำร้อง
  subject          String   
  /// เหตุผลความจำเป็น  
  reason           String?    @db.Text 

  status           AssetRequestStatus @default(DRAFT)

  /// 🔗 เชื่อมเข้ากับ WfRequest (ระบบ Workflow)
  wfRequestId      Int?       @unique
  wfRequest        WfRequest? @relation(fields: [wfRequestId], references: [id])

  /// ✅ [NEW] ตารางเชื่อมเอกสารแนบในคำร้อง (เช่น ใบเสนอราคาซ่อม, รูปของพัง)
  documents        AdmAssetRequestDocument[]

  items            AdmAssetRequestItem[]

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([companyId, docNo])
  @@index([companyId, fiscalYear, requestType])
  @@map("adm_asset_requests")
}

/// 📎 4. Transaction Detail: รายการครุภัณฑ์ในเอกสารคำร้อง
model AdmAssetRequestItem {
  id               Int        @id @default(autoincrement())
  requestId        Int
  request          AdmAssetRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  
  /// กรณีเป็นคำร้องขอ "จัดซื้อ" (PROCUREMENT) จะยังไม่มี assetId ผูกมาด้วย ให้ใส่ชื่อ/ราคาประเมินไปก่อน กรณีเป็นคำร้อง "ขอเบิก/ขอซ่อม/ขอจำหน่าย" จะต้องระบุ assetId ตัวที่มีอยู่จริงในระบบ
  assetId          Int?       
  asset            AdmAsset?  @relation(fields: [assetId], references: [id])
  /// ชื่อรายการ (กรณีขอซื้อใหม่) หรือ ดึงมาจาก Asset (กรณีซ่อม/จำหน่าย)
  itemName         String     
  /// ราคาประเมิน (ตอนขอซื้อ) หรือ ราคาประเมินซ่อม
  estimatedPrice   Decimal?   @db.Decimal(18, 2) 
  /// จำนวน (มักจะใช้ตอนขอซื้อ ถ้าเบิก/ซ่อมจะเป็น 1 เสมอเพราะผูก ID)
  quantity         Int        @default(1) 
  
  remark           String?    @db.Text

  @@map("adm_asset_request_items")
}

/// ✅ [NEW] ตารางกลางสำหรับเชื่อม "ตัวครุภัณฑ์" กับ DMS
model AdmAssetAttachment {
  id           Int      @id @default(autoincrement())
  companyId    Int
  company      OrgCompany @relation(fields: [companyId], references: [id])

  assetId      Int
  asset        AdmAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  /// 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId      Int      @unique
  media        SysMedia @relation(fields: [mediaId], references: [id])

  /// ประเภทไฟล์: 'PHOTO' (รูปตัวเครื่อง), 'WARRANTY' (ใบรับประกัน), 'MANUAL' (คู่มือ)
  attachmentType String?  
  createdAt    DateTime @default(now())

  @@index([companyId, assetId])
  @@map("adm_asset_attachments")
}

/// ✅ [NEW] ตารางกลางสำหรับเชื่อม "ใบคำร้อง" กับ DMS
model AdmAssetRequestDocument {
  id           Int      @id @default(autoincrement())
  companyId    Int
  company      OrgCompany @relation(fields: [companyId], references: [id])

  requestId    Int
  request      AdmAssetRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  mediaId      Int      @unique
  media        SysMedia @relation(fields: [mediaId], references: [id])

  createdAt    DateTime @default(now())

  @@index([companyId, requestId])
  @@map("adm_asset_request_documents")
}

// ==========================================
// MODULE: HR GRIEVANCE (ระบบร้องเรียนขอความเป็นธรรมและอุทธรณ์)
// ==========================================

enum GrievanceStatus {
  DRAFT            // ร่างคำร้อง
  SUBMITTED        // ส่งเรื่องแล้ว (รอ HR/ส่วนกลางรับเรื่อง)
  INVESTIGATING    // กำลังตรวจสอบ/สอบสวน (วิ่ง Workflow คณะกรรมการ)
  RESOLVED         // ยุติเรื่อง/แก้ปัญหาแล้ว (มีข้อสรุป)
  REJECTED         // ปฏิเสธคำร้อง (เช่น ไม่มีมูลความจริง)
  WITHDRAWN        // ผู้ร้องขอถอนเรื่องไปเอง
}

enum GrievanceSeverity {
  LOW       // ทั่วไป (เช่น สภาพแวดล้อมการทำงาน, แอร์เย็นไป)
  MEDIUM    // ปานกลาง (เช่น ความขัดแย้งทั่วไปกับเพื่อนร่วมงาน)
  HIGH      // สูง (เช่น การเลือกปฏิบัติ, การกลั่นแกล้ง, อุทธรณ์โทษ)
  CRITICAL  // วิกฤต (เช่น คุกคามทางเพศ, ทุจริตคอร์รัปชัน, ละเมิดกฎหมายร้ายแรง)
}

/// ⚖️ 1. Master Data: ประเภทการร้องเรียน (แยกตามบริษัท)
model HrGrievanceType {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// เช่น "HARASSMENT", "APPEAL", "UNFAIR"
  code        String     
  /// เช่น "การคุกคาม/ข่มขู่", "อุทธรณ์บทลงโทษ", "การปฏิบัติไม่เป็นธรรม"
  name        String     
  description String?    @db.Text
  
  /// 🔒 ควบคุมการเข้าถึง: ถ้าเป็นเรื่องลับมาก (เช่น ทุจริตผู้บริหาร) จะเห็นได้เฉพาะคณะกรรมการเฉพาะกิจเท่านั้น
  isConfidential Boolean @default(true)

  tickets     HrGrievanceTicket[]

  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([companyId, code])
  @@map("hr_grievance_types")
}

/// 📝 2. Transaction: ใบคำร้องเรียนขอความเป็นธรรม / ใบอุทธรณ์
model HrGrievanceTicket {
  id              Int        @id @default(autoincrement())
  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  docNo           String     // เลขที่คำร้อง (เช่น GRV-2026-0001)

  typeId          Int
  type            HrGrievanceType @relation(fields: [typeId], references: [id])

  /// 👤 ผู้ร้องเรียน (เป็น Null ได้ ถ้าระบบอนุญาตให้ร้องเรียนแบบไม่เปิดเผยตัวตน - Whistleblower)
  requesterId     Int?
  requester       HrEmployee? @relation("GrievanceRequester", fields: [requesterId], references: [id])
  
  /// 🎭 ต้องการปกปิดชื่อหรือไม่ (ถ้า True หน้าบ้านระบบจะไม่โชว์ชื่อผู้ร้องให้คู่กรณีหรือหัวหน้าเห็น)
  isAnonymous     Boolean    @default(false) 

  /// 🎯 ผู้ถูกร้องเรียน (คู่กรณี) - (เป็น Null ได้ ถ้าร้องเรียนนโยบายบริษัท ไม่ได้เจาะจงตัวบุคคล)
  accusedId       Int?
  accused         HrEmployee? @relation("GrievanceAccused", fields: [accusedId], references: [id])

  /// 🔗 อ้างอิงกรณี "อุทธรณ์บทลงโทษ" (ดึง ID จากใบลงโทษเดิมมาเพื่อขอความเมตตาลดโทษ)
  refDisciplinaryActionId Int?
  refDisciplinaryAction   HrDisciplinaryAction? @relation(fields: [refDisciplinaryActionId], references: [id])
  /// หัวข้อเรื่องร้องเรียน
  subject         String    
  /// รายละเอียดเหตุการณ์
  description     String     @db.Text 
  severity        GrievanceSeverity @default(MEDIUM)
  /// วันที่เกิดเหตุ (ถ้าระบุได้)
  incidentDate    DateTime?  @db.Date 
  /// รองรับไฟล์หลากหลาย: รูปภาพแชท, คลิปเสียงเหตุการณ์, เอกสาร PDF อ้างอิง
  evidences       HrGrievanceEvidence[]  

  status          GrievanceStatus @default(DRAFT)

  /// ⚖️ ผลการสอบสวน / ข้อสรุปจากคณะกรรมการหรือ HR
  resolutionSummary String?  @db.Text
  resolvedAt        DateTime?


  /// *** โฟลว์นี้มักจะข้ามหัวหน้างานปกติ ไปหา HR Manager หรือ "คณะกรรมการพิจารณาเรื่องร้องทุกข์" ทันที
  wfRequestId     Int?       @unique
  wfRequest       WfRequest? @relation(fields: [wfRequestId], references: [id])

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([companyId, docNo])
  @@index([companyId, requesterId]) // ค้นหาเรื่องที่ตัวเองเคยร้องเรียน
  @@index([companyId, accusedId])   // ค้นหาว่าคนๆ นี้เคยโดนร้องเรียนกี่ครั้ง
  @@index([companyId, status])
  @@map("hr_grievance_tickets")
}

///เอกสารที่เกี่ยวกับการฝึกอบรม
model HrTrainingDocument {
  id          Int      @id @default(autoincrement())

  /// 🏢 หัวใจของ Multi-company: ต้องเชื่อมกับ OrgCompany โดยตรง
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id])

  /// 🎓 เชื่อมกับหลักสูตรอบรม (สมมติชื่อโมเดล HrTraining)
  trainingId  Int      
  
  /// 📁 เชื่อมกับ DMS (SysMedia)
  mediaId     Int      @unique
  media       SysMedia @relation(fields: [mediaId], references: [id])
  
  docType     String   // 'HANDOUT' (เอกสารประกอบ), 'EXAM' (ข้อสอบ), 'CERT' (เกียรติบัตร)
  createdAt   DateTime @default(now())

  /// 🚀 INDEX STRATEGY: สำคัญมากสำหรับการแยกข้อมูลแต่ละบริษัทให้เร็ว
  @@index([companyId, trainingId])
  @@map("hr_training_documents")
}

///บทลงโทษเชื่อมต่อกับเอกสารกลาง
model HrDisciplinaryDocument {
  id                Int      @id @default(autoincrement())

  /// 🏢 Multi-tenancy
  companyId         Int
  company           OrgCompany @relation(fields: [companyId], references: [id])

  /// ⚖️ เชื่อมกับรายการบทลงโทษ (สมมติชื่อโมเดล HrDisciplinaryAction)
  disciplinaryId    Int      
  disciplinary      HrDisciplinaryAction @relation(fields: [disciplinaryId], references: [id], onDelete: Cascade)
  
  /// 📁 เชื่อมกับ DMS (SysMedia)
  mediaId           Int      @unique
  media             SysMedia @relation(fields: [mediaId], references: [id])
  
  /// ประเภทเอกสาร (เช่น 'WARNING_LETTER', 'INVESTIGATION_REPORT', 'EVIDENCE')
  docType           String   
  createdAt         DateTime @default(now())

  @@index([companyId, disciplinaryId])
  @@map("hr_disciplinary_documents")
}

/// ✅ [NEW] ตารางกลางสำหรับเชื่อม "หลักฐานการร้องเรียน" กับ DMS
model HrGrievanceEvidence {
  id                Int      @id @default(autoincrement())
  companyId         Int
  company           OrgCompany @relation(fields: [companyId], references: [id])

  ticketId          Int
  ticket            HrGrievanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  /// 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId           Int      @unique
  media             SysMedia @relation(fields: [mediaId], references: [id])

  /// ระบุว่าใครเป็นคนส่ง: 'REQUESTER' (ผู้ร้องแนบมา) หรือ 'INVESTIGATOR' (คณะกรรมการแนบเพิ่มระหว่างสอบสวน)
  providedBy        String   @default("REQUESTER") 
  
  createdAt         DateTime @default(now())

  @@index([companyId, ticketId])
  @@map("hr_grievance_evidences")
}

/// --- 🛒 1. เอกสารการจัดซื้อ (Purchasing: PO, Invoice, Quotation) ---
model EcomPurchaseDocument {
  id          Int      @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id])

  /// ✅ แก้ไข: เชื่อมโยงกับตาราง ProPurchaseOrder ที่มีอยู่จริง
  purchaseId  Int      
  purchase    ProPurchaseOrder @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  
  mediaId     Int      @unique
  docType     String   // 'PO', 'INVOICE', 'QUOTATION'
  media       SysMedia @relation(fields: [mediaId], references: [id])
  createdAt   DateTime @default(now())

  @@index([companyId, purchaseId])
  @@map("ecom_purchase_documents")
}

/// --- 💰 2. รูปสลิปการโอนเงิน (Payment Slips) ---
model EcomPaymentSlip {
  id          Int      @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id])
  
  /// ✅ แก้ไข: เชื่อมโยงกับตาราง ComPayment ที่มีอยู่จริง
  paymentId   Int      
  payment     ComPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  
  mediaId     Int      @unique
  media       SysMedia @relation(fields: [mediaId], references: [id])
  createdAt   DateTime @default(now())

  @@index([companyId, paymentId])
  @@map("ecom_payment_slips")
}

/// --- 📦 3. เอกสารการขายและขนส่ง (Sales & Shipping: Tax Invoice, Waybill) ---
model EcomShippingDocument {
  id          Int      @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id])

  /// ✅ แก้ไข: เนื่องจากคุณยังไม่มีตาราง Shipping แยก ผมแนะนำให้ผูกกับ ComOrder โดยตรงครับ
  orderId     Int      
  order       ComOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  mediaId     Int      @unique
  docType     String   // 'WAYBILL' (ใบปะหน้า), 'POD' (หลักฐานการส่ง), 'TAX_INVOICE'
  media       SysMedia @relation(fields: [mediaId], references: [id])
  createdAt   DateTime @default(now())

  @@index([companyId, orderId])
  @@map("ecom_shipping_documents")
}

/// --- 📢 4. เอกสารโปรโมชั่น (Promotions: T&C, Banner Docs) ---
model EcomPromotionDocument {
  id          Int      @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id])

  /// ✅ แก้ไข: เชื่อมโยงกับตาราง ComDiscount ที่ทำหน้าที่เป็นโปรโมชั่น
  discountId  Int      
  discount    ComDiscount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  
  mediaId     Int      @unique
  media       SysMedia @relation(fields: [mediaId], references: [id])
  createdAt   DateTime @default(now())

  @@index([companyId, discountId])
  @@map("ecom_promotion_documents")
}

/// --- ↩️ 5. เอกสารการคืนสินค้า (Returns: Evidence, Refund Docs) ---
model EcomReturnDocument {
  id          Int      @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id])
  
  /// ✅ แก้ไข: เชื่อมโยงกับตาราง ComReturnRequest ที่มีอยู่จริง
  returnRequestId Int      
  returnRequest   ComReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  
  mediaId     Int      @unique
  docType     String   // 'DAMAGE_EVIDENCE' (รูปของพัง), 'REFUND_SLIP'
  media       SysMedia @relation(fields: [mediaId], references: [id])
  createdAt   DateTime @default(now())

  @@index([companyId, returnRequestId])
  @@map("ecom_return_documents")
}



/// ✅ [NEW] ตารางกลางสำหรับเชื่อมสื่อและเอกสารของประกาศ
model ComAnnouncementMedia {
  id              Int      @id @default(autoincrement())
  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id])

  announcementId  Int
  announcement    ComAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  // 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId         Int      @unique
  media           SysMedia @relation(fields: [mediaId], references: [id])

  // 'BANNER_IMAGE', 'ATTACHMENT_PDF'
  mediaType       String?  
  createdAt       DateTime @default(now())

  @@index([companyId, announcementId])
  @@map("com_announcement_media")
}

/// ✅ [NEW] ตารางกลางสำหรับเอกสารประกอบของร้านค้า
model ComShopDocument {
  id              Int      @id @default(autoincrement())

  /// 🏢 Multi-tenancy
  companyId       Int
  company         OrgCompany @relation(fields: [companyId], references: [id])

  /// 🏪 เชื่อมกับตาราง Shop Profile
  shopProfileId   Int
  shopProfile     ComShopProfile @relation(fields: [shopProfileId], references: [id], onDelete: Cascade)

  /// 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId         Int      @unique
  media           SysMedia @relation(fields: [mediaId], references: [id])

  /// ประเภทเอกสาร: 'DBD_CERTIFICATE' (ใบจดทะเบียน), 'ID_CARD' (บัตร ปชช.), 'BANK_BOOK' (หน้าบุ๊คแบงก์)
  docType         String?   
  createdAt       DateTime @default(now())

  @@index([companyId, shopProfileId])
  @@map("com_shop_documents")
}

/// ✅ [NEW] ตารางกลางสำหรับเอกสารเกี่ยวกับคลังสินค้า (Warehouse Documents)
model ComWarehouseDocument {
  id          Int      @id @default(autoincrement())
  
  /// 🏢 Multi-tenancy
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id])

  /// 🏭 เชื่อมกับคลังสินค้า
  warehouseId Int
  warehouse   ComWarehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  /// 📁 เชื่อมกับระบบจัดการไฟล์กลาง DMS (SysMedia)
  mediaId     Int      @unique
  media       SysMedia @relation(fields: [mediaId], references: [id])

  /// ประเภทเอกสาร เช่น 'LEASE_AGREEMENT' (สัญญาเช่า), 'INSURANCE' (ประกันภัย), 'FLOOR_PLAN' (ผังคลัง), 'PERMIT' (ใบอนุญาต), 'PHOTO' (รูปภาพ)
  docType     String?  
  createdAt   DateTime @default(now())

  @@index([companyId, warehouseId])
  @@map("com_warehouse_documents")
}

/// 🚚 [NEW] ตั้งค่าการเชื่อมต่อ API ขนส่งภายนอก (รองรับรายบริษัท และรายสาขา)
model CfgLogisticsProvider {
  id          Int        @id @default(autoincrement())
  companyId   Int
  company     OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🌟 [เพิ่มใหม่] รองรับ Multi-Shop (Null = ใช้การตั้งค่าส่วนกลางของบริษัท)
  shopId      Int?
  shop        ComShopProfile? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  /// ชื่อขนส่ง เช่น 'FLASH', 'KERRY', 'JNT', 'THAIPOST', 'NINJAVAN'
  providerName String    
  isActive     Boolean   @default(true)

  /// ข้อมูลเชื่อมต่อ API ของขนส่งเจ้านั้นๆ
  apiKey       String?
  apiSecret    String?
  merchantId   String?   // รหัสลูกค้าของขนส่ง 

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // 🌟 [ปรับปรุง] เปลี่ยนเงื่อนไข Unique ให้ครอบคลุมสาขาด้วย
  @@unique([companyId, shopId, providerName])
  @@map("cfg_logistics_providers")
}

/// 💳 [NEW] ตั้งค่าการเชื่อมต่อ Payment Gateway (รองรับรายบริษัท และรายสาขา)
model CfgPaymentGateway {
  id            Int        @id @default(autoincrement())
  companyId     Int
  company       OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🌟 [เพิ่มใหม่] รองรับ Multi-Shop (Null = ใช้การตั้งค่าส่วนกลางของบริษัท)
  shopId        Int?
  shop          ComShopProfile? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  /// ชื่อผู้ให้บริการ เช่น 'OMISE', 'GBPRIME', 'STRIPE', 'KSHER'
  providerName  String    
  isActive      Boolean    @default(true)

  /// ข้อมูลเชื่อมต่อ API 
  publicKey     String?    
  secretKey     String?    
  merchantId    String?    
  webhookSecret String?    

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // 🌟 [ปรับปรุง] เปลี่ยนเงื่อนไข Unique ให้ครอบคลุมสาขาด้วย
  @@unique([companyId, shopId, providerName])
  @@map("cfg_payment_gateways")
}

/// 📄 [NEW] ตารางใบเสร็จรับเงิน / ใบกำกับภาษี (Tax Invoice / Receipt)
model ComInvoice {
  id        Int        @id @default(autoincrement())
  
  /// 🏢 ล็อกสิทธิ์ของ SME เจ้าของข้อมูล (Multi-tenancy)
  companyId Int
  company   OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 🏪 รองรับระบบหลายสาขา (ออกเอกสารในนามชื่อและที่ตั้งของสาขาไหน)
  shopId    Int
  shop      ComShopProfile @relation(fields: [shopId], references: [id])

  /// 🛒 ผูกกับคำสั่งซื้อต้นทาง (1 คำสั่งซื้อ มีสิทธิ์ออกใบกำกับภาษีได้ 1 ใบ)
  orderId   Int        @unique
  order     ComOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  /// 🆔 เลขที่เอกสารใบกำกับภาษี เช่น INV2026050001 (รันระบบนับแยกรายบริษัท/สาขา)
  invoiceNo String

  /// ประเภทเอกสาร: 'TAX_INVOICE' (ใบกำกับภาษีเต็มรูป), 'RECEIPT' (ใบเสร็จรับเงินทั่วไป)
  type      String     @default("TAX_INVOICE")
  
  /// สถานะเอกสาร: 'ISSUED' (ออกแล้ว), 'CANCELLED' (ยกเลิก/ออกใบแทน)
  status    String     @default("ISSUED") 


  /// เลขประจำตัวผู้เสียภาษี 13 หลัก หรือ เลขบัตรประชาชน
  taxId       String   
  /// รหัสสาขา 5 หลัก (เช่น '00000' สำหรับสำนักงานใหญ่ หรือ '00001' สำหรับสาขา)
  branchCode  String   @default("00000") 
  /// ชื่อบริษัท/ห้างหุ้นส่วน หรือ ชื่อ-นามสกุล ของผู้เสียภาษี
  name        String   
  phone       String?
  email       String?
  /// ที่อยู่เต็มสำหรับการเปิดบิลใบกำกับภาษี
  address     String   @db.Text 

  /// ยอดรวมราคาสินค้าก่อนหักส่วนลด
  subTotal       Decimal   @db.Decimal(10, 2) 
  /// ส่วนลดท้ายบิล
  discountAmount Decimal   @default(0) @db.Decimal(10, 2) 
  /// ยอดรวมที่นำไปคิดภาษี (ฐานภาษี)
  vatableAmount  Decimal   @db.Decimal(10, 2) 
  /// ยอดภาษีมูลค่าเพิ่ม (ปกติ 7%)
  vatAmount      Decimal   @db.Decimal(10, 2) 
  /// ยอดเงินสุทธิรวม VAT (ยอดรวมที่จ่ายจริง)
  netAmount      Decimal   @db.Decimal(10, 2) 

  
  /// เชื่อมโยงเข้าศูนย์กลางคลังไฟล์ DMS เก็บเป็นไฟล์ PDF ใบกำกับภาษีจริง
  mediaId        Int?      @unique
  media          SysMedia? @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  /// รองรับระบบใบกำกับภาษีอิเล็กทรอนิกส์ในอนาคต (E-Tax Invoice ready)
  isETax         Boolean   @default(false)
  /// รหัสอ้างอิงเอกสารที่ได้รับคืนมาจากระบบ Provider หรือสรรพากร
  eTaxRefId      String?   

  cancelReason   String?   @db.Text
  cancelledAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, invoiceNo])
  @@index([companyId, status])
  @@map("com_invoices")
}

/// ประเภทของแพลตฟอร์มภายนอก
enum MarketplaceType {
  SHOPEE
  LAZADA
  TIKTOK
  LINE_SHOPPING
  OTHER
}

/// สถานะการผูกสินค้า (เพื่อรองรับระบบ AI และ Human Confirm)
enum MappingStatus {
  PENDING    // 🤖 AI เสนอมาว่าคล้ายกัน (รอคนกดยืนยัน)
  CONFIRMED  // ✅ คนกดยืนยันแล้ว (สามารถตัดสต๊อกจริงได้เลย)
  REJECTED   // ❌ คนกดปฏิเสธ (AI จับคู่มาผิด)
}

/// ตารางตัวกลางสำหรับ Mapping สินค้า ERP กับแพลตฟอร์มภายนอก (รองรับ Multi-company)
model IntProductMapping {
  id                  Int               @id @default(autoincrement())
  
  /// 🏢 รองรับ Multi-company (แต่ละบริษัทผูกของใครของมัน)
  companyId           Int               
  company             OrgCompany        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 📦 โยงไปหาสินค้าหลัก (Master Product) ในระบบ KKV Business OS
  productId           Int               
  product             ComProduct        @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// 🔗 [เพิ่มใหม่] โยงไปหาตารางพักข้อมูลสินค้า (Marketplace Cache) 
  marketplaceProductId Int?
  marketplaceProduct   IntMarketplaceProduct? @relation(fields: [marketplaceProductId], references: [id], onDelete: Cascade)

  /// 🛒 ข้อมูลแพลตฟอร์ม
  platform            MarketplaceType   
  /// ID ของร้านค้าบนแพลตฟอร์มนั้นๆ (รองรับกรณี 1 บริษัทเปิดร้าน Shopee 3 ร้าน)
  storeAccountId      String?           

  /// 🔑 ข้อมูลอ้างอิงฝั่งแพลตฟอร์มภายนอก (ได้มาจาก API ของ Shopee/Lazada)
  externalProductId   String            // รหัสสินค้าหลัก (Item ID)
  externalVariationId String?           // รหัสตัวเลือกย่อย (Model/Variation ID) เช่น สีแดง, ไซส์ M
  externalSku         String?           // รหัส SKU บนแพลตฟอร์ม (ถ้ามี)
  externalName        String            // ชื่อสินค้าบนแพลตฟอร์ม (ที่ยาวๆ ใส่คีย์เวิร์ด SEO)

  /// 🚦 ระบบ AI Matching & Confirmation
  mappingStatus       MappingStatus     @default(PENDING) 
  /// เก็บเปอร์เซ็นต์ความเหมือนที่ AI (Gemini) วิเคราะห์ให้ (เช่น 0.75 หมายถึง 75%)
  aiMatchScore        Float?            

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  /// ป้องกันไม่ให้ผูกสินค้ารหัสเดียวกันจากร้านเดียวกันซ้ำ
  @@unique([companyId, platform, storeAccountId, externalProductId, externalVariationId], name: "unique_marketplace_item")
  @@index([companyId, productId])
  @@map("int_product_mappings")
}

/// ตารางพักข้อมูลสินค้าจากมาร์เก็ตเพลสภายนอก (Marketplace Product Cache)
model IntMarketplaceProduct {
  id                Int               @id @default(autoincrement())
  companyId         Int
  company           OrgCompany        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  platform          MarketplaceType
  /// ID ร้านค้า เช่น shop_mall_01
  storeAccountId    String            
  /// Item ID จาก Shopee/Lazada
  externalProductId String    
  /// ชื่อสินค้าบน Shopee
  name              String            
  description       String?           @db.Text
  /// ราคาบนแพลตฟอร์ม
  rawPrice          Decimal           @db.Decimal(10, 2) 
  /// สต๊อกบนแพลตฟอร์ม
  rawStock          Int               @default(0)        
  
  /// 🖼️ ลิงก์รูปภาพ (ตอนแรกเป็น URL ของ Shopee พอโหลดเสร็จจะเปลี่ยนเป็น GCS URL ของเรา)
  imageUrl          String?           @db.Text
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  mappings          IntProductMapping[]

  @@unique([companyId, platform, storeAccountId, externalProductId])
  @@map("int_marketplace_products")
}

/// ตารางเก็บบันทึกลายนิ้วมือดิจิทัลของไฟล์ที่ถูกส่งออก (Tamper-Proof Trace)
model LogDocumentTrace {
  id              Int      @id @default(autoincrement())
  companyId       Int
  
  /// รหัส SHA-256 ของไฟล์
  fileHash        String   
  originalFileId  Int
  
  /// ใครเป็นคนกดโหลด/ดูไฟล์นี้
  downloadedById  Int
  downloadedAt    DateTime @default(now())

  // Relations
  company         OrgCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  originalFile    DocFile    @relation(fields: [originalFileId], references: [id], onDelete: Cascade)
  downloadedBy    SecUser    @relation("DownloadedByTrace", fields: [downloadedById], references: [id], onDelete: Cascade)

  @@index([companyId, fileHash])
  @@map("log_document_trace")
}